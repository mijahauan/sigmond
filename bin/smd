#!/usr/bin/env python3
"""smd — Sigmond system installer and lifecycle manager.

Dr. SigMonD: "Zo... ven did your signals first start to propagate?"

The verbs split into three buckets — the same Configure / Observe / Operate
groups used by the TUI's left tree:

Configure (what should exist):
    smd add         <git-url>                                    clone a component repo
    smd software    install [<client>] [--force] |               install + configure, or
                    apply [--dry-run]                            reconcile to current config
    smd enable      <name>...                                    set enabled=true in topology
    smd disable     <name>...                                    set enabled=false + stop units
    smd remove      <name>...                                    remove from topology
    smd config      show | migrate | init <c> | edit <c>         per-client config
    smd validate                                                 cross-client harmonization
    (smd install / smd apply are kept as aliases for the software subverbs.)

Observe (what is, read-only):
    smd list        [--update | --catalog] [--components C1,C2]  per-component status table
                    [--ref R] [--fetch] [--dry-run] [--json]
    smd status      [<component>]                                service health
    smd log         [--files | --level LEVEL] [<client>]         tail journal or file logs
    smd diag        [net | cpu-affinity | cpu-freq]              diagnostics
    smd environment list | probe | describe                      discover network peers
    smd watch       <wspr|psk|hfdl|codar|ka9q|uploads|verifier> [args...] unified service watcher
    smd ka9q-watch                                               upstream-drift watcher (alias)
    smd psk-watch   [N | -v]                                     PSK Reporter upload events (alias)
    smd wspr-watch  [N | -v]                                     WSPRnet upload events (alias)
    smd hfdl-watch  [N | -v]                                     HFDL decoded-frame activity (alias)
    smd codar-watch [N | -v]                                     CODAR ionospheric soundings (alias)
    smd sources     list | add | remove | apply                  per-client SDR source selection

Operate (run things now, may need sudo):
    smd start       [<component> [<instance>]]
    smd stop        [<component> [<instance>]]
    smd restart     [<component> [<instance>]]
    smd reload      [--via=auto|systemd|socket]  [<component>]
    smd tui                                                      launch interactive TUI

Topology file (default: /etc/sigmond/topology.toml) controls which
components are enabled on this host; all commands respect the topology.

Lifecycle verbs (start/stop/restart/reload/list/status):
  Without <component>: operate on all enabled components.
  With <component>: operate on that component's instances.
  With <component> <instance>: operate on a single instance only.
"""

import os
import sys
from pathlib import Path

# Bootstrap step 1 — re-exec into sigmond's venv Python if we're not
# already there.
#
# Why: install.sh builds <repo>/venv with sigmond installed editable
# plus its declared extras (`tui`, …) — including ka9q-python which
# rules like rule_ka9q_python_compat import.  Our shebang resolves
# to the system interpreter, which doesn't see those packages, so
# any feature behind an extra fails with `ModuleNotFoundError`.
# Re-exec into the venv interpreter so smd always runs with sigmond's
# full dependency closure available.
#
# Derived from this script's location (repo-relative) rather than a
# hardcoded /opt/sigmond/venv — the post-consolidation venv lives at
# /opt/git/sigmond/sigmond/venv per RADIOD-IDENTIFICATION-era
# consolidation work, but smd shouldn't be tied to a specific FHS
# layout.  See sigmond commit `cb23292` (the consolidation).
#
# Skipped when:
#   * the venv doesn't exist yet (install.sh hasn't run / dev checkout)
#   * we're already running from the venv (no infinite re-exec loop)
#   * SIGMOND_NO_VENV_REEXEC=1 is set (escape hatch for debugging)
_VENV_ROOT = Path(__file__).resolve().parent.parent / 'venv'
_VENV_PY = _VENV_ROOT / 'bin' / 'python'
# sys.prefix is the *interpreter*-side signal of "am I running in this
# venv?" — the bin/python symlink that uv creates points at the system
# python3.13, so comparing sys.executable.resolve() to _VENV_PY.resolve()
# yields a false positive (both resolve to /usr/bin/python3.13) and the
# re-exec is skipped.  sys.prefix is set per-invocation and isn't
# resolve-collapsed.
if (_VENV_PY.is_file()
        and not Path(sys.prefix).is_relative_to(_VENV_ROOT)
        and not os.environ.get('SIGMOND_NO_VENV_REEXEC')):
    os.execv(str(_VENV_PY), [str(_VENV_PY), *sys.argv])
    # execv only returns on failure; if it does, fall through and let
    # the rest of bootstrap continue with the system interpreter.

import argparse
import configparser
import math
import pwd
import re
import shutil
import subprocess
import textwrap
import time
from typing import Optional

# Bootstrap step 2 — add sibling lib/ to sys.path so `import sigmond`
# works when running from the repo, from /usr/local/sbin/smd, or from a
# symlink.
_SCRIPT = Path(__file__).resolve()
for _candidate in (_SCRIPT.parent.parent / 'lib',        # repo layout
                   Path('/opt/sigmond/lib'),             # installed layout
                   Path('/usr/local/lib/sigmond')):      # alt installed
    if (_candidate / 'sigmond' / '__init__.py').exists():
        sys.path.insert(0, str(_candidate))
        break

