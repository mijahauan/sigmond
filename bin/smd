#!/usr/bin/env python3
"""smd — Sigmond system installer and lifecycle manager.

Dr. SigMonD: "Zo... ven did your signals first start to propagate?"

Usage:
    smd install    [<client>]  [--components COMP,...]  [--dry-run]  [--yes]
    smd apply      [--dry-run]
    smd start      [<component> [<instance>]]
    smd stop       [<component> [<instance>]]
    smd restart    [<component> [<instance>]]
    smd reload     [--via=auto|systemd|socket]  [<component>]
    smd list       [--json]  [--available | --all]  [<component>]
    smd log        [--files | --level LEVEL]  [<client>]
    smd status     [<component>]
    smd update
    smd diag

Topology file (default: /etc/sigmond/topology.toml) controls which
components are enabled on this host.  All commands respect the topology.

Lifecycle verbs (start/stop/restart/reload/list/status):
  Without <component>: operate on all enabled components.
  With <component>: operate on that component's instances.
  With <component> <instance>: operate on a single instance only.
"""

import argparse
import configparser
import os
import shutil
import subprocess
import sys
import textwrap
import time
