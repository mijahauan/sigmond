#!/usr/bin/env python3
"""smd — Sigmond system installer and lifecycle manager.

Dr. SigMonD: "Zo... ven did your signals first start to propagate?"

Usage:
    smd install    [<client>]  [--components COMP,...]  [--dry-run]  [--yes]
    smd apply      [--dry-run]
    smd start      [<component> [<instance>]]
    smd stop       [<component> [<instance>]]
    smd restart    [<component> [<instance>]]
    smd reload     [--via=auto|systemd|socket]  [<component>]
    smd list       [--json]  [--available | --all]  [<component>]
    smd log        [--files | --level LEVEL]  [<client>]
    smd status     [<component>]
    smd update
    smd diag

Topology file (default: /etc/sigmond/topology.toml) controls which
components are enabled on this host.  All commands respect the topology.

Lifecycle verbs (start/stop/restart/reload/list/status):
  Without <component>: operate on all enabled components.
  With <component>: operate on that component's instances.
  With <component> <instance>: operate on a single instance only.
"""

import argparse
import configparser
import os
import shutil
import subprocess
import sys
import textwrap
import time
from pathlib import Path

# Bootstrap: add sibling lib/ to sys.path so `import sigmond` works when
# running from the repo, from /usr/local/sbin/smd, or from a symlink.
_SCRIPT = Path(__file__).resolve()
for _candidate in (_SCRIPT.parent.parent / 'lib',        # repo layout
                   Path('/opt/sigmond/lib'),             # installed layout
                   Path('/usr/local/lib/sigmond')):      # alt installed
    if (_candidate / 'sigmond' / '__init__.py').exists():
        sys.path.insert(0, str(_candidate))
        break

try:
    from sigmond.commands.validate import cmd_validate
    from sigmond.commands.config   import cmd_config_show, cmd_config_migrate
    from sigmond.lifecycle         import resolve_units, UnitRef
    from sigmond.catalog           import load_catalog, CatalogEntry, get_entry, resolve_name, find_client_binary
    from sigmond.installer         import install_client as _do_install_client
    from sigmond.log_cmd           import (
        follow_journal, follow_files, flatten_log_paths,
        get_inventory_log_paths, set_log_level, send_sighup,
        client_env_key,
    )
    _HAS_SIGMOND_LIB = True
except ImportError:
    _HAS_SIGMOND_LIB = False

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------

TOPOLOGY_PATH   = Path('/etc/sigmond/topology.toml')
SIGMOND_CONF    = Path('/etc/sigmond')
SIGMOND_LOG     = Path('/var/log/sigmond')

# ---------------------------------------------------------------------------
# Banner
# ---------------------------------------------------------------------------

BANNER = r"""
          .---.
         / o o \     "Zo... ven did your
         \ ._. /      signals first start
          |||||       to propagate?"
         /|||||\             ______
        / ||||| \            \    /
       '  |||||  '            \  /
          (  )                 \/
       ~~smoke~~               |   /
                  -------------'  /
                  ---------------/
                  |            |
     Dr. SigMonD — Signal Monitor Daemon
"""

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def _run(cmd: list, *, cwd=None, capture=True, sudo=False) -> subprocess.CompletedProcess:
    if sudo and os.geteuid() != 0:
        cmd = ['sudo'] + cmd
    return subprocess.run(cmd, cwd=cwd,
                          capture_output=capture, text=True)


def _ok(msg):   print(f'  \033[32m✓\033[0m  {msg}')
def _warn(msg): print(f'  \033[33m⚠\033[0m  {msg}')
def _err(msg):  print(f'  \033[31m✗\033[0m  {msg}', file=sys.stderr)
def _info(msg): print(f'     {msg}')


def _heading(title: str):
    print(f'\n\033[1m━━━ {title} ━━━\033[0m')


def _need_root(cmd_name: str) -> bool:
    if os.geteuid() != 0:
        print(f'smd {cmd_name}: must run as root (sudo smd {cmd_name})',
              file=sys.stderr)
        return True
    return False


# ---------------------------------------------------------------------------
# Client contract queries
# ---------------------------------------------------------------------------

def _get_client_inventory(client_name: str, timeout: float = 5.0):
    """Call <client> inventory --json. Returns parsed dict or None."""
    import json as _json
    binary = find_client_binary(client_name) if _HAS_SIGMOND_LIB else shutil.which(client_name)
    if not binary:
        return None
    try:
        r = subprocess.run(
            [binary, 'inventory', '--json'],
            capture_output=True, text=True, timeout=timeout,
        )
        if r.returncode != 0:
            return None
        return _json.loads(r.stdout)
    except (subprocess.SubprocessError, _json.JSONDecodeError, OSError):
        return None


def _get_client_validate(client_name: str, timeout: float = 5.0):
    """Call <client> validate --json. Returns parsed dict or None."""
    import json as _json
    binary = find_client_binary(client_name) if _HAS_SIGMOND_LIB else shutil.which(client_name)
    if not binary:
        return None
    try:
        r = subprocess.run(
            [binary, 'validate', '--json'],
            capture_output=True, text=True, timeout=timeout,
        )
        if r.returncode != 0:
            return None
        return _json.loads(r.stdout)
    except (subprocess.SubprocessError, _json.JSONDecodeError, OSError):
        return None


# ---------------------------------------------------------------------------
# Topology
# ---------------------------------------------------------------------------

def _load_topology(path: Path, client_dir_override: str = None) -> dict:
    """
    Load topology.toml.  Returns a dict with:
      topology['client_dir']     — Path to wsprdaemon-client
      topology['components']     — dict of component_name → {enabled, description, managed}
    Falls back to sensible defaults if topology.toml is absent.
    """
    import tomllib

    defaults = {
        'client_dir': Path('/home/wsprdaemon/wsprdaemon-client'),
        'smd_bin':    Path('/usr/local/sbin/smd'),
        'components': {
            'radiod':    {'enabled': True,  'managed': True,  'description': 'ka9q-radio SDR daemon'},
            'wspr':      {'enabled': True,  'managed': True,  'description': 'WSPR/FST4W decoder and uploader'},
            'ka9q-web':  {'enabled': True,  'managed': True,  'description': 'ka9q-web radiod status UI'},
            'grape':     {'enabled': True,  'managed': False, 'description': 'GRAPE hf-timestd recording'},
            'rac':       {'enabled': False, 'managed': False, 'description': 'Remote access channel (frpc)'},
        },
    }

    if client_dir_override:
        defaults['client_dir'] = Path(client_dir_override)

    if not path.exists():
        _warn(f'No topology file at {path} — using defaults')
        return defaults

    with open(path, 'rb') as f:
        raw = tomllib.load(f)

    result = dict(defaults)

    sig = raw.get('sigmond', {})
    if 'wsprdaemon_client' in sig:
        result['client_dir'] = Path(sig['wsprdaemon_client'])
    if client_dir_override:
        result['client_dir'] = Path(client_dir_override)
    if 'smd_bin' in sig:
        result['smd_bin'] = Path(sig['smd_bin'])

    comps = raw.get('component', {})
    for name, cfg in comps.items():
        result['components'][name] = {
            'enabled':     cfg.get('enabled', False),
            'managed':     cfg.get('managed', True),
            'description': cfg.get('description', ''),
        }

    return result


def _enabled_components(topology: dict, only: list = None) -> list:
    """Return sorted list of enabled component names, filtered by only if given."""
    enabled = [n for n, c in topology['components'].items() if c['enabled']]
    if only:
        enabled = [n for n in enabled if n in only]
    return sorted(enabled)


# ---------------------------------------------------------------------------
# Dependency management (reads wsprdaemon-client/deps.conf)
# ---------------------------------------------------------------------------

# Map each component to the deps.conf sections it needs
COMPONENT_DEPS = {
    'radiod':              ['ka9q-radio'],
    'wspr':                ['ka9q-python', 'wspr-recorder', 'kiwiclient', 'ftlib-pskreporter'],
    'wsprdaemon-client':   ['ka9q-python', 'wspr-recorder', 'kiwiclient', 'ftlib-pskreporter'],
    'ka9q-web':            ['ka9q-web'],
    'grape':               [],   # legacy alias for hf-timestd
    'hf-timestd':          [],   # manages itself
    'psk-recorder':        [],   # manages itself
    'wspr-recorder':       [],   # manages itself
    'rac':                 [],
}

# Deps that require a C build step after cloning
BUILD_STEPS = {
    'ka9q-radio': '_build_ka9q_radio',
    'ka9q-web':   '_build_ka9q_web_with_onion',
}


def _load_deps_conf(client_dir: Path) -> configparser.ConfigParser:
    deps_file = client_dir / 'deps.conf'
    if not deps_file.exists():
        _err(f'deps.conf not found at {deps_file}')
        return None
    cfg = configparser.ConfigParser()
    cfg.read(deps_file)
    return cfg


def _ensure_venv(venv_dir: Path) -> bool:
    if venv_dir.exists():
        return True
    _info(f'Creating Python venv at {venv_dir} ...')
    r = _run([sys.executable, '-m', 'venv', str(venv_dir)])
    if r.returncode != 0:
        _err(f'venv creation failed: {r.stderr.strip()}')
        return False
    return True


def _install_git_dep(section: str, dcfg: configparser.ConfigParser) -> bool:
    url        = dcfg.get(section, 'url', fallback='').strip()
    pinned     = dcfg.get(section, 'commit', fallback='').strip()
    install_to = dcfg.get(section, 'install_to', fallback='').strip()

    if not url or not install_to:
        _err(f'[{section}] missing url or install_to in deps.conf')
        return False

    target = Path(install_to)

    if not target.exists():
        _info(f'Cloning {section} → {target} ...')
        r = _run(['git', 'clone', url, str(target)])
        if r.returncode != 0:
            _err(f'git clone {section} failed: {r.stderr.strip()}')
            return False
        if pinned:
            _run(['git', '-C', str(target), 'checkout', pinned])

    # Verify commit
    if pinned:
        r = _run(['git', '-c', f'safe.directory={target}',
                  '-C', str(target), 'rev-parse', 'HEAD'])
        current = r.stdout.strip()
        if current and not current.startswith(pinned[:12]):
            _warn(f'{section}: at {current[:12]}, deps.conf pins {pinned[:12]}')
            _info(f'To update: git -C {target} fetch && git -C {target} checkout {pinned}')
        else:
            _ok(f'{section}: {current[:12]}')

    return True


def _install_pypi_dep(section: str, dcfg: configparser.ConfigParser,
                      venv_dir: Path) -> bool:
    url    = dcfg.get(section, 'url', fallback='').strip()
    commit = dcfg.get(section, 'commit', fallback='').strip()

    pip = str(venv_dir / 'bin' / 'pip')
    is_git = url.startswith('git+')
    pkg_name = url.rstrip('/').split('/')[-1].replace('.git', '') if is_git else url

    r = _run([pip, 'show', pkg_name])
    if r.returncode == 0:
        installed_ver = next(
            (l.split(':', 1)[1].strip() for l in r.stdout.splitlines()
             if l.startswith('Version:')), 'unknown')
        if installed_ver == commit or (is_git and commit[:8] in r.stdout):
            _ok(f'{section}: {installed_ver}')
            return True
        _warn(f'{section}: have {installed_ver}, want {commit[:12]}')

    spec = f'{url}@{commit}' if is_git else f'{url}=={commit}'
    _info(f'Installing {section} ({spec}) ...')
    r = _run([pip, 'install', spec])
    if r.returncode != 0:
        _err(f'{section} install failed: {r.stderr.strip()[-400:]}')
        return False
    _ok(f'{section}: installed')
    return True


def _build_ka9q_radio(src_dir: Path) -> bool:
    binary = Path('/usr/local/sbin/radiod')
    # Check if installed binary matches built binary
    built = src_dir / 'src' / 'radiod'
    if binary.exists() and built.exists():
        import hashlib
        def _sha(p):
            return hashlib.sha256(p.read_bytes()).hexdigest()
        if _sha(binary) == _sha(built):
            _ok('ka9q-radio: already installed and current')
            return True

    nproc = str(os.cpu_count() or 2)
    _info(f'Building ka9q-radio (make -j{nproc}) ...')
    r = _run(['make', f'-j{nproc}'], cwd=str(src_dir), capture=False)
    if r is None or (hasattr(r, 'returncode') and r.returncode != 0):
        _err('ka9q-radio build failed')
        return False
    r = _run(['make', 'install'], cwd=str(src_dir), sudo=True)
    if r.returncode != 0:
        _err(f'ka9q-radio install failed: {r.stderr.strip()}')
        return False
    _ok('ka9q-radio: built and installed')
    return True


def _build_onion(src_dir: Path) -> bool:
    if Path('/usr/local/lib/libonion.so').exists():
        _ok('onion: already installed')
        return True
    build_dir = src_dir / 'build'
    build_dir.mkdir(exist_ok=True)
    _info('Configuring onion ...')
    r = _run(['cmake', '..', '-DCMAKE_INSTALL_PREFIX=/usr/local',
              '-DHAVE_SQLITE3=OFF', '-DHAVE_REDIS=OFF', '-DHAVE_HIREDIS=OFF',
              '-DHAVE_JPEG=OFF', '-DHAVE_PAM=OFF', '-DHAVE_SYSTEMD=OFF',
              '-DHAVE_XML2=OFF', '-DONION_USE_SSL=ON'],
             cwd=str(build_dir))
    if r.returncode != 0:
        _err(f'onion cmake failed: {r.stderr.strip()}')
        return False
    nproc = str(os.cpu_count() or 2)
    _info(f'Building onion (make -j{nproc}) ...')
    r = _run(['make', f'-j{nproc}'], cwd=str(build_dir))
    if r.returncode != 0:
        _err(f'onion build failed: {r.stderr[-400:]}')
        return False
    r = _run(['make', 'install'], cwd=str(build_dir), sudo=True)
    if r.returncode != 0:
        _err(f'onion install failed: {r.stderr.strip()}')
        return False
    _run(['ldconfig'], sudo=True)
    _ok('onion: built and installed')
    return True


def _build_ka9q_web_with_onion(src_dir: Path) -> bool:
    # onion is a build-time dependency of ka9q-web
    dcfg = configparser.ConfigParser()
    deps_conf = src_dir.parent / 'wsprdaemon-client' / 'deps.conf'
    if deps_conf.exists():
        dcfg.read(deps_conf)
    onion_url    = dcfg.get('ka9q-web', 'onion_url', fallback='https://github.com/davidmoreno/onion.git')
    onion_commit = dcfg.get('ka9q-web', 'onion_commit', fallback='')
    onion_src    = Path(dcfg.get('ka9q-web', 'onion_src', fallback='/home/wsprdaemon/onion'))

    if not onion_src.exists():
        _info(f'Cloning onion → {onion_src} ...')
        r = _run(['git', 'clone', onion_url, str(onion_src)])
        if r.returncode != 0:
            _err(f'git clone onion failed: {r.stderr.strip()}')
            return False
        if onion_commit:
            _run(['git', '-C', str(onion_src), 'checkout', onion_commit])

    if not _build_onion(onion_src):
        return False

    binary = Path('/usr/local/sbin/ka9q-web')
    built  = src_dir / 'ka9q-web'
    if binary.exists() and built.exists():
        import hashlib
        def _sha(p): return hashlib.sha256(p.read_bytes()).hexdigest()
        if _sha(binary) == _sha(built):
            _ok('ka9q-web: already installed and current')
            return True

    nproc = str(os.cpu_count() or 2)
    _info(f'Building ka9q-web (make -j{nproc}) ...')
    r = _run(['make', f'-j{nproc}'], cwd=str(src_dir))
    if r.returncode != 0:
        _err(f'ka9q-web build failed: {r.stderr[-400:]}')
        return False
    r = _run(['make', 'install'], cwd=str(src_dir), sudo=True)
    if r.returncode != 0:
        _err(f'ka9q-web install failed: {r.stderr.strip()}')
        return False
    _ok('ka9q-web: built and installed')
    return True


def _collect_deps_for_components(components: list) -> list:
    """Return deduplicated ordered list of dep section names needed."""
    seen = set()
    result = []
    for comp in components:
        for dep in COMPONENT_DEPS.get(comp, []):
            if dep not in seen:
                seen.add(dep)
                result.append(dep)
    return result


# ---------------------------------------------------------------------------
# System-level install steps
# ---------------------------------------------------------------------------

def _install_systemd_units(client_dir: Path) -> int:
    unit_src = client_dir / 'systemd'
    unit_dst = Path('/etc/systemd/system')
    linked = []
    for pat in ('*.service', '*.target', '*.timer'):
        for f in unit_src.glob(pat):
            src = f.resolve()
            dst = unit_dst / f.name
            if dst.is_symlink() and dst.resolve() == src:
                continue
            r = _run(['ln', '-sf', str(src), str(dst)], sudo=True)
            if r.returncode == 0:
                linked.append(f.name)
            else:
                _err(f'could not symlink {f.name}: {r.stderr.strip()}')
    if linked:
        _run(['systemctl', 'daemon-reload'], sudo=True)
        _ok(f'systemd units: {len(linked)} symlinked')
    else:
        _ok('systemd units: all symlinks already current')
    return len(linked)


def _symlink(src: Path, dst: Path, label: str) -> bool:
    """Create or update a symlink dst → src.  Uses sudo if needed."""
    src = src.resolve()
    if dst.is_symlink() and dst.resolve() == src:
        return True   # already correct
    r = _run(['ln', '-sf', str(src), str(dst)], sudo=True)
    if r.returncode != 0:
        _err(f'could not symlink {dst}: {r.stderr.strip()}')
        return False
    _ok(f'{label}: {dst} → {src}')
    return True


def _install_smd_itself(sigmond_dir: Path, smd_bin: Path) -> bool:
    src = sigmond_dir / 'bin' / 'smd'
    if not src.exists():
        return True  # running from installed location already
    return _symlink(src, smd_bin, 'smd')


def _install_wrapper_scripts(client_dir: Path) -> None:
    sbin = Path('/usr/local/sbin')
    scripts = ['wd-ka9q-record', 'wd-kiwi-record', 'wd-kiwi-cleanup',
               'wd-spool-clean', 'wd-decode', 'wd-post',
               'wd-upload-wsprnet', 'wd-upload-wsprdaemon', 'wd-ctl']
    linked = []
    for name in scripts:
        src = client_dir / 'bin' / name
        if not src.exists():
            continue
        dst = sbin / name
        if dst.is_symlink() and dst.resolve() == src.resolve():
            continue
        r = _run(['ln', '-sf', str(src.resolve()), str(dst)], sudo=True)
        if r.returncode == 0:
            linked.append(name)
        else:
            _err(f'could not symlink {name}: {r.stderr.strip()}')
    if linked:
        _ok(f'scripts: {len(linked)} symlinked in {sbin}/')
    else:
        _ok('scripts: all symlinks already current')


def _install_wdlib(client_dir: Path) -> None:
    opt_lib = Path('/opt/wsprdaemon/lib')
    _run(['mkdir', '-p', str(opt_lib)], sudo=True)
    wdlib_src = client_dir / 'lib' / 'wdlib'
    wdlib_dst = opt_lib / 'wdlib'
    if not wdlib_src.is_dir():
        return
    if wdlib_dst.is_symlink():
        target = wdlib_dst.resolve()
        if target == wdlib_src.resolve():
            return
        _run(['rm', str(wdlib_dst)], sudo=True)
    elif wdlib_dst.exists():
        _run(['rm', '-rf', str(wdlib_dst)], sudo=True)
    _run(['ln', '-s', str(wdlib_src), str(wdlib_dst)], sudo=True)
    _ok('wdlib: symlinked into /opt/wsprdaemon/lib/')


def _run_wd_ctl_apply(client_dir: Path, dry_run: bool) -> bool:
    wd_ctl = Path('/usr/local/sbin/wd-ctl')
    if not wd_ctl.exists():
        wd_ctl = client_dir / 'bin' / 'wd-ctl'
    if not wd_ctl.exists():
        _err('wd-ctl not found — cannot generate env files and start services')
        return False
    cmd = [str(wd_ctl), 'apply']
    if dry_run:
        _info('dry-run: would run: sudo ' + ' '.join(cmd))
        return True
    _info('Running wd-ctl apply ...')
    r = _run(cmd, capture=False, sudo=True)
    return r.returncode == 0


def _ensure_sigmond_dirs() -> None:
    for d in [SIGMOND_CONF, SIGMOND_LOG]:
        _run(['mkdir', '-p', str(d)], sudo=True)


# ---------------------------------------------------------------------------
# smd install
# ---------------------------------------------------------------------------

def cmd_install(args) -> int:
    client = getattr(args, 'client', None)
    if client:
        return _install_single_client(args)
    return _install_full_suite(args)


def _install_single_client(args) -> int:
    """Catalog-driven install of a single client: smd install <client>."""
    client = args.client
    dry_run = getattr(args, 'dry_run', False)
    yes = getattr(args, 'yes', False)

    try:
        catalog = load_catalog()
    except FileNotFoundError as exc:
        _err(str(exc))
        return 1

    entry = get_entry(client, catalog)
    if entry is None:
        _err(f"unknown client '{client}' — see: smd list --available")
        return 1

    if not entry.install_script:
        _err(f"'{entry.name}' has no install_script in the catalog")
        _info(f"for radiod/ka9q-web, use: smd install  (full-suite legacy path)")
        return 1

    _heading(f'install {entry.name}')
    _info(f'repo:   {entry.repo}')
    _info(f'script: {entry.install_script}')

    if dry_run:
        _info('(dry-run) would clone repo and run install.sh')
        return 0

    if _need_root('install'):
        return 1

    try:
        result = _do_install_client(entry, dry_run=dry_run, yes=yes, pull=True)
    except RuntimeError as exc:
        _err(str(exc))
        return 1

    if result:
        _ok(f'{entry.name} installed successfully')
        _info(f'next: edit /etc/{entry.name}/ config, then: smd start --components {entry.name}')
        return 0
    else:
        _err(f'{entry.name} install failed')
        return 1


def _install_full_suite(args) -> int:
    """Legacy full-suite install (wsprdaemon-client-centric)."""
    if _need_root('install'):
        return 1

    print(BANNER)
    topology = _load_topology(
        Path(args.topology) if args.topology else TOPOLOGY_PATH,
        client_dir_override=args.client_dir,
    )
    client_dir = topology['client_dir']
    smd_bin    = topology['smd_bin']

    only = [c.strip() for c in args.components.split(',')] if args.components else None
    components = _enabled_components(topology, only)

    if not components:
        print('No components enabled — check topology.toml.')
        return 1

    print(f'Installing components: {", ".join(components)}')
    print(f'wsprdaemon-client:     {client_dir}')
    if args.dry_run:
        print('(dry-run mode — no changes will be made)\n')

    _ensure_sigmond_dirs()
    errors = 0

    # --- 1. Install smd itself ---
    _heading('Sigmond')
    sigmond_dir = Path(__file__).resolve().parent.parent
    if not args.dry_run:
        _install_smd_itself(sigmond_dir, smd_bin)

    # --- 2. Dependencies ---
    dcfg = _load_deps_conf(client_dir)
    if dcfg is None:
        return 1

    venv_dir = Path('/opt/wsprdaemon/venv')
    if not args.dry_run and not _ensure_venv(venv_dir):
        return 1

    needed_deps = _collect_deps_for_components(components)
    if needed_deps:
        _heading('Dependencies')
        for dep in needed_deps:
            if dep not in dcfg.sections():
                _warn(f'{dep}: not in deps.conf, skipping')
                continue
            dep_type = dcfg.get(dep, 'type', fallback='').strip()
            if args.dry_run:
                _info(f'would install [{dep}] ({dep_type})')
                continue
            if dep_type == 'git':
                if not _install_git_dep(dep, dcfg):
                    errors += 1
                # Build step if this dep needs one
                if dep in BUILD_STEPS:
                    src_dir = Path(dcfg.get(dep, 'install_to', fallback=''))
                    fn_name = BUILD_STEPS[dep]
                    fn = globals()[fn_name]
                    if src_dir.exists() and not fn(src_dir):
                        errors += 1
            elif dep_type == 'pypi':
                if not _install_pypi_dep(dep, dcfg, venv_dir):
                    errors += 1

    # --- 3. Scripts, wdlib, systemd units ---
    _heading('wsprdaemon-client')
    if not args.dry_run:
        _install_wdlib(client_dir)
        _install_wrapper_scripts(client_dir)
        _install_systemd_units(client_dir)
    else:
        _info('would install wdlib, scripts, and systemd units')

    # --- 4. Service configuration and start (wd-ctl apply) ---
    _heading('Services')
    if 'wspr' in components or 'radiod' in components:
        if not _run_wd_ctl_apply(client_dir, args.dry_run):
            _warn('wd-ctl apply reported errors — check output above')
            errors += 1

    # --- 5. grape status check (hf-timestd manages itself) ---
    if 'grape' in components and not args.dry_run:
        _heading('GRAPE / hf-timestd')
        r = _run(['systemctl', 'is-active', 'timestd-core-recorder.service'])
        if r.returncode == 0:
            _ok('timestd-core-recorder: running')
        else:
            _warn('timestd-core-recorder: not running  (hf-timestd manages its own install)')

    # --- Summary ---
    print()
    if errors:
        print(f'\033[31msmd install completed with {errors} error(s).\033[0m')
        return 1
    print(f'\033[32msmd install complete.\033[0m  Run \033[1msmd status\033[0m to verify.')
    return 0


# ---------------------------------------------------------------------------
# smd apply
# ---------------------------------------------------------------------------

def cmd_apply(args) -> int:
    if _need_root('apply'):
        return 1
    topology = _load_topology(
        Path(args.topology) if args.topology else TOPOLOGY_PATH,
    )
    _heading('apply')
    ok = _run_wd_ctl_apply(topology['client_dir'], getattr(args, 'dry_run', False))
    return 0 if ok else 1


# ---------------------------------------------------------------------------
# smd start / stop / restart / reload
# ---------------------------------------------------------------------------

def cmd_start(args) -> int:
    if _need_root('start'):
        return 1
    topology = _load_topology(Path(args.topology) if args.topology else TOPOLOGY_PATH)
    only = [c.strip() for c in args.components.split(',')] if args.components else None
    enabled = _enabled_components(topology, only)

    try:
        units = resolve_units(enabled, enabled)
    except ValueError as exc:
        _err(f"component resolution failed: {exc}")
        return 1

    # Filter to configured instances only (not orphaned)
    units = [u for u in units if not u.orphaned]

    _heading('start')
    for unit in units:
        r = _run(['systemctl', 'start', unit.unit], sudo=True)
        if r.returncode == 0:
            _ok(f'{unit.unit}')
        else:
            _err(f'{unit.unit}: {r.stderr.strip()}')
    return 0


def cmd_stop(args) -> int:
    if _need_root('stop'):
        return 1
    topology = _load_topology(Path(args.topology) if args.topology else TOPOLOGY_PATH)
    only = [c.strip() for c in args.components.split(',')] if args.components else None
    enabled = _enabled_components(topology, only)

    try:
        units = resolve_units(enabled, enabled)
    except ValueError as exc:
        _err(f"component resolution failed: {exc}")
        return 1

    # Filter to configured instances only
    units = [u for u in units if not u.orphaned]

    _heading('stop')
    # Stop in reverse order
    for unit in reversed(units):
        r = _run(['systemctl', 'stop', unit.unit], sudo=True)
        if r.returncode == 0:
            _ok(f'{unit.unit}')
        else:
            _err(f'{unit.unit}: {r.stderr.strip()}')
    return 0


def cmd_restart(args) -> int:
    if _need_root('restart'):
        return 1
    topology = _load_topology(Path(args.topology) if args.topology else TOPOLOGY_PATH)
    only = [c.strip() for c in args.components.split(',')] if args.components else None
    enabled = _enabled_components(topology, only)

    try:
        units = resolve_units(enabled, enabled)
    except ValueError as exc:
        _err(f"component resolution failed: {exc}")
        return 1

    # Filter to configured instances only
    units = [u for u in units if not u.orphaned]

    _heading('restart')
    any_failed = False
    for unit in units:
        # Reset any failed state before restarting
        _run(['systemctl', 'reset-failed', unit.unit], sudo=True)
        r = _run(['systemctl', 'restart', unit.unit], sudo=True)
        if r.returncode == 0:
            _ok(f'{unit.unit}')
        else:
            _err(f'{unit.unit}: {r.stderr.strip()}')
            any_failed = True
    return 1 if any_failed else 0


def cmd_reload(args) -> int:
    if _need_root('reload'):
        return 1
    topology = _load_topology(Path(args.topology) if args.topology else TOPOLOGY_PATH)
    only = [c.strip() for c in args.components.split(',')] if args.components else None
    enabled = _enabled_components(topology, only)

    try:
        units = resolve_units(enabled, enabled)
    except ValueError as exc:
        _err(f"component resolution failed: {exc}")
        return 1

    # Filter to configured instances only
    units = [u for u in units if not u.orphaned]

    _heading('reload')
    any_failed = False
    for unit in units:
        # Try systemctl reload first; fall back to try-restart
        r = _run(['systemctl', 'reload', unit.unit], sudo=True)
        if r.returncode == 0:
            _ok(f'{unit.unit}')
        else:
            # Fall back to try-restart
            r = _run(['systemctl', 'try-restart', unit.unit], sudo=True)
            if r.returncode == 0:
                _ok(f'{unit.unit} (via try-restart)')
            else:
                _err(f'{unit.unit}: {r.stderr.strip()}')
                any_failed = True
    return 1 if any_failed else 0


# smd status / list
# ---------------------------------------------------------------------------

def cmd_status(args) -> int:
    topology = _load_topology(Path(args.topology) if args.topology else TOPOLOGY_PATH)
    only = [c.strip() for c in args.components.split(',')] if args.components else None
    enabled = _enabled_components(topology, only)

    try:
        units = resolve_units(enabled, enabled)
    except ValueError as exc:
        _err(f"component resolution failed: {exc}")
        return 1

    _heading('status')
    any_bad = False

    # Group by component for display
    by_component: dict[str, list[UnitRef]] = {}
    for unit in units:
        if unit.component not in by_component:
            by_component[unit.component] = []
        by_component[unit.component].append(unit)

    for comp in sorted(by_component.keys()):
        comp_units = by_component[comp]
        print(f'\n  {comp}:')
        if not comp_units:
            _info('(no managed services)')
            continue

        for unit_ref in comp_units:
            # Check unit state
            r = _run(['systemctl', 'is-active', unit_ref.unit])
            state = r.stdout.strip() or 'unknown'
            sym = '✓' if state == 'active' else '✗'
            color = '\033[32m' if state == 'active' else '\033[31m'

            orphan_tag = ' [orphaned]' if unit_ref.orphaned else ''
            print(f'    {color}{sym}\033[0m  {unit_ref.unit}: {state}{orphan_tag}')

            if state not in ('active', 'inactive'):
                any_bad = True

    # Inventory enrichment for installed clients
    if _HAS_SIGMOND_LIB:
        try:
            catalog = load_catalog()
        except FileNotFoundError:
            catalog = {}
        seen = set()
        for comp in sorted(by_component.keys()):
            entry = get_entry(comp, catalog) if catalog else None
            if entry is None or entry.kind != 'client' or entry.name in seen:
                continue
            seen.add(entry.name)
            inv = _get_client_inventory(entry.name)
            if inv is None:
                continue
            version = inv.get('version', '?')
            contract = inv.get('contract_version', '?')
            instances = inv.get('instances', [])
            issues = inv.get('issues', [])
            git = inv.get('git', {})
            sha = git.get('short', '')
            sha_tag = f'  ({sha})' if sha else ''

            print(f'\n  {entry.name}  v{version}{sha_tag}  contract={contract}')
            for inst in instances:
                name = inst.get('instance', '?')
                channels = inst.get('ka9q_channels', 0)
                freqs = inst.get('frequencies_hz', [])
                modes = inst.get('modes', [])
                parts = [f'{channels} ch'] if channels else []
                if modes:
                    parts.append(f'modes={",".join(str(m) for m in modes)}')
                elif freqs:
                    parts.append(f'{len(freqs)} freqs')
                _info(f'{name}: {", ".join(parts)}' if parts else name)
            for issue in issues:
                sev = issue.get('severity', 'warn') if isinstance(issue, dict) else 'warn'
                msg = issue.get('message', str(issue)) if isinstance(issue, dict) else str(issue)
                if sev == 'fail':
                    _err(msg)
                else:
                    _warn(msg)

    print()
    return 1 if any_bad else 0


def cmd_list(args) -> int:
    show_available = getattr(args, 'available', False)
    show_all = getattr(args, 'all', False)

    if show_available or show_all:
        return _list_catalog(args, include_configured=show_all)
    return _list_configured(args)


def _list_catalog(args, *, include_configured: bool) -> int:
    import json as _json

    try:
        catalog = load_catalog()
    except FileNotFoundError as exc:
        _err(str(exc))
        return 1

    if args.json:
        out = []
        for name, entry in sorted(catalog.items()):
            d = {
                'name': entry.name,
                'kind': entry.kind,
                'description': entry.description,
                'repo': entry.repo,
                'uses': list(entry.uses),
                'contract': entry.contract,
                'install_script': entry.install_script,
                'installed': entry.is_installed(),
            }
            out.append(d)
        print(_json.dumps(out, indent=2))
    else:
        servers = [(n, e) for n, e in sorted(catalog.items()) if e.kind == 'server']
        clients = [(n, e) for n, e in sorted(catalog.items()) if e.kind == 'client']

        _heading('catalog — available')
        if servers:
            print(f'\n  Servers ({len(servers)})')
            for _, entry in servers:
                _print_catalog_entry(entry)
        if clients:
            print(f'\n  Clients ({len(clients)})')
            for _, entry in clients:
                _print_catalog_entry(entry)

    if include_configured:
        print()
        return _list_configured(args)
    return 0


def _print_catalog_entry(entry) -> None:
    installed = entry.is_installed()
    sym = '✓' if installed else '·'
    color = '\033[32m' if installed else '\033[90m'
    contract_tag = f'  contract={entry.contract}' if entry.contract else ''
    print(f'    {color}{sym}\033[0m  {entry.name:22s} {entry.description}{contract_tag}')


def _list_configured(args) -> int:
    topology = _load_topology(Path(args.topology) if args.topology else TOPOLOGY_PATH)
    only = [c.strip() for c in args.components.split(',')] if args.components else None
    enabled = _enabled_components(topology, only)

    try:
        units = resolve_units(enabled, enabled)
    except ValueError as exc:
        _err(f"component resolution failed: {exc}")
        return 1

    if args.json:
        import json as _json
        units_data = []
        for unit_ref in units:
            r = _run(['systemctl', 'is-active', unit_ref.unit])
            state = r.stdout.strip() or 'unknown'
            units_data.append({
                'component': unit_ref.component,
                'unit': unit_ref.unit,
                'template': unit_ref.template,
                'instance': unit_ref.instance,
                'kind': unit_ref.kind,
                'source': unit_ref.source,
                'active_state': state,
                'orphaned': unit_ref.orphaned,
            })
        print(_json.dumps(units_data, indent=2))
    else:
        _heading('configured units')
        by_component: dict[str, list[UnitRef]] = {}
        for unit in units:
            if unit.component not in by_component:
                by_component[unit.component] = []
            by_component[unit.component].append(unit)

        for comp in sorted(by_component.keys()):
            print(f'\n  {comp}:')
            for unit_ref in sorted(by_component[comp], key=lambda u: u.unit):
                r = _run(['systemctl', 'is-active', unit_ref.unit])
                state = r.stdout.strip() or 'unknown'
                sym = '✓' if state == 'active' else '✗'
                color = '\033[32m' if state == 'active' else '\033[31m'
                orphan_tag = ' [orphaned]' if unit_ref.orphaned else ''
                print(f'    {color}{sym}\033[0m  {unit_ref.unit}: {state}{orphan_tag}')

    return 0


# ---------------------------------------------------------------------------
# smd log
# ---------------------------------------------------------------------------

def cmd_log(args) -> int:
    client = getattr(args, 'client', None)
    level = getattr(args, 'level', None)
    files = getattr(args, 'files', False)

    # --- set log level mode ---
    if level:
        topology = _load_topology(Path(args.topology) if args.topology else TOPOLOGY_PATH)
        key = set_log_level(client, level)
        _ok(f'{key}={level.upper()} written to coordination.env')

        if client:
            only = [client]
            enabled = _enabled_components(topology, only)
            if not enabled:
                enabled = [client]
            try:
                units = resolve_units(enabled, _enabled_components(topology))
                unit_names = [u.unit for u in units if not u.orphaned]
            except (ValueError, Exception):
                unit_names = []

            if unit_names:
                failed = send_sighup(unit_names)
                for u in unit_names:
                    if u in failed:
                        _warn(f'SIGHUP {u}: failed')
                    else:
                        _ok(f'SIGHUP {u}')
            else:
                _info(f'no units resolved for {client} — SIGHUP skipped')
        else:
            _info('CLIENT_LOG_LEVEL set; send SIGHUP to individual clients to apply')
        return 0

    # --- follow mode (requires a client name) ---
    if not client:
        _err('smd log: specify a client name (e.g. smd log psk-recorder)')
        return 1

    if files:
        log_paths = get_inventory_log_paths(client)
        if not log_paths:
            _err(f'{client}: no log_paths in inventory (is {client} installed?)')
            return 1
        paths = flatten_log_paths(log_paths)
        if not paths:
            _err(f'{client}: log_paths is empty')
            return 1
        missing = [p for p in paths if not Path(p).exists()]
        if missing:
            for m in missing:
                _warn(f'not found: {m}')
        existing = [p for p in paths if Path(p).exists()]
        if not existing:
            _err(f'{client}: none of the log files exist yet')
            return 1
        _info(f'tailing {len(existing)} file(s) for {client}...')
        follow_files(existing)
        return 0  # unreachable after exec

    # --- default: journalctl follow ---
    topology = _load_topology(Path(args.topology) if args.topology else TOPOLOGY_PATH)
    only = [client]
    enabled = _enabled_components(topology, only)
    if not enabled:
        enabled = [client]
    try:
        all_enabled = _enabled_components(topology)
        units = resolve_units(enabled, all_enabled)
        unit_names = [u.unit for u in units if not u.orphaned]
    except (ValueError, Exception):
        unit_names = []

    if not unit_names:
        _warn(f'no units resolved for {client} — trying journalctl with pattern')
        unit_names = [f'{client}*']

    _info(f'following journal for: {", ".join(unit_names)}')
    follow_journal(unit_names)
    return 0  # unreachable after exec


# ---------------------------------------------------------------------------
# smd update
# ---------------------------------------------------------------------------

def cmd_update(args) -> int:
    if _need_root('update'):
        return 1
    topology = _load_topology(Path(args.topology) if args.topology else TOPOLOGY_PATH)
    client_dir = topology['client_dir']

    _heading('update')
    _info(f'Pulling wsprdaemon-client ({client_dir}) ...')
    r = _run(['git', '-C', str(client_dir), 'pull'], capture=False)
    if r.returncode != 0:
        _err('git pull failed')
        return 1

    # Re-run install to pick up any changed deps / units / scripts
    args.client_dir  = None
    args.components  = None
    args.dry_run     = False
    args.topology    = getattr(args, 'topology', None)
    return cmd_install(args)


# ---------------------------------------------------------------------------
# smd diag
# ---------------------------------------------------------------------------

def cmd_diag(args) -> int:
    topology = _load_topology(Path(args.topology) if args.topology else TOPOLOGY_PATH)
    client_dir = topology['client_dir']

    _heading('diagnostics')
    errors = 0

    # Network
    for host in ['wsprnet.org', 'graphs.wsprdaemon.org', 'logs.wsprdaemon.org']:
        r = _run(['ping', '-c1', '-W2', host])
        if r.returncode == 0:
            _ok(f'network: {host} reachable')
        else:
            _warn(f'network: {host} unreachable')

    # Deps commit check
    dcfg = _load_deps_conf(client_dir)
    if dcfg:
        print()
        _info('Dependency versions:')
        for dep in dcfg.sections():
            dep_type   = dcfg.get(dep, 'type', fallback='').strip()
            pinned     = dcfg.get(dep, 'commit', fallback='').strip()
            install_to = dcfg.get(dep, 'install_to', fallback='').strip()
            if dep_type == 'git' and install_to:
                r = _run(['git', '-c', f'safe.directory={install_to}',
                          '-C', install_to, 'rev-parse', 'HEAD'])
                current = r.stdout.strip()
                if r.returncode != 0 or not current:
                    _warn(f'{dep}: not installed at {install_to}')
                    errors += 1
                elif current.startswith(pinned[:12]):
                    _ok(f'{dep}: {current[:12]}')
                else:
                    _warn(f'{dep}: have {current[:12]}, want {pinned[:12]}')
                    errors += 1

    # Client self-validation
    if _HAS_SIGMOND_LIB:
        try:
            catalog = load_catalog()
        except FileNotFoundError:
            catalog = {}

        if catalog:
            only = [c.strip() for c in args.components.split(',')] if getattr(args, 'components', None) else None
            enabled = _enabled_components(topology, only)
            print()
            _info('Client validation:')
            seen = set()
            for comp in enabled:
                entry = get_entry(comp, catalog)
                if entry is None or entry.kind != 'client' or entry.name in seen:
                    continue
                seen.add(entry.name)
                val = _get_client_validate(entry.name)
                if val is None:
                    _info(f'  {entry.name}: validate unavailable')
                    continue
                ok = val.get('ok', False)
                if ok:
                    _ok(f'{entry.name}: all checks passed')
                else:
                    _warn(f'{entry.name}: validation failed')
                    errors += 1
                for issue in val.get('issues', []):
                    if isinstance(issue, dict):
                        sev = issue.get('severity', 'warn')
                        msg = issue.get('message', '')
                    else:
                        sev, msg = 'warn', str(issue)
                    if sev == 'fail':
                        _err(f'  {entry.name}: {msg}')
                    else:
                        _warn(f'  {entry.name}: {msg}')

    # Service health
    print()
    cmd_status(args)

    print()
    if errors:
        print(f'\033[33mdiag: {errors} issue(s) found\033[0m')
    else:
        print('\033[32mdiag: all checks passed\033[0m')
    return 0 if not errors else 1


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

def main() -> int:
    parser = argparse.ArgumentParser(
        prog='smd',
        description='Sigmond — HamSCI suite installer and lifecycle manager',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=textwrap.dedent('''\
            commands:
              install   install and configure all enabled components
              apply     reconcile running services with current config
              start     start all managed services
              stop      stop all managed services
              status    show service health
              update    pull latest code and re-apply
              diag      run diagnostics
        '''),
    )
    parser.add_argument('--topology', metavar='FILE',
                        help=f'topology file (default: {TOPOLOGY_PATH})')
    sub = parser.add_subparsers(dest='command')

    # install
    p = sub.add_parser('install', help='install and configure components')
    p.add_argument('client', nargs='?', default=None,
                   help='specific client to install from catalog (e.g. psk-recorder)')
    p.add_argument('--components', metavar='C1,C2',
                   help='comma-separated subset (default: all enabled in topology)')
    p.add_argument('--client-dir', metavar='DIR',
                   help='path to wsprdaemon-client (overrides topology)')
    p.add_argument('--dry-run', action='store_true',
                   help='show what would be done without making changes')
    p.add_argument('--yes', '-y', action='store_true',
                   help='accept defaults, no interactive prompts')

    # apply
    p = sub.add_parser('apply', help='reconcile services with current config')
    p.add_argument('--dry-run', action='store_true')

    # start
    p = sub.add_parser('start', help='start managed services')
    p.add_argument('--components', metavar='C1,C2')

    # stop
    p = sub.add_parser('stop', help='stop managed services')
    p.add_argument('--components', metavar='C1,C2')

    # status
    p = sub.add_parser('status', help='show service health')
    p.add_argument('--components', metavar='C1,C2')

    # restart (NEW)
    p = sub.add_parser('restart', help='restart managed services')
    p.add_argument('--components', metavar='C1,C2')

    # reload (NEW)
    p = sub.add_parser('reload', help='reload managed services (signal or restart)')
    p.add_argument('--components', metavar='C1,C2')
    p.add_argument('--via', choices=['auto', 'systemd', 'socket'], default='auto',
                   help='routing strategy for reload (default: auto)')

    # list (NEW)
    p = sub.add_parser('list', help='list resolved units for components')
    p.add_argument('--components', metavar='C1,C2')
    p.add_argument('--json', action='store_true',
                   help='emit machine-readable JSON')
    list_scope = p.add_mutually_exclusive_group()
    list_scope.add_argument('--available', action='store_true',
                            help='show catalog of known clients (what could be installed)')
    list_scope.add_argument('--all', action='store_true',
                            help='show catalog + configured units together')

    # log
    p = sub.add_parser('log', help='view logs or set log level for a client')
    p.add_argument('client', nargs='?', default=None,
                   help='client name (e.g. psk-recorder, hf-timestd)')
    p.add_argument('--files', action='store_true',
                   help='tail file logs from inventory log_paths instead of journal')
    p.add_argument('--level', metavar='LEVEL',
                   help='set log level (DEBUG/INFO/WARNING/ERROR/CRITICAL) in coordination.env + SIGHUP')

    # update
    sub.add_parser('update', help='pull latest code and re-apply')

    # diag
    p = sub.add_parser('diag', help='run cross-component diagnostics')
    p.add_argument('--components', metavar='C1,C2')

    # validate (Phase 1)
    p = sub.add_parser('validate',
                       help='run cross-client harmonization rules (read-only)')
    p.add_argument('--json', action='store_true',
                   help='emit machine-readable JSON')

    # config (Phase 1)
    p_config = sub.add_parser('config',
                              help='inspect or migrate sigmond coordination config')
    config_sub = p_config.add_subparsers(dest='config_command')

    p = config_sub.add_parser('show',
                              help='dump effective coordination + client view')
    p.add_argument('--json', action='store_true')

    p = config_sub.add_parser('migrate',
                              help='extract coordination.toml from wsprdaemon.conf')
    p.add_argument('--from', dest='from_', metavar='FILE',
                   help='source wsprdaemon.conf (default: /etc/wsprdaemon/wsprdaemon.conf)')
    p.add_argument('--to', metavar='FILE',
                   help='destination coordination.toml (default: /etc/sigmond/coordination.toml)')
    p.add_argument('--write', action='store_true',
                   help='write the migrated file (otherwise print to stdout)')
    p.add_argument('--force', action='store_true',
                   help='overwrite target even if it already exists')

    args = parser.parse_args()
    if not args.command:
        print(BANNER)
        parser.print_help()
        return 0

    dispatch = {
        'install': cmd_install,
        'apply':   cmd_apply,
        'start':   cmd_start,
        'stop':    cmd_stop,
        'restart': cmd_restart,
        'reload':  cmd_reload,
        'list':    cmd_list,
        'log':     cmd_log,
        'status':  cmd_status,
        'update':  cmd_update,
        'diag':    cmd_diag,
    }

    if args.command in ('validate', 'config'):
        if not _HAS_SIGMOND_LIB:
            print('smd: sigmond library not found; install lib/sigmond alongside bin/smd',
                  file=sys.stderr)
            return 1
        if args.command == 'validate':
            return cmd_validate(args)
        # config
        sub_cmd = getattr(args, 'config_command', None)
        if sub_cmd == 'show':
            return cmd_config_show(args)
        if sub_cmd == 'migrate':
            return cmd_config_migrate(args)
        p_config.print_help()
        return 0

    return dispatch[args.command](args)


if __name__ == '__main__':
    sys.exit(main())
