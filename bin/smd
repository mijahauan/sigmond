# WD-RAC (frpc) install + config
# ---------------------------------------------------------------------------

_FRPC_VERSION   = '0.64.0'
_FRPS_URL       = 'gw2.wsprdaemon.org'
_FRPS_URL_HAMSCI = 'vpn.hamsci.org'
_FRPS_PORT      = 35736                              # secure frps port (35735 = open/legacy)
_FRPC_TOKEN     = 'e6fe04d781252e10b89b1ec490e005df' # shared token for frps-secure
_RAC_PORT_BASE  = 35800
_RAC_WEB_OFFSET = 10000
_FRPC_BIN       = Path('/usr/local/sbin/frpc')
_FRPC_INI       = Path('/etc/sigmond/frpc.ini')      # legacy — kept for migration removal
_FRPC_CONFIG    = Path('/etc/sigmond/frpc.toml')     # current config (TOML, TLS + token auth)
_FRPC_KEY       = Path('/etc/sigmond/frpc_id_rsa')   # dedicated keypair for this station
_FRPS_CA_CERT   = Path('/etc/sigmond/frps-ca.crt')  # gateway self-signed cert
_RAC_SERVICE    = 'wd-rac'


def _frpc_arch_suffix() -> str:
    import platform
    machine = platform.machine()
    if machine == 'x86_64':
        return 'linux_amd64'
    if machine in ('armv7l', 'armv6l'):
        return 'linux_arm'
    if machine == 'aarch64':
        return 'linux_arm64'
    raise RuntimeError(f'frpc: unsupported architecture {machine}')


def _install_frpc(dry_run: bool = False) -> bool:
    """Download the frpc binary if not present or version is wrong."""
    if _FRPC_BIN.exists():
        r = _run([str(_FRPC_BIN), '--version'])
        if r.returncode == 0 and _FRPC_VERSION in r.stdout:
            _ok(f'frpc: {_FRPC_VERSION} already installed')
            return True
        _info(f'frpc: version mismatch, reinstalling {_FRPC_VERSION}')

    try:
        arch = _frpc_arch_suffix()
    except RuntimeError as exc:
        _err(str(exc))
        return False

    import urllib.request, tarfile, tempfile
    tarname = f'frp_{_FRPC_VERSION}_{arch}.tar.gz'
    url = f'https://github.com/fatedier/frp/releases/download/v{_FRPC_VERSION}/{tarname}'

    if dry_run:
        _info(f'dry-run: would download {url} → {_FRPC_BIN}')
        return True

    _info(f'Downloading frpc {_FRPC_VERSION} ({arch}) ...')
    with tempfile.TemporaryDirectory() as tmp:
        tar_path = Path(tmp) / tarname
        try:
            urllib.request.urlretrieve(url, str(tar_path))
        except Exception as exc:
            _err(f'frpc download failed: {exc}')
            return False
        with tarfile.open(str(tar_path)) as tf:
            # The binary is at frp_VERSION_ARCH/frpc inside the archive
            member = next((m for m in tf.getmembers() if m.name.endswith('/frpc')), None)
            if member is None:
                _err('frpc not found in downloaded archive')
                return False
            member.name = 'frpc'
            tf.extract(member, path=tmp)
        frpc_extracted = Path(tmp) / 'frpc'
        r = _run(['install', '-m', '755', str(frpc_extracted), str(_FRPC_BIN)], sudo=True)
        if r.returncode != 0:
            _err(f'frpc install failed: {r.stderr.strip()}')
            return False

    _ok(f'frpc: {_FRPC_VERSION} installed to {_FRPC_BIN}')
    return True


def _read_rac_topology(topology: dict) -> tuple[str, int]:
    """Return (rac_id, rac_number) from topology, or ('', -1) if not configured."""
    comp = topology.get('components', {}).get('wd-rac', {})
    rac_id     = comp.get('rac_id', '').strip()
    rac_number = comp.get('rac_number', -1)
    try:
        rac_number = int(rac_number)
    except (TypeError, ValueError):
        rac_number = -1
    return rac_id, rac_number


def _detect_rac_defaults() -> tuple[str, int]:
    """Try to detect RAC ID and number from the wsprdaemon v4 config.

    Returns (rac_id, rac_number) where either can be empty/''-1 if undetectable.

    Reads /etc/wsprdaemon/wsprdaemon.conf (INI format):
      [general]  rac = <number>
      [receiver:NAME]  call = <reporter-id>   ← first one becomes default rac_id
    """
    import configparser as _cp
    wdconf = Path('/etc/wsprdaemon/wsprdaemon.conf')
    if not wdconf.exists():
        return '', -1

    cfg = _cp.ConfigParser(
        comment_prefixes=(';', '#'),
        inline_comment_prefixes=(';', '#'),
        strict=False,
        interpolation=None,
    )
    try:
        cfg.read(wdconf)
    except Exception:
        return '', -1

    # rac_number from [general] rac =
    rac_number = -1
    if cfg.has_section('general'):
        try:
            rac_number = int(cfg.get('general', 'rac', fallback='').strip())
        except (ValueError, TypeError):
            pass

    # rac_id from first [receiver:NAME] call =
    rac_id = ''
    for section in cfg.sections():
        parts = section.split(':')
        if parts[0] == 'receiver' and len(parts) == 2:
            call = cfg.get(section, 'call', fallback='').strip()
            if call:
                rac_id = call
                break

    return rac_id, rac_number


_WD_USER    = 'wsprdaemon'
_WD_SSH_DIR = Path(f'/home/{_WD_USER}/.ssh')


def _find_wd_pubkey() -> Path | None:
    """Return the wsprdaemon user's SSH public key path, or None."""
    for name in ('id_ed25519', 'id_rsa', 'id_ecdsa'):
        p = _WD_SSH_DIR / f'{name}.pub'
        if p.exists():
            return p
    return None


def _ensure_frpc_keypair(dry_run: bool = False) -> bool:
    """Ensure there is an SSH public key for frpc authentication.

    Preference order:
      1. /home/wsprdaemon/.ssh/id_*.pub — already registered on the gateway
         via wd-upload-wsprdaemon uploads (no admin action needed).
      2. /etc/sigmond/frpc_id_rsa.pub   — fallback: generate a dedicated key
         and display it so the operator can register it manually.
    """
    pub = _find_wd_pubkey()
    if pub:
        _ok(f'frpc identity: using {_WD_USER} SSH key  →  {pub}')
        _info('  (auto-registered on gateway via wsprdaemon uploads)')
        return True

    # Fall back to dedicated key.
    fallback_pub = Path(str(_FRPC_KEY) + '.pub')
    if _FRPC_KEY.exists() and fallback_pub.exists():
        _ok(f'frpc identity: using dedicated key  →  {_FRPC_KEY}')
        return True
    if dry_run:
        _info(f'dry-run: would generate SSH keypair at {_FRPC_KEY}')
        return True

    import tempfile as _tf2, socket as _sock
    with _tf2.TemporaryDirectory() as td:
        tmp = Path(td) / 'frpc_id_rsa'
        r = subprocess.run(
            ['ssh-keygen', '-t', 'ed25519', '-N', '',
             '-C', f'wd-rac@{_sock.gethostname()}', '-f', str(tmp)],
            capture_output=True, text=True,
        )
        if r.returncode != 0:
            _err(f'ssh-keygen failed: {r.stderr.strip()}')
            return False
        _run(['mkdir', '-p', str(_FRPC_KEY.parent)], sudo=True)
        _run(['install', '-m', '600', str(tmp),          str(_FRPC_KEY)],          sudo=True)
        _run(['install', '-m', '644', str(tmp) + '.pub', str(_FRPC_KEY) + '.pub'], sudo=True)
    pub_txt = fallback_pub.read_text().strip() if fallback_pub.exists() else '(unreadable)'
    _ok(f'frpc identity: generated dedicated key  →  {_FRPC_KEY}')
    _warn('wsprdaemon SSH key not found — gateway registration is not automatic.')
    _warn('Send this public key to the RAC administrator to register the station:')
    _info(f'  {pub_txt}')
    return True


def _frpc_user_field() -> str:
    """Return the 16-char sha256 prefix used as the frpc user identity.

    Uses the wsprdaemon user's key if available (auto-registered via uploads),
    otherwise the dedicated /etc/sigmond/frpc_id_rsa.pub.
    Matches: sha256sum <pubkey_file> | cut -c1-16
    """
    import hashlib
    pub = _find_wd_pubkey() or Path(str(_FRPC_KEY) + '.pub')
    if not pub.exists():
        return ''
    return hashlib.sha256(pub.read_bytes()).hexdigest()[:16]


def _bootstrap_rac_registration(rac_id: str, dry_run: bool = False) -> bool:
    """Upload a spots-free .tbz to the gateway FTP so the server auto-provisions
    the station's SFTP/frpc account before any spots have been sent.

    The tar contains only:
      wsprdaemon/uploads_config.txt       — version metadata
      wsprdaemon/client_upload_info.txt   — reporter_id + ssh_public_key

    The server (wsprdaemon_server.py) processes this, creates a Linux user for
    the reporter, and adds the public key to authorized_keys — making the frps
    auth plugin accept the frpc connection on the next attempt.

    FTP is used here because SFTP requires the account to already exist.
    FTP accepts anonymous uploads (noisegraphs:xahFie6g) on gw2 only.
    """
    import ftplib, io, tarfile, time as _time

    pub_path = _find_wd_pubkey() or Path(str(_FRPC_KEY) + '.pub')
    if not pub_path.exists():
        _warn('bootstrap: no SSH public key found — skipping FTP registration')
        return False

    pubkey   = pub_path.read_text().strip()
    upload_id = rac_id.replace('/', '_')
    ts        = _time.strftime('%y%m%d_%H%M_%S', _time.gmtime())
    tar_name  = f'{upload_id}_{ts}.tbz'

    config_txt = (
        'CLIENT_VERSION=4.0\n'
        'UPLOADS_WSPRNET_LINE_FORMAT_VERSION=1\n'
        'UPLOADS_WSPRDAEMON_SPOT_LINE_FORMAT_VERSION=3\n'
        'SIGNAL_LEVEL_UPLOAD=yes\n'
    ).encode()
    info_txt = f'reporter_id={rac_id}\nssh_public_key={pubkey}\n'.encode()

    # Build the tar in memory.
    buf = io.BytesIO()
    with tarfile.open(fileobj=buf, mode='w:bz2') as tf:
        for arcname, data in [
            ('wsprdaemon/uploads_config.txt',    config_txt),
            ('wsprdaemon/client_upload_info.txt', info_txt),
        ]:
            ti = tarfile.TarInfo(name=arcname)
            ti.size = len(data)
            ti.mtime = int(_time.time())
            tf.addfile(ti, io.BytesIO(data))
    tbz_bytes = buf.getvalue()

    _info(f'bootstrap: uploading registration tar {tar_name} ({len(tbz_bytes)} B) ...')

    if dry_run:
        _info(f'dry-run: would FTP {tar_name} to gw2.wsprdaemon.org/upload/')
        return True

    ftp_server  = 'gw2.wsprdaemon.org'
    ftp_user    = 'noisegraphs'
    ftp_passwd  = 'xahFie6g'
    ftp_path    = 'upload'
    try:
        with ftplib.FTP(timeout=30) as ftp:
            ftp.connect(ftp_server)
            ftp.login(user=ftp_user, passwd=ftp_passwd)
            ftp.set_pasv(True)
            ftp.storbinary(f'STOR {ftp_path}/{tar_name}', io.BytesIO(tbz_bytes))
        _ok(f'bootstrap: registration uploaded  →  {ftp_server}/upload/{tar_name}')
        _info('  Server will create the gateway account and authorize the SSH key.')
        _info('  The frpc tunnel will connect on its next retry (≤30 s).')
        return True
    except Exception as exc:
        _warn(f'bootstrap: FTP upload failed: {exc}')
        _warn('  Tunnel will retry — registration will complete after the first spot upload.')
        return False   # non-fatal: frpc retries; registration completes via spot upload


def _fetch_frps_ca_cert(dry_run: bool = False) -> bool:
    """Fetch the frps server's TLS cert and save to _FRPS_CA_CERT."""
    if _FRPS_CA_CERT.exists():
        _ok(f'frps CA cert: {_FRPS_CA_CERT}')
        return True
    if dry_run:
        _info(f'dry-run: would fetch TLS cert from {_FRPS_URL}:{_FRPS_PORT}')
        return True
    import ssl as _ssl, socket as _sock2
    try:
        ctx = _ssl.SSLContext(_ssl.PROTOCOL_TLS_CLIENT)
        ctx.check_hostname = False
        ctx.verify_mode = _ssl.CERT_NONE
        with _sock2.create_connection((_FRPS_URL, _FRPS_PORT), timeout=10) as raw:
            with ctx.wrap_socket(raw) as s:
                der = s.getpeercert(binary_form=True)
        pem = _ssl.DER_cert_to_PEM_cert(der)
    except Exception as exc:
        _err(f'failed to fetch frps CA cert from {_FRPS_URL}:{_FRPS_PORT}: {exc}')
        return False
    import tempfile as _tf3
    with _tf3.NamedTemporaryFile('w', suffix='.crt', delete=False) as tf:
        tf.write(pem)
        tf_path = tf.name
    _run(['mkdir', '-p', str(_FRPS_CA_CERT.parent)], sudo=True)
    r = _run(['install', '-m', '644', tf_path, str(_FRPS_CA_CERT)], sudo=True)
    Path(tf_path).unlink(missing_ok=True)
    if r.returncode != 0:
        _err(f'failed to save CA cert: {r.stderr.strip()}')
        return False
    _ok(f'frps CA cert: fetched and saved  →  {_FRPS_CA_CERT}')
    return True


def _write_frpc_config(rac_id: str, rac_number: int, dry_run: bool = False) -> bool:
    """Write /etc/sigmond/frpc.toml with TLS + token auth for the secure frps port."""
    if not rac_id:
        _err('wd-rac: rac_id is empty')
        return False
    if rac_number < 0:
        _err('wd-rac: rac_number not set')
        return False

    frps_host = _FRPS_URL_HAMSCI if 200 <= rac_number <= 299 else _FRPS_URL
    ssh_port  = _RAC_PORT_BASE + rac_number
    web_port  = ssh_port + _RAC_WEB_OFFSET
    user_field = _frpc_user_field()

    local_ssh_port = 22
    try:
        for line in Path('/etc/ssh/sshd_config').read_text().splitlines():
            if line.startswith('Port '):
                local_ssh_port = int(line.split()[1])
    except Exception:
        pass

    lines = [
        f'serverAddr = "{frps_host}"',
        f'serverPort = {_FRPS_PORT}',
    ]
    if user_field:
        lines.append(f'user = "{user_field}"')
    lines += [
        '',
        '[auth]',
        'method = "token"',
        f'token = "{_FRPC_TOKEN}"',
        '',
        '[transport.tls]',
        'enable = true',
        f'trustedCaFile = "{_FRPS_CA_CERT}"',
        '',
        '[webServer]',
        'addr = "127.0.0.1"',
        'port = 7500',
        '',
        '[[proxies]]',
        f'name = "{rac_id}"',
        'type = "tcp"',
        'localIP = "127.0.0.1"',
        f'localPort = {local_ssh_port}',
        f'remotePort = {ssh_port}',
        '',
        '[[proxies]]',
        f'name = "{rac_id}-WEB"',
        'type = "tcp"',
        'localIP = "127.0.0.1"',
        'localPort = 8081',
        f'remotePort = {web_port}',
    ]
    content = '\n'.join(lines) + '\n'

    if dry_run:
        _info(f'dry-run: would write {_FRPC_CONFIG}:\n{textwrap.indent(content, "     ")}')
        return True

    _run(['mkdir', '-p', str(_FRPC_CONFIG.parent)], sudo=True)
    import tempfile as _tf4
    with _tf4.NamedTemporaryFile('w', suffix='.toml', delete=False) as tf:
        tf.write(content)
        tf_path = tf.name
    r = _run(['install', '-m', '640', tf_path, str(_FRPC_CONFIG)], sudo=True)
    Path(tf_path).unlink(missing_ok=True)
    if r.returncode != 0:
        _err(f'frpc.toml write failed: {r.stderr.strip()}')
        return False
    _ok(f'frpc.toml: written ({rac_id}, channel {rac_number}, port {ssh_port})')
    return True


def _write_frpc_ini(rac_id: str, rac_number: int, dry_run: bool = False) -> bool:
    """Write /etc/sigmond/frpc.ini for the given RAC ID and number."""
    if not rac_id:
        _err('wd-rac: rac_id is empty — set it in topology.toml [component.wd-rac]')
        return False
    if rac_number < 0:
        _err('wd-rac: rac_number not set — obtain it from the RAC administrator')
        return False

    frps_host = _FRPS_URL_HAMSCI if 200 <= rac_number <= 299 else _FRPS_URL
    ssh_port  = _RAC_PORT_BASE + rac_number
    web_port  = ssh_port + _RAC_WEB_OFFSET

    # Detect non-standard sshd port
    local_ssh_port = 22
    try:
        sshd_cfg = Path('/etc/ssh/sshd_config').read_text()
        for line in sshd_cfg.splitlines():
            if line.startswith('Port '):
                local_ssh_port = int(line.split()[1])
    except Exception:
        pass

    ini_content = f"""\
[common]
admin_addr = 127.0.0.1
admin_port = 7500
server_addr = {frps_host}
server_port = {_FRPS_PORT}

[{rac_id}]
type = tcp
local_ip = 127.0.0.1
local_port = {local_ssh_port}
remote_port = {ssh_port}

[{rac_id}-WEB]
type = tcp
local_ip = 127.0.0.1
local_port = 8081
remote_port = {web_port}
"""
    if dry_run:
        _info(f'dry-run: would write {_FRPC_INI}:\n{textwrap.indent(ini_content, "     ")}')
        return True

    _run(['mkdir', '-p', str(_FRPC_INI.parent)], sudo=True)
    import tempfile, shutil as _shutil
    with tempfile.NamedTemporaryFile('w', suffix='.ini', delete=False) as tf:
        tf.write(ini_content)
        tf_path = tf.name
    r = _run(['install', '-m', '640', tf_path, str(_FRPC_INI)], sudo=True)
    Path(tf_path).unlink(missing_ok=True)
    if r.returncode != 0:
        _err(f'frpc.ini write failed: {r.stderr.strip()}')
        return False
    _ok(f'frpc.ini: written ({rac_id}, channel {rac_number}, port {ssh_port})')
    return True


def _install_rac_service(dry_run: bool = False) -> bool:
    """Write and enable the wd-rac systemd service."""
    unit_path = Path('/etc/systemd/system/wd-rac.service')
    unit_content = f"""\
[Unit]
Description=WsprDaemon Remote Access Channel (frpc tunnel)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart={_FRPC_BIN} -c {_FRPC_CONFIG}
Restart=always
RestartSec=30s
TimeoutStartSec=30

[Install]
WantedBy=multi-user.target
"""
    if dry_run:
        _info(f'dry-run: would write {unit_path} and enable wd-rac.service')
        return True

    import tempfile
    with tempfile.NamedTemporaryFile('w', suffix='.service', delete=False) as tf:
        tf.write(unit_content)
        tf_path = tf.name
    r = _run(['install', '-m', '644', tf_path, str(unit_path)], sudo=True)
    Path(tf_path).unlink(missing_ok=True)
    if r.returncode != 0:
        _err(f'wd-rac.service write failed: {r.stderr.strip()}')
        return False
    # Remove legacy frpc.ini now that we use frpc.toml.
    if _FRPC_INI.exists():
        _run(['rm', '-f', str(_FRPC_INI)], sudo=True)
    _run(['systemctl', 'daemon-reload'], sudo=True)
    _run(['systemctl', 'enable', 'wd-rac.service'], sudo=True)
    _run(['systemctl', 'restart', 'wd-rac.service'], sudo=True)
    _ok('wd-rac.service: installed and enabled')
    return True


def _install_wd_rac(topology: dict, dry_run: bool = False, yes: bool = False) -> bool:
    """Full wd-rac install: frpc binary + frpc.ini + systemd service."""
    rac_id, rac_number = _read_rac_topology(topology)

    # Fall back to wsprdaemon.conf auto-detection when not explicitly configured.
    if not rac_id or rac_number < 0:
        detected_id, detected_num = _detect_rac_defaults()
        if not rac_id and detected_id:
            rac_id = detected_id
            _info(f'wd-rac: rac_id auto-detected from wsprdaemon.conf: {rac_id}')
        if rac_number < 0 and detected_num >= 0:
            rac_number = detected_num
            _info(f'wd-rac: rac_number auto-detected from wsprdaemon.conf: {rac_number}')

    # Interactive prompt when still missing and running in a real terminal.
    if (not rac_id or rac_number < 0) and not yes and sys.stdin.isatty():
        import readline  # noqa: F401 — enables line editing on input()
        print()
        print('  wd-rac needs two values from the RAC administrator:')
        if not rac_id:
            try:
                val = input('  RAC ID   (e.g. AI6VN-0, leave blank to skip): ').strip()
                if val:
                    rac_id = val
            except (EOFError, KeyboardInterrupt):
                pass
        if rac_number < 0:
            try:
                val = input('  RAC number (integer from admin email, leave blank to skip): ').strip()
                if val:
                    rac_number = int(val)
            except (EOFError, KeyboardInterrupt, ValueError):
                pass

    if not rac_id or rac_number < 0:
        _warn('wd-rac: rac_id or rac_number not set — tunnel will not be started')
        _warn('  To configure: run  smd tui  and press  a  (RAC screen)')
        _warn('  Or:           sudo smd install --components wd-rac  (prompts interactively)')

    ok = True
    ok = _install_frpc(dry_run) and ok
    ok = _ensure_frpc_keypair(dry_run) and ok
    ok = _fetch_frps_ca_cert(dry_run) and ok
    if rac_id:
        _bootstrap_rac_registration(rac_id, dry_run)   # non-fatal; ignore return value
    if rac_id and rac_number >= 0:
        ok = _write_frpc_config(rac_id, rac_number, dry_run) and ok
        ok = _install_rac_service(dry_run) and ok
    return ok


def rac_status() -> dict:
    """Return a dict with frpc connection status for display/TUI."""
    result = {
        'frpc_installed': _FRPC_BIN.exists(),
        'frpc_version':   '',
        'config_exists':  _FRPC_CONFIG.exists(),
        'service_active': False,
        'tunnel_ok':      False,
        'rac_id':         '',
        'rac_number':     -1,
        'ssh_port':       -1,
    }
    if result['frpc_installed']:
        r = _run([str(_FRPC_BIN), '--version'])
        if r.returncode == 0:
            result['frpc_version'] = r.stdout.strip().split()[-1]

    if result['config_exists']:
        try:
            import tomllib
            with open(_FRPC_CONFIG, 'rb') as f:
                cfg = tomllib.load(f)
            for proxy in cfg.get('proxies', []):
                if not proxy.get('name', '').endswith('-WEB'):
                    result['rac_id']    = proxy.get('name', '')
                    rp = proxy.get('remotePort', -1)
                    result['ssh_port']   = rp
                    result['rac_number'] = rp - _RAC_PORT_BASE if rp > 0 else -1
                    break
        except Exception:
            pass

    r = _run(['systemctl', 'is-active', 'wd-rac.service'])
    result['service_active'] = (r.returncode == 0 and r.stdout.strip() == 'active')

    if result['service_active']:
        import socket
        try:
            with socket.create_connection((_FRPS_URL, _FRPS_PORT), timeout=3):
                result['tunnel_ok'] = True
        except OSError:
            result['tunnel_ok'] = False

    return result


# ---------------------------------------------------------------------------
# System-level install steps
# ---------------------------------------------------------------------------

def _install_systemd_units(client_dir: Path) -> int:
    unit_src = client_dir / 'systemd'
    unit_dst = Path('/etc/systemd/system')
    linked = []
    for pat in ('*.service', '*.target', '*.timer'):
        for f in unit_src.glob(pat):
            src = f.resolve()
            dst = unit_dst / f.name
            if dst.is_symlink() and dst.resolve() == src:
                continue
            r = _run(['ln', '-sf', str(src), str(dst)], sudo=True)
            if r.returncode == 0:
                linked.append(f.name)
            else:
                _err(f'could not symlink {f.name}: {r.stderr.strip()}')
    if linked:
        _run(['systemctl', 'daemon-reload'], sudo=True)
        _ok(f'systemd units: {len(linked)} symlinked')
    else:
        _ok('systemd units: all symlinks already current')
    return len(linked)


def _symlink(src: Path, dst: Path, label: str) -> bool:
    """Create or update a symlink dst → src.  Uses sudo if needed."""
    src = src.resolve()
    if dst.is_symlink() and dst.resolve() == src:
        return True   # already correct
    r = _run(['ln', '-sf', str(src), str(dst)], sudo=True)
    if r.returncode != 0:
        _err(f'could not symlink {dst}: {r.stderr.strip()}')
        return False
    _ok(f'{label}: {dst} → {src}')
    return True


def _install_smd_itself(sigmond_dir: Path, smd_bin: Path) -> bool:
    src = sigmond_dir / 'bin' / 'smd'
    if not src.exists():
        return True  # running from installed location already
    return _symlink(src, smd_bin, 'smd')


def _install_wrapper_scripts(client_dir: Path) -> None:
    sbin = Path('/usr/local/sbin')
    scripts = ['wd-ka9q-record', 'wd-kiwi-record', 'wd-kiwi-cleanup',
               'wd-spool-clean', 'wd-decode', 'wd-post',
               'wd-upload-wsprnet', 'wd-upload-wsprdaemon', 'wd-ctl']
    linked = []
    for name in scripts:
        src = client_dir / 'bin' / name
        if not src.exists():
            continue
        dst = sbin / name
        if dst.is_symlink() and dst.resolve() == src.resolve():
            continue
        r = _run(['ln', '-sf', str(src.resolve()), str(dst)], sudo=True)
        if r.returncode == 0:
            linked.append(name)
        else:
            _err(f'could not symlink {name}: {r.stderr.strip()}')
    if linked:
        _ok(f'scripts: {len(linked)} symlinked in {sbin}/')
    else:
        _ok('scripts: all symlinks already current')


def _install_wdlib(client_dir: Path) -> None:
    opt_lib = Path('/opt/wsprdaemon/lib')
    _run(['mkdir', '-p', str(opt_lib)], sudo=True)
    wdlib_src = client_dir / 'lib' / 'wdlib'
    wdlib_dst = opt_lib / 'wdlib'
    if not wdlib_src.is_dir():
        return
    if wdlib_dst.is_symlink():
        target = wdlib_dst.resolve()
        if target == wdlib_src.resolve():
            return
        _run(['rm', str(wdlib_dst)], sudo=True)
    elif wdlib_dst.exists():
        _run(['rm', '-rf', str(wdlib_dst)], sudo=True)
    _run(['ln', '-s', str(wdlib_src), str(wdlib_dst)], sudo=True)
    _ok('wdlib: symlinked into /opt/wsprdaemon/lib/')


def _run_wd_ctl_apply(client_dir: Path, dry_run: bool) -> bool:
    wd_ctl = Path('/usr/local/sbin/wd-ctl')
    if not wd_ctl.exists():
        wd_ctl = client_dir / 'bin' / 'wd-ctl'
    if not wd_ctl.exists():
        _err('wd-ctl not found — cannot generate env files and start services')
        return False
    cmd = [str(wd_ctl), 'apply']
    if dry_run:
        _info('dry-run: would run: sudo ' + ' '.join(cmd))
        return True
    _info('Running wd-ctl apply ...')
    r = _run(cmd, capture=False, sudo=True)
    return r.returncode == 0


def _ensure_sigmond_dirs() -> None:
    for d in [SIGMOND_CONF, SIGMOND_LOG]:
        _run(['mkdir', '-p', str(d)], sudo=True)


# ---------------------------------------------------------------------------
# smd install
# ---------------------------------------------------------------------------

def cmd_install(args) -> int:
    client = getattr(args, 'client', None)
    if client:
        return _install_single_client(args)
    return _install_full_suite(args)


def _install_single_client(args) -> int:
    """Catalog-driven install of a single client: smd install <client>."""
    client = args.client
    dry_run = getattr(args, 'dry_run', False)
    yes = getattr(args, 'yes', False)

    try:
        catalog = load_catalog()
    except FileNotFoundError as exc:
        _err(str(exc))
        return 1

    entry = get_entry(client, catalog)
    if entry is None:
        _err(f"unknown client '{client}' — see: smd list --available")
        return 1

    if not entry.install_script:
        # wd-rac is handled natively (frpc binary + ini + service).
        if entry.name == 'wd-rac':
            if _need_root('install'):
                return 1
            _netdiag_auto_refresh('install')
            _heading('wd-rac (Remote Access Channel)')
            topology = _load_topology(TOPOLOGY_PATH)
            return 0 if _install_wd_rac(topology, dry_run, yes=yes) else 1
        _err(f"'{entry.name}' has no install_script in the catalog")
        if entry.name in ('ka9q-radio', 'ka9q-web'):
            _info(f"ka9q-radio/ka9q-web are built via ka9q-update; use: smd install  (full suite)")
        return 1

    _heading(f'install {entry.name}')
    _info(f'repo:   {entry.repo}')
    _info(f'script: {entry.install_script}')

    if dry_run:
        _info('(dry-run) would clone repo and run install.sh')
        return 0

    if _need_root('install'):
        return 1

    _netdiag_auto_refresh('install')

    try:
        result = _do_install_client(entry, dry_run=dry_run, yes=yes, pull=True)
    except RuntimeError as exc:
        _err(str(exc))
        return 1

    if result:
        _ok(f'{entry.name} installed successfully')
        _info(f'next: edit /etc/{entry.name}/ config, then: smd start --components {entry.name}')
        return 0
    else:
        _err(f'{entry.name} install failed')
        return 1


def _install_full_suite(args) -> int:
    """Catalog-driven full-suite install.

    For each enabled component in the topology:
    - If the catalog entry has an install_script, install via the catalog
      (clone repo + run the client's own install.sh).
    - For C projects without install_scripts (radiod, ka9q-web), delegate
      to ka9q-update's install-ka9q.sh.
    """
    if _need_root('install'):
        return 1

    print(BANNER)
    _netdiag_auto_refresh('install')
    topology = _load_topology(
        Path(args.topology) if args.topology else TOPOLOGY_PATH,
        client_dir_override=getattr(args, 'client_dir', None),
    )
    smd_bin = topology['smd_bin']

    if args.components:
        # Explicit --components list bypasses the topology enabled filter so
        # the TUI (and CLI users) can install disabled-but-not-yet-installed
        # components without first editing topology.toml.
        components = [c.strip() for c in args.components.split(',')]
    else:
        components = _enabled_components(topology, None)
        if not components:
            print('No components enabled — check topology.toml or use: smd install <name>')
            return 1

    dry_run = getattr(args, 'dry_run', False)
    yes = getattr(args, 'yes', False)

    # Load the catalog to classify each component.
    try:
        catalog = load_catalog()
    except FileNotFoundError as exc:
        _err(str(exc))
        return 1

    # Classify components into catalog-driven vs. ka9q-update.
    catalog_queue = []    # CatalogEntry objects with install_script
    ka9q_update_needed = False
    unknown = []

    for comp in components:
        entry = get_entry(comp, catalog)
        if entry is None:
            unknown.append(comp)
            continue
        if entry.install_script:
            catalog_queue.append(entry)
        elif entry.name in ('ka9q-radio', 'ka9q-web'):
            ka9q_update_needed = True
        elif entry.kind in ('library', 'infra') and not entry.install_script:
            # Handled by sigmond itself (e.g. ka9q-python via venv, wd-rac via _install_frpc).
            pass
        else:
            unknown.append(comp)

    # --- Show install plan ---
    _heading('install plan')
    if ka9q_update_needed:
        c_names = [e.name for e in sorted(catalog.values(), key=lambda e: e.name)
                   if e.name in ('ka9q-radio', 'ka9q-web')
                   and e.name in [get_entry(c, catalog).name
                                  for c in components
                                  if get_entry(c, catalog) and not get_entry(c, catalog).install_script
                                  and get_entry(c, catalog).name in ('ka9q-radio', 'ka9q-web')]]
        _info(f'ka9q-update:  {", ".join(c_names) or "ka9q-radio + ka9q-web"}')
    for entry in catalog_queue:
        _info(f'catalog:      {entry.name:22s} → {entry.install_script}')
    for comp in unknown:
        _warn(f'unknown:      {comp} (not in catalog, skipping)')

    wd_rac_needed = 'wd-rac' in components
    if not catalog_queue and not ka9q_update_needed and not wd_rac_needed:
        _warn('nothing to install')
        return 0
    if wd_rac_needed:
        _info('wd-rac:       Remote Access Channel (frpc tunnel)')

    if dry_run:
        print('\n(dry-run mode — no changes will be made)')
        return 0

    if not yes:
        resp = input('\nProceed? [Y/n] ').strip().lower()
        if resp and resp not in ('y', 'yes'):
            print('Aborted.')
            return 0

    _ensure_sigmond_dirs()
    errors = 0

    # --- 1. Install smd itself + TUI venv ---
    _heading('Sigmond')
    sigmond_dir = Path(__file__).resolve().parent.parent
    _install_smd_itself(sigmond_dir, smd_bin)
    if not _ensure_sigmond_venv():
        _warn('TUI venv setup failed — smd tui will not work')
        errors += 1

    # --- 2. C projects via ka9q-update ---
    if ka9q_update_needed:
        _heading('ka9q-update (radiod + ka9q-web)')
        if not _install_via_ka9q_update():
            errors += 1

    # --- 3. Catalog-driven clients ---
    for entry in catalog_queue:
        _heading(f'install {entry.name}')
        try:
            result = _do_install_client(entry, dry_run=False, yes=yes, pull=True)
            if result:
                _ok(f'{entry.name} installed')
            else:
                _err(f'{entry.name} install failed')
                errors += 1
        except RuntimeError as exc:
            _err(f'{entry.name}: {exc}')
            errors += 1

    # --- 4. deps.conf dependencies ---
    client_dir = topology['client_dir']
    dcfg = _load_deps_conf(client_dir)
    if dcfg:
        deps_needed = _collect_deps_for_components(components)
        if deps_needed:
            _heading('dependencies (deps.conf)')
            venv_dir = Path('/opt/wsprdaemon/venv')
            for dep in deps_needed:
                if dep not in dcfg.sections():
                    _warn(f'{dep}: not found in deps.conf — skipping')
                    continue
                dep_type = dcfg.get(dep, 'type', fallback='').strip()
                if dep_type == 'git':
                    if not _install_git_dep(dep, dcfg):
                        errors += 1
                    # Trigger build step if this dep needs one
                    if dep in BUILD_STEPS:
                        install_to = dcfg.get(dep, 'install_to', fallback='').strip()
                        if install_to:
                            build_fn = globals().get(BUILD_STEPS[dep])
                            if build_fn and not build_fn(Path(install_to)):
                                errors += 1
                elif dep_type == 'pypi':
                    # Skip pypi deps that are catalog-managed (already installed via smd catalog path).
                    from sigmond.catalog import load_catalog as _lc, get_entry as _ge
                    try:
                        _cat = _lc()
                        if _ge(dep, _cat) is not None:
                            _ok(f'{dep}: managed by sigmond catalog — skipping deps.conf install')
                            continue
                    except Exception:
                        pass
                    if not _install_pypi_dep(dep, dcfg, venv_dir):
                        errors += 1
                else:
                    _warn(f'{dep}: unknown type "{dep_type}" in deps.conf — skipping')

    # --- 5. wd-rac (frpc tunnel) ---
    if 'wd-rac' in components:
        _heading('wd-rac (Remote Access Channel)')
        if not _install_wd_rac(topology, dry_run, yes=yes):
            errors += 1

    # --- Summary ---
    print()
    if errors:
        print(f'\033[31msmd install completed with {errors} error(s).\033[0m')
        return 1
    print(f'\033[32msmd install complete.\033[0m  Run \033[1msmd status\033[0m to verify.')
    return 0


# ka9q-update paths — searched in order.
_KA9Q_UPDATE_CANDIDATES = [
    Path('/home/mjh/git/ka9q-update'),
    Path('/opt/git/ka9q-update'),
]


def _find_ka9q_update() -> Path | None:
    """Locate the ka9q-update repo."""
    for p in _KA9Q_UPDATE_CANDIDATES:
        script = p / 'install-ka9q.sh'
        if script.exists():
            return script
    return None


def _install_via_ka9q_update() -> bool:
    """Delegate radiod + ka9q-web build/install to ka9q-update."""
    script = _find_ka9q_update()
    if script is None:
        _err('ka9q-update not found — install it to /opt/git/ka9q-update')
        _info('  git clone https://github.com/mijahauan/ka9q-update /opt/git/ka9q-update')
        return False
    _info(f'running {script} /opt/git ...')
    r = _run([str(script), '/opt/git'], capture=False, sudo=True)
    if r.returncode != 0:
        _err('ka9q-update install-ka9q.sh failed')
        return False
    _ok('ka9q-update: radiod + ka9q-web installed')
    _ensure_radiod_running()
    return True


def _ensure_radiod_running() -> None:
    """Start any known radiod@ instances that aren't currently active.

    Discovers instances from drop-in directories and running units so we
    catch instances that use the indirect template (no per-instance .service
    file in /etc/systemd/system/).
    """
    import glob as _glob
    seen: set[str] = set()

    # Instances with drop-in config dirs
    for d in _glob.glob('/etc/systemd/system/radiod@*.service.d'):
        name = Path(d).name  # radiod@foo.service.d
        unit = name[:-len('.d')]   # radiod@foo.service
        seen.add(unit)

    # Instances systemd already knows about (running or stopped)
    r = _run(
        ['systemctl', 'list-units', 'radiod@*', '--all',
         '--no-legend', '--plain', '--no-pager'],
        capture=True, sudo=False,
    )
    for line in r.stdout.splitlines():
        parts = line.split()
        if parts:
            seen.add(parts[0])

    for unit in sorted(seen):
        instance = unit[len('radiod@'):-len('.service')]
        r = _run(['systemctl', 'is-active', unit], capture=True, sudo=False)
        if r.stdout.strip() == 'active':
            _ok(f'radiod@{instance} already running')
            continue
        _info(f'starting radiod@{instance} ...')
        r = _run(['systemctl', 'enable', '--now', unit], capture=False, sudo=True)
        if r.returncode == 0:
            _ok(f'radiod@{instance} started')
        else:
            _warn(f'radiod@{instance} failed to start')


# ---------------------------------------------------------------------------
# smd apply
# ---------------------------------------------------------------------------

def _restart_upload_services_last() -> None:
    """Restart active wd-upload-* services so they start after all producers."""
    import subprocess as _sp
    r = _sp.run(
        ['systemctl', 'list-units', '--type=service', '--state=active',
         '--no-legend', '--no-pager', 'wd-upload-*'],
        capture_output=True, text=True,
    )
    units = [line.split()[0] for line in r.stdout.splitlines() if line.strip()]
    if not units:
        return
    _info('upload services: restarting last so producers are ready...')
    for unit in sorted(units):
        r2 = _run(['systemctl', 'restart', unit], sudo=True)
        if r2.returncode == 0:
            _ok(f'{unit}: restarted')
        else:
            _err(f'{unit}: {r2.stderr.strip()}')


def cmd_apply(args) -> int:
    if _need_root('apply'):
        return 1
    topology = _load_topology(
        Path(args.topology) if args.topology else TOPOLOGY_PATH,
    )
    dry_run = getattr(args, 'dry_run', False)
    _heading('apply')
    _netdiag_auto_refresh('apply')

    # Ensure deploy.toml link-kind install steps are present for all installed
    # catalog components.  This catches unit files that install.sh omitted or
    # that were accidentally removed.
    if _HAS_SIGMOND_LIB:
        try:
            from sigmond.installer import apply_deploy_toml_links
            from sigmond.catalog import load_catalog
            catalog = load_catalog()
            reloaded = False
            for name, entry in sorted(catalog.items()):
                repo_dir = Path('/opt/git') / name
                if not repo_dir.exists():
                    continue
                msgs = apply_deploy_toml_links(repo_dir, dry_run=dry_run)
                for msg in msgs:
                    if msg.startswith('  warning'):
                        _warn(msg.strip())
                    elif not msg.startswith('  (dry'):
                        _ok(f'deploy links: {msg.strip()}')
                        if '/etc/systemd' in msg:
                            reloaded = True
            if reloaded and not dry_run:
                _run(['systemctl', 'daemon-reload'], sudo=True)
        except Exception:
            pass  # non-fatal

    # Write CPU affinity drop-ins for radiod and restart any with wrong pinning
    # BEFORE wd-ctl apply so radiod is already correctly pinned when clients start.
    if _HAS_SIGMOND_LIB and not dry_run:
        try:
            enabled = _enabled_components(topology)
            from sigmond.lifecycle import resolve_units as _resolve_units
            radiod_units = [
                u for u in _resolve_units(enabled, enabled)
                if not u.orphaned and u.component == 'ka9q-radio' and u.kind == 'service'
            ]
            if radiod_units:
                _ensure_radiod_affinity_drop_ins(radiod_units, topology.get('cpu_affinity'))
        except Exception:
            pass  # non-fatal; affinity is best-effort

    ok = _run_wd_ctl_apply(topology['client_dir'], dry_run)

    # Restart wd-upload-* services AFTER everything else — they depend on
    # decoders being active and fail with "unavailable resources" if started too early.
    if not dry_run:
        _restart_upload_services_last()

    return 0 if ok else 1


# ---------------------------------------------------------------------------
# smd start / stop / restart / reload
# ---------------------------------------------------------------------------

def _ensure_radiod_affinity_drop_ins(radiod_units: list,
                                     topology_cpu_affinity=None) -> None:
    """Write smd-cpu-affinity.conf drop-ins for radiod service instances.

    Assigns physical core 0 to the first instance (alphabetically), core 1 to
    the second, etc.  Runs daemon-reload after writing so the constraints are
    in effect when the units start.

    For any instance already running with the wrong CPU affinity, restarts it
    so the new constraint takes effect immediately.
    """
    try:
        from sigmond.cpu import get_physical_cores, parse_cpu_mask
    except ImportError:
        return

    cores = get_physical_cores()
    if not cores:
        return

    sorted_units = sorted(radiod_units, key=lambda u: u.instance or u.unit)
    valid_unit_names = {u.unit for u in sorted_units}
    wrote_any = False
    units_to_restart: list[str] = []

    # Remove drop-in dirs for radiod instances that no longer exist.
    # These are left behind when an instance is removed from /etc/radio/
    # and would otherwise create ghost entries in CPU affinity reports.
    sys_dir = Path('/etc/systemd/system')
    for p in sorted(sys_dir.glob('radiod@*.service.d')):
        unit_name = p.name[:-2]  # strip '.d'
        if '@.' in unit_name:
            continue  # skip bare template radiod@.service.d
        if unit_name not in valid_unit_names:
            drop_in = p / _SMD_AFFINITY_DROP_IN
            if drop_in.exists():
                _ok(f'removing orphaned radiod affinity drop-in for {unit_name}')
                _run(['rm', '-rf', str(p)], sudo=True)
                wrote_any = True

    for i, unit_ref in enumerate(sorted_units):
        core_cpus = cores[i] if i < len(cores) else cores[-1]
        label = f'radiod {unit_ref.instance or unit_ref.unit} → CPUs {_cpu_list_str(core_cpus)}'
        if _write_affinity_drop_in(unit_ref.unit, core_cpus, label):
            _ok(f'affinity: {unit_ref.unit} → CPUs {_cpu_list_str(core_cpus)}')
            wrote_any = True

            # Check if the unit is already running with the wrong affinity.
            r_active = _run(['systemctl', 'is-active', '--quiet', unit_ref.unit])
            if r_active.returncode == 0:
                r_cur = _run(['systemctl', 'show', '-p', 'CPUAffinity',
                              '--value', unit_ref.unit])
                current_cpus = parse_cpu_mask(r_cur.stdout.strip())
                if current_cpus != core_cpus:
                    units_to_restart.append(unit_ref.unit)

    if wrote_any:
        _run(['systemctl', 'daemon-reload'], sudo=True)

    for unit in units_to_restart:
        _info(f'affinity changed: restarting {unit} to apply new CPU pinning')
        _run(['systemctl', 'restart', unit], sudo=True)


def cmd_start(args) -> int:
    if _need_root('start'):
        return 1
    topology = _load_topology(Path(args.topology) if args.topology else TOPOLOGY_PATH)
    only = [c.strip() for c in args.components.split(',')] if args.components else None
    enabled = _enabled_components(topology, only)

    try:
        units = resolve_units(enabled, enabled)
    except ValueError as exc:
        _err(f"component resolution failed: {exc}")
        return 1

    # Filter to configured instances only (not orphaned)
    units = [u for u in units if not u.orphaned]

    # Order: radiod first, then clients per coordination.toml (CONTRACT §5.4)
    if _HAS_SIGMOND_LIB:
        coord = load_coordination()
        units = order_units(units, coordination=coord)

    # Write CPU affinity drop-ins for radiod instances before starting them.
    radiod_services = [u for u in units
                       if u.component == 'ka9q-radio' and u.kind == 'service']
    if radiod_services:
        _ensure_radiod_affinity_drop_ins(radiod_services, topology.get('cpu_affinity'))

    _heading('start')
    _netdiag_auto_refresh('start')
    rc = 0
    for unit in units:
        r = _run(['systemctl', 'start', unit.unit], sudo=True)
        if r.returncode == 0:
            _ok(f'{unit.unit}')
        else:
            _err(f'{unit.unit}: {r.stderr.strip()}')
            rc = 1
    return rc


def cmd_stop(args) -> int:
    if _need_root('stop'):
        return 1
    topology = _load_topology(Path(args.topology) if args.topology else TOPOLOGY_PATH)
    only = [c.strip() for c in args.components.split(',')] if args.components else None
    enabled = _enabled_components(topology, only)

    try:
        units = resolve_units(enabled, enabled)
    except ValueError as exc:
        _err(f"component resolution failed: {exc}")
        return 1

    # Filter to configured instances only
    units = [u for u in units if not u.orphaned]

    # Order then reverse: clients stop first, radiod last (CONTRACT §5.4)
    if _HAS_SIGMOND_LIB:
        coord = load_coordination()
        units = order_units(units, coordination=coord)

    _heading('stop')
    # Stop in reverse order
    for unit in reversed(units):
        r = _run(['systemctl', 'stop', unit.unit], sudo=True)
        if r.returncode == 0:
            _ok(f'{unit.unit}')
        else:
            _err(f'{unit.unit}: {r.stderr.strip()}')
    return 0


# ---------------------------------------------------------------------------
# CPU affinity management
# ---------------------------------------------------------------------------
# Pure functions and constants are in lib/sigmond/cpu.py (imported above).
# CLI-only helpers that need _run() / _ok() / _err() stay here.


def _write_affinity_drop_in(unit: str, cpus: set, label: str) -> bool:
    """Write /etc/systemd/system/<unit>.d/smd-cpu-affinity.conf."""
    import tempfile
    drop_dir = Path(f'/etc/systemd/system/{unit}.d')
    drop_in  = drop_dir / _SMD_AFFINITY_DROP_IN
    content  = _render_drop_in(cpus, label)
    r = _run(['mkdir', '-p', str(drop_dir)], sudo=True)
    if r.returncode != 0:
        _err(f'{unit}: cannot create {drop_dir}')
        return False
    try:
        with tempfile.NamedTemporaryFile(mode='w', suffix='.conf',
                                         delete=False, dir='/tmp') as f:
            f.write(content)
            tmp = f.name
        r = _run(['mv', tmp, str(drop_in)], sudo=True)
        if r.returncode != 0:
            _err(f'{unit}: mv failed')
            return False
        # 644 so non-root processes (TUI) can read the configured CPU set
        _run(['chmod', '644', str(drop_in)], sudo=True)
    except OSError as e:
        _err(f'{unit}: {e}')
        return False
    return True


def _remove_foreign_affinity_drop_ins() -> list:
    """Remove cpu-affinity drop-ins written by hf-timestd and wd-ctl."""
    results = []
    for name in _FOREIGN_AFFINITY_DROP_INS:
        for p in sorted(Path('/etc/systemd/system').glob(f'*.d/{name}')):
            r = _run(['rm', '-f', str(p)], sudo=True)
            results.append((p, r.returncode == 0))
    return results


def _disable_hftimestd_affinity_watcher() -> None:
    """Disable and stop the hf-timestd units that monitor radiod for reinstalls."""
    for unit in _HFTIMESTD_AFFINITY_UNITS:
        r = _run(['systemctl', 'is-enabled', '--quiet', unit])
        if r.returncode == 0:
            _run(['systemctl', 'disable', '--now', unit], sudo=True)
            _ok(f'disabled + stopped {unit}')
        else:
            _info(f'{unit}: not enabled (skipping)')


def _apply_cpu_affinity_runtime(unit: str, cpus: set) -> bool:
    """Apply CPUAffinity/AllowedCPUs to a running unit without restarting it."""
    cpu_str = _cpu_list_str(cpus)
    r = _run(['systemctl', 'set-property', '--runtime', unit,
              f'CPUAffinity={cpu_str}', f'AllowedCPUs={cpu_str}'], sudo=True)
    if r.returncode == 0:
        return True
    r2 = _run(['systemctl', 'show', '-p', 'MainPID', '--value', unit])
    pid = r2.stdout.strip()
    if pid and pid != '0':
        mask = ','.join(str(c) for c in sorted(cpus))
        r3 = _run(['taskset', '-a', '-cp', mask, pid], sudo=True)
        return r3.returncode == 0
    return False


def cmd_diag_cpu_affinity(args) -> int:
    """Show CPU affinity of every running smd-managed service process.

    Renders from sigmond.cpu.build_affinity_report() — same report that
    powers the TUI CPU affinity screen and smd status's summary block.
    With --json, emits the full report for programmatic consumers.
    """
    import json as _json
    from sigmond.cpu import build_affinity_report, affinity_report_to_dict

    topology = _load_topology(Path(args.topology) if args.topology else TOPOLOGY_PATH)
    show_all_threads = getattr(args, 'threads', False)
    want_json = getattr(args, 'json', False)

    report = build_affinity_report(topology.get('cpu_affinity'))

    if want_json:
        _json.dump(affinity_report_to_dict(report), sys.stdout, indent=2)
        sys.stdout.write('\n')
        return 0

    _heading('diag: CPU affinity')

    any_running = False
    for ua in report.units:
        if not ua.main_pid:
            _info(f'{ua.unit}: not running')
            continue

        any_running = True
        # Preserve /proc's raw Cpus_allowed_list format so thread-group
        # keys (also raw /proc format) compare correctly against the
        # process mask in the diff-only thread display below.
        systemd_mask_str = _cpu_list_str(ua.systemd_mask) if ua.systemd_mask else ''
        proc_cpus_str = ua.observed_mask_raw or '?'
        sd_note = f'  [systemd CPUAffinity: {systemd_mask_str}]' if systemd_mask_str else ''

        if ua.mask_mismatch:
            _warn(f'{ua.unit}  (pid {ua.main_pid})  actual CPUs: {proc_cpus_str}{sd_note}')
            _info(f'       {ua.role} overrides systemd affinity via sched_setaffinity()')
        else:
            _ok(f'{ua.unit}  (pid {ua.main_pid})  CPUs: {proc_cpus_str}{sd_note}')

        thread_groups = ua.thread_groups
        if not thread_groups:
            continue

        if show_all_threads:
            display_masks = sorted(thread_groups)
        else:
            display_masks = sorted(m for m in thread_groups if m != proc_cpus_str)

        if display_masks:
            total_threads = sum(len(v) for v in thread_groups.values())
            if not show_all_threads:
                diff_count = sum(len(thread_groups[m]) for m in display_masks)
                _info(f'       {total_threads} threads — showing {diff_count} with non-process affinity:')
            else:
                _info(f'       {total_threads} threads:')
            for mask in display_masks:
                threads = thread_groups[mask]
                unique_names = sorted(set(n for _, n in threads))
                name_str = ', '.join(unique_names)
                if len(name_str) > 60:
                    name_str = name_str[:57] + '...'
                diff_flag = '  ← differs' if mask != proc_cpus_str else ''
                print(f'         CPUs {mask:<10s}  ×{len(threads):>3}  {name_str}{diff_flag}')
        elif not show_all_threads:
            total = sum(len(v) for v in thread_groups.values())
            _info(f'       {total} threads — all share process affinity ({proc_cpus_str})')

    if not any_running:
        _info('No active managed service processes found.')

    if getattr(args, 'apply', False):
        if os.geteuid() != 0:
            _err('--apply requires root  (sudo smd diag cpu-affinity --apply)')
            return 1

        plan = _compute_affinity_plan(topology.get('cpu_affinity'))
        radiod_plan = plan.radiod
        other_cpus = plan.other_cpus

        _heading('cpu-affinity apply')
        if radiod_plan:
            for unit, cpus in radiod_plan.items():
                _info(f'radiod  {unit}: CPUs {_cpu_list_str(cpus)}')
        else:
            _info('radiod: (no running instances found)')
        _info(f'other   CPUs: {_cpu_list_str(other_cpus)}')
        print()

        _info('Disabling hf-timestd affinity watcher units ...')
        _disable_hftimestd_affinity_watcher()
        print()

        _info('Removing foreign affinity drop-ins ...')
        removed = _remove_foreign_affinity_drop_ins()
        if removed:
            for path, ok in removed:
                (_ok if ok else _warn)(
                    f'{"removed" if ok else "could not remove"} {path}')
        else:
            _info('(none found)')
        print()

        _info('Writing smd affinity drop-ins ...')
        errors = 0

        for unit, cpus in radiod_plan.items():
            label = f'radiod instance → CPUs {_cpu_list_str(cpus)}'
            if _write_affinity_drop_in(unit, cpus, label):
                _ok(f'{unit}: {label}')
            else:
                errors += 1

        stale = Path('/etc/systemd/system/radiod@.service.d') / _SMD_AFFINITY_DROP_IN
        if stale.exists():
            _run(['rm', '-f', str(stale)], sudo=True)
            _info('removed stale radiod@.service template drop-in')

        for unit in _AFFINITY_UNITS:
            label = f'other → CPUs {_cpu_list_str(other_cpus)}'
            if _write_affinity_drop_in(unit, other_cpus, label):
                _ok(f'{unit}: {label}')
            else:
                errors += 1
        print()

        _info('Running systemctl daemon-reload ...')
        r = _run(['systemctl', 'daemon-reload'], sudo=True)
        _ok('daemon-reload done') if r.returncode == 0 else _warn('daemon-reload reported errors')
        print()

        _info('Applying to running units via systemctl set-property --runtime ...')
        for unit, cpus in radiod_plan.items():
            if _apply_cpu_affinity_runtime(unit, cpus):
                _ok(f'{unit}: applied')
            else:
                _info(f'{unit}: not running or set-property unsupported')

        for unit in _AFFINITY_UNITS:
            glob_pat = unit.replace('@.service', '@*.service')
            r2 = _run(['systemctl', 'list-units', '--no-legend', '--no-pager',
                       '--state=running', '--output=json', glob_pat])
            try:
                instances = [u.get('unit', '') for u in _json.loads(r2.stdout)
                             if u.get('unit', '')]
            except Exception:
                instances = []
            if not instances and '@' not in unit:
                instances = [unit]
            for inst in instances:
                if _apply_cpu_affinity_runtime(inst, other_cpus):
                    _ok(f'{inst}: applied')
                else:
                    _info(f'{inst}: not running or set-property unsupported')
        print()

        if errors:
            _err(f'{errors} drop-in(s) failed to write')
            return 1
        _ok('CPU affinity policy applied')
        _info('(Services will fully enforce AllowedCPUs via cgroup after next restart)')

    print()
    return 0


def cmd_diag_cpu_freq(args) -> int:
    """Show and optionally apply per-CPU scaling_max_freq based on radiod CPU assignment."""
    topology  = getattr(args, '_topology_override', None) or \
                _load_topology(Path(args.topology) if args.topology else TOPOLOGY_PATH)
    cfg       = topology.get('cpu_freq', {})
    radiod_max_mhz = cfg.get('radiod_max_mhz', 3200)
    other_max_mhz  = cfg.get('other_max_mhz',  1400)
    do_apply  = getattr(args, 'apply', False)

    _heading('diag: CPU frequencies')

    if do_apply and os.geteuid() != 0:
        _err('--apply requires root  (sudo smd diag cpu-freq --apply)')
        return 1

    radiod_cpus = _get_radiod_cpus()
    cpu_count   = os.cpu_count() or 1

    _info(f'Policy:  radiod CPUs → {radiod_max_mhz} MHz max  |  '
          f'other CPUs → {other_max_mhz} MHz max')
    if radiod_cpus:
        _info(f'Radiod CPUs (CPUAffinity): {sorted(radiod_cpus)}')
    else:
        _warn('No radiod CPUAffinity detected — radiod may not be running')
    print()
    _info('  (Configure limits in /etc/sigmond/topology.toml  [cpu_freq])')
    print()

    changes = 0
    errors  = 0

    for cpu in range(cpu_count):
        role       = 'radiod' if cpu in radiod_cpus else 'other '
        target_mhz = radiod_max_mhz if cpu in radiod_cpus else other_max_mhz
        target_khz = target_mhz * 1000

        freq_dir = Path(f'/sys/devices/system/cpu/cpu{cpu}/cpufreq')
        if not freq_dir.exists():
            _warn(f'cpu{cpu:2d}: no cpufreq sysfs — driver not loaded or VM?')
            continue

        try:
            current_khz = int((freq_dir / 'scaling_max_freq').read_text().strip())
        except (OSError, ValueError) as e:
            _warn(f'cpu{cpu:2d}: cannot read scaling_max_freq: {e}')
            continue

        avail_path = freq_dir / 'scaling_available_frequencies'
        if avail_path.exists():
            try:
                avail = sorted(int(f) for f in avail_path.read_text().split() if f.isdigit())
                candidates = [f for f in avail if f <= target_khz]
                nearest_khz = max(candidates) if candidates else (avail[0] if avail else target_khz)
            except (ValueError, IndexError):
                nearest_khz = target_khz
        else:
            nearest_khz = target_khz

        current_mhz = current_khz  // 1000
        nearest_mhz = nearest_khz // 1000

        if current_khz == nearest_khz:
            _ok(f'cpu{cpu:2d}  [{role}]  {current_mhz:5d} MHz  ✓')
        else:
            arrow = f'{current_mhz} → {nearest_mhz} MHz'
            if do_apply:
                try:
                    (freq_dir / 'scaling_max_freq').write_text(str(nearest_khz))
                    _ok(f'cpu{cpu:2d}  [{role}]  {arrow}  applied')
                    changes += 1
                except OSError as e:
                    _err(f'cpu{cpu:2d}: write failed: {e}')
                    errors += 1
            else:
                _warn(f'cpu{cpu:2d}  [{role}]  {arrow}  (run with --apply to set)')
                changes += 1

    print()
    if do_apply:
        if errors:
            _err(f'{errors} CPU(s) failed to update')
            return 1
        _ok(f'{changes} CPU(s) updated' if changes else 'All CPUs already match policy')
    else:
        if changes:
            _info(f'{changes} CPU(s) differ from policy')
        else:
            _ok('All CPUs match policy')

    return 0


def cmd_restart(args) -> int:
    if _need_root('restart'):
        return 1
    topology = _load_topology(Path(args.topology) if args.topology else TOPOLOGY_PATH)
    only = [c.strip() for c in args.components.split(',')] if args.components else None
    enabled = _enabled_components(topology, only)

    try:
        units = resolve_units(enabled, enabled)
    except ValueError as exc:
        _err(f"component resolution failed: {exc}")
        return 1

    # Filter to configured instances only
    units = [u for u in units if not u.orphaned]

    # Order: radiod first, then clients per coordination.toml (CONTRACT §5.4)
    if _HAS_SIGMOND_LIB:
        coord = load_coordination()
        units = order_units(units, coordination=coord)

    _heading('restart')
    any_failed = False
    for unit in units:
        # Reset any failed state before restarting
        _run(['systemctl', 'reset-failed', unit.unit], sudo=True)
        r = _run(['systemctl', 'restart', unit.unit], sudo=True)
        if r.returncode == 0:
            _ok(f'{unit.unit}')
        else:
            _err(f'{unit.unit}: {r.stderr.strip()}')
            any_failed = True
    return 1 if any_failed else 0


def cmd_reload(args) -> int:
    if _need_root('reload'):
        return 1
    topology = _load_topology(Path(args.topology) if args.topology else TOPOLOGY_PATH)
    only = [c.strip() for c in args.components.split(',')] if args.components else None
    enabled = _enabled_components(topology, only)

    try:
        units = resolve_units(enabled, enabled)
    except ValueError as exc:
        _err(f"component resolution failed: {exc}")
        return 1

    # Filter to configured instances only
    units = [u for u in units if not u.orphaned]

    # Order: radiod first, then clients per coordination.toml (CONTRACT §5.4)
    if _HAS_SIGMOND_LIB:
        coord = load_coordination()
        units = order_units(units, coordination=coord)

    _heading('reload')
    any_failed = False
    for unit in units:
        # Try systemctl reload first; fall back to try-restart
        r = _run(['systemctl', 'reload', unit.unit], sudo=True)
        if r.returncode == 0:
            _ok(f'{unit.unit}')
        else:
            # Fall back to try-restart
            r = _run(['systemctl', 'try-restart', unit.unit], sudo=True)
            if r.returncode == 0:
                _ok(f'{unit.unit} (via try-restart)')
            else:
                _err(f'{unit.unit}: {r.stderr.strip()}')
                any_failed = True
    return 1 if any_failed else 0


# smd status / list
# ---------------------------------------------------------------------------

def cmd_status(args) -> int:
    topology = _load_topology(Path(args.topology) if args.topology else TOPOLOGY_PATH)
    only = [c.strip() for c in args.components.split(',')] if args.components else None
    enabled = _enabled_components(topology, only)

    # ── action needed ────────────────────────────────────────────────────────
    if _HAS_SIGMOND_LIB:
        try:
            from sigmond.catalog import load_catalog, next_steps
            _catalog = load_catalog()
            _items = next_steps(enabled, _catalog)
            if _items:
                _heading('action needed')
                for kind, subject, action in _items:
                    if kind == 'install':
                        _warn(f'{subject}  —  enabled in topology but not yet installed')
                        _info(f'       run:  {action}')
                    elif kind == 'enable_dep':
                        _warn(subject)
                        _info(f'       fix:  {action}')
                print()
        except Exception:
            pass

    try:
        units = resolve_units(enabled, enabled)
    except ValueError as exc:
        _err(f"component resolution failed: {exc}")
        return 1

    _heading('status')
    any_bad = False

    # Group by component for display
    by_component: dict[str, list[UnitRef]] = {}
    for unit in units:
        if unit.component not in by_component:
            by_component[unit.component] = []
        by_component[unit.component].append(unit)

    for comp in sorted(by_component.keys()):
        comp_units = by_component[comp]
        print(f'\n  {comp}:')
        if not comp_units:
            _info('(no managed services)')
            continue

        for unit_ref in comp_units:
            # Check unit state
            r = _run(['systemctl', 'is-active', unit_ref.unit])
            state = r.stdout.strip() or 'unknown'
            sym = '✓' if state == 'active' else '✗'
            color = '\033[32m' if state == 'active' else '\033[31m'

            orphan_tag = ' [orphaned]' if unit_ref.orphaned else ''
            print(f'    {color}{sym}\033[0m  {unit_ref.unit}: {state}{orphan_tag}')

            if state not in ('active', 'inactive'):
                any_bad = True

    # Inventory enrichment for installed clients
    if _HAS_SIGMOND_LIB:
        try:
            catalog = load_catalog()
        except FileNotFoundError:
            catalog = {}
        seen = set()
        for comp in sorted(by_component.keys()):
            entry = get_entry(comp, catalog) if catalog else None
            if entry is None or entry.kind != 'client' or entry.name in seen:
                continue
            seen.add(entry.name)
            inv = _get_client_inventory(entry.name)
            if inv is None:
                continue
            version = inv.get('version', '?')
            contract = inv.get('contract_version', '?')
            instances = inv.get('instances', [])
            issues = inv.get('issues', [])
            git = inv.get('git', {})
            sha = git.get('short', '')
            sha_tag = f'  ({sha})' if sha else ''

            print(f'\n  {entry.name}  v{version}{sha_tag}  contract={contract}')
            for inst in instances:
                name = inst.get('instance', '?')
                channels = inst.get('ka9q_channels', 0)
                freqs = inst.get('frequencies_hz', [])
                modes = inst.get('modes', [])
                parts = [f'{channels} ch'] if channels else []
                if modes:
                    parts.append(f'modes={",".join(str(m) for m in modes)}')
                elif freqs:
                    parts.append(f'{len(freqs)} freqs')
                _info(f'{name}: {", ".join(parts)}' if parts else name)
            for issue in issues:
                sev = issue.get('severity', 'warn') if isinstance(issue, dict) else 'warn'
                msg = issue.get('message', str(issue)) if isinstance(issue, dict) else str(issue)
                if sev == 'fail':
                    _err(msg)
                else:
                    _warn(msg)

    # CPU affinity summary — one block, surfaced only when there's a
    # local radiod (otherwise there's nothing to protect).
    if _HAS_SIGMOND_LIB:
        try:
            from sigmond.cpu import build_affinity_report
            _aff_report = build_affinity_report()
        except Exception:
            _aff_report = None
        if _aff_report is not None and _aff_report.radiod_cpus:
            print('\n  CPU affinity:')
            _info(f'radiod cores: {sorted(_aff_report.radiod_cpus)} '
                  f'(other pool: {len(_aff_report.plan.other_cpus)} CPUs)')
            foreign_count = sum(len(u.foreign_drop_ins) for u in _aff_report.units)
            unenforced = [u.unit for u in _aff_report.units
                          if u.role == 'radiod' and u.main_pid
                          and not u.drop_in_present]
            pinned = [c for c in _aff_report.contention if not c.is_default]
            bad_gov = [cpu for cpu in _aff_report.radiod_cpus
                       if _aff_report.capabilities.governors.get(cpu) not in
                       (None, 'performance')]
            warnings = []
            if unenforced:
                warnings.append(
                    f'{len(unenforced)} radiod unit(s) unenforced — run '
                    f'sudo smd diag cpu-affinity --apply')
            if foreign_count:
                warnings.append(f'{foreign_count} foreign drop-in(s) present')
            if pinned:
                warnings.append(
                    f'{len(pinned)} pinned process(es) overlap radiod cores')
            if bad_gov:
                warnings.append(
                    f'governor not \'performance\' on cpus {sorted(bad_gov)}')
            if warnings:
                for w in warnings:
                    _warn(w)
                any_bad = True
            else:
                _ok('plan applied, no contention, no foreign drop-ins')

    _netdiag_status_line()

    print()
    return 1 if any_bad else 0


def cmd_list(args) -> int:
    show_available = getattr(args, 'available', False)
    show_all = getattr(args, 'all', False)

    if show_available or show_all:
        return _list_catalog(args, include_configured=show_all)
    return _list_configured(args)


def _list_catalog(args, *, include_configured: bool) -> int:
    import json as _json

    try:
        catalog = load_catalog()
    except FileNotFoundError as exc:
        _err(str(exc))
        return 1

    if args.json:
        out = []
        for name, entry in sorted(catalog.items()):
            d = {
                'name': entry.name,
                'kind': entry.kind,
                'description': entry.description,
                'repo': entry.repo,
                'uses': list(entry.uses),
                'contract': entry.contract,
                'install_script': entry.install_script,
                'installed': entry.is_installed(),
            }
            out.append(d)
        print(_json.dumps(out, indent=2))
    else:
        servers = [(n, e) for n, e in sorted(catalog.items()) if e.kind == 'server']
        clients = [(n, e) for n, e in sorted(catalog.items()) if e.kind == 'client']
        infra   = [(n, e) for n, e in sorted(catalog.items()) if e.kind == 'infra']

        _heading('catalog — available')
        if servers:
            print(f'\n  Servers ({len(servers)})')
            for _, entry in servers:
                _print_catalog_entry(entry)
        if clients:
            print(f'\n  Clients ({len(clients)})')
            for _, entry in clients:
                _print_catalog_entry(entry)
        if infra:
            print(f'\n  Infra ({len(infra)})')
            for _, entry in infra:
                _print_catalog_entry(entry)

    if include_configured:
        print()
        return _list_configured(args)
    return 0


def _print_catalog_entry(entry) -> None:
    installed = entry.is_installed()
    sym = '✓' if installed else '·'
    color = '\033[32m' if installed else '\033[90m'
    contract_tag = f'  contract={entry.contract}' if entry.contract else ''
    print(f'    {color}{sym}\033[0m  {entry.name:22s} {entry.description}{contract_tag}')


def _list_configured(args) -> int:
    topology = _load_topology(Path(args.topology) if args.topology else TOPOLOGY_PATH)
    only = [c.strip() for c in args.components.split(',')] if args.components else None
    enabled = _enabled_components(topology, only)

    try:
        units = resolve_units(enabled, enabled)
    except ValueError as exc:
        _err(f"component resolution failed: {exc}")
        return 1

    if args.json:
        import json as _json
        units_data = []
        for unit_ref in units:
            r = _run(['systemctl', 'is-active', unit_ref.unit])
            state = r.stdout.strip() or 'unknown'
            units_data.append({
                'component': unit_ref.component,
                'unit': unit_ref.unit,
                'template': unit_ref.template,
                'instance': unit_ref.instance,
                'kind': unit_ref.kind,
                'source': unit_ref.source,
                'active_state': state,
                'orphaned': unit_ref.orphaned,
            })
        print(_json.dumps(units_data, indent=2))
    else:
        _heading('configured units')
        by_component: dict[str, list[UnitRef]] = {}
        for unit in units:
            if unit.component not in by_component:
                by_component[unit.component] = []
            by_component[unit.component].append(unit)

        for comp in sorted(by_component.keys()):
            print(f'\n  {comp}:')
            for unit_ref in sorted(by_component[comp], key=lambda u: u.unit):
                r = _run(['systemctl', 'is-active', unit_ref.unit])
                state = r.stdout.strip() or 'unknown'
                sym = '✓' if state == 'active' else '✗'
                color = '\033[32m' if state == 'active' else '\033[31m'
                orphan_tag = ' [orphaned]' if unit_ref.orphaned else ''
                print(f'    {color}{sym}\033[0m  {unit_ref.unit}: {state}{orphan_tag}')

    return 0


# ---------------------------------------------------------------------------
# smd log
# ---------------------------------------------------------------------------

def cmd_log(args) -> int:
    client = getattr(args, 'client', None)
    level = getattr(args, 'level', None)
    files = getattr(args, 'files', False)

    # --- set log level mode ---
    if level:
        topology = _load_topology(Path(args.topology) if args.topology else TOPOLOGY_PATH)
        key = set_log_level(client, level)
        _ok(f'{key}={level.upper()} written to coordination.env')

        if client:
            only = [client]
            enabled = _enabled_components(topology, only)
            if not enabled:
                enabled = [client]
            try:
                units = resolve_units(enabled, _enabled_components(topology))
                unit_names = [u.unit for u in units if not u.orphaned]
            except (ValueError, Exception):
                unit_names = []

            if unit_names:
                failed = send_sighup(unit_names)
                for u in unit_names:
                    if u in failed:
                        _warn(f'SIGHUP {u}: failed')
                    else:
                        _ok(f'SIGHUP {u}')
            else:
                _info(f'no units resolved for {client} — SIGHUP skipped')
        else:
            _info('CLIENT_LOG_LEVEL set; send SIGHUP to individual clients to apply')
        return 0

    # --- follow mode (requires a client name) ---
    if not client:
        _err('smd log: specify a client name (e.g. smd log psk-recorder)')
        return 1

    if files:
        log_paths = get_inventory_log_paths(client)
        if not log_paths:
            _err(f'{client}: no log_paths in inventory (is {client} installed?)')
            return 1
        paths = flatten_log_paths(log_paths)
        if not paths:
            _err(f'{client}: log_paths is empty')
            return 1
        missing = [p for p in paths if not Path(p).exists()]
        if missing:
            for m in missing:
                _warn(f'not found: {m}')
        existing = [p for p in paths if Path(p).exists()]
        if not existing:
            _err(f'{client}: none of the log files exist yet')
            return 1
        _info(f'tailing {len(existing)} file(s) for {client}...')
        follow_files(existing)
        return 0  # unreachable after exec

    # --- default: journalctl follow ---
    topology = _load_topology(Path(args.topology) if args.topology else TOPOLOGY_PATH)
    only = [client]
    enabled = _enabled_components(topology, only)
    if not enabled:
        enabled = [client]
    try:
        all_enabled = _enabled_components(topology)
        units = resolve_units(enabled, all_enabled)
        unit_names = [u.unit for u in units if not u.orphaned]
    except (ValueError, Exception):
        unit_names = []

    if not unit_names:
        try:
            from sigmond.catalog import load_catalog
            entry = load_catalog().get(client)
        except Exception:
            entry = None
        if entry is not None and not entry.is_installed():
            _err(f'{client}: enabled in topology but not installed. '
                 f'Install first:  sudo smd install {client}')
        else:
            _err(f'{client}: no systemd units resolved (no deploy.toml or '
                 f'fallback shim).  Is it fully installed?')
        return 1

    _info(f'following journal for: {", ".join(unit_names)}')
    follow_journal(unit_names)
    return 0  # unreachable after exec


# ---------------------------------------------------------------------------
# smd update
# ---------------------------------------------------------------------------

def cmd_update(args) -> int:
    """Pull the latest commit for every installed catalog component.

    For each catalog entry that has a repo URL and a clone under /opt/git/,
    runs `git pull --ff-only` (or `git fetch + checkout <ref>` when --ref is
    given).  radiod is source-only and requires a ka9q-update rebuild to
    produce a new binary; smd warns rather than silently skipping it.
    After all pulls, `smd apply` is run to reload any changed systemd units.
    """
    if _need_root('update'):
        return 1

    dry_run  = getattr(args, 'dry_run', False)
    ref      = getattr(args, 'ref', None)

    components_filter: set[str] | None = None
    if getattr(args, 'components', None):
        components_filter = {c.strip() for c in args.components.split(',')}

    try:
        catalog = load_catalog()
    except FileNotFoundError as exc:
        _err(str(exc))
        return 1

    _heading('update')
    errors   = 0
    opt_git  = Path('/opt/git')

    # Load topology once using the library object API (version field required).
    from sigmond.topology import load_topology as _lib_load_topology
    _topo_obj = _lib_load_topology(Path(args.topology) if args.topology else TOPOLOGY_PATH)

    # --- sigmond self-update (only on full update, not component-targeted) ---
    if not components_filter:
        sigmond_dir = Path(__file__).resolve().parent.parent
        if (sigmond_dir / '.git').exists():
            _info(f'sigmond: pulling ({sigmond_dir}) ...')
            if not dry_run:
                r = _run(['git', '-C', str(sigmond_dir), 'pull', '--ff-only'],
                         capture=False)
                if r.returncode != 0:
                    _warn('sigmond: self-update failed — continuing')
                    errors += 1
                else:
                    _ok('sigmond: up to date')
                # Always sync the catalog after self-update so new entries are live.
                catalog_src = sigmond_dir / 'etc' / 'catalog.toml'
                catalog_dst = Path('/etc/sigmond/catalog.toml')
                if catalog_src.exists():
                    try:
                        import shutil as _shutil
                        _shutil.copy2(str(catalog_src), str(catalog_dst))
                        _ok('sigmond: catalog synced to /etc/sigmond/catalog.toml')
                    except Exception as _exc:
                        _warn(f'sigmond: could not sync catalog: {_exc}')
            else:
                _info('sigmond: (dry-run) would pull and sync catalog')

    # --- pull each installed catalog repo ---
    for name in sorted(catalog):
        entry = catalog[name]
        if components_filter and name not in components_filter:
            continue
        if not entry.repo:
            continue

        repo_dir = opt_git / name
        if not repo_dir.exists():
            # Not installed; skip silently unless explicitly requested.
            if components_filter:
                _warn(f'{name}: not found at {repo_dir} — install first with: smd install {name}')
            continue

        # Respect the per-component version policy from topology.toml.
        comp = _topo_obj.components.get(name)
        comp_version = (comp.version if comp else 'latest') or 'latest'
        effective_ref = ref  # --ref flag overrides topology setting
        if effective_ref is None:
            if comp_version == 'ignore':
                _info(f'{name}: version = ignore — skipping')
                continue
            elif comp_version != 'latest':
                effective_ref = comp_version  # pinned ref from topology

        before = _git_head_ref(repo_dir) if not dry_run else '?'
        if dry_run:
            if comp_version == 'ignore' and ref is None:
                _info(f'{name}: (dry-run) would skip (version = ignore)')
            else:
                action = (f'checkout {effective_ref}'
                          if effective_ref else 'pull latest')
                _info(f'{name}: (dry-run) would {action}')
            continue

        _info(f'{name}: pulling ...')
        try:
            _clone_repo(entry, pull_if_exists=True, ref=effective_ref)
            after = _git_head_ref(repo_dir)
            if after == before:
                _ok(f'{name}: already at {after}')
            else:
                _ok(f'{name}: {before} → {after}')
                if name == 'ka9q-radio' and after != before:
                    _warn('ka9q-radio: source updated — rebuild binaries: smd install --components ka9q-radio')
        except RuntimeError as exc:
            _err(f'{name}: {exc}')
            errors += 1

    if dry_run:
        _info('(dry-run) no changes made')
        return 0

    # --- apply: reload any changed systemd units ---
    _heading('apply')
    args.dry_run = False
    apply_rc = cmd_apply(args)
    if apply_rc != 0:
        errors += 1

    if errors:
        _warn(f'update finished with {errors} error(s)')
        return 1
    _ok('all components up to date')
    return 0


# ---------------------------------------------------------------------------
# smd diag
# ---------------------------------------------------------------------------

def _netdiag_auto_refresh(verb: str) -> None:
    """Ensure the net-diag cache is fresh before a mutating verb runs.

    Best-effort: any failure is non-fatal (we don't want a broken diag
    path to block install/apply/start). Prints a one-liner summary of
    the classification so the operator sees the network verdict every
    time they mutate state.

    When the cache is stale and we are root, the Tier-2 passive IGMP
    listen (~130 s) is launched as a detached background process so it
    never blocks the calling verb.  Results are written to the cache and
    also logged to /var/log/sigmond/net-diag.log.
    """
    if not _HAS_SIGMOND_LIB:
        return
    try:
        from sigmond import net_diag
    except Exception:
        return
    try:
        cache = net_diag.load_cache()
        if net_diag.is_cache_fresh(cache):
            report = net_diag._report_from_dict(cache['report'])
            _info(f'network: {report.classification} '
                  f'(cached {int(cache["age_s"]/60)}m ago)')
            return
        if os.geteuid() != 0:
            # Tier-1 only (no raw socket), completes quickly.
            report, _from_cache = net_diag.run_cached(
                listen_seconds=0, force=True)
            _info(f'network: {report.classification}')
            if report.classification in ('lan-needs-querier', 'lan-unsafe'):
                for line in report.recommendation.split('. '):
                    line = line.strip().rstrip('.')
                    if line:
                        _warn(line)
        else:
            # Tier-2 passive IGMP listen takes ~130 s — never block the
            # calling verb.  Spawn a detached child to run it in the
            # background; results land in the cache for the next invocation.
            import datetime
            log_path = Path('/var/log/sigmond/net-diag.log')
            try:
                log_path.parent.mkdir(parents=True, exist_ok=True)
                lf = open(log_path, 'a')
                lf.write(f'\n# {datetime.datetime.now().isoformat()} '
                         f'— triggered by smd {verb}\n')
                lf.flush()
                smd_bin = sys.argv[0] if (sys.argv and
                                          os.path.isfile(sys.argv[0])) else 'smd'
                subprocess.Popen(
                    [smd_bin, 'diag', 'net'],
                    stdout=lf, stderr=lf,
                    start_new_session=True,
                    close_fds=True,
                )
                _info(f'network: IGMP diagnosis running in background '
                      f'→ {log_path}')
            except Exception as bg_exc:
                _warn(f'network: could not launch background diagnosis: {bg_exc}')
    except Exception as exc:
        # Diagnosis must never block a mutating verb.
        _warn(f'network diagnosis skipped: {exc}')


def _netdiag_status_line() -> None:
    """Render the cached classification as a block in `smd status`."""
    if not _HAS_SIGMOND_LIB:
        return
    try:
        from sigmond import net_diag
    except Exception:
        return
    cache = net_diag.load_cache()
    print('\n  network:')
    if cache is None:
        _info('no cached diagnosis — run: sudo smd diag net')
        return
    report = net_diag._report_from_dict(cache['report'])
    age_min = int(cache['age_s'] / 60)
    stale = ' [stale]' if not net_diag.is_cache_fresh(cache) else ''
    label = f'{report.classification} (checked {age_min}m ago){stale}'
    if report.classification == 'lan-capable':
        _ok(label)
    elif report.classification in ('lan-needs-querier', 'lan-unsafe'):
        _warn(label)
    else:
        _info(label)
    if report.queriers:
        q = report.queriers[0]
        _info(f'querier: v{q.version} {q.source} on {q.interface or "?"}')
    if report.classification in ('lan-needs-querier', 'lan-unsafe'):
        _info(f'fix: {report.recommendation}')


def cmd_diag_net(args) -> int:
    """Classify the host's network environment for multi-host radiod safety.

    Tier 1 checks run unprivileged (interface enum, /proc/net/igmp).
    Tier 2 (passive raw-socket IGMP listen) needs root; without it, we
    still classify from kernel state but may return 'unknown'.
    """
    import json as _json
    from sigmond import net_diag

    listen_s = getattr(args, 'listen', None)
    if listen_s is None:
        listen_s = 130
    iface = getattr(args, 'interface', None)
    want_json = getattr(args, 'json', False)

    # Progress callback for the passive listen — prints to stderr so
    # --json stdout stays clean. Skipped in JSON mode to keep logs tidy.
    def _progress(elapsed, total, n_queriers):
        if want_json:
            return
        suffix = f', {n_queriers} querier(s) seen' if n_queriers else ''
        print(f'  listening for IGMP queries... {elapsed}/{total} s{suffix}',
              file=sys.stderr, flush=True)

    prog = _progress if (os.geteuid() == 0 and listen_s > 0) else None

    try:
        report = net_diag.run(listen_seconds=listen_s, interface=iface,
                              progress=prog)
    except KeyboardInterrupt:
        _warn('interrupted before classification could complete')
        return 130
    # Explicit `smd diag net` always refreshes the cache so subsequent
    # fast verbs (status, list, validate) see the latest classification.
    if report.listen_root and report.classification != 'unknown':
        net_diag.save_cache(report)

    if want_json:
        _json.dump(report.to_dict(), sys.stdout, indent=2)
        sys.stdout.write('\n')
        return 0

    _heading('diag: network')

    # Interfaces
    _info('Interfaces:')
    for i in report.interfaces:
        if not i.is_up or i.is_loopback:
            continue
        tags = []
        if i.is_wireless:    tags.append('wireless')
        if i.is_bridge:      tags.append(f'bridge[{",".join(i.bridge_members) or "-"}]')
        if i.is_bond:        tags.append('bond')
        if i.is_overlay:     tags.append('overlay')
        if not i.has_multicast: tags.append('no-multicast')
        if i.is_default_route: tags.append('default-route')
        tag_str = f'  ({", ".join(tags)})' if tags else ''
        addrs = ', '.join(i.addrs_v4) or '(no v4)'
        print(f'         {i.name:<14s}  {addrs}{tag_str}')
    print()

    # Joined groups by interface (collapsed)
    if report.joined_groups:
        _info('Multicast groups joined (/proc/net/igmp):')
        by_iface: dict = {}
        for g in report.joined_groups:
            by_iface.setdefault(g.interface, []).append(g)
        for ifname, groups in sorted(by_iface.items()):
            ver = groups[0].igmp_version
            uniq = sorted({g.group for g in groups})
            non_local = [g for g in uniq if not g.startswith('224.0.0.')]
            local_count = len(uniq) - len(non_local)
            if non_local:
                extra = f'  [+{local_count} link-local]' if local_count else ''
                shown = ', '.join(non_local[:6]) + ('...' if len(non_local) > 6 else '')
            else:
                extra = ''
                shown = f'(link-local only: {local_count} group{"s" if local_count != 1 else ""})'
            print(f'         {ifname:<14s}  {ver}   {shown}{extra}')
        print()

    # Queriers
    if report.listen_root:
        if report.queriers:
            _info('IGMP queriers observed:')
            for q in report.queriers:
                qqic = f', QQIC={q.qqic_s}s' if q.qqic_s is not None else ''
                _ok(f'{q.interface or "?"}  v{q.version} from {q.source}  '
                    f'(max_resp={q.max_resp_ms}ms{qqic})')
        else:
            _info(f'IGMP queriers: none observed in {report.listen_seconds}s listen')
        for err in report.listen_errors:
            _warn(err)
        print()
    else:
        _info('IGMP queriers: passive listen skipped (re-run with sudo for '
              'definitive querier detection)')
        print()

    # Classification
    _info(f'Classification: {report.classification}')
    from sigmond.net_diag import CLASSES
    _info(f'  {CLASSES.get(report.classification, "")}')
    for reason in report.reasons:
        _info(f'  • {reason}')
    print()
    _info('Recommendation:')
    for line in report.recommendation.split('. '):
        line = line.strip().rstrip('.')
        if line:
            _info(f'  {line}.')
    print()
    return 0


def cmd_diag(args) -> int:
    topology = _load_topology(Path(args.topology) if args.topology else TOPOLOGY_PATH)
    client_dir = topology['client_dir']

    _heading('diagnostics')
    errors = 0

    # Network
    for host in ['wsprnet.org', 'graphs.wsprdaemon.org', 'logs.wsprdaemon.org']:
        r = _run(['ping', '-c1', '-W2', host])
        if r.returncode == 0:
            _ok(f'network: {host} reachable')
        else:
            _warn(f'network: {host} unreachable')

    # Deps commit check
    dcfg = _load_deps_conf(client_dir)
    if dcfg:
        print()
        _info('Dependency versions:')
        for dep in dcfg.sections():
            dep_type   = dcfg.get(dep, 'type', fallback='').strip()
            pinned     = dcfg.get(dep, 'commit', fallback='').strip()
            install_to = dcfg.get(dep, 'install_to', fallback='').strip()
            if dep_type == 'git' and install_to:
                r = _run(['git', '-c', f'safe.directory={install_to}',
                          '-C', install_to, 'rev-parse', 'HEAD'])
                current = r.stdout.strip()
                if r.returncode != 0 or not current:
                    _warn(f'{dep}: not installed at {install_to}')
                    errors += 1
                elif current.startswith(pinned[:12]):
                    _ok(f'{dep}: {current[:12]}')
                else:
                    _warn(f'{dep}: have {current[:12]}, want {pinned[:12]}')
                    errors += 1

    # Client self-validation
    if _HAS_SIGMOND_LIB:
        try:
            catalog = load_catalog()
        except FileNotFoundError:
            catalog = {}

        if catalog:
            only = [c.strip() for c in args.components.split(',')] if getattr(args, 'components', None) else None
            enabled = _enabled_components(topology, only)
            print()
            _info('Client validation:')
            seen = set()
            for comp in enabled:
                entry = get_entry(comp, catalog)
                if entry is None or entry.kind != 'client' or entry.name in seen:
                    continue
                seen.add(entry.name)
                val = _get_client_validate(entry.name)
                if val is None:
                    _info(f'  {entry.name}: validate unavailable')
                    continue
                ok = val.get('ok', False)
                if ok:
                    _ok(f'{entry.name}: all checks passed')
                else:
                    _warn(f'{entry.name}: validation failed')
                    errors += 1
                for issue in val.get('issues', []):
                    if isinstance(issue, dict):
                        sev = issue.get('severity', 'warn')
                        msg = issue.get('message', '')
                    else:
                        sev, msg = 'warn', str(issue)
                    if sev == 'fail':
                        _err(f'  {entry.name}: {msg}')
                    else:
                        _warn(f'  {entry.name}: {msg}')

    # Service health
    print()
    cmd_status(args)

    print()
    if errors:
        print(f'\033[33mdiag: {errors} issue(s) found\033[0m')
    else:
        print('\033[32mdiag: all checks passed\033[0m')
    return 0 if not errors else 1


# ---------------------------------------------------------------------------
# smd completion
# ---------------------------------------------------------------------------

_BASH_COMPLETION = r"""
# bash completion for smd
# Source this file or drop it in /etc/bash_completion.d/smd
# Generate with: smd completion bash

_smd_complete() {
    local cur prev words cword
    _init_completion 2>/dev/null || {
        cur="${COMP_WORDS[COMP_CWORD]}"
        prev="${COMP_WORDS[COMP_CWORD-1]}"
        words=("${COMP_WORDS[@]}")
        cword=$COMP_CWORD
    }

    local top_cmds="install apply start stop status restart reload list log update diag validate config tui completion"
    local components="radiod wspr-recorder hf-timestd psk-recorder wsprdaemon-client ka9q-web rac"
    local log_clients="wspr-recorder hf-timestd psk-recorder wsprdaemon-client"

    if [[ "$prev" == "--components" ]]; then
        COMPREPLY=($(compgen -W "$components" -- "$cur"))
        return
    fi

    if [[ "$prev" =~ ^(--topology|--from|--to|--client-dir|--input|--output)$ ]]; then
        COMPREPLY=($(compgen -f -- "$cur"))
        return
    fi

    if [[ "$prev" == "--level" ]]; then
        COMPREPLY=($(compgen -W "DEBUG INFO WARNING ERROR CRITICAL" -- "$cur"))
        return
    fi

    if [[ "$prev" == "--via" ]]; then
        COMPREPLY=($(compgen -W "auto systemd socket" -- "$cur"))
        return
    fi

    case $cword in
        1)
            COMPREPLY=($(compgen -W "$top_cmds" -- "$cur"))
            ;;
        2)
            case "${words[1]}" in
                install)
                    COMPREPLY=($(compgen -W "$components --components --client-dir --dry-run --yes --topology" -- "$cur"))
                    ;;
                apply)
                    COMPREPLY=($(compgen -W "--dry-run --topology" -- "$cur"))
                    ;;
                start|stop|status|restart)
                    COMPREPLY=($(compgen -W "$components --components --topology" -- "$cur"))
                    ;;
                reload)
                    COMPREPLY=($(compgen -W "$components --components --via --topology" -- "$cur"))
                    ;;
                list)
                    COMPREPLY=($(compgen -W "--json --available --all --components --topology" -- "$cur"))
                    ;;
                log)
                    COMPREPLY=($(compgen -W "$log_clients --files --level --topology" -- "$cur"))
                    ;;
                update)
                    COMPREPLY=($(compgen -W "$components --components --ref --dry-run --topology" -- "$cur"))
                    ;;
                diag)
                    COMPREPLY=($(compgen -W "cpu-affinity cpu-freq net --components --topology" -- "$cur"))
                    ;;
                validate)
                    COMPREPLY=($(compgen -W "--json --topology" -- "$cur"))
                    ;;
                config)
                    COMPREPLY=($(compgen -W "show migrate backup restore edit" -- "$cur"))
                    ;;
                completion)
                    COMPREPLY=($(compgen -W "bash" -- "$cur"))
                    ;;
                tui)
                    COMPREPLY=()
                    ;;
            esac
            ;;
        *)
            case "${words[1]}" in
                install)
                    COMPREPLY=($(compgen -W "$components --components --client-dir --dry-run --yes --topology" -- "$cur"))
                    ;;
                apply)
                    COMPREPLY=($(compgen -W "--dry-run --topology" -- "$cur"))
                    ;;
                start|stop|status|restart)
                    COMPREPLY=($(compgen -W "$components --components --topology" -- "$cur"))
                    ;;
                reload)
                    COMPREPLY=($(compgen -W "$components --components --via --topology" -- "$cur"))
                    ;;
                list)
                    COMPREPLY=($(compgen -W "--json --available --all --components --topology" -- "$cur"))
                    ;;
                log)
                    COMPREPLY=($(compgen -W "$log_clients --files --level --topology" -- "$cur"))
                    ;;
                update)
                    COMPREPLY=($(compgen -W "$components --components --ref --dry-run --topology" -- "$cur"))
                    ;;
                diag)
                    case "${words[2]}" in
                        cpu-affinity)
                            COMPREPLY=($(compgen -W "--components --threads --apply --json --topology" -- "$cur"))
                            ;;
                        cpu-freq)
                            COMPREPLY=($(compgen -W "--apply --radiod-max-mhz --other-max-mhz --topology" -- "$cur"))
                            ;;
                        net)
                            COMPREPLY=($(compgen -W "--interface --listen --json --topology" -- "$cur"))
                            ;;
                        *)
                            COMPREPLY=($(compgen -W "cpu-affinity cpu-freq net --components --topology" -- "$cur"))
                            ;;
                    esac
                    ;;
                validate)
                    COMPREPLY=($(compgen -W "--json --topology" -- "$cur"))
                    ;;
                config)
                    case "${words[2]}" in
                        show)
                            COMPREPLY=($(compgen -W "--json --topology" -- "$cur"))
                            ;;
                        migrate)
                            COMPREPLY=($(compgen -W "--from --to --write --force --topology" -- "$cur"))
                            ;;
                        backup)
                            COMPREPLY=($(compgen -W "--output" -- "$cur"))
                            ;;
                        restore)
                            COMPREPLY=($(compgen -W "--input" -- "$cur"))
                            ;;
                        *)
                            COMPREPLY=($(compgen -W "show migrate backup restore edit" -- "$cur"))
                            ;;
                    esac
                    ;;
                completion)
                    case "${words[2]}" in
                        bash)
                            COMPREPLY=($(compgen -W "--install" -- "$cur"))
                            ;;
                        *)
                            COMPREPLY=($(compgen -W "bash" -- "$cur"))
                            ;;
                    esac
                    ;;
            esac
            ;;
    esac
}

complete -F _smd_complete smd

# Short aliases for common smd subcommands.
# Add to your shell with: source <(smd completion bash)
smdt()   { smd tui "$@"; }
smdtui() { smd tui "$@"; }

# smdt / smdtui take no subcommands; just complete --topology via file completion.
_smdt_complete() {
    local cur="${COMP_WORDS[COMP_CWORD]}"
    COMPREPLY=($(compgen -W "--topology" -- "$cur"))
    if [[ "$cur" == --topology* || "${COMP_WORDS[COMP_CWORD-1]}" == "--topology" ]]; then
        COMPREPLY=($(compgen -f -- "$cur"))
    fi
}
complete -F _smdt_complete smdt smdtui
"""


def cmd_completion(args) -> int:
    sub = getattr(args, 'completion_command', None)
    if sub == 'bash':
        if getattr(args, 'install', False):
            dest = Path.home() / '.local' / 'share' / 'bash-completion' / 'completions' / 'smd'
            dest.parent.mkdir(parents=True, exist_ok=True)
            dest.write_text(_BASH_COMPLETION.strip() + '\n')
            print(f'Installed to {dest}')
            print('Activate in your current session with:')
            print('  source <(smd completion bash)')
            return 0
        print(_BASH_COMPLETION.strip())
        return 0
    print('Usage: smd completion bash [--install]')
    print()
    print('To activate in the current session:')
    print('  source <(smd completion bash)')
    print()
    print('To install for your user (creates the directory automatically):')
    print('  smd completion bash --install')
    print()
    print('To install system-wide:')
    print('  sudo smd completion bash > /etc/bash_completion.d/smd')
    print()
    print('The completion script also defines short aliases:')
    print('  smdt   →  smd tui')
    print('  smdtui →  smd tui')
    return 0


# ---------------------------------------------------------------------------
# smd tui (TUI configurator) + deprecated `smd config edit` alias
# ---------------------------------------------------------------------------

# ka9q-python is strongly recommended for the TUI radiod screen; installed
# editable from the first sibling checkout found. TUI deps (textual, rich)
# come from sigmond's own [tui] extra defined in pyproject.toml.
_KA9Q_PYTHON_PATHS = [
    Path('/home/wsprdaemon/ka9q-python'),
    Path('/home/mjh/git/ka9q-python'),
    Path('/opt/git/ka9q-python'),
]


def _ensure_sigmond_venv() -> bool:
    """Create SIGMOND_VENV and install sigmond[tui] (+ ka9q-python if present).

    Uses uv when available for faster installs; falls back to bare pip/venv.
    Returns True if the venv is ready, False on failure.
    """
    venv_python = SIGMOND_VENV / 'bin' / 'python'
    pip = SIGMOND_VENV / 'bin' / 'pip'
    sigmond_dir = Path(__file__).resolve().parent.parent
    uv = shutil.which('uv')

    if not venv_python.exists():
        _info(f'Creating TUI venv at {SIGMOND_VENV} ...')
        SIGMOND_VENV.parent.mkdir(parents=True, exist_ok=True)
        if uv:
            r = _run([uv, 'venv', '--python', sys.executable, str(SIGMOND_VENV)])
        else:
            r = _run([sys.executable, '-m', 'venv', str(SIGMOND_VENV)])
        if r.returncode != 0:
            _err(f'venv creation failed: {r.stderr.strip()}')
            return False

    def _pip_show(pkg):
        if uv:
            return _run([uv, 'pip', 'show', '--python', str(venv_python), pkg])
        if pip.exists():
            return _run([str(pip), 'show', pkg])
        # No pip and no uv — assume not installed so we attempt install.
        return subprocess.CompletedProcess([], returncode=1)

    def _pip_install(*args):
        if uv:
            return _run([uv, 'pip', 'install', '--python', str(venv_python), *args])
        return _run([str(pip), 'install', *args])

    # Install sigmond itself with [tui] extras (idempotent — check first).
    r = _pip_show('textual')
    if r.returncode != 0:
        _info('Installing sigmond[tui] into venv ...')
        r = _pip_install('-e', f'{sigmond_dir}[tui]')
        if r.returncode != 0:
            _err(f'sigmond[tui] install failed: {r.stderr.strip()[-200:]}')
            return False

    # Optional: ka9q-python editable from a sibling checkout.
    r = _pip_show('ka9q-python')
    if r.returncode != 0:
        for path in _KA9Q_PYTHON_PATHS:
            if (path / 'pyproject.toml').exists():
                _info(f'Installing ka9q-python (editable) from {path} ...')
                r = _pip_install('-e', str(path))
                if r.returncode != 0:
                    _warn(f'ka9q-python install failed: {r.stderr.strip()[-200:]}')
                break

    _ok(f'TUI venv ready at {SIGMOND_VENV}')
    return True


def cmd_tui(args) -> int:
    """Launch the sigmond TUI.

    Launches directly if the current Python can import the TUI (dev venv,
    already in /opt/sigmond/venv, or system python with deps); otherwise
    re-execs into the production venv, creating it if needed.
    """
    try:
        import textual  # noqa: F401 — probe before launch() defers the import
        from sigmond.tui import launch
        launch()
    except ImportError:
        return _reexec_into_tui_venv()
    return 0


def cmd_config_edit(args) -> int:
    """Deprecated alias for `smd tui`.  Remove after next release."""
    _warn("'smd config edit' is deprecated; use 'smd tui' instead")
    return cmd_tui(args)


# Paths archived by `smd config backup`.  Missing paths are silently skipped.
_BACKUP_PATHS = [
    Path('/etc/sigmond'),
    Path('/etc/radio'),
    Path('/etc/wsprdaemon'),
    Path('/etc/hf-timestd'),
    Path('/etc/psk-recorder'),
    Path('/etc/systemd/system/wsprdaemon.service'),
    Path('/etc/systemd/system/wsprdaemon.target'),
    Path('/etc/systemd/system/wsprdaemon.target.wants'),
    Path('/etc/sudoers.d/wsprdaemon'),
    Path('/etc/cron.d/ka9q-cleanups'),
    Path('/etc/cron.d/timestd-freshness-monitor'),
    Path('/etc/logrotate.d/hf-timestd'),
    Path('/etc/logrotate.d/wspr.rotate'),
]


def cmd_config_restore(args) -> int:
    """Extract a sigmond config backup tarball over the live system."""
    import tarfile

    src = Path(getattr(args, 'input', None) or '')
    if not src or not src.exists():
        _err('--input FILE is required and must exist')
        _info('Usage:  sudo smd config restore --input ~/sigmond-config-*.tar.gz')
        return 1
    if not tarfile.is_tarfile(src):
        _err(f'{src} is not a valid tar archive')
        return 1

    _heading('config restore')
    _info(f'Source: {src}')

    # List contents for the user to review.
    try:
        with tarfile.open(src, 'r:gz') as tar:
            members = tar.getnames()
    except Exception as exc:
        _err(f'Cannot read archive: {exc}')
        return 1

    _info(f'Archive contains {len(members)} entries, e.g.:')
    for m in members[:8]:
        _info(f'  {m}')
    if len(members) > 8:
        _info(f'  … and {len(members) - 8} more')

    _info('Extracting to / …')
    try:
        with tarfile.open(src, 'r:gz') as tar:
            tar.extractall('/')
    except PermissionError as exc:
        _err(f'Permission denied: {exc}')
        _info('Re-run with sudo:  sudo smd config restore --input ...')
        return 1
    except Exception as exc:
        _err(str(exc))
        return 1

    _ok('Restore complete')
    _info('Reconcile running services:  sudo smd apply')
    return 0


def _real_home() -> Path:
    """Return the invoking user's home dir even when running under sudo."""
    import pwd as _pwd
    sudo_user = os.environ.get('SUDO_USER')
    if sudo_user:
        try:
            return Path(_pwd.getpwnam(sudo_user).pw_dir)
        except KeyError:
            pass
    return Path.home()


def cmd_config_backup(args) -> int:
    """Create a tar.gz snapshot of all sigmond + client configuration."""
    import tarfile
    import socket

    output = Path(args.output) if getattr(args, 'output', None) else None
    if output is None:
        ts = time.strftime('%Y%m%d-%H%M%S')
        output = _real_home() / f'sigmond-config-{socket.gethostname()}-{ts}.tar.gz'

    _heading('config backup')

    present = [p for p in _BACKUP_PATHS if p.exists()]
    absent  = [p for p in _BACKUP_PATHS if not p.exists()]
    for p in absent:
        _warn(f'not found (skipping): {p}')

    _info(f'Archiving {len(present)} path(s) → {output}')
    try:
        with tarfile.open(output, 'w:gz') as tar:
            for path in present:
                tar.add(path, recursive=True)
    except PermissionError as exc:
        _err(f'Permission denied: {exc}')
        _info('Re-run with sudo:  sudo smd config backup')
        return 1
    except Exception as exc:
        _err(str(exc))
        return 1

    kb = output.stat().st_size // 1024
    _ok(f'Backup written: {output}  ({kb} KB)')
    _info(f'Copy off this machine:')
    _info(f'  scp {output} user@workstation:.')
    _info(f'Restore after OS reinstall:')
    _info(f'  ./install.sh && sudo tar xzf {output.name} -C / && sudo smd apply')
    return 0


def _reexec_into_tui_venv() -> int:
    venv_python = SIGMOND_VENV / 'bin' / 'python'

    if Path(sys.prefix) == SIGMOND_VENV:
        # Already running inside the prod venv and textual still can't import.
        _err(f'TUI venv at {SIGMOND_VENV} is missing sigmond[tui]')
        _info('Rebuild with:  sudo smd install')
        return 1

    if not venv_python.exists():
        if os.geteuid() == 0:
            if not _ensure_sigmond_venv():
                return 1
        else:
            _err(f'TUI venv not found at {SIGMOND_VENV}')
            _info('Create it with:  sudo smd tui')
            _info('(first run creates the venv; subsequent runs do not need sudo)')
            return 1

    script = str(Path(__file__).resolve())
    os.execv(str(venv_python), [str(venv_python), script, *sys.argv[1:]])
    return 1  # unreachable


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

def main() -> int:
    parser = argparse.ArgumentParser(
        prog='smd',
        description='Sigmond — HamSCI suite installer and lifecycle manager',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=textwrap.dedent('''\
            commands:
              install            install and configure all enabled components
              apply              reconcile running services with current config
              start              start all managed services
              stop               stop all managed services
              status             show service health
              update             pull latest code and re-apply
              diag               run diagnostics  (see: smd diag --help)
              diag cpu-affinity  show CPU affinity of all managed service processes
              diag cpu-freq      show/apply CPU frequency limits per radiod policy
              diag net           classify network for multi-host radiod (IGMP/mcast)
              completion bash    emit bash tab-completion script
        '''),
    )
    parser.add_argument('--topology', metavar='FILE',
                        help=f'topology file (default: {TOPOLOGY_PATH})')
    sub = parser.add_subparsers(dest='command')

    # install
    p = sub.add_parser('install', help='install and configure components')
    p.add_argument('client', nargs='?', default=None,
                   help='specific client to install from catalog (e.g. psk-recorder)')
    p.add_argument('--components', metavar='C1,C2',
                   help='comma-separated subset (default: all enabled in topology)')
    p.add_argument('--client-dir', metavar='DIR',
                   help='path to wsprdaemon-client (overrides topology)')
    p.add_argument('--dry-run', action='store_true',
                   help='show what would be done without making changes')
    p.add_argument('--yes', '-y', action='store_true',
                   help='accept defaults, no interactive prompts')

    # apply
    p = sub.add_parser('apply', help='reconcile services with current config')
    p.add_argument('--dry-run', action='store_true')

    # start
    p = sub.add_parser('start', help='start managed services')
    p.add_argument('--components', metavar='C1,C2')

    # stop
    p = sub.add_parser('stop', help='stop managed services')
    p.add_argument('--components', metavar='C1,C2')

    # status
    p = sub.add_parser('status', help='show service health')
    p.add_argument('--components', metavar='C1,C2')

    # restart (NEW)
    p = sub.add_parser('restart', help='restart managed services')
    p.add_argument('--components', metavar='C1,C2')

    # reload (NEW)
    p = sub.add_parser('reload', help='reload managed services (signal or restart)')
    p.add_argument('--components', metavar='C1,C2')
    p.add_argument('--via', choices=['auto', 'systemd', 'socket'], default='auto',
                   help='routing strategy for reload (default: auto)')

    # list (NEW)
    p = sub.add_parser('list', help='list resolved units for components')
    p.add_argument('--components', metavar='C1,C2')
    p.add_argument('--json', action='store_true',
                   help='emit machine-readable JSON')
    list_scope = p.add_mutually_exclusive_group()
    list_scope.add_argument('--available', action='store_true',
                            help='show catalog of known clients (what could be installed)')
    list_scope.add_argument('--all', action='store_true',
                            help='show catalog + configured units together')

    # log
    p = sub.add_parser('log', help='view logs or set log level for a client')
    p.add_argument('client', nargs='?', default=None,
                   help='client name (e.g. psk-recorder, hf-timestd)')
    p.add_argument('--files', action='store_true',
                   help='tail file logs from inventory log_paths instead of journal')
    p.add_argument('--level', metavar='LEVEL',
                   help='set log level (DEBUG/INFO/WARNING/ERROR/CRITICAL) in coordination.env + SIGHUP')

    # update
    p = sub.add_parser('update', help='pull latest code for all installed components and re-apply')
    p.add_argument('--components', metavar='C1,C2',
                   help='comma-separated subset of components to update (default: all installed)')
    p.add_argument('--ref', metavar='COMMIT_OR_BRANCH',
                   help='git ref to check out (default: latest on current branch)')
    p.add_argument('--dry-run', action='store_true',
                   help='show what would be updated without making changes')

    # diag  (with its own sub-commands)
    p_diag = sub.add_parser('diag', help='run cross-component diagnostics')
    p_diag.add_argument('--components', metavar='C1,C2')
    diag_sub = p_diag.add_subparsers(dest='diag_command')

    p = diag_sub.add_parser('cpu-affinity',
                             help='show CPU affinity of all managed service processes')
    p.add_argument('--components', metavar='C1,C2')
    p.add_argument('--threads', action='store_true',
                   help='show every thread grouped by CPU mask (default: only differing threads)')
    p.add_argument('--apply', action='store_true',
                   help='remove foreign affinity drop-ins and write smd-managed ones (requires root)')
    p.add_argument('--json', action='store_true',
                   help='emit the full affinity report as JSON (incompatible with --apply)')

    p = diag_sub.add_parser('cpu-freq',
                             help='show (and optionally apply) per-CPU frequency limits')
    p.add_argument('--apply', action='store_true',
                   help='write scaling_max_freq to sysfs (requires root)')
    p.add_argument('--radiod-max-mhz', type=int, metavar='MHZ',
                   help='override radiod CPU max frequency (default: from topology.toml or 3200)')
    p.add_argument('--other-max-mhz', type=int, metavar='MHZ',
                   help='override other CPU max frequency (default: from topology.toml or 1400)')

    p = diag_sub.add_parser('net',
                             help='classify network for multi-host radiod (IGMP, multicast)')
    p.add_argument('--interface', metavar='IFACE',
                   help='bind passive IGMP listen to this interface (default: all)')
    p.add_argument('--listen', type=int, metavar='SECONDS', default=130,
                   help='seconds to listen for IGMP queries when run as root (default: 130)')
    p.add_argument('--json', action='store_true',
                   help='emit full report as JSON')

    # completion
    p_completion = sub.add_parser('completion', help='emit shell tab-completion script')
    completion_sub = p_completion.add_subparsers(dest='completion_command')
    p_bash = completion_sub.add_parser('bash', help='emit bash completion script (source or install)')
    p_bash.add_argument('--install', action='store_true',
                        help='install to ~/.local/share/bash-completion/completions/smd (creates dir)')

    # validate (Phase 1)
    p = sub.add_parser('validate',
                       help='run cross-client harmonization rules (read-only)')
    p.add_argument('--json', action='store_true',
                   help='emit machine-readable JSON')

    # config (Phase 1)
    p_config = sub.add_parser('config',
                              help='inspect or migrate sigmond coordination config')
    config_sub = p_config.add_subparsers(dest='config_command')

    p = config_sub.add_parser('show',
                              help='dump effective coordination + client view')
    p.add_argument('--json', action='store_true')

    p = config_sub.add_parser('migrate',
                              help='extract coordination.toml from wsprdaemon.conf')
    p.add_argument('--from', dest='from_', metavar='FILE',
                   help='source wsprdaemon.conf (default: /etc/wsprdaemon/wsprdaemon.conf)')
    p.add_argument('--to', metavar='FILE',
                   help='destination coordination.toml (default: /etc/sigmond/coordination.toml)')
    p.add_argument('--write', action='store_true',
                   help='write the migrated file (otherwise print to stdout)')
    p.add_argument('--force', action='store_true',
                   help='overwrite target even if it already exists')

    p = config_sub.add_parser('backup', help='snapshot all config to a tar.gz')
    p.add_argument('--output', metavar='FILE',
                   help='output path (default: ~/sigmond-config-<host>-<date>.tar.gz)')

    p = config_sub.add_parser('restore', help='extract a config backup over the live system')
    p.add_argument('--input', metavar='FILE', required=True,
                   help='backup tar.gz to restore (e.g. ~/sigmond-config-*.tar.gz)')

    config_sub.add_parser('edit', help='[deprecated] use `smd tui` instead')

    # environment — situational awareness (site inventory + reconciliation).
    p_env = sub.add_parser('environment',
                           help='inventory peers declared in environment.toml vs what is observed')
    env_sub = p_env.add_subparsers(dest='env_command')

    p = env_sub.add_parser('list',
                           help='show declared peers + latest cached delta status')
    p.add_argument('--json', action='store_true')
    p.add_argument('--kind', choices=['radiod', 'kiwisdr', 'gpsdo', 'time_source'],
                   help='restrict output to one kind')

    p = env_sub.add_parser('probe',
                           help='run discovery, reconcile, write cache')
    p.add_argument('--source',
                   choices=['mdns', 'multicast', 'ntp', 'http_kiwisdr', 'gpsdo', 'all'],
                   default='all')
    p.add_argument('--kind', choices=['radiod', 'kiwisdr', 'gpsdo', 'time_source'])
    p.add_argument('--force', action='store_true',
                   help='ignore per-source cadence (still honours 5s hard floor)')
    p.add_argument('--timeout', type=float, default=3.0,
                   help='per-probe timeout in seconds (default 3.0)')
    p.add_argument('--json', action='store_true',
                   help='also emit machine-readable summary on stdout')

    p = env_sub.add_parser('describe',
                           help='show declared + observed details for one peer')
    p.add_argument('peer', help='declared id or observed endpoint/hostname')
    p.add_argument('--json', action='store_true')

    # tui — primary entry point (replaces `smd config edit`).
    sub.add_parser('tui', help='launch the sigmond TUI')

    args = parser.parse_args()
    if not args.command:
        print(BANNER)
        parser.print_help()
        return 0

    dispatch = {
        'install': cmd_install,
        'apply':   cmd_apply,
        'start':   cmd_start,
        'stop':    cmd_stop,
        'restart': cmd_restart,
        'reload':  cmd_reload,
        'list':    cmd_list,
        'log':     cmd_log,
        'status':  cmd_status,
        'update':  cmd_update,
        'tui':     cmd_tui,
    }

    if args.command == 'completion':
        return cmd_completion(args)

    if args.command == 'diag':
        diag_cmd = getattr(args, 'diag_command', None)
        if diag_cmd == 'cpu-affinity':
            return cmd_diag_cpu_affinity(args)
        if diag_cmd == 'cpu-freq':
            topo = _load_topology(Path(args.topology) if args.topology else TOPOLOGY_PATH)
            if getattr(args, 'radiod_max_mhz', None):
                topo['cpu_freq']['radiod_max_mhz'] = args.radiod_max_mhz
            if getattr(args, 'other_max_mhz', None):
                topo['cpu_freq']['other_max_mhz'] = args.other_max_mhz
            args._topology_override = topo
            return cmd_diag_cpu_freq(args)
        if diag_cmd == 'net':
            return cmd_diag_net(args)
        return cmd_diag(args)

    if args.command in ('validate', 'config', 'environment'):
        if not _HAS_SIGMOND_LIB:
            print('smd: sigmond library not found; install lib/sigmond alongside bin/smd',
                  file=sys.stderr)
            return 1
        if args.command == 'validate':
            return cmd_validate(args)
        if args.command == 'environment':
            env_cmd = getattr(args, 'env_command', None)
            if env_cmd == 'list':
                return cmd_environment_list(args)
            if env_cmd == 'probe':
                return cmd_environment_probe(args)
            if env_cmd == 'describe':
                return cmd_environment_describe(args)
            p_env.print_help()
            return 0
        # config
        sub_cmd = getattr(args, 'config_command', None)
        if sub_cmd == 'show':
            return cmd_config_show(args)
        if sub_cmd == 'migrate':
            return cmd_config_migrate(args)
        if sub_cmd == 'backup':
            return cmd_config_backup(args)
        if sub_cmd == 'restore':
            return cmd_config_restore(args)
        if sub_cmd == 'edit':
            return cmd_config_edit(args)
        p_config.print_help()
        return 0

    # Mutating verbs require root and acquire the lifecycle lock (CONTRACT §5.5).
    _MUTATING = {'install', 'apply', 'start', 'stop', 'restart', 'reload', 'update'}
    if args.command in _MUTATING:
        if _need_root(args.command):
            return 1
        if _HAS_SIGMOND_LIB:
            with lifecycle_lock(reason=args.command):
                return dispatch[args.command](args)

    return dispatch[args.command](args)


if __name__ == '__main__':
    sys.exit(main())
