# Entry point
# ---------------------------------------------------------------------------

def _add_uploads_watch_args(p) -> None:
    """Argument spec shared by `smd uploads-watch` and `smd watch uploads`."""
    p.add_argument('--backlog', metavar='MIN', type=int, default=10,
                   help='start by replaying this many minutes of journal '
                        'history for WSPR uploads (default 10).  PSK '
                        'uploads are live-only because the psk-recorder '
                        'file log lacks embedded timestamps.')


def _add_verifier_watch_args(p) -> None:
    """Argument spec for `smd watch verifier`."""
    p.add_argument('--instance', metavar='RADIOD_ID', default=None,
                   help='specific wspr-recorder@<id> instance '
                        '(default: all wspr-recorder@* journal events)')
    p.add_argument('--backlog', metavar='MIN', type=int, default=60,
                   help='start by replaying this many minutes of journal '
                        'history (default 60; verifier passes fire every '
                        '~5 min so 60 catches the recent ~12 passes)')


def _add_wspr_watch_args(p) -> None:
    """Argument spec shared by `smd wspr-watch` and `smd watch wspr`."""
    p.add_argument('recent', nargs='?', type=int, default=0, metavar='N',
                   help='also print up to N spots per band under each '
                        'cycle summary (default 0 = counts only; '
                        '-v = print all)')
    p.add_argument('-v', '--verbose', action='store_true',
                   help='per-cycle mode showing ALL spots — same '
                        'cadence as N, no per-band cap')
    p.add_argument('--instance', metavar='RADIOD_ID', default=None,
                   help='specific wspr-recorder@<id> instance '
                        '(default: all wspr-recorder@* journal events)')
    p.add_argument('--backlog', metavar='MIN', type=int, default=10,
                   help='start by replaying this many minutes of journal '
                        'history (default 10; rows for those cycles have '
                        'usually been shipped + deleted so per-band '
                        'detail will be missing)')
    p.add_argument('--rejected', '-r', action='store_true',
                   help='when a cycle ships with posted > added (wsprnet '
                        'rejected some spots), list the individual '
                        'rejected spot_keys under the cycle line.  '
                        'Requires WSPRNET_AUDIT=1 + WSPRNET_BATCH_SIZE=1 '
                        'on the producer; for larger batches wsprnet '
                        'reports aggregate rejection only.')


def _add_psk_watch_args(p) -> None:
    """Argument spec shared by `smd psk-watch` and `smd watch psk`."""
    p.add_argument('recent', nargs='?', type=int, default=0, metavar='N',
                   help='per-FT8-cycle mode (15 s cadence): print up to '
                        'N spots from each mode under each cycle summary '
                        '(default 0 = counts only; -v = print all)')
    p.add_argument('-v', '--verbose', action='store_true',
                   help='per-cycle mode showing ALL spots — same '
                        'cadence as N, no per-mode cap')
    p.add_argument('--instance', metavar='RADIOD_ID', default=None,
                   help='specific radiod instance (default: most recently '
                        'modified /var/log/psk-recorder/<id>.log)')


def _add_hfdl_watch_args(p) -> None:
    """Argument spec shared by `smd hfdl-watch` and `smd watch hfdl`."""
    p.add_argument('recent', nargs='?', type=int, default=0, metavar='N',
                   help='per-15s-window mode: print up to N frames per '
                        'band under the summary (default 0 = counts only; '
                        '-v = print all)')
    p.add_argument('-v', '--verbose', action='store_true',
                   help='per-window mode showing ALL frames — same '
                        'cadence as N, no per-band cap')
    p.add_argument('--instance', metavar='RADIOD_ID', default=None,
                   help='specific radiod instance, e.g. my-rx888 '
                        '(default: first active hfdl-recorder@*)')


def _add_codar_watch_args(p) -> None:
    """Argument spec shared by `smd codar-watch` and `smd watch codar`."""
    p.add_argument('recent', nargs='?', type=int, default=0, metavar='N',
                   help='per-15s-window mode (matches CPI cadence): print '
                        'up to N records per station under the summary '
                        '(default 0 = counts only; -v = print all)')
    p.add_argument('-v', '--verbose', action='store_true',
                   help='per-window mode showing ALL records — same '
                        'cadence as N, no per-station cap')
    p.add_argument('--instance', metavar='RADIOD_ID', default=None,
                   help='specific radiod instance, e.g. ac0g-bee1-rx888 '
                        '(default: first active codar-sounder@*, or '
                        'most-recently-modified data dir if no service)')


def _add_ka9q_watch_args(p) -> None:
    """Argument spec shared by `smd ka9q-watch` and `smd watch ka9q`."""
    p.add_argument('--ka9q-python', metavar='PATH',
                   help='path to ka9q-python checkout '
                        '(default: $KA9Q_PYTHON_PATH or /opt/git/sigmond/ka9q-python)')
    p.add_argument('--ka9q-radio', metavar='PATH',
                   help='path to ka9q-radio checkout '
                        '(default: $KA9Q_RADIO_PATH or /opt/git/sigmond/ka9q-radio)')
    p.add_argument('--remote', default='origin',
                   help='git remote to compare against (default: origin)')
    p.add_argument('--branch', default='main',
                   help='upstream branch to compare against (default: main)')
    p.add_argument('--no-fetch', action='store_true',
                   help="skip 'git fetch' (use local refs as-is)")
    p.add_argument('--json', action='store_true',
                   help='emit machine-readable JSON')


def main() -> int:
    # Hide argparse's auto-generated subparser listing — the grouped
    # epilog covers the same verbs categorised by intent (Configure /
    # Observe / Operate, mirroring the TUI tree), and the alphabetical
    # auto-listing was redundant.  Per-verb detail still works via
    # `smd <verb> --help`.
    class _GroupedHelpFormatter(argparse.RawDescriptionHelpFormatter):
        def _format_action(self, action):
            if isinstance(action, argparse._SubParsersAction):
                return ''
            return super()._format_action(action)

    parser = argparse.ArgumentParser(
        prog='smd',
        description='Sigmond — HamSCI suite installer and lifecycle manager',
        formatter_class=_GroupedHelpFormatter,
        epilog=textwrap.dedent('''\
            verbs (grouped by intent — same as the TUI tree):

              Configure (what should exist):
                add        clone a component repo
                install    install + configure components (--force to rebuild)
                enable     enable in topology.toml
                disable    disable + stop its units
                remove     remove from topology
                config     show / migrate / init / edit per-client config
                validate   cross-client harmonization checks

              Observe (what is — read-only):
                list       per-component status table  (also: --apply to pull)
                status     service health
                log        tail journal or file logs
                diag       diagnostics  (net | cpu-affinity | cpu-freq)
                environment   discover network peers
                watch      unified live-tail interface
                           (wspr | psk | ka9q)

              Operate (run things now — may need sudo):
                start / stop / restart / reload    systemd verbs
                apply      reconcile running services with current config
                storage    manage local sink backend (SQLite default;
                           migrate-to-sqlite removes leftover ClickHouse)
                tui        launch interactive TUI

              Other:
                completion bash    emit bash tab-completion script

            Run  smd <verb> --help  for verb-specific options.
        '''),
    )
    parser.add_argument('--topology', metavar='FILE',
                        help=f'topology file (default: {TOPOLOGY_PATH})')
    sub = parser.add_subparsers(dest='command')

    # add — clone (or pull) a component repo into /opt/git/sigmond/<name>/
    p = sub.add_parser('add', help='clone a component repo (run sudo smd install + enable to bring it online)')
    p.add_argument('url', help='git URL of the component repo (e.g. git@github.com:owner/foo.git)')

    # enable — set [component.<name>].enabled = true in topology.toml
    p = sub.add_parser('enable', help='enable component(s) in /etc/sigmond/topology.toml')
    p.add_argument('names', nargs='+', help='one or more component names')

    # disable — set enabled = false AND stop the component's units
    p = sub.add_parser('disable', help='disable component(s) and stop their units')
    p.add_argument('names', nargs='+', help='one or more component names')

    # remove — delete the [component.<name>] section AND stop units
    p = sub.add_parser('remove', help='remove component section from topology and stop its units')
    p.add_argument('names', nargs='+', help='one or more component names')

    # install + apply share their option set between the top-level form
    # (`smd install`, `smd apply` — kept for muscle memory) and the
    # grouped form (`smd software install`, `smd software apply` — the
    # preferred form going forward; "software" reads as a noun verb-pair
    # the way operators already think about it).
    def _add_install_args(p):
        p.add_argument('client', nargs='?', default=None,
                       help='specific client to install from catalog (e.g. psk-recorder)')
        p.add_argument('--components', metavar='C1,C2',
                       help='comma-separated subset (default: all enabled in topology)')
        p.add_argument('--client-dir', metavar='DIR',
                       help='path to wsprdaemon-client (overrides topology)')
        p.add_argument('--dry-run', action='store_true',
                       help='show what would be done without making changes')
        p.add_argument('--yes', '-y', action='store_true',
                       help='accept defaults, no interactive prompts')
        p.add_argument('--force', '-f', action='store_true',
                       help='rebuild/reinstall even if the binary appears current '
                            '(skips SHA short-circuits and `make` rebuild gating)')

    def _add_apply_args(p):
        p.add_argument('--dry-run', action='store_true')

    _add_install_args(sub.add_parser(
        'install', help='install and configure components '
                       '(alias for `smd software install`)'))
    _add_apply_args(sub.add_parser(
        'apply', help='reconcile services with current config '
                      '(alias for `smd software apply`)'))

    # software — grouped parent for the install/apply pair.  Both
    # subverbs accept the exact same flags as the top-level forms.
    p_software = sub.add_parser(
        'software',
        help='install or reconcile sigmond-managed software components')
    software_sub = p_software.add_subparsers(dest='software_command')
    _add_install_args(software_sub.add_parser(
        'install', help='install and configure components'))
    _add_apply_args(software_sub.add_parser(
        'apply', help='reconcile services with current config'))

    # start
    # All four lifecycle verbs accept positional component names (systemctl
    # style) or the literal keyword `all`.  Bare `smd start` (no args) is
    # equivalent to `smd start all` for backward compat.  --components is
    # kept as a deprecated alias.
    p = sub.add_parser('start', help='start managed services')
    p.add_argument('names', nargs='*',
                   help='component names, or "all" (default: all enabled)')
    p.add_argument('--components', metavar='C1,C2',
                   help='deprecated; same as positional names')

    # stop
    p = sub.add_parser('stop', help='stop managed services')
    p.add_argument('names', nargs='*',
                   help='component names, or "all" (default: all enabled)')
    p.add_argument('--components', metavar='C1,C2',
                   help='deprecated; same as positional names')

    # status
    p = sub.add_parser('status', help='show service health')
    p.add_argument('names', nargs='*',
                   help='component names (default: all enabled)')
    p.add_argument('--components', metavar='C1,C2',
                   help='deprecated; same as positional names')

    # restart (NEW)
    p = sub.add_parser('restart', help='restart managed services')
    p.add_argument('names', nargs='*',
                   help='component names, or "all" (default: all enabled)')
    p.add_argument('--components', metavar='C1,C2',
                   help='deprecated; same as positional names')

    # reload (NEW)
    p = sub.add_parser('reload', help='reload managed services (signal or restart)')
    p.add_argument('names', nargs='*',
                   help='component names, or "all" (default: all enabled)')
    p.add_argument('--components', metavar='C1,C2',
                   help='deprecated; same as positional names')
    p.add_argument('--via', choices=['auto', 'systemd', 'socket'], default='auto',
                   help='routing strategy for reload (default: auto)')

    # list — unified status surface (was: smd list + smd update)
    p = sub.add_parser('list',
                       help='show component status (lifecycle + git + version policy); '
                            '--update pulls and re-applies updates')
    p.add_argument('--components', metavar='C1,C2',
                   help='comma-separated subset of components')
    p.add_argument('--catalog', action='store_true',
                   help='show catalog of known clients (what could be installed)')
    # --update is the canonical flag; --apply is kept as a hidden alias
    # for muscle-memory and any tooling that hasn't migrated yet.
    p.add_argument('--update', '--apply', dest='update', action='store_true',
                   help='pull latest code per topology version policy and reapply '
                        '(was: smd update / smd list --apply; requires root)')
    p.add_argument('--fetch', action='store_true',
                   help='run `git fetch` per repo before computing divergence '
                        '(default: use cached upstream refs)')
    p.add_argument('--ref', metavar='COMMIT_OR_BRANCH',
                   help='with --update: force a specific git ref instead of '
                        'using each component\'s topology version policy')
    p.add_argument('--dry-run', action='store_true',
                   help='with --update: preview what would be pulled without '
                        'making changes')
    p.add_argument('--json', action='store_true',
                   help='emit machine-readable JSON')

    # log
    p = sub.add_parser('log', help='view logs or set log level for a client')
    p.add_argument('client', nargs='?', default=None,
                   help='client name (e.g. psk-recorder, hf-timestd)')
    p.add_argument('--files', action='store_true',
                   help='tail file logs from inventory log_paths instead of journal')
    p.add_argument('--level', metavar='LEVEL',
                   help='set log level (DEBUG/INFO/WARNING/ERROR/CRITICAL) in coordination.env + SIGHUP')

    # wisdom — FFTW3 wisdom-file planner
    p_wisdom = sub.add_parser('wisdom',
                              help='FFTW3 wisdom-file planner (radiod uses /etc/fftw/wisdomf)')
    wisdom_sub = p_wisdom.add_subparsers(dest='wisdom_command')

    p = wisdom_sub.add_parser('plan',
                              help='run fftwf-wisdom for every radiod transform; install /etc/fftw/wisdomf')
    p.add_argument('--no-install', action='store_true',
                   help='leave the result at /etc/fftw/wisdomf.new without renaming over wisdomf')

    p = wisdom_sub.add_parser('status',
                              help='show whether /etc/fftw/wisdomf exists and how old it is')

    # diag  (with its own sub-commands)
    p_diag = sub.add_parser('diag', help='run cross-component diagnostics')
    p_diag.add_argument('--components', metavar='C1,C2')
    diag_sub = p_diag.add_subparsers(dest='diag_command')

    p = diag_sub.add_parser('cpu-affinity',
                             help='show CPU affinity of all managed service processes')
    p.add_argument('--components', metavar='C1,C2')
    p.add_argument('--threads', action='store_true',
                   help='show every thread grouped by CPU mask (default: only differing threads)')
    p.add_argument('--apply', action='store_true',
                   help='remove foreign affinity drop-ins and write smd-managed ones (requires root)')
    p.add_argument('--json', action='store_true',
                   help='emit the full affinity report as JSON (incompatible with --apply)')

    p = diag_sub.add_parser(
        'cpu-freq',
        help='show + manage per-CPU frequency caps (alias of `smd cpu`)',
        description=(
            'Identical to `smd cpu` — kept under `diag` as the older name.  '
            'See `smd cpu --help` for full usage; flags are the same here.'
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    p.add_argument('--apply', action='store_true',
                   help='BARE-METAL ONLY: write scaling_max_freq to sysfs '
                        '(requires root; no effect inside a Proxmox VM)')
    p.add_argument('--reapply', action='store_true',
                   help='PROXMOX VM ONLY: SSH to the host and re-run the '
                        'cpu-pin hookscript (reapplies freq caps + vCPU '
                        'pinning without a VM restart)')
    p.add_argument('--radiod-max-mhz', type=int, metavar='MHZ',
                   help='override radiod CPU max frequency (default: from topology.toml or 3200)')
    p.add_argument('--other-max-mhz', type=int, metavar='MHZ',
                   help='override other CPU max frequency (default: from topology.toml or 1400)')

    # `smd cpu` — short alias for `smd diag cpu-freq`.  When running in a
    # Proxmox VM, fetches live per-pCPU freqs from the host via the same
    # SSH path install.sh used for grub edits.  No sub-command needed: it
    # just shows the live table.
    p_cpu = sub.add_parser(
        'cpu',
        help='show + manage per-CPU frequency caps (live data via SSH on Proxmox VMs)',
        description=(
            'Show per-CPU frequencies and apply the radiod/worker freq cap '
            'policy.  By default just prints the live table: cur/max/hw_max '
            'MHz per CPU + governor.  On a Proxmox VM the live data comes '
            'from the host over SSH (the VM kernel cannot see real freqs).  '
            'On bare metal it reads /sys/devices/system/cpu/cpu*/cpufreq.'
        ),
        epilog=(
            'Examples:\n'
            '  smd cpu                  # show live table (no changes)\n'
            '  sudo smd cpu --apply     # bare-metal: write the caps to /sys\n'
            '  sudo smd cpu --reapply   # VM: re-run the host hookscript\n'
            '\n'
            'Policy comes from /etc/sigmond/topology.toml [cpu_freq]:\n'
            '  radiod_max_mhz (default 3200)  applied to CPUs running radiod\n'
            '  other_max_mhz  (default 1400)  applied to every other CPU\n'
            'Override per-invocation with --radiod-max-mhz / --other-max-mhz.\n'
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    p_cpu.add_argument(
        '--apply', action='store_true',
        help=('BARE-METAL ONLY: write the policy caps to '
              '/sys/devices/system/cpu/cpu*/cpufreq/scaling_max_freq.  '
              'No effect inside a Proxmox VM (the VM does not own the '
              'real CPU policy — use --reapply there instead).  '
              'Requires root.'))
    p_cpu.add_argument(
        '--reapply', action='store_true',
        help=('PROXMOX VM ONLY: SSH to the host and re-execute the '
              'cpu-pin hookscript (/var/lib/vz/snippets/cpu-pin-<VMID>.sh).  '
              'That rewrites scaling_max_freq for every pinned pCPU AND '
              're-pins KVM vCPU threads — the same operation the hookscript '
              'performs at VM start.  Use this when host-side tuned or a '
              'host reboot has reset the caps; avoids bouncing the VM.'))
    p_cpu.add_argument(
        '--radiod-max-mhz', type=int, metavar='MHZ',
        help='override radiod CPU max frequency for this invocation '
             '(default: topology.toml cpu_freq.radiod_max_mhz, else 3200)')
    p_cpu.add_argument(
        '--other-max-mhz', type=int, metavar='MHZ',
        help='override other CPU max frequency for this invocation '
             '(default: topology.toml cpu_freq.other_max_mhz, else 1400)')

    p = diag_sub.add_parser('net',
                             help='classify network for multi-host radiod (IGMP, multicast)')
    p.add_argument('--interface', metavar='IFACE',
                   help='bind passive IGMP listen to this interface (default: all)')
    p.add_argument('--listen', type=int, metavar='SECONDS', default=130,
                   help='seconds to listen for IGMP queries when run as root (default: 130)')
    p.add_argument('--json', action='store_true',
                   help='emit full report as JSON')

    # public-ip — quick outbound-IP lookup
    p_pip = sub.add_parser(
        'public-ip',
        help='show this host\'s outbound public IP (IPv4 + IPv6)',
        description=(
            'Query one or more public-IP echo services and print the '
            'host\'s outbound public address.  Two resolvers must agree '
            'before an answer is shown without a warning.  Useful for '
            'declaring the station to upstream services (RAC tunnels, '
            'wsprnet station map, firewall ACLs).'
        ),
    )
    p_pip.add_argument('--no-v6', dest='v6', action='store_false', default=True,
                       help='skip IPv6 probe (default: try both)')
    p_pip.add_argument('-q', '--quiet', action='store_true',
                       help='print only the IP(s) on stdout, no decorations '
                            '(scriptable: `MY_IP=$(smd public-ip -q --no-v6)`)')

    # completion
    p_completion = sub.add_parser('completion', help='emit shell tab-completion script')
    completion_sub = p_completion.add_subparsers(dest='completion_command')
    p_bash = completion_sub.add_parser('bash', help='emit bash completion script (source or install)')
    p_bash.add_argument('--install', action='store_true',
                        help='install to ~/.local/share/bash-completion/completions/smd (creates dir)')

    # validate (Phase 1)
    p = sub.add_parser('validate',
                       help='run cross-client harmonization rules (read-only)')
    p.add_argument('--json', action='store_true',
                   help='emit machine-readable JSON')

    # psk-watch — live tail of psk-recorder's PSK Reporter upload activity
    p_tts = sub.add_parser('timestd-tune-storage',
                           help='size hf-timestd retention policy to local '
                                'disk (writes timestd-prune drop-ins)')
    p_tts.add_argument('--apply', action='store_true',
                       help='write the drop-ins (default: print recommendation only)')

    # storage — local sink backend management (SQLite is now the default;
    # this verb removes leftover ClickHouse installs on migrated hosts).
    # smd verifier report — windowed audit of "uploaded but never
    # appeared in wspr.rx" cohort.  Source data lives in
    # ``/var/lib/sigmond/sink.db``'s ``wsprnet_audit`` +
    # ``wsprnet_audit_batch`` tables, populated by wspr-recorder when
    # ``WSPRNET_AUDIT=1`` is set in its env file.
    p_verifier = sub.add_parser(
        'verifier',
        help='report on wsprnet upload audit (uploaded → verified '
             'in wspr.rx → lost / dropped)',
    )
    verifier_sub = p_verifier.add_subparsers(dest='verifier_command')
    p_v_report = verifier_sub.add_parser(
        'report',
        help='show delivered/lost/in-flight counts over a time window '
             'from the wsprnet_audit table',
    )
    p_v_report.add_argument(
        '--window', metavar='DURATION', default='1h',
        help='time window to summarise (default 1h; suffix s/m/h/d, '
             "e.g. '30m', '24h', '7d')",
    )
    p_v_report.add_argument(
        '--rx-call', metavar='CALLSIGN', default=None,
        help='restrict to one reporter (e.g. AC0G/B4); defaults to '
             'auto-detect on single-receiver hosts, all on multi-receiver',
    )
    p_v_report.add_argument(
        '--lost', action='store_true',
        help='list each lost spot under the summary (time, tx_sign, '
             'frequency); these are the spots that wsprnet either '
             'rejected at upload or accepted-then-silently-dropped',
    )
    p_v_report.add_argument(
        '--in-flight', action='store_true',
        help='list each in-flight spot under the summary — those '
             'uploaded but not yet matched in wspr.rx by the '
             'verifier (still inside the 2 h wait window)',
    )
    p_v_report.add_argument(
        '--cadence', action='store_true',
        help='audit cycle-by-cycle health: list any 2-min WSPR '
             'cycle in the window that produced zero spots '
             '(suggesting a wspr-recorder restart/OOM kill) or '
             'an anomalously-low count vs the median',
    )
    p_v_report.add_argument(
        '--rejected', action='store_true',
        help='list each spot wsprnet explicitly rejected at upload '
             "(when WSPRNET_BATCH_SIZE=1 is set in the uploader's "
             'env — see report output for the toggle hint)',
    )
    p_v_report.add_argument(
        '--silent-drop', action='store_true',
        dest='silent_drop',
        help='list each spot wsprnet ack\'d as added then never '
             'indexed into wspr.rx (the smoking-gun cohort for '
             'silent server-side drops, same WSPRNET_BATCH_SIZE=1 '
             'prerequisite)',
    )
    p_v_report.add_argument(
        '--delivered', action='store_true',
        help='list each delivered spot under the summary (verified '
             'present in wspr.rx); useful for sanity-checking but '
             'usually noisy on a busy site',
    )
    p_v_report.add_argument(
        '--json', action='store_true',
        help='emit a JSON document instead of human-readable text',
    )
    p_v_report.add_argument(
        '--db', metavar='PATH', default='/var/lib/sigmond/sink.db',
        help='sink.db path (default /var/lib/sigmond/sink.db)',
    )
    # PR 7: target switch — same verb covers wspr (default) and psk side.
    p_v_report.add_argument(
        '--target', choices=('wspr', 'psk'), default='wspr',
        help='which delivery path to verify. "wspr" (default) audits '
             'the wsprnet upload via the local wsprnet_audit table. '
             '"psk" audits the FT8/FT4 forwarding queue in the local '
             'SQLite sink (rows still pending vs stale).',
    )
    p_v_report.add_argument(
        '--psk-in-flight-sec', metavar='SECONDS', type=int,
        default=None, dest='psk_in_flight_sec',
        help='--target=psk only: queue-age window after which a row '
             'still in the local queue counts as stale rather than '
             'in_flight (default 300s = 5 min).',
    )

    p_storage = sub.add_parser('storage',
                               help='manage the local sink backend '
                                    '(SQLite default; remove leftover '
                                    'ClickHouse install)')
    storage_sub = p_storage.add_subparsers(dest='storage_command')
    p_mig = storage_sub.add_parser(
        'migrate-to-sqlite',
        help='remove a local ClickHouse install once SQLite is the '
             'chosen sink (default: dry-run; --yes to execute)',
    )
    p_mig.add_argument('--yes', action='store_true',
                       help='actually stop services, purge packages, '
                            'and delete /var/lib/clickhouse '
                            '(destructive; requires root)')

    p_trim = storage_sub.add_parser(
        'trim',
        help='delete pending_uploads rows older than --max-age '
             '(janitor for queues without an external consumer; '
             'default: dry-run; --yes to apply)',
    )
    p_trim.add_argument(
        '--max-age', metavar='DURATION', default='24h',
        help='delete rows with queued_at older than this (default: 24h). '
             'Suffixes: s/m/h/d; bare number = seconds.',
    )
    p_trim.add_argument(
        '--db', metavar='PATH', default=None,
        help='sink db path (default: /var/lib/sigmond/sink.db)',
    )
    p_trim.add_argument(
        '--target-db', metavar='NAME', default=None, dest='target_db',
        help='restrict the trim to one logical sink ("hfdl", '
             '"timestd", "psk", ...).  Required when different '
             'producers want different TTLs.',
    )
    p_trim.add_argument(
        '--target-table', metavar='NAME', default=None, dest='target_table',
        help='further restrict to one table within --target-db '
             '(e.g. "spots", "events"); requires --target-db.',
    )
    p_trim.add_argument(
        '--yes', action='store_true',
        help='actually run the DELETE (destructive; requires root)',
    )
    p_trim.add_argument(
        '--all', action='store_true', dest='trim_all',
        help='apply per-target retention policies (PSK_RETENTION_MIN, '
             'WSPR_RETENTION_MIN, ...) in one pass. Mutually exclusive '
             'with --max-age/--target-db/--target-table; ignores those '
             'when set. Min 30 min floor enforced.',
    )

    p_psk = sub.add_parser('psk-watch',
                           help='live tail of PSK Reporter upload events '
                                '(alias: smd watch psk)')
    _add_psk_watch_args(p_psk)

    # wspr-watch — live tail of wsprdaemon-client's WSPRnet upload activity
    p_wspr = sub.add_parser('wspr-watch',
                            help='live tail of WSPRnet upload events '
                                 '(alias: smd watch wspr)')
    _add_wspr_watch_args(p_wspr)

    # hfdl-watch — live tail of hfdl-recorder per-band decoded frames
    p_hfdl = sub.add_parser('hfdl-watch',
                            help='live tail of HFDL decoded-frame activity '
                                 '(alias: smd watch hfdl)')
    _add_hfdl_watch_args(p_hfdl)

    # codar-watch — live tail of codar-sounder per-station soundings
    p_codar = sub.add_parser('codar-watch',
                             help='live tail of CODAR ionospheric soundings '
                                  '(alias: smd watch codar)')
    _add_codar_watch_args(p_codar)

    # ka9q-watch — alert on upstream ka9q-radio changes that could break clients
    p = sub.add_parser('ka9q-watch',
                       help='check ka9q-radio upstream for changes that could '
                            'break ka9q-python RTP clients '
                            '(alias: smd watch ka9q)')
    _add_ka9q_watch_args(p)

    # watch — unified live-tail / observe interface
    #
    # Convenience verb so each per-service watcher is reachable via a
    # consistent `smd watch <service>` shape, in addition to the older
    # standalone names.  Targets share their argument specs with the
    # standalone verbs (`_add_*_watch_args` helpers), so behavior is
    # identical — only the invocation is different.
    p_watch = sub.add_parser('watch',
                             help='unified live-tail interface '
                                  '(smd watch wspr | psk | hfdl | codar | ka9q | uploads | verifier)')
    watch_sub = p_watch.add_subparsers(dest='watch_target')

    p_w_wspr = watch_sub.add_parser(
        'wspr',
        help='live tail of WSPRnet upload events '
             '(two lines per batch: "start" + "done")',
    )
    _add_wspr_watch_args(p_w_wspr)

    p_w_psk = watch_sub.add_parser(
        'psk',
        help='live tail of PSK Reporter upload events '
             '(per-poll ft8/ft4 counts + batch flushes)',
    )
    _add_psk_watch_args(p_w_psk)

    p_w_hfdl = watch_sub.add_parser(
        'hfdl',
        help='live tail of HFDL decoded-frame activity '
             '(per-band frame counts + GS/aircraft tallies)',
    )
    _add_hfdl_watch_args(p_w_hfdl)

    p_w_codar = watch_sub.add_parser(
        'codar',
        help='live tail of CODAR ionospheric soundings '
             '(per-station peak counts + layer + SNR rollup)',
    )
    _add_codar_watch_args(p_w_codar)

    p_w_ka9q = watch_sub.add_parser(
        'ka9q',
        help='check ka9q-radio upstream for changes that could '
             'break ka9q-python RTP clients',
    )
    _add_ka9q_watch_args(p_w_ka9q)

    p_w_uploads = watch_sub.add_parser(
        'uploads',
        help='live tail of WSPRnet / wsprdaemon.org / PSK Reporter '
             'upload activity (per-batch shipped counts + totals)',
    )
    _add_uploads_watch_args(p_w_uploads)

    p_w_verifier = watch_sub.add_parser(
        'verifier',
        help='live tail of upload-verifier passes — confirm our spots '
             'round-tripped through wsprnet.org (wsprdaemon.org coming '
             'next).  One line per ~5 min pass.',
    )
    _add_verifier_watch_args(p_w_verifier)

    # config (Phase 1)
    p_config = sub.add_parser('config',
                              help='inspect or migrate sigmond coordination config')
    config_sub = p_config.add_subparsers(dest='config_command')

    p = config_sub.add_parser('show',
                              help='dump effective coordination + client view')
    p.add_argument('--json', action='store_true')

    p = config_sub.add_parser('identity',
                              help='operator identity (callsign + grid) — '
                                   'shared default for all client wizards')
    p.add_argument('--call', metavar='CALL',
                   help='operator callsign (e.g. AI6VN); uppercased automatically')
    p.add_argument('--grid', metavar='GRID',
                   help='Maidenhead 4/6-char grid (e.g. CM87us)')
    p.add_argument('--lat', type=float, metavar='DEG',
                   help='latitude in decimal degrees')
    p.add_argument('--lon', type=float, metavar='DEG',
                   help='longitude in decimal degrees')
    p.add_argument('--json', action='store_true',
                   help='emit current identity as JSON, no prompts')

    p = config_sub.add_parser('refresh',
                              help='re-render /etc/sigmond/coordination.env '
                                   'from coordination.toml (after a hand-edit)')
    p.add_argument('--dry-run', action='store_true',
                   help='print the rendered env file to stdout, do not write')

    p = config_sub.add_parser('migrate',
                              help='extract coordination.toml from wsprdaemon.conf')
    p.add_argument('--from', dest='from_', metavar='FILE',
                   help='source wsprdaemon.conf (default: /etc/wsprdaemon/wsprdaemon.conf)')
    p.add_argument('--to', metavar='FILE',
                   help='destination coordination.toml (default: /etc/sigmond/coordination.toml)')
    p.add_argument('--write', action='store_true',
                   help='write the migrated file (otherwise print to stdout)')
    p.add_argument('--force', action='store_true',
                   help='overwrite target even if it already exists')

    p = config_sub.add_parser('backup', help='snapshot all config to a tar.gz')
    p.add_argument('--output', metavar='FILE',
                   help='output path (default: ~/sigmond-config-<host>-<date>.tar.gz)')

    p = config_sub.add_parser('restore', help='extract a config backup over the live system')
    p.add_argument('--input', metavar='FILE', required=True,
                   help='backup tar.gz to restore (e.g. ~/sigmond-config-*.tar.gz)')

    p = config_sub.add_parser('init',
                              help="invoke a client's first-run config wizard")
    p.add_argument('client', help='client name (e.g. hf-timestd)')
    p.add_argument('instance', nargs='?', default=None,
                   help='optional instance name for multi-source clients '
                        '(e.g. radiod-0).  Single-instance is the default.')

    p = config_sub.add_parser('edit',
                              help="invoke a client's config edit flow, "
                                   "or open $EDITOR on its config when no "
                                   "wizard is advertised")
    p.add_argument('client', nargs='?', default=None,
                   help='client name (omit for the legacy TUI redirect)')
    p.add_argument('instance', nargs='?', default=None,
                   help='optional instance name for multi-source clients')

    # environment — situational awareness (site inventory + reconciliation).
    p_env = sub.add_parser('environment',
                           help='inventory peers declared in environment.toml vs what is observed')
    env_sub = p_env.add_subparsers(dest='env_command')

    p = env_sub.add_parser('list',
                           help='show declared peers + latest cached delta status')
    p.add_argument('--json', action='store_true')
    p.add_argument('--kind', choices=['radiod', 'kiwisdr', 'gpsdo', 'time_source'],
                   help='restrict output to one kind')

    p = env_sub.add_parser('probe',
                           help='run discovery, reconcile, write cache')
    p.add_argument('--source',
                   choices=['mdns', 'multicast', 'ntp', 'http_kiwisdr', 'gpsdo', 'all'],
                   default='all')
    p.add_argument('--kind', choices=['radiod', 'kiwisdr', 'gpsdo', 'time_source'])
    p.add_argument('--force', action='store_true',
                   help='ignore per-source cadence (still honours 5s hard floor)')
    p.add_argument('--timeout', type=float, default=3.0,
                   help='per-probe timeout in seconds (default 3.0)')
    p.add_argument('--json', action='store_true',
                   help='also emit machine-readable summary on stdout')

    p = env_sub.add_parser('describe',
                           help='show declared + observed details for one peer')
    p.add_argument('peer', help='declared id or observed endpoint/hostname')
    p.add_argument('--json', action='store_true')

    # tui — primary entry point (replaces `smd config edit`).
    sub.add_parser('tui', help='launch the sigmond TUI')

    args = parser.parse_args()
    if not args.command:
        print(BANNER)
        parser.print_help()
        return 0

    dispatch = {
        'add':     cmd_add,
        'enable':  cmd_enable,
        'disable': cmd_disable,
        'remove':  cmd_remove,
        'install': cmd_install,
        'apply':   cmd_apply,
        'start':   cmd_start,
        'stop':    cmd_stop,
        'restart': cmd_restart,
        'reload':  cmd_reload,
        'list':    cmd_list,
        'log':     cmd_log,
        'status':  cmd_status,
        'tui':     cmd_tui,
        'public-ip': cmd_public_ip,
    }

    if args.command == 'completion':
        return cmd_completion(args)

    if args.command == 'wisdom':
        wis_cmd = getattr(args, 'wisdom_command', None)
        if wis_cmd == 'plan':
            if _need_root('wisdom plan'):
                return 1
            return cmd_wisdom_plan(args)
        if wis_cmd == 'status':
            return cmd_wisdom_status(args)
        p_wisdom.print_help()
        return 0

    if args.command == 'cpu':
        # Shortcut: `smd cpu` → cmd_diag_cpu_freq with the same topology
        # override pipeline as `smd diag cpu-freq`.
        topo = _load_topology(Path(args.topology) if args.topology else TOPOLOGY_PATH)
        if getattr(args, 'radiod_max_mhz', None):
            topo['cpu_freq']['radiod_max_mhz'] = args.radiod_max_mhz
        if getattr(args, 'other_max_mhz', None):
            topo['cpu_freq']['other_max_mhz'] = args.other_max_mhz
        args._topology_override = topo
        return cmd_diag_cpu_freq(args)

    if args.command == 'diag':
        diag_cmd = getattr(args, 'diag_command', None)
        if diag_cmd == 'cpu-affinity':
            return cmd_diag_cpu_affinity(args)
        if diag_cmd == 'cpu-freq':
            topo = _load_topology(Path(args.topology) if args.topology else TOPOLOGY_PATH)
            if getattr(args, 'radiod_max_mhz', None):
                topo['cpu_freq']['radiod_max_mhz'] = args.radiod_max_mhz
            if getattr(args, 'other_max_mhz', None):
                topo['cpu_freq']['other_max_mhz'] = args.other_max_mhz
            args._topology_override = topo
            return cmd_diag_cpu_freq(args)
        if diag_cmd == 'net':
            return cmd_diag_net(args)
        return cmd_diag(args)

    if args.command == 'psk-watch':
        return cmd_psk_watch(args)

    if args.command == 'wspr-watch':
        return cmd_wspr_watch(args)

    if args.command == 'hfdl-watch':
        return cmd_hfdl_watch(args)

    if args.command == 'codar-watch':
        return cmd_codar_watch(args)

    if args.command == 'watch':
        target = getattr(args, 'watch_target', None)
        if target == 'wspr':
            return cmd_wspr_watch(args)
        if target == 'psk':
            return cmd_psk_watch(args)
        if target == 'hfdl':
            return cmd_hfdl_watch(args)
        if target == 'codar':
            return cmd_codar_watch(args)
        if target == 'ka9q':
            if not _HAS_SIGMOND_LIB:
                print('smd: sigmond library not found; install '
                      'lib/sigmond alongside bin/smd', file=sys.stderr)
                return 1
            return cmd_ka9q_watch(args)
        if target == 'uploads':
            return cmd_uploads_watch(args)
        if target == 'verifier':
            return cmd_verifier_watch(args)
        p_watch.print_help()
        return 0

    if args.command == 'storage':
        storage_cmd = getattr(args, 'storage_command', None)
        if storage_cmd == 'migrate-to-sqlite':
            return cmd_storage_migrate_to_sqlite(args)
        if storage_cmd == 'trim':
            return cmd_storage_trim(args)
        p_storage.print_help()
        return 0

    if args.command == 'verifier':
        verifier_cmd = getattr(args, 'verifier_command', None)
        if verifier_cmd == 'report' and getattr(args, 'target', 'wspr') == 'psk':
            try:
                from sigmond.commands.verifier_report_psk import (
                    cmd_verifier_report_psk,
                )
            except ImportError as exc:
                _err(f"verifier report --target psk unavailable: {exc}")
                return 1
            return cmd_verifier_report_psk(args)
        if verifier_cmd == 'report':
            if not _HAS_SIGMOND_LIB:
                print(
                    'smd: sigmond library not found; install '
                    'lib/sigmond alongside bin/smd',
                    file=sys.stderr,
                )
                return 1
            from sigmond.commands.verifier_report import cmd_verifier_report
            return cmd_verifier_report(args)
        p_verifier.print_help()
        return 0

    if args.command == 'timestd-tune-storage':
        return cmd_timestd_tune_storage(args)

    if args.command in ('validate', 'config', 'environment', 'ka9q-watch'):
        if not _HAS_SIGMOND_LIB:
            print('smd: sigmond library not found; install lib/sigmond alongside bin/smd',
                  file=sys.stderr)
            return 1
        if args.command == 'validate':
            return cmd_validate(args)
        if args.command == 'ka9q-watch':
            return cmd_ka9q_watch(args)
        if args.command == 'environment':
            env_cmd = getattr(args, 'env_command', None)
            if env_cmd == 'list':
                return cmd_environment_list(args)
            if env_cmd == 'probe':
                return cmd_environment_probe(args)
            if env_cmd == 'describe':
                return cmd_environment_describe(args)
            p_env.print_help()
            return 0
        # config
        sub_cmd = getattr(args, 'config_command', None)
        if sub_cmd == 'show':
            return cmd_config_show(args)
        if sub_cmd == 'identity':
            # Writing /etc/sigmond/coordination.toml + .env requires root.
            # _need_root re-execvps under sudo when run as a normal user, so
            # the prompts (if any) run after elevation.
            if not getattr(args, 'json', False) and _need_root('config identity'):
                return 1
            return cmd_config_identity(args)
        if sub_cmd == 'refresh':
            # --dry-run is read-only; only the writing path needs root.
            if not getattr(args, 'dry_run', False) and _need_root('config refresh'):
                return 1
            return cmd_config_refresh(args)
        if sub_cmd == 'migrate':
            return cmd_config_migrate(args)
        if sub_cmd == 'backup':
            return cmd_config_backup(args)
        if sub_cmd == 'restore':
            return cmd_config_restore(args)
        if sub_cmd == 'init':
            # radiod's wizard writes /etc/radio/ + appends to
            # /etc/sigmond/coordination.toml + re-renders coordination.env
            # — needs root.  Other clients shell out to client-owned
            # scripts that handle their own escalation, so we don't
            # auto-elevate the general case.
            if (getattr(args, 'client', None) == 'radiod'
                    and _need_root('config init radiod')):
                return 1
            return cmd_config_init(args)
        if sub_cmd == 'edit':
            # `smd config edit <client>` is the new client-aware form
            # (CONTRACT-v0.5 §14).  Bare `smd config edit` retains the
            # deprecated TUI redirect so old muscle memory still works.
            if getattr(args, 'client', None):
                return cmd_config_edit_client(args)
            return cmd_config_edit(args)
        p_config.print_help()
        return 0

    # `smd software <install|apply>` — rewrite into the corresponding
    # top-level command so the rest of the dispatch (mutating-lock,
    # root check, sigmond-lib gate) and the cmd_install/cmd_apply
    # handlers themselves can stay unaware of the new grouping.  The
    # arg namespaces are identical because both forms share the same
    # _add_install_args / _add_apply_args definitions.
    if args.command == 'software':
        sub_cmd = getattr(args, 'software_command', None)
        if sub_cmd in ('install', 'apply'):
            args.command = sub_cmd  # fall through to dispatch below
        else:
            p_software.print_help()
            return 0

    # Mutating verbs require root and acquire the lifecycle lock (CONTRACT §5.5).
    _MUTATING = {'install', 'apply', 'start', 'stop', 'restart', 'reload', 'update'}
    if args.command in _MUTATING:
        if _need_root(args.command):
            return 1
        if _HAS_SIGMOND_LIB:
            with lifecycle_lock(reason=args.command):
                return dispatch[args.command](args)

    return dispatch[args.command](args)


def _install_sigint_handler() -> None:
    """Replace Python's default SIGINT (Ctrl-C) traceback with a clean
    one-line exit message — matches the feel of standard CLI tools like
    apt or systemctl."""
    import signal as _signal
    def _handler(signum, frame):
        # Newline so the prompt lands cleanly past any half-printed output.
        sys.stderr.write('\nsmd: interrupted\n')
        sys.exit(130)  # 128 + SIGINT, conventional shell exit code
    _signal.signal(_signal.SIGINT, _handler)


if __name__ == '__main__':
    _install_sigint_handler()
    try:
        sys.exit(main())
    except KeyboardInterrupt:
        # Belt-and-suspenders for any path that catches and re-raises.
        sys.stderr.write('\nsmd: interrupted\n')
        sys.exit(130)
    except BrokenPipeError:
        # `smd ... | head` etc.; not an error.
        sys.exit(0)
