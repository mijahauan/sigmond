# symlink.
_SCRIPT = Path(__file__).resolve()
for _candidate in (_SCRIPT.parent.parent / 'lib',        # repo layout
                   Path('/opt/sigmond/lib'),             # installed layout
                   Path('/usr/local/lib/sigmond')):      # alt installed
    if (_candidate / 'sigmond' / '__init__.py').exists():
        sys.path.insert(0, str(_candidate))
        break

