BANNER = r"""
          .---.
         / o o \     "Zo... ven did your
         \ ._. /      signals first start
          |||||       to propagate?"
         /|||||\             ______
        / ||||| \            \    /
       '  |||||  '            \  /
          (  )                 \/
       ~~smoke~~               |   /
                  -------------'  /
                  ---------------/
                  |            |
     Dr. SigMonD — Signal Monitor Daemon
"""

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def _run(cmd: list, *, cwd=None, capture=True, sudo=False) -> subprocess.CompletedProcess:
    if sudo and os.geteuid() != 0:
        cmd = ['sudo'] + cmd
    return subprocess.run(cmd, cwd=cwd,
                          capture_output=capture, text=True)


def _ok(msg):   print(f'  \033[32m✓\033[0m  {msg}')
def _warn(msg): print(f'  \033[33m⚠\033[0m  {msg}')
def _err(msg):  print(f'  \033[31m✗\033[0m  {msg}', file=sys.stderr)
def _info(msg): print(f'     {msg}')


def _heading(title: str):
    print(f'\n\033[1m━━━ {title} ━━━\033[0m')


def _need_root(cmd_name: str) -> bool:
    if os.geteuid() != 0:
        print(f'smd {cmd_name}: must run as root (sudo smd {cmd_name})',
              file=sys.stderr)
        return True
    return False


# ---------------------------------------------------------------------------
# Client contract queries
# ---------------------------------------------------------------------------

def _get_client_inventory(client_name: str, timeout: float = 5.0):
    """Call <client> inventory --json. Returns parsed dict or None."""
    import json as _json
    binary = find_client_binary(client_name) if _HAS_SIGMOND_LIB else shutil.which(client_name)
    if not binary:
        return None
    try:
        r = subprocess.run(
            [binary, 'inventory', '--json'],
            capture_output=True, text=True, timeout=timeout,
        )
        if r.returncode != 0:
            return None
        return _json.loads(r.stdout)
    except (subprocess.SubprocessError, _json.JSONDecodeError, OSError):
        return None


def _get_client_validate(client_name: str, timeout: float = 5.0):
    """Call <client> validate --json. Returns parsed dict or None."""
    import json as _json
    binary = find_client_binary(client_name) if _HAS_SIGMOND_LIB else shutil.which(client_name)
    if not binary:
        return None
    try:
        r = subprocess.run(
            [binary, 'validate', '--json'],
            capture_output=True, text=True, timeout=timeout,
        )
        if r.returncode != 0:
            return None
        return _json.loads(r.stdout)
    except (subprocess.SubprocessError, _json.JSONDecodeError, OSError):
        return None


# ---------------------------------------------------------------------------
# Topology
# ---------------------------------------------------------------------------

def _load_topology(path: Path, client_dir_override: str = None) -> dict:
    """Thin adapter — delegates to sigmond.topology.load_topology() and
    flattens the dataclass into the dict shape that CLI callers expect."""
    from sigmond.topology import load_topology as _lib_load_topology

    t = _lib_load_topology(path=path, client_dir_override=client_dir_override)
    return {
        'client_dir': t.client_dir,
        'smd_bin':    t.smd_bin,
        'components': {
            name: {
                'enabled':     c.enabled,
                'managed':     c.managed,
                'description': c.description,
            } for name, c in t.components.items()
        },
        'cpu_freq':     dict(t.cpu_freq),
        'cpu_affinity': dict(t.cpu_affinity),
    }


def _enabled_components(topology: dict, only: list = None) -> list:
    """Return sorted list of enabled component names, filtered by only if given."""
    enabled = [n for n, c in topology['components'].items() if c['enabled']]
    if only:
        enabled = [n for n in enabled if n in only]
    return sorted(enabled)


# ---------------------------------------------------------------------------
# Dependency management (reads wsprdaemon-client/deps.conf)
# ---------------------------------------------------------------------------

# Map each component to the deps.conf sections it needs
COMPONENT_DEPS = {
    'radiod':              ['ka9q-radio'],
    'wspr':                ['ka9q-python', 'wspr-recorder', 'kiwiclient', 'ftlib-pskreporter'],
    'wsprdaemon-client':   ['ka9q-python', 'wspr-recorder', 'kiwiclient', 'ftlib-pskreporter'],
    'ka9q-web':            ['ka9q-web'],
    'grape':               [],   # legacy alias for hf-timestd
    'hf-timestd':          [],   # manages itself
    'psk-recorder':        [],   # manages itself
    'wspr-recorder':       [],   # manages itself
    'rac':                 [],
}

# Deps that require a C build step after cloning
BUILD_STEPS = {
    'ka9q-radio': '_build_ka9q_radio',
    'ka9q-web':   '_build_ka9q_web_with_onion',
}


def _load_deps_conf(client_dir: Path) -> configparser.ConfigParser:
    deps_file = client_dir / 'deps.conf'
    if not deps_file.exists():
        _err(f'deps.conf not found at {deps_file}')
        return None
    cfg = configparser.ConfigParser()
    cfg.read(deps_file)
    return cfg


def _ensure_venv(venv_dir: Path) -> bool:
    if venv_dir.exists():
        return True
    _info(f'Creating Python venv at {venv_dir} ...')
    r = _run([sys.executable, '-m', 'venv', str(venv_dir)])
    if r.returncode != 0:
        _err(f'venv creation failed: {r.stderr.strip()}')
        return False
    return True


def _install_git_dep(section: str, dcfg: configparser.ConfigParser) -> bool:
    url        = dcfg.get(section, 'url', fallback='').strip()
    pinned     = dcfg.get(section, 'commit', fallback='').strip()
    install_to = dcfg.get(section, 'install_to', fallback='').strip()

    if not url or not install_to:
        _err(f'[{section}] missing url or install_to in deps.conf')
        return False

    target = Path(install_to)

    if not target.exists():
        _info(f'Cloning {section} → {target} ...')
        r = _run(['git', 'clone', url, str(target)])
        if r.returncode != 0:
            _err(f'git clone {section} failed: {r.stderr.strip()}')
            return False
        if pinned:
            _run(['git', '-C', str(target), 'checkout', pinned])

    # Verify commit
    if pinned:
        r = _run(['git', '-c', f'safe.directory={target}',
                  '-C', str(target), 'rev-parse', 'HEAD'])
        current = r.stdout.strip()
        if current and not current.startswith(pinned[:12]):
            _warn(f'{section}: at {current[:12]}, deps.conf pins {pinned[:12]}')
            _info(f'To update: git -C {target} fetch && git -C {target} checkout {pinned}')
        else:
            _ok(f'{section}: {current[:12]}')

    return True


def _install_pypi_dep(section: str, dcfg: configparser.ConfigParser,
                      venv_dir: Path) -> bool:
    url    = dcfg.get(section, 'url', fallback='').strip()
    commit = dcfg.get(section, 'commit', fallback='').strip()

    pip = str(venv_dir / 'bin' / 'pip')
    is_git = url.startswith('git+')
    pkg_name = url.rstrip('/').split('/')[-1].replace('.git', '') if is_git else url

    r = _run([pip, 'show', pkg_name])
    if r.returncode == 0:
        installed_ver = next(
            (l.split(':', 1)[1].strip() for l in r.stdout.splitlines()
             if l.startswith('Version:')), 'unknown')
        if installed_ver == commit or (is_git and commit[:8] in r.stdout):
            _ok(f'{section}: {installed_ver}')
            return True
        _warn(f'{section}: have {installed_ver}, want {commit[:12]}')

    spec = f'{url}@{commit}' if is_git else f'{url}=={commit}'
    _info(f'Installing {section} ({spec}) ...')
    r = _run([pip, 'install', spec])
    if r.returncode != 0:
        _err(f'{section} install failed: {r.stderr.strip()[-400:]}')
        return False
    _ok(f'{section}: installed')
    return True


def _build_ka9q_radio(src_dir: Path) -> bool:
    binary = Path('/usr/local/sbin/radiod')
    # Check if installed binary matches built binary
    built = src_dir / 'src' / 'radiod'
    if binary.exists() and built.exists():
        import hashlib
        def _sha(p):
            return hashlib.sha256(p.read_bytes()).hexdigest()
        if _sha(binary) == _sha(built):
            _ok('ka9q-radio: already installed and current')
            return True

    nproc = str(os.cpu_count() or 2)
    _info(f'Building ka9q-radio (make -j{nproc}) ...')
    r = _run(['make', f'-j{nproc}'], cwd=str(src_dir), capture=False)
    if r is None or (hasattr(r, 'returncode') and r.returncode != 0):
        _err('ka9q-radio build failed')
        return False
    r = _run(['make', 'install'], cwd=str(src_dir), sudo=True)
    if r.returncode != 0:
        _err(f'ka9q-radio install failed: {r.stderr.strip()}')
        return False
    _ok('ka9q-radio: built and installed')
    return True


def _build_onion(src_dir: Path) -> bool:
    if Path('/usr/local/lib/libonion.so').exists():
        _ok('onion: already installed')
        return True
    build_dir = src_dir / 'build'
    build_dir.mkdir(exist_ok=True)
    _info('Configuring onion ...')
    r = _run(['cmake', '..', '-DCMAKE_INSTALL_PREFIX=/usr/local',
              '-DHAVE_SQLITE3=OFF', '-DHAVE_REDIS=OFF', '-DHAVE_HIREDIS=OFF',
              '-DHAVE_JPEG=OFF', '-DHAVE_PAM=OFF', '-DHAVE_SYSTEMD=OFF',
              '-DHAVE_XML2=OFF', '-DONION_USE_SSL=ON'],
             cwd=str(build_dir))
    if r.returncode != 0:
        _err(f'onion cmake failed: {r.stderr.strip()}')
        return False
    nproc = str(os.cpu_count() or 2)
    _info(f'Building onion (make -j{nproc}) ...')
    r = _run(['make', f'-j{nproc}'], cwd=str(build_dir))
    if r.returncode != 0:
        _err(f'onion build failed: {r.stderr[-400:]}')
        return False
    r = _run(['make', 'install'], cwd=str(build_dir), sudo=True)
    if r.returncode != 0:
        _err(f'onion install failed: {r.stderr.strip()}')
        return False
    _run(['ldconfig'], sudo=True)
    _ok('onion: built and installed')
    return True


def _build_ka9q_web_with_onion(src_dir: Path) -> bool:
    # onion is a build-time dependency of ka9q-web
    dcfg = configparser.ConfigParser()
    deps_conf = src_dir.parent / 'wsprdaemon-client' / 'deps.conf'
    if deps_conf.exists():
        dcfg.read(deps_conf)
    onion_url    = dcfg.get('ka9q-web', 'onion_url', fallback='https://github.com/davidmoreno/onion.git')
    onion_commit = dcfg.get('ka9q-web', 'onion_commit', fallback='')
    onion_src    = Path(dcfg.get('ka9q-web', 'onion_src', fallback='/home/wsprdaemon/onion'))

    if not onion_src.exists():
        _info(f'Cloning onion → {onion_src} ...')
        r = _run(['git', 'clone', onion_url, str(onion_src)])
        if r.returncode != 0:
            _err(f'git clone onion failed: {r.stderr.strip()}')
            return False
        if onion_commit:
            _run(['git', '-C', str(onion_src), 'checkout', onion_commit])

    if not _build_onion(onion_src):
        return False

    binary = Path('/usr/local/sbin/ka9q-web')
    built  = src_dir / 'ka9q-web'
    if binary.exists() and built.exists():
        import hashlib
        def _sha(p): return hashlib.sha256(p.read_bytes()).hexdigest()
        if _sha(binary) == _sha(built):
            _ok('ka9q-web: already installed and current')
            return True

    nproc = str(os.cpu_count() or 2)
    _info(f'Building ka9q-web (make -j{nproc}) ...')
    r = _run(['make', f'-j{nproc}'], cwd=str(src_dir))
    if r.returncode != 0:
        _err(f'ka9q-web build failed: {r.stderr[-400:]}')
        return False
    r = _run(['make', 'install'], cwd=str(src_dir), sudo=True)
    if r.returncode != 0:
        _err(f'ka9q-web install failed: {r.stderr.strip()}')
        return False
    _ok('ka9q-web: built and installed')
    return True


def _collect_deps_for_components(components: list) -> list:
    """Return deduplicated ordered list of dep section names needed."""
    seen = set()
    result = []
    for comp in components:
        for dep in COMPONENT_DEPS.get(comp, []):
            if dep not in seen:
                seen.add(dep)
                result.append(dep)
    return result


# ---------------------------------------------------------------------------
# System-level install steps
# ---------------------------------------------------------------------------

def _install_systemd_units(client_dir: Path) -> int:
    unit_src = client_dir / 'systemd'
    unit_dst = Path('/etc/systemd/system')
    linked = []
    for pat in ('*.service', '*.target', '*.timer'):
        for f in unit_src.glob(pat):
            src = f.resolve()
            dst = unit_dst / f.name
            if dst.is_symlink() and dst.resolve() == src:
                continue
            r = _run(['ln', '-sf', str(src), str(dst)], sudo=True)
            if r.returncode == 0:
                linked.append(f.name)
            else:
                _err(f'could not symlink {f.name}: {r.stderr.strip()}')
    if linked:
        _run(['systemctl', 'daemon-reload'], sudo=True)
        _ok(f'systemd units: {len(linked)} symlinked')
    else:
        _ok('systemd units: all symlinks already current')
    return len(linked)


def _symlink(src: Path, dst: Path, label: str) -> bool:
    """Create or update a symlink dst → src.  Uses sudo if needed."""
    src = src.resolve()
    if dst.is_symlink() and dst.resolve() == src:
        return True   # already correct
    r = _run(['ln', '-sf', str(src), str(dst)], sudo=True)
    if r.returncode != 0:
        _err(f'could not symlink {dst}: {r.stderr.strip()}')
        return False
    _ok(f'{label}: {dst} → {src}')
    return True


def _install_smd_itself(sigmond_dir: Path, smd_bin: Path) -> bool:
    src = sigmond_dir / 'bin' / 'smd'
    if not src.exists():
        return True  # running from installed location already
    return _symlink(src, smd_bin, 'smd')


def _install_wrapper_scripts(client_dir: Path) -> None:
    sbin = Path('/usr/local/sbin')
    scripts = ['wd-ka9q-record', 'wd-kiwi-record', 'wd-kiwi-cleanup',
               'wd-spool-clean', 'wd-decode', 'wd-post',
               'wd-upload-wsprnet', 'wd-upload-wsprdaemon', 'wd-ctl']
    linked = []
    for name in scripts:
        src = client_dir / 'bin' / name
        if not src.exists():
            continue
        dst = sbin / name
        if dst.is_symlink() and dst.resolve() == src.resolve():
            continue
        r = _run(['ln', '-sf', str(src.resolve()), str(dst)], sudo=True)
        if r.returncode == 0:
            linked.append(name)
        else:
            _err(f'could not symlink {name}: {r.stderr.strip()}')
    if linked:
        _ok(f'scripts: {len(linked)} symlinked in {sbin}/')
    else:
        _ok('scripts: all symlinks already current')


def _install_wdlib(client_dir: Path) -> None:
    opt_lib = Path('/opt/wsprdaemon/lib')
    _run(['mkdir', '-p', str(opt_lib)], sudo=True)
    wdlib_src = client_dir / 'lib' / 'wdlib'
    wdlib_dst = opt_lib / 'wdlib'
    if not wdlib_src.is_dir():
        return
    if wdlib_dst.is_symlink():
        target = wdlib_dst.resolve()
        if target == wdlib_src.resolve():
            return
        _run(['rm', str(wdlib_dst)], sudo=True)
    elif wdlib_dst.exists():
        _run(['rm', '-rf', str(wdlib_dst)], sudo=True)
    _run(['ln', '-s', str(wdlib_src), str(wdlib_dst)], sudo=True)
    _ok('wdlib: symlinked into /opt/wsprdaemon/lib/')


def _run_wd_ctl_apply(client_dir: Path, dry_run: bool) -> bool:
    wd_ctl = Path('/usr/local/sbin/wd-ctl')
    if not wd_ctl.exists():
        wd_ctl = client_dir / 'bin' / 'wd-ctl'
    if not wd_ctl.exists():
        _err('wd-ctl not found — cannot generate env files and start services')
        return False
    cmd = [str(wd_ctl), 'apply']
    if dry_run:
        _info('dry-run: would run: sudo ' + ' '.join(cmd))
        return True
    _info('Running wd-ctl apply ...')
    r = _run(cmd, capture=False, sudo=True)
    return r.returncode == 0


def _ensure_sigmond_dirs() -> None:
    for d in [SIGMOND_CONF, SIGMOND_LOG]:
        _run(['mkdir', '-p', str(d)], sudo=True)


# ---------------------------------------------------------------------------
# smd install
# ---------------------------------------------------------------------------

def cmd_install(args) -> int:
    client = getattr(args, 'client', None)
    if client:
        return _install_single_client(args)
    return _install_full_suite(args)


def _install_single_client(args) -> int:
    """Catalog-driven install of a single client: smd install <client>."""
    client = args.client
    dry_run = getattr(args, 'dry_run', False)
    yes = getattr(args, 'yes', False)

    try:
        catalog = load_catalog()
    except FileNotFoundError as exc:
        _err(str(exc))
        return 1

    entry = get_entry(client, catalog)
    if entry is None:
        _err(f"unknown client '{client}' — see: smd list --available")
        return 1

    if not entry.install_script:
        _err(f"'{entry.name}' has no install_script in the catalog")
        if entry.name in ('radiod', 'ka9q-web'):
            _info(f"radiod/ka9q-web are built via ka9q-update; use: smd install  (full suite)")
        return 1

    _heading(f'install {entry.name}')
    _info(f'repo:   {entry.repo}')
    _info(f'script: {entry.install_script}')

    if dry_run:
        _info('(dry-run) would clone repo and run install.sh')
        return 0

    if _need_root('install'):
        return 1

    try:
        result = _do_install_client(entry, dry_run=dry_run, yes=yes, pull=True)
    except RuntimeError as exc:
        _err(str(exc))
        return 1

    if result:
        _ok(f'{entry.name} installed successfully')
        _info(f'next: edit /etc/{entry.name}/ config, then: smd start --components {entry.name}')
        return 0
    else:
        _err(f'{entry.name} install failed')
        return 1


def _install_full_suite(args) -> int:
    """Catalog-driven full-suite install.

    For each enabled component in the topology:
    - If the catalog entry has an install_script, install via the catalog
      (clone repo + run the client's own install.sh).
    - For C projects without install_scripts (radiod, ka9q-web), delegate
      to ka9q-update's install-ka9q.sh.
    """
    if _need_root('install'):
        return 1

    print(BANNER)
    topology = _load_topology(
        Path(args.topology) if args.topology else TOPOLOGY_PATH,
        client_dir_override=getattr(args, 'client_dir', None),
    )
    smd_bin = topology['smd_bin']

    if args.components:
        # Explicit --components list bypasses the topology enabled filter so
        # the TUI (and CLI users) can install disabled-but-not-yet-installed
        # components without first editing topology.toml.
        components = [c.strip() for c in args.components.split(',')]
    else:
        components = _enabled_components(topology, None)
        if not components:
            print('No components enabled — check topology.toml or use: smd install <name>')
            return 1

    dry_run = getattr(args, 'dry_run', False)
    yes = getattr(args, 'yes', False)

    # Load the catalog to classify each component.
    try:
        catalog = load_catalog()
    except FileNotFoundError as exc:
        _err(str(exc))
        return 1

    # Classify components into catalog-driven vs. ka9q-update.
    catalog_queue = []    # CatalogEntry objects with install_script
    ka9q_update_needed = False
    unknown = []

    for comp in components:
        entry = get_entry(comp, catalog)
        if entry is None:
            unknown.append(comp)
            continue
        if entry.install_script:
            catalog_queue.append(entry)
        elif entry.name in ('radiod', 'ka9q-web'):
            ka9q_update_needed = True
        else:
            unknown.append(comp)

    # --- Show install plan ---
    _heading('install plan')
    if ka9q_update_needed:
        c_names = [e.name for e in sorted(catalog.values(), key=lambda e: e.name)
                   if e.name in ('radiod', 'ka9q-web')
                   and e.name in [get_entry(c, catalog).name
                                  for c in components
                                  if get_entry(c, catalog) and not get_entry(c, catalog).install_script
                                  and get_entry(c, catalog).name in ('radiod', 'ka9q-web')]]
        _info(f'ka9q-update:  {", ".join(c_names) or "radiod + ka9q-web"}')
    for entry in catalog_queue:
        _info(f'catalog:      {entry.name:22s} → {entry.install_script}')
    for comp in unknown:
        _warn(f'unknown:      {comp} (not in catalog, skipping)')

    if not catalog_queue and not ka9q_update_needed:
        _warn('nothing to install')
        return 0

    if dry_run:
        print('\n(dry-run mode — no changes will be made)')
        return 0

    if not yes:
        resp = input('\nProceed? [Y/n] ').strip().lower()
        if resp and resp not in ('y', 'yes'):
            print('Aborted.')
            return 0

    _ensure_sigmond_dirs()
    errors = 0

    # --- 1. Install smd itself + TUI venv ---
    _heading('Sigmond')
    sigmond_dir = Path(__file__).resolve().parent.parent
    _install_smd_itself(sigmond_dir, smd_bin)
    if not _ensure_sigmond_venv():
        _warn('TUI venv setup failed — smd tui will not work')
        errors += 1

    # --- 2. C projects via ka9q-update ---
    if ka9q_update_needed:
        _heading('ka9q-update (radiod + ka9q-web)')
        if not _install_via_ka9q_update():
            errors += 1

    # --- 3. Catalog-driven clients ---
    for entry in catalog_queue:
        _heading(f'install {entry.name}')
        try:
            result = _do_install_client(entry, dry_run=False, yes=yes, pull=True)
            if result:
                _ok(f'{entry.name} installed')
            else:
                _err(f'{entry.name} install failed')
                errors += 1
        except RuntimeError as exc:
            _err(f'{entry.name}: {exc}')
            errors += 1

    # --- Summary ---
    print()
    if errors:
        print(f'\033[31msmd install completed with {errors} error(s).\033[0m')
        return 1
    print(f'\033[32msmd install complete.\033[0m  Run \033[1msmd status\033[0m to verify.')
    return 0


# ka9q-update paths — searched in order.
_KA9Q_UPDATE_CANDIDATES = [
    Path('/home/mjh/git/ka9q-update'),
    Path('/opt/git/ka9q-update'),
]


def _find_ka9q_update() -> Path | None:
    """Locate the ka9q-update repo."""
    for p in _KA9Q_UPDATE_CANDIDATES:
        script = p / 'install-ka9q.sh'
        if script.exists():
            return script
    return None


def _install_via_ka9q_update() -> bool:
    """Delegate radiod + ka9q-web build/install to ka9q-update."""
    script = _find_ka9q_update()
    if script is None:
        _err('ka9q-update not found — install it to /opt/git/ka9q-update')
        _info('  git clone https://github.com/mijahauan/ka9q-update /opt/git/ka9q-update')
        return False
    _info(f'running {script} ...')
    r = _run([str(script)], capture=False, sudo=True)
    if r.returncode != 0:
        _err('ka9q-update install-ka9q.sh failed')
        return False
    _ok('ka9q-update: radiod + ka9q-web installed')
    return True


