#!/usr/bin/env python3
"""smd — Sigmond system installer and lifecycle manager.

Dr. SigMonD: "Zo... ven did your signals first start to propagate?"

Usage:
    smd install    [<client>]  [--components COMP,...]  [--dry-run]  [--yes]
    smd apply      [--dry-run]
    smd start      [<component> [<instance>]]
    smd stop       [<component> [<instance>]]
    smd restart    [<component> [<instance>]]
    smd reload     [--via=auto|systemd|socket]  [<component>]
    smd list       [--json]  [--available | --all]  [<component>]
    smd log        [--files | --level LEVEL]  [<client>]
    smd status     [<component>]
    smd update
    smd diag

Topology file (default: /etc/sigmond/topology.toml) controls which
components are enabled on this host.  All commands respect the topology.

Lifecycle verbs (start/stop/restart/reload/list/status):
  Without <component>: operate on all enabled components.
  With <component>: operate on that component's instances.
  With <component> <instance>: operate on a single instance only.
"""

import argparse
import configparser
import os
import shutil
import subprocess
import sys
import textwrap
import time
from pathlib import Path

# Bootstrap: add sibling lib/ to sys.path so `import sigmond` works when
# running from the repo, from /usr/local/sbin/smd, or from a symlink.
_SCRIPT = Path(__file__).resolve()
for _candidate in (_SCRIPT.parent.parent / 'lib',        # repo layout
                   Path('/opt/sigmond/lib'),             # installed layout
                   Path('/usr/local/lib/sigmond')):      # alt installed
    if (_candidate / 'sigmond' / '__init__.py').exists():
        sys.path.insert(0, str(_candidate))
        break

try:
    from sigmond.commands.validate import cmd_validate
    from sigmond.commands.config   import cmd_config_show, cmd_config_migrate
    from sigmond.lifecycle         import resolve_units, UnitRef, lifecycle_lock, order_units
    from sigmond.coordination      import load_coordination
    from sigmond.catalog           import load_catalog, CatalogEntry, get_entry, resolve_name, find_client_binary
    from sigmond.installer         import install_client as _do_install_client
    from sigmond.paths             import SIGMOND_VENV
    from sigmond.log_cmd           import (
        follow_journal, follow_files, flatten_log_paths,
        get_inventory_log_paths, set_log_level, send_sighup,
        client_env_key,
    )
    from sigmond.cpu import (
        cpu_list_str      as _cpu_list_str,
        parse_cpu_mask    as _parse_cpu_mask,
        get_physical_cores as _get_physical_cores,
        get_radiod_instances as _get_radiod_instances,
        get_radiod_cpus   as _get_radiod_cpus,
        compute_affinity_plan as _compute_affinity_plan,
        read_proc_cpus    as _read_proc_cpus,
        thread_affinity_groups as _thread_affinity_groups,
        render_drop_in    as _render_drop_in,
        SMD_AFFINITY_DROP_IN as _SMD_AFFINITY_DROP_IN,
        FOREIGN_AFFINITY_DROP_INS as _FOREIGN_AFFINITY_DROP_INS,
        HFTIMESTD_AFFINITY_UNITS as _HFTIMESTD_AFFINITY_UNITS,
        AFFINITY_UNITS as _AFFINITY_UNITS,
    )
    _HAS_SIGMOND_LIB = True
except ImportError:
    _HAS_SIGMOND_LIB = False

# ---------------------------------------------------------------------------
