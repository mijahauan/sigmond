def _load_deps_conf(client_dir: Path) -> configparser.ConfigParser:
    candidates = [client_dir / 'deps.conf', Path('/opt/git/sigmond/wsprdaemon-client/deps.conf')]
    for deps_file in candidates:
        if deps_file.exists():
            cfg = configparser.ConfigParser()
            cfg.read(deps_file)
            return cfg
    _err(f'deps.conf not found at {candidates[0]}')
    return None


def _ensure_venv(venv_dir: Path) -> bool:
    if venv_dir.exists():
        return True
    _info(f'Creating Python venv at {venv_dir} ...')
    r = _run([sys.executable, '-m', 'venv', str(venv_dir)])
    if r.returncode != 0:
        _err(f'venv creation failed: {r.stderr.strip()}')
        return False
    return True


def _install_git_dep(section: str, dcfg: configparser.ConfigParser) -> bool:
    url        = dcfg.get(section, 'url', fallback='').strip()
    pinned     = dcfg.get(section, 'commit', fallback='').strip()
    install_to = dcfg.get(section, 'install_to', fallback='').strip()
    use_latest = pinned.lower() == 'latest'

    if not url or not install_to:
        _err(f'[{section}] missing url or install_to in deps.conf')
        return False

    target = Path(install_to)

    if not target.exists():
        _info(f'Cloning {section} → {target} ...')
        r = _run(['git', 'clone', url, str(target)])
        if r.returncode != 0:
            _err(f'git clone {section} failed: {r.stderr.strip()}')
            return False
        if not use_latest and pinned:
            _run(['git', '-C', str(target), 'checkout', pinned])
    elif use_latest:
        _info(f'Pulling {section} to latest ...')
        _run(['git', '-C', str(target), 'pull'])
    else:
        # Repo exists and a specific commit is pinned — fetch and checkout if needed.
        r = _run(['git', '-c', f'safe.directory={target}',
                  '-C', str(target), 'rev-parse', 'HEAD'])
        current = r.stdout.strip()
        if pinned and current and not current.startswith(pinned[:12]):
            _info(f'{section}: at {current[:12]}, fetching pinned {pinned[:12]} ...')
            _run(['git', '-C', str(target), 'fetch', '--tags', 'origin'])
            r2 = _run(['git', '-C', str(target), 'checkout', pinned])
            if r2.returncode != 0:
                _err(f'{section}: checkout {pinned[:12]} failed: {r2.stderr.strip()}')
                return False

    r = _run(['git', '-c', f'safe.directory={target}',
              '-C', str(target), 'rev-parse', 'HEAD'])
    current = r.stdout.strip()
    if use_latest:
        _ok(f'{section}: {current[:12]} (latest)')
    elif pinned and current and not current.startswith(pinned[:12]):
        _warn(f'{section}: at {current[:12]}, want {pinned[:12]} — checkout failed?')
    else:
        _ok(f'{section}: {current[:12]}')

    return True


def _install_pypi_dep(section: str, dcfg: configparser.ConfigParser,
                      venv_dir: Path) -> bool:
    url    = dcfg.get(section, 'url', fallback='').strip()
    commit = dcfg.get(section, 'commit', fallback='').strip()
    use_latest = commit.lower() == 'latest'

    pip = str(venv_dir / 'bin' / 'pip')
    is_git = url.startswith('git+')
    pkg_name = url.rstrip('/').split('/')[-1].replace('.git', '') if is_git else url

    if use_latest:
        _info(f'Upgrading {section} ({pkg_name}) to latest ...')
        r = _run([pip, 'install', '--upgrade', url])
        if r.returncode != 0:
            _err(f'{section} upgrade failed: {r.stderr.strip()[-400:]}')
            return False
        ver_r = _run([pip, 'show', pkg_name])
        installed_ver = next(
            (l.split(':', 1)[1].strip() for l in ver_r.stdout.splitlines()
             if l.startswith('Version:')), 'unknown')
        _ok(f'{section}: {installed_ver} (latest)')
        return True

    r = _run([pip, 'show', pkg_name])
    if r.returncode == 0:
        installed_ver = next(
            (l.split(':', 1)[1].strip() for l in r.stdout.splitlines()
             if l.startswith('Version:')), 'unknown')
        if installed_ver == commit or (is_git and commit[:8] in r.stdout):
            _ok(f'{section}: {installed_ver}')
            return True
        _warn(f'{section}: have {installed_ver}, want {commit[:12]}')

    spec = f'{url}@{commit}' if is_git else f'{url}=={commit}'
    _info(f'Installing {section} ({spec}) ...')
    r = _run([pip, 'install', spec])
    if r.returncode != 0:
        _err(f'{section} install failed: {r.stderr.strip()[-400:]}')
        return False
    _ok(f'{section}: installed')
    return True


def _build_ka9q_radio(src_dir: Path, force: bool = False) -> bool:
    binary = Path('/usr/local/sbin/radiod')
    built = src_dir / 'src' / 'radiod'
    if not force and binary.exists() and built.exists():
        import hashlib
        def _sha(p):
            return hashlib.sha256(p.read_bytes()).hexdigest()
        if _sha(binary) == _sha(built):
            _ok('ka9q-radio: already installed and current  (use --force to rebuild)')
            return True

    # Disable Fobos and HydraSDR front-ends by default: their userspace
    # libs (libfobos, libhydrasdr) aren't in Debian/Ubuntu apt, so the
    # default build fails on `fobos.h: No such file or directory`.
    # Operators with those rigs should build the libs from source first,
    # then rebuild ka9q-radio manually with these flags omitted.
    build_flags = ['ENABLE_FOBOS=0', 'ENABLE_HYDRASDR=0']

    if force:
        _info('--force: running `make clean` before rebuild')
        _run(['make', 'clean'], cwd=str(src_dir), capture=False)

    nproc = str(os.cpu_count() or 2)
    _info(f'Building ka9q-radio (make -j{nproc} {" ".join(build_flags)}) ...')
    r = _run(['make', f'-j{nproc}', *build_flags],
             cwd=str(src_dir), capture=False)
    if r is None or (hasattr(r, 'returncode') and r.returncode != 0):
        _err('ka9q-radio build failed')
        return False
    r = _run(['make', 'install', *build_flags], cwd=str(src_dir), sudo=True)
    if r.returncode != 0:
        _err(f'ka9q-radio install failed: {r.stderr.strip()}')
        return False
    _ok('ka9q-radio: built and installed')
    return True


def _build_onion(src_dir: Path) -> bool:
    if Path('/usr/local/lib/libonion.so').exists():
        _ok('onion: already installed')
        return True
    build_dir = src_dir / 'build'
    build_dir.mkdir(exist_ok=True)
    _info('Configuring onion ...')
    r = _run(['cmake', '..', '-DCMAKE_INSTALL_PREFIX=/usr/local',
              '-DHAVE_SQLITE3=OFF', '-DHAVE_REDIS=OFF', '-DHAVE_HIREDIS=OFF',
              '-DHAVE_JPEG=OFF', '-DHAVE_PAM=OFF', '-DHAVE_SYSTEMD=OFF',
              '-DHAVE_XML2=OFF', '-DONION_USE_SSL=ON'],
             cwd=str(build_dir))
    if r.returncode != 0:
        _err(f'onion cmake failed: {r.stderr.strip()}')
        return False
    nproc = str(os.cpu_count() or 2)
    _info(f'Building onion (make -j{nproc}) ...')
    r = _run(['make', f'-j{nproc}'], cwd=str(build_dir))
    if r.returncode != 0:
        _err(f'onion build failed: {r.stderr[-400:]}')
        return False
    r = _run(['make', 'install'], cwd=str(build_dir), sudo=True)
    if r.returncode != 0:
        _err(f'onion install failed: {r.stderr.strip()}')
        return False
    _run(['ldconfig'], sudo=True)
    _ok('onion: built and installed')
    return True


def _build_ka9q_web_with_onion(src_dir: Path) -> bool:
    # onion is a build-time dependency of ka9q-web
    dcfg = configparser.ConfigParser()
    deps_conf = src_dir.parent / 'wsprdaemon-client' / 'deps.conf'
    if deps_conf.exists():
        dcfg.read(deps_conf)
    onion_url    = dcfg.get('ka9q-web', 'onion_url', fallback='https://github.com/davidmoreno/onion.git')
    onion_commit = dcfg.get('ka9q-web', 'onion_commit', fallback='')
    onion_src    = Path(dcfg.get('ka9q-web', 'onion_src', fallback='/home/wsprdaemon/onion'))

    if not onion_src.exists():
        _info(f'Cloning onion → {onion_src} ...')
        r = _run(['git', 'clone', onion_url, str(onion_src)])
        if r.returncode != 0:
            _err(f'git clone onion failed: {r.stderr.strip()}')
            return False
        if onion_commit:
            _run(['git', '-C', str(onion_src), 'checkout', onion_commit])

    if not _build_onion(onion_src):
        return False

    binary = Path('/usr/local/sbin/ka9q-web')
    built  = src_dir / 'ka9q-web'
    if binary.exists() and built.exists():
        import hashlib
        def _sha(p): return hashlib.sha256(p.read_bytes()).hexdigest()
        if _sha(binary) == _sha(built):
            _ok('ka9q-web: already installed and current')
            return True

    nproc = str(os.cpu_count() or 2)
    _info(f'Building ka9q-web (make -j{nproc}) ...')
    r = _run(['make', f'-j{nproc}'], cwd=str(src_dir))
    if r.returncode != 0:
        _err(f'ka9q-web build failed: {r.stderr[-400:]}')
        return False
    r = _run(['make', 'install'], cwd=str(src_dir), sudo=True)
    if r.returncode != 0:
        _err(f'ka9q-web install failed: {r.stderr.strip()}')
        return False
    _ok('ka9q-web: built and installed')
    return True


def _collect_deps_for_components(components: list) -> list:
    """Return deduplicated ordered list of dep section names needed."""
    seen = set()
    result = []
    for comp in components:
        for dep in COMPONENT_DEPS.get(comp, []):
            if dep not in seen:
                seen.add(dep)
                result.append(dep)
    return result


# ---------------------------------------------------------------------------
# WD-RAC (frpc) install + config
# ---------------------------------------------------------------------------

_FRPC_VERSION   = '0.64.0'
_FRPS_URL       = 'gw2.wsprdaemon.org'
_FRPS_URL_HAMSCI = 'vpn.hamsci.org'
_FRPS_PORT      = 35736                              # secure frps port (35735 = open/legacy)
_FRPC_TOKEN     = 'e6fe04d781252e10b89b1ec490e005df' # shared token for frps-secure
_RAC_PORT_BASE  = 35800
_RAC_WEB_OFFSET = 10000
_FRPC_BIN       = Path('/usr/local/sbin/frpc')
_FRPC_INI       = Path('/etc/sigmond/frpc.ini')      # legacy — kept for migration removal
_FRPC_CONFIG    = Path('/etc/sigmond/frpc.toml')     # current config (TOML, TLS + token auth)
_FRPC_KEY       = Path('/etc/sigmond/frpc_id_rsa')   # dedicated keypair for this station
_FRPS_CA_CERT   = Path('/etc/sigmond/frps-ca.crt')  # gateway self-signed cert
_RAC_SERVICE    = 'wd-rac'


def _frpc_arch_suffix() -> str:
    import platform
    machine = platform.machine()
    if machine == 'x86_64':
        return 'linux_amd64'
    if machine in ('armv7l', 'armv6l'):
        return 'linux_arm'
    if machine == 'aarch64':
        return 'linux_arm64'
    raise RuntimeError(f'frpc: unsupported architecture {machine}')


def _install_frpc(dry_run: bool = False) -> bool:
    """Download the frpc binary if not present or version is wrong."""
    if _FRPC_BIN.exists():
        r = _run([str(_FRPC_BIN), '--version'])
        if r.returncode == 0 and _FRPC_VERSION in r.stdout:
            _ok(f'frpc: {_FRPC_VERSION} already installed')
            return True
        _info(f'frpc: version mismatch, reinstalling {_FRPC_VERSION}')

    try:
        arch = _frpc_arch_suffix()
    except RuntimeError as exc:
        _err(str(exc))
        return False

    import urllib.request, tarfile, tempfile
    tarname = f'frp_{_FRPC_VERSION}_{arch}.tar.gz'
    url = f'https://github.com/fatedier/frp/releases/download/v{_FRPC_VERSION}/{tarname}'

    if dry_run:
        _info(f'dry-run: would download {url} → {_FRPC_BIN}')
        return True

    _info(f'Downloading frpc {_FRPC_VERSION} ({arch}) ...')
    with tempfile.TemporaryDirectory() as tmp:
        tar_path = Path(tmp) / tarname
        try:
            urllib.request.urlretrieve(url, str(tar_path))
        except Exception as exc:
            _err(f'frpc download failed: {exc}')
            return False
        with tarfile.open(str(tar_path)) as tf:
            # The binary is at frp_VERSION_ARCH/frpc inside the archive
            member = next((m for m in tf.getmembers() if m.name.endswith('/frpc')), None)
            if member is None:
                _err('frpc not found in downloaded archive')
                return False
            member.name = 'frpc'
            tf.extract(member, path=tmp)
        frpc_extracted = Path(tmp) / 'frpc'
        r = _run(['install', '-m', '755', str(frpc_extracted), str(_FRPC_BIN)], sudo=True)
        if r.returncode != 0:
            _err(f'frpc install failed: {r.stderr.strip()}')
            return False

    _ok(f'frpc: {_FRPC_VERSION} installed to {_FRPC_BIN}')
    return True


def _read_rac_topology(topology: dict) -> tuple[str, int]:
    """Return (rac_id, rac_number) from topology, or ('', -1) if not configured."""
    comp = topology.get('components', {}).get('wd-rac', {})
    rac_id     = comp.get('rac_id', '').strip()
    rac_number = comp.get('rac_number', -1)
    try:
        rac_number = int(rac_number)
    except (TypeError, ValueError):
        rac_number = -1
    return rac_id, rac_number


def _detect_rac_defaults() -> tuple[str, int]:
    """Try to detect RAC ID and number from the wsprdaemon v4 config.

    Returns (rac_id, rac_number) where either can be empty/''-1 if undetectable.

    Reads /etc/wsprdaemon/wsprdaemon.conf (INI format):
      [general]  rac = <number>
      [receiver:NAME]  call = <reporter-id>   ← first one becomes default rac_id
    """
    import configparser as _cp
    wdconf = Path('/etc/wsprdaemon/wsprdaemon.conf')
    if not wdconf.exists():
        return '', -1

    cfg = _cp.ConfigParser(
        comment_prefixes=(';', '#'),
        inline_comment_prefixes=(';', '#'),
        strict=False,
        interpolation=None,
    )
    try:
        cfg.read(wdconf)
    except Exception:
        return '', -1

    # rac_number from [general] rac =
    rac_number = -1
    if cfg.has_section('general'):
        try:
            rac_number = int(cfg.get('general', 'rac', fallback='').strip())
        except (ValueError, TypeError):
            pass

    # rac_id from first [receiver:NAME] call =
    rac_id = ''
    for section in cfg.sections():
        parts = section.split(':')
        if parts[0] == 'receiver' and len(parts) == 2:
            call = cfg.get(section, 'call', fallback='').strip()
            if call:
                rac_id = call
                break

    return rac_id, rac_number


_WD_USER    = 'wsprdaemon'
_WD_SSH_DIR = Path(f'/home/{_WD_USER}/.ssh')


def _find_wd_pubkey() -> Path | None:
    """Return the wsprdaemon user's SSH public key path, or None."""
    for name in ('id_ed25519', 'id_rsa', 'id_ecdsa'):
        p = _WD_SSH_DIR / f'{name}.pub'
        if p.exists():
            return p
    return None


def _ensure_frpc_keypair(dry_run: bool = False) -> bool:
    """Ensure there is an SSH public key for frpc authentication.

    Preference order:
      1. /home/wsprdaemon/.ssh/id_*.pub — already registered on the gateway
         via wd-upload-wsprdaemon uploads (no admin action needed).
      2. /etc/sigmond/frpc_id_rsa.pub   — fallback: generate a dedicated key
         and display it so the operator can register it manually.
    """
    pub = _find_wd_pubkey()
    if pub:
        _ok(f'frpc identity: using {_WD_USER} SSH key  →  {pub}')
        _info('  (auto-registered on gateway via wsprdaemon uploads)')
        return True

    # Fall back to dedicated key.
    fallback_pub = Path(str(_FRPC_KEY) + '.pub')
    if _FRPC_KEY.exists() and fallback_pub.exists():
        _ok(f'frpc identity: using dedicated key  →  {_FRPC_KEY}')
        return True
    if dry_run:
        _info(f'dry-run: would generate SSH keypair at {_FRPC_KEY}')
        return True

    import tempfile as _tf2, socket as _sock
    with _tf2.TemporaryDirectory() as td:
        tmp = Path(td) / 'frpc_id_rsa'
        r = subprocess.run(
            ['ssh-keygen', '-t', 'ed25519', '-N', '',
             '-C', f'wd-rac@{_sock.gethostname()}', '-f', str(tmp)],
            capture_output=True, text=True,
        )
        if r.returncode != 0:
            _err(f'ssh-keygen failed: {r.stderr.strip()}')
            return False
        _run(['mkdir', '-p', str(_FRPC_KEY.parent)], sudo=True)
        _run(['install', '-m', '600', str(tmp),          str(_FRPC_KEY)],          sudo=True)
        _run(['install', '-m', '644', str(tmp) + '.pub', str(_FRPC_KEY) + '.pub'], sudo=True)
    pub_txt = fallback_pub.read_text().strip() if fallback_pub.exists() else '(unreadable)'
    _ok(f'frpc identity: generated dedicated key  →  {_FRPC_KEY}')
    _warn('wsprdaemon SSH key not found — gateway registration is not automatic.')
    _warn('Send this public key to the RAC administrator to register the station:')
    _info(f'  {pub_txt}')
    return True


def _frpc_user_field() -> str:
    """Return the 16-char sha256 prefix used as the frpc user identity.

    Uses the wsprdaemon user's key if available (auto-registered via uploads),
    otherwise the dedicated /etc/sigmond/frpc_id_rsa.pub.
    Matches: sha256sum <pubkey_file> | cut -c1-16
    """
    import hashlib
    pub = _find_wd_pubkey() or Path(str(_FRPC_KEY) + '.pub')
    if not pub.exists():
        return ''
    return hashlib.sha256(pub.read_bytes()).hexdigest()[:16]


def _bootstrap_rac_registration(rac_id: str, dry_run: bool = False) -> bool:
    """Upload a spots-free .tbz to the gateway FTP so the server auto-provisions
    the station's SFTP/frpc account before any spots have been sent.

    The tar contains only:
      wsprdaemon/uploads_config.txt       — version metadata
      wsprdaemon/client_upload_info.txt   — reporter_id + ssh_public_key

    The server (wsprdaemon_server.py) processes this, creates a Linux user for
    the reporter, and adds the public key to authorized_keys — making the frps
    auth plugin accept the frpc connection on the next attempt.

    FTP is used here because SFTP requires the account to already exist.
    FTP accepts anonymous uploads (noisegraphs:xahFie6g) on gw2 only.
    """
    import ftplib, io, tarfile, time as _time

    pub_path = _find_wd_pubkey() or Path(str(_FRPC_KEY) + '.pub')
    if not pub_path.exists():
        _warn('bootstrap: no SSH public key found — skipping FTP registration')
        return False

    pubkey   = pub_path.read_text().strip()
    upload_id = rac_id.replace('/', '_')
    ts        = _time.strftime('%y%m%d_%H%M_%S', _time.gmtime())
    tar_name  = f'{upload_id}_{ts}.tbz'

    config_txt = (
        'CLIENT_VERSION=4.0\n'
        'UPLOADS_WSPRNET_LINE_FORMAT_VERSION=1\n'
        'UPLOADS_WSPRDAEMON_SPOT_LINE_FORMAT_VERSION=3\n'
        'SIGNAL_LEVEL_UPLOAD=yes\n'
    ).encode()
    info_txt = f'reporter_id={rac_id}\nssh_public_key={pubkey}\n'.encode()

    # Build the tar in memory.
    buf = io.BytesIO()
    with tarfile.open(fileobj=buf, mode='w:bz2') as tf:
        for arcname, data in [
            ('wsprdaemon/uploads_config.txt',    config_txt),
            ('wsprdaemon/client_upload_info.txt', info_txt),
        ]:
            ti = tarfile.TarInfo(name=arcname)
            ti.size = len(data)
            ti.mtime = int(_time.time())
            tf.addfile(ti, io.BytesIO(data))
    tbz_bytes = buf.getvalue()

    _info(f'bootstrap: uploading registration tar {tar_name} ({len(tbz_bytes)} B) ...')

    if dry_run:
        _info(f'dry-run: would FTP {tar_name} to gw2.wsprdaemon.org/upload/')
        return True

    ftp_server  = 'gw2.wsprdaemon.org'
    ftp_user    = 'noisegraphs'
    ftp_passwd  = 'xahFie6g'
    ftp_path    = 'upload'
    try:
        with ftplib.FTP(timeout=30) as ftp:
            ftp.connect(ftp_server)
            ftp.login(user=ftp_user, passwd=ftp_passwd)
            ftp.set_pasv(True)
            ftp.storbinary(f'STOR {ftp_path}/{tar_name}', io.BytesIO(tbz_bytes))
        _ok(f'bootstrap: registration uploaded  →  {ftp_server}/upload/{tar_name}')
        _info('  Server will create the gateway account and authorize the SSH key.')
        _info('  The frpc tunnel will connect on its next retry (≤30 s).')
        return True
    except Exception as exc:
        _warn(f'bootstrap: FTP upload failed: {exc}')
        _warn('  Tunnel will retry — registration will complete after the first spot upload.')
        return False   # non-fatal: frpc retries; registration completes via spot upload


def _fetch_frps_ca_cert(dry_run: bool = False) -> bool:
    """Fetch the frps server's TLS cert and save to _FRPS_CA_CERT."""
    if _FRPS_CA_CERT.exists():
        _ok(f'frps CA cert: {_FRPS_CA_CERT}')
        return True
    if dry_run:
        _info(f'dry-run: would fetch TLS cert from {_FRPS_URL}:{_FRPS_PORT}')
        return True
    import ssl as _ssl, socket as _sock2
    try:
        ctx = _ssl.SSLContext(_ssl.PROTOCOL_TLS_CLIENT)
        ctx.check_hostname = False
        ctx.verify_mode = _ssl.CERT_NONE
        with _sock2.create_connection((_FRPS_URL, _FRPS_PORT), timeout=10) as raw:
            with ctx.wrap_socket(raw) as s:
                der = s.getpeercert(binary_form=True)
        pem = _ssl.DER_cert_to_PEM_cert(der)
    except Exception as exc:
        _err(f'failed to fetch frps CA cert from {_FRPS_URL}:{_FRPS_PORT}: {exc}')
        return False
    import tempfile as _tf3
    with _tf3.NamedTemporaryFile('w', suffix='.crt', delete=False) as tf:
        tf.write(pem)
        tf_path = tf.name
    _run(['mkdir', '-p', str(_FRPS_CA_CERT.parent)], sudo=True)
    r = _run(['install', '-m', '644', tf_path, str(_FRPS_CA_CERT)], sudo=True)
    Path(tf_path).unlink(missing_ok=True)
    if r.returncode != 0:
        _err(f'failed to save CA cert: {r.stderr.strip()}')
        return False
    _ok(f'frps CA cert: fetched and saved  →  {_FRPS_CA_CERT}')
    return True


def _write_frpc_config(rac_id: str, rac_number: int, dry_run: bool = False) -> bool:
    """Write /etc/sigmond/frpc.toml with TLS + token auth for the secure frps port."""
    if not rac_id:
        _err('wd-rac: rac_id is empty')
        return False
    if rac_number < 0:
        _err('wd-rac: rac_number not set')
        return False

    frps_host = _FRPS_URL_HAMSCI if 200 <= rac_number <= 299 else _FRPS_URL
    ssh_port  = _RAC_PORT_BASE + rac_number
    web_port  = ssh_port + _RAC_WEB_OFFSET
    user_field = _frpc_user_field()

    local_ssh_port = 22
    try:
        for line in Path('/etc/ssh/sshd_config').read_text().splitlines():
            if line.startswith('Port '):
                local_ssh_port = int(line.split()[1])
    except Exception:
        pass

    lines = [
        f'serverAddr = "{frps_host}"',
        f'serverPort = {_FRPS_PORT}',
    ]
    if user_field:
        lines.append(f'user = "{user_field}"')
    lines += [
        '',
        '[auth]',
        'method = "token"',
        f'token = "{_FRPC_TOKEN}"',
        '',
        '[transport.tls]',
        'enable = true',
        f'trustedCaFile = "{_FRPS_CA_CERT}"',
        '',
        '[webServer]',
        'addr = "127.0.0.1"',
        'port = 7500',
        '',
        '[[proxies]]',
        f'name = "{rac_id}"',
        'type = "tcp"',
        'localIP = "127.0.0.1"',
        f'localPort = {local_ssh_port}',
        f'remotePort = {ssh_port}',
        '',
        '[[proxies]]',
        f'name = "{rac_id}-WEB"',
        'type = "tcp"',
        'localIP = "127.0.0.1"',
        'localPort = 8081',
        f'remotePort = {web_port}',
    ]
    content = '\n'.join(lines) + '\n'

    if dry_run:
        _info(f'dry-run: would write {_FRPC_CONFIG}:\n{textwrap.indent(content, "     ")}')
        return True

    _run(['mkdir', '-p', str(_FRPC_CONFIG.parent)], sudo=True)
    import tempfile as _tf4
    with _tf4.NamedTemporaryFile('w', suffix='.toml', delete=False) as tf:
        tf.write(content)
        tf_path = tf.name
    r = _run(['install', '-m', '640', tf_path, str(_FRPC_CONFIG)], sudo=True)
    Path(tf_path).unlink(missing_ok=True)
    if r.returncode != 0:
        _err(f'frpc.toml write failed: {r.stderr.strip()}')
        return False
    _ok(f'frpc.toml: written ({rac_id}, channel {rac_number}, port {ssh_port})')
    return True


def _write_frpc_ini(rac_id: str, rac_number: int, dry_run: bool = False) -> bool:
    """Write /etc/sigmond/frpc.ini for the given RAC ID and number."""
    if not rac_id:
        _err('wd-rac: rac_id is empty — set it in topology.toml [component.wd-rac]')
        return False
    if rac_number < 0:
        _err('wd-rac: rac_number not set — obtain it from the RAC administrator')
        return False

    frps_host = _FRPS_URL_HAMSCI if 200 <= rac_number <= 299 else _FRPS_URL
    ssh_port  = _RAC_PORT_BASE + rac_number
    web_port  = ssh_port + _RAC_WEB_OFFSET

    # Detect non-standard sshd port
    local_ssh_port = 22
    try:
        sshd_cfg = Path('/etc/ssh/sshd_config').read_text()
        for line in sshd_cfg.splitlines():
            if line.startswith('Port '):
                local_ssh_port = int(line.split()[1])
    except Exception:
        pass

    ini_content = f"""\
[common]
admin_addr = 127.0.0.1
admin_port = 7500
server_addr = {frps_host}
server_port = {_FRPS_PORT}

[{rac_id}]
type = tcp
local_ip = 127.0.0.1
local_port = {local_ssh_port}
remote_port = {ssh_port}

[{rac_id}-WEB]
type = tcp
local_ip = 127.0.0.1
local_port = 8081
remote_port = {web_port}
"""
    if dry_run:
        _info(f'dry-run: would write {_FRPC_INI}:\n{textwrap.indent(ini_content, "     ")}')
        return True

    _run(['mkdir', '-p', str(_FRPC_INI.parent)], sudo=True)
    import tempfile, shutil as _shutil
    with tempfile.NamedTemporaryFile('w', suffix='.ini', delete=False) as tf:
        tf.write(ini_content)
        tf_path = tf.name
    r = _run(['install', '-m', '640', tf_path, str(_FRPC_INI)], sudo=True)
    Path(tf_path).unlink(missing_ok=True)
    if r.returncode != 0:
        _err(f'frpc.ini write failed: {r.stderr.strip()}')
        return False
    _ok(f'frpc.ini: written ({rac_id}, channel {rac_number}, port {ssh_port})')
    return True


def _install_rac_service(dry_run: bool = False) -> bool:
    """Write and enable the wd-rac systemd service."""
    unit_path = Path('/etc/systemd/system/wd-rac.service')
    unit_content = f"""\
[Unit]
Description=WsprDaemon Remote Access Channel (frpc tunnel)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart={_FRPC_BIN} -c {_FRPC_CONFIG}
Restart=always
RestartSec=30s
TimeoutStartSec=30

[Install]
WantedBy=multi-user.target
"""
    if dry_run:
        _info(f'dry-run: would write {unit_path} and enable wd-rac.service')
        return True

    import tempfile
    with tempfile.NamedTemporaryFile('w', suffix='.service', delete=False) as tf:
        tf.write(unit_content)
        tf_path = tf.name
    r = _run(['install', '-m', '644', tf_path, str(unit_path)], sudo=True)
    Path(tf_path).unlink(missing_ok=True)
    if r.returncode != 0:
        _err(f'wd-rac.service write failed: {r.stderr.strip()}')
        return False
    # Remove legacy frpc.ini now that we use frpc.toml.
    if _FRPC_INI.exists():
        _run(['rm', '-f', str(_FRPC_INI)], sudo=True)
    _run(['systemctl', 'daemon-reload'], sudo=True)
    _run(['systemctl', 'enable', 'wd-rac.service'], sudo=True)
    _run(['systemctl', 'restart', 'wd-rac.service'], sudo=True)
    _ok('wd-rac.service: installed and enabled')
    return True


def _install_wd_rac(topology: dict, dry_run: bool = False, yes: bool = False) -> bool:
    """Full wd-rac install: frpc binary + frpc.ini + systemd service."""
    rac_id, rac_number = _read_rac_topology(topology)

    # Fall back to wsprdaemon.conf auto-detection when not explicitly configured.
    if not rac_id or rac_number < 0:
        detected_id, detected_num = _detect_rac_defaults()
        if not rac_id and detected_id:
            rac_id = detected_id
            _info(f'wd-rac: rac_id auto-detected from wsprdaemon.conf: {rac_id}')
        if rac_number < 0 and detected_num >= 0:
            rac_number = detected_num
            _info(f'wd-rac: rac_number auto-detected from wsprdaemon.conf: {rac_number}')

    # Interactive prompt when still missing and running in a real terminal.
    if (not rac_id or rac_number < 0) and not yes and sys.stdin.isatty():
        import readline  # noqa: F401 — enables line editing on input()
        print()
        print('  wd-rac needs two values from the RAC administrator:')
        if not rac_id:
            try:
                val = input('  RAC ID   (e.g. AI6VN-0, leave blank to skip): ').strip()
                if val:
                    rac_id = val
            except (EOFError, KeyboardInterrupt):
                pass
        if rac_number < 0:
            try:
                val = input('  RAC number (integer from admin email, leave blank to skip): ').strip()
                if val:
                    rac_number = int(val)
            except (EOFError, KeyboardInterrupt, ValueError):
                pass

    if not rac_id or rac_number < 0:
        _warn('wd-rac: rac_id or rac_number not set — tunnel will not be started')
        _warn('  To configure: run  smd tui  and press  a  (RAC screen)')
        _warn('  Or:           sudo smd install --components wd-rac  (prompts interactively)')

    ok = True
    ok = _install_frpc(dry_run) and ok
    ok = _ensure_frpc_keypair(dry_run) and ok
    ok = _fetch_frps_ca_cert(dry_run) and ok
    if rac_id:
        _bootstrap_rac_registration(rac_id, dry_run)   # non-fatal; ignore return value
    if rac_id and rac_number >= 0:
        ok = _write_frpc_config(rac_id, rac_number, dry_run) and ok
        ok = _install_rac_service(dry_run) and ok
    return ok


def rac_status() -> dict:
    """Return a dict with frpc connection status for display/TUI."""
    result = {
        'frpc_installed': _FRPC_BIN.exists(),
        'frpc_version':   '',
        'config_exists':  _FRPC_CONFIG.exists(),
        'service_active': False,
        'tunnel_ok':      False,
        'rac_id':         '',
        'rac_number':     -1,
        'ssh_port':       -1,
    }
    if result['frpc_installed']:
        r = _run([str(_FRPC_BIN), '--version'])
        if r.returncode == 0:
            result['frpc_version'] = r.stdout.strip().split()[-1]

    if result['config_exists']:
        try:
            import tomllib
            with open(_FRPC_CONFIG, 'rb') as f:
                cfg = tomllib.load(f)
            for proxy in cfg.get('proxies', []):
                if not proxy.get('name', '').endswith('-WEB'):
                    result['rac_id']    = proxy.get('name', '')
                    rp = proxy.get('remotePort', -1)
                    result['ssh_port']   = rp
                    result['rac_number'] = rp - _RAC_PORT_BASE if rp > 0 else -1
                    break
        except Exception:
            pass

    r = _run(['systemctl', 'is-active', 'wd-rac.service'])
    result['service_active'] = (r.returncode == 0 and r.stdout.strip() == 'active')

    if result['service_active']:
        import socket
        try:
            with socket.create_connection((_FRPS_URL, _FRPS_PORT), timeout=3):
                result['tunnel_ok'] = True
        except OSError:
            result['tunnel_ok'] = False

    return result


# ---------------------------------------------------------------------------
# System-level install steps
# ---------------------------------------------------------------------------

def _install_systemd_units(client_dir: Path) -> int:
    unit_src = client_dir / 'systemd'
    unit_dst = Path('/etc/systemd/system')
    linked = []
    for pat in ('*.service', '*.target', '*.timer'):
        for f in unit_src.glob(pat):
            src = f.resolve()
            dst = unit_dst / f.name
            if dst.is_symlink() and dst.resolve() == src:
                continue
            r = _run(['ln', '-sf', str(src), str(dst)], sudo=True)
            if r.returncode == 0:
                linked.append(f.name)
            else:
                _err(f'could not symlink {f.name}: {r.stderr.strip()}')
    if linked:
        _run(['systemctl', 'daemon-reload'], sudo=True)
        _ok(f'systemd units: {len(linked)} symlinked')
    else:
        _ok('systemd units: all symlinks already current')
    return len(linked)


def _symlink(src: Path, dst: Path, label: str) -> bool:
    """Create or update a symlink dst → src.  Uses sudo if needed."""
    src = src.resolve()
    if dst.is_symlink() and dst.resolve() == src:
        return True   # already correct
    r = _run(['ln', '-sf', str(src), str(dst)], sudo=True)
    if r.returncode != 0:
        _err(f'could not symlink {dst}: {r.stderr.strip()}')
        return False
    _ok(f'{label}: {dst} → {src}')
    return True


def _install_smd_itself(sigmond_dir: Path, smd_bin: Path) -> bool:
    src = sigmond_dir / 'bin' / 'smd'
    if not src.exists():
        return True  # running from installed location already
    return _symlink(src, smd_bin, 'smd')


def _install_wrapper_scripts(client_dir: Path) -> None:
    sbin = Path('/usr/local/sbin')
    scripts = ['wd-ka9q-record', 'wd-kiwi-record', 'wd-kiwi-cleanup',
               'wd-spool-clean', 'wd-decode', 'wd-post',
               'wd-upload-wsprnet', 'wd-upload-wsprdaemon', 'wd-ctl']
    linked = []
    for name in scripts:
        src = client_dir / 'bin' / name
        if not src.exists():
            continue
        dst = sbin / name
        if dst.is_symlink() and dst.resolve() == src.resolve():
            continue
        r = _run(['ln', '-sf', str(src.resolve()), str(dst)], sudo=True)
        if r.returncode == 0:
            linked.append(name)
        else:
            _err(f'could not symlink {name}: {r.stderr.strip()}')
    if linked:
        _ok(f'scripts: {len(linked)} symlinked in {sbin}/')
    else:
        _ok('scripts: all symlinks already current')


def _install_wdlib(client_dir: Path) -> None:
    opt_lib = Path('/opt/wsprdaemon/lib')
    _run(['mkdir', '-p', str(opt_lib)], sudo=True)
    wdlib_src = client_dir / 'lib' / 'wdlib'
    wdlib_dst = opt_lib / 'wdlib'
    if not wdlib_src.is_dir():
        return
    if wdlib_dst.is_symlink():
        target = wdlib_dst.resolve()
        if target == wdlib_src.resolve():
            return
        _run(['rm', str(wdlib_dst)], sudo=True)
    elif wdlib_dst.exists():
        _run(['rm', '-rf', str(wdlib_dst)], sudo=True)
    _run(['ln', '-s', str(wdlib_src), str(wdlib_dst)], sudo=True)
    _ok('wdlib: symlinked into /opt/wsprdaemon/lib/')


_WD_CTL_NOISE_RE = __import__('re').compile(
    r'^(?:'
    r'Parsing config:'
    r'|  Env files:'
    r'|  No orphaned instances'
    r'|  Units: already in place'
    r'|  Wrappers installed'
    r'|  tmpfs (?:size|already mounted)'
    r'|  Mount unit:'
    r'|  systemd daemon reloaded'
    r'|  Spool janitor:.* enabled'
    r'|  Bash completion:'
    r'|Apply complete\.'
    # _manage_radiod section noise — keep only the real transition lines
    r'|--- radiod:'
    r'|  ka9q-radio source: OK'
    r'|  Running and config is current'
    r')'
)


def _print_wd_ctl_filtered(stdout: str, stderr: str) -> None:
    """Print wd-ctl output with status-only lines suppressed.

    Keeps anything that isn't recognised noise (real transitions like
    'Started: X', errors, warnings, removed-orphan messages).
    """
    for line in stdout.splitlines():
        if line.strip() and not _WD_CTL_NOISE_RE.match(line):
            print(line)
    if stderr.strip():
        print(stderr, file=sys.stderr)


def _run_wd_ctl_apply(client_dir: Path, dry_run: bool) -> bool:
    wd_ctl = Path('/usr/local/sbin/wd-ctl')
    if not wd_ctl.exists():
        wd_ctl = client_dir / 'bin' / 'wd-ctl'
    if not wd_ctl.exists():
        _err('wd-ctl not found — cannot generate env files and start services')
        return False
    cmd = [str(wd_ctl), 'apply']
    if dry_run:
        _info('dry-run: would run: sudo WD_SKIP_AFFINITY=1 ' + ' '.join(cmd))
        return True
    # sigmond owns CPU affinity for all managed services (radiod + workers).
    # WD_SKIP_AFFINITY=1 tells wd-ctl to skip its own affinity drop-ins
    # rather than write them and have sigmond delete them moments later.
    if os.geteuid() == 0:
        env = {**os.environ, 'WD_SKIP_AFFINITY': '1'}
        r = subprocess.run(cmd, env=env, capture_output=True, text=True,
                           stdin=subprocess.DEVNULL)
    else:
        r = subprocess.run(['sudo', 'WD_SKIP_AFFINITY=1'] + cmd,
                           capture_output=True, text=True,
                           stdin=subprocess.DEVNULL)
    _print_wd_ctl_filtered(r.stdout, r.stderr)
    return r.returncode == 0


def _ensure_sigmond_dirs() -> None:
    for d in [SIGMOND_CONF, SIGMOND_LOG]:
        _run(['mkdir', '-p', str(d)], sudo=True)


# ---------------------------------------------------------------------------
# smd add / enable / disable / remove  — systemctl-style component lifecycle
# ---------------------------------------------------------------------------
#
# Lifecycle:
#   add      — clone repo into /opt/git/sigmond/<name>/ (or git pull if there)
#   install  — run deploy.toml install steps (existing cmd_install)
#   config init|edit — configure (existing cmd_config_init / cmd_config_edit)
#   enable   — set [component.<name>].enabled=true in topology.toml
#   start    — refuses unless installed AND configured
#   disable  — set enabled=false AND stop the component's units
#   remove   — delete the [component.<name>] section AND stop units


def _derive_component_name_from_url(url: str) -> str:
    """codar-sounder.git → 'codar-sounder' ; git@github.com:owner/foo → 'foo' ."""
    stem = url.rstrip('/').rsplit('/', 1)[-1]
    if stem.endswith('.git'):
        stem = stem[:-4]
    return stem


def _stop_component_units(component: str) -> None:
    """systemctl-stop everything declared by component's deploy.toml."""
    if not _HAS_SIGMOND_LIB:
        return
    try:
        topology = _load_topology(TOPOLOGY_PATH)
        # If still in topology, resolve via library; otherwise read the
        # deploy.toml directly so disable/remove still works after the
        # topology entry is gone.
        try:
            units = resolve_units([component], [component])
        except Exception:
            from sigmond.component_state import (_read_deploy_toml,
                                                  _systemd_unit_names,
                                                  _expand_running_instances)
            deploy = _read_deploy_toml(component)
            unit_names: list[str] = []
            if deploy:
                for u in _systemd_unit_names(deploy):
                    if '@.' in u:
                        unit_names.extend(_expand_running_instances(u))
                    else:
                        unit_names.append(u)
            for u in unit_names:
                _run(['systemctl', 'stop', u], sudo=True)
            return
        for unit in [u for u in units if not u.orphaned]:
            _run(['systemctl', 'stop', unit.unit], sudo=True)
    except Exception as exc:
        _warn(f'{component}: stop units skipped — {exc}')


def cmd_add(args) -> int:
    """Clone a sigmond-managed component into /opt/git/sigmond/<name>/.

    No topology edit; operator runs `smd enable` separately.  If the
    component is already cloned, fast-forward pulls so `smd add` doubles
    as a per-component refresh.
    """
    if _need_root('add'):
        return 1

    url = getattr(args, 'url', None)
    if not url:
        _err('smd add: URL required (e.g. git@github.com:owner/<name>.git)')
        return 1

    name = _derive_component_name_from_url(url)
    repo_dir = Path('/opt/git/sigmond') / name

    if repo_dir.exists():
        _info(f'{name}: already cloned at {repo_dir} — pulling latest')
        r = _run(['git', '-C', str(repo_dir), 'pull', '--ff-only'])
        if r.returncode != 0:
            _err(f'{name}: pull failed: {r.stderr.strip() or r.stdout.strip()}')
            return 1
    else:
        _info(f'{name}: cloning {url} → {repo_dir}')
        repo_dir.parent.mkdir(parents=True, exist_ok=True)
        r = _run(['git', 'clone', url, str(repo_dir)])
        if r.returncode != 0:
            _err(f'{name}: clone failed: {r.stderr.strip()}')
            return 1

    if not (repo_dir / 'deploy.toml').exists():
        _err(f'{name}: not a sigmond-managed component (no deploy.toml at {repo_dir})')
        _err(f'         repo is at {repo_dir}; sudo rm -rf {repo_dir} to undo.')
        return 1

    _ok(f'{name}: added')
    _info(f'  next: sudo smd install {name}')
    _info(f'        sudo smd config init {name}')
    _info(f'        sudo smd enable {name}')
    return 0


def cmd_enable(args) -> int:
    """Set [component.<name>].enabled=true in /etc/sigmond/topology.toml."""
    if _need_root('enable'):
        return 1
    if not _HAS_SIGMOND_LIB:
        _err('enable: sigmond library not importable')
        return 1

    from sigmond.topology import set_component_enabled
    from sigmond.catalog import load_catalog

    names = getattr(args, 'names', []) or []
    if not names:
        _err('smd enable: name required (e.g. smd enable hfdl-recorder)')
        return 1

    try:
        catalog = load_catalog()
    except FileNotFoundError as exc:
        _err(str(exc))
        return 1

    rc = 0
    for name in names:
        if name not in catalog:
            _err(f'{name}: not in catalog (clone it first with: sudo smd add <url>)')
            rc = 1
            continue
        changed = set_component_enabled(name, True, TOPOLOGY_PATH,
                                         description=catalog[name].description)
        if changed:
            _ok(f'{name}: enabled in topology')
        else:
            _info(f'{name}: already enabled')
    if rc == 0:
        _info('  start with: sudo smd start')
    return rc


def cmd_disable(args) -> int:
    """Set enabled=false in topology AND stop the component's running units."""
    if _need_root('disable'):
        return 1
    if not _HAS_SIGMOND_LIB:
        _err('disable: sigmond library not importable')
        return 1

    from sigmond.topology import set_component_enabled
    from sigmond.catalog import load_catalog

    names = getattr(args, 'names', []) or []
    if not names:
        _err('smd disable: name required')
        return 1

    try:
        catalog = load_catalog()
    except FileNotFoundError as exc:
        _err(str(exc))
        return 1

    rc = 0
    for name in names:
        if name not in catalog:
            _warn(f'{name}: not in catalog — proceeding to stop any leftover units')
        # Always try to stop units first (matches the operator's intent
        # "I want this off").  Then flip the topology flag.
        _stop_component_units(name)
        if name in catalog:
            changed = set_component_enabled(name, False, TOPOLOGY_PATH)
            if changed:
                _ok(f'{name}: disabled in topology + units stopped')
            else:
                _ok(f'{name}: already disabled (units stopped)')
    return rc


def cmd_remove(args) -> int:
    """Delete the [component.<name>] section from topology AND stop units.

    Does NOT delete the cloned source — that stays under /opt/git/sigmond/
    so the operator can `smd enable <name>` again later without re-cloning.
    """
    if _need_root('remove'):
        return 1
    if not _HAS_SIGMOND_LIB:
        _err('remove: sigmond library not importable')
        return 1

    from sigmond.topology import remove_component

    names = getattr(args, 'names', []) or []
    if not names:
        _err('smd remove: name required')
        return 1

    for name in names:
        _stop_component_units(name)
        removed = remove_component(name, TOPOLOGY_PATH)
        if removed:
            _ok(f'{name}: removed from topology + units stopped')
        else:
            _info(f'{name}: not in topology (units stopped if any were running)')
    return 0


# ---------------------------------------------------------------------------
# smd install
# ---------------------------------------------------------------------------

def cmd_install(args) -> int:
    client = getattr(args, 'client', None)
    if client:
        return _install_single_client(args)
    return _install_full_suite(args)


def _install_single_client(args) -> int:
    """Catalog-driven install of a single client: smd install <client>."""
    client = args.client
    dry_run = getattr(args, 'dry_run', False)
    yes = getattr(args, 'yes', False)

    try:
        catalog = load_catalog()
    except FileNotFoundError as exc:
        _err(str(exc))
        return 1

    entry = get_entry(client, catalog)
    if entry is None:
        # Wave 2 fall-through: discover from /opt/git/sigmond/<client>/deploy.toml.
        # A drop-in client author who's already cloned their repo gets
        # auto-discovered without any sigmond-side catalog edit.
        from sigmond.discover import find_deploy_toml, synthesize_catalog_entry
        deploy_path = find_deploy_toml(client)
        if deploy_path is not None:
            entry = synthesize_catalog_entry(deploy_path)
        if entry is None:
            _err(f"unknown client '{client}' — see: smd list --available")
            return 1

    if not entry.install_script:
        # wd-rac is handled natively (frpc binary + ini + service).
        if entry.name == 'wd-rac':
            if _need_root('install'):
                return 1
            _netdiag_auto_refresh('install')
            _heading('wd-rac (Remote Access Channel)')
            topology = _load_topology(TOPOLOGY_PATH)
            return 0 if _install_wd_rac(topology, dry_run, yes=yes) else 1
        _err(f"'{entry.name}' has no install_script in the catalog")
        if entry.name == 'ka9q-radio':
            _info(f"{entry.name} is built natively by sigmond (apt deps + make install); "
                  f"use: smd install --components ka9q-radio --yes")
        return 1

    _heading(f'install {entry.name}')
    _info(f'repo:   {entry.repo}')
    _info(f'script: {entry.install_script}')

    if dry_run:
        _info('(dry-run) would clone repo and run install.sh')
        return 0

    if _need_root('install'):
        return 1

    _netdiag_auto_refresh('install')

    try:
        result = _do_install_client(entry, dry_run=dry_run, yes=yes, pull=True)
    except RuntimeError as exc:
        _err(str(exc))
        return 1

    if result:
        _ok(f'{entry.name} installed successfully')
        _info(f'next: edit /etc/{entry.name}/ config, then: smd start --components {entry.name}')
        return 0
    else:
        _err(f'{entry.name} install failed')
        return 1


def _install_full_suite(args) -> int:
    """Catalog-driven full-suite install.

    For each enabled component in the topology:
    - If the catalog entry has an install_script, install via the catalog
      (clone repo + run the client's own install.sh).
    - For C projects without install_scripts (radiod, ka9q-web), delegate
      to ka9q-update's install-ka9q.sh.
    """
    if _need_root('install'):
        return 1

    print(BANNER)
    _netdiag_auto_refresh('install')
    topology = _load_topology(
        Path(args.topology) if args.topology else TOPOLOGY_PATH,
        client_dir_override=getattr(args, 'client_dir', None),
    )
    smd_bin = topology['smd_bin']

    if args.components:
        # Explicit --components list bypasses the topology enabled filter so
        # the TUI (and CLI users) can install disabled-but-not-yet-installed
        # components without first editing topology.toml.
        components = [c.strip() for c in args.components.split(',')]
    else:
        components = _enabled_components(topology, None)
        if not components:
            print('No components enabled — check topology.toml or use: smd install <name>')
            return 1

    dry_run = getattr(args, 'dry_run', False)
    yes = getattr(args, 'yes', False)

    # Load the catalog to classify each component.
    try:
        catalog = load_catalog()
    except FileNotFoundError as exc:
        _err(str(exc))
        return 1

    # Classify components into catalog-driven vs. native C-build.
    catalog_queue = []    # CatalogEntry objects with install_script
    radiod_needed = False
    unknown = []

    # C projects without install_script — built natively by sigmond
    # (apt-install build deps + make install).  Today only ka9q-radio
    # goes through this path; 'radiod' (the systemd service name) is a
    # topology_alias for the same entry and resolves via get_entry().
    C_BUILD_NAMES = ('ka9q-radio',)

    for comp in components:
        entry = get_entry(comp, catalog)
        if entry is None:
            unknown.append(comp)
            continue
        if entry.install_script:
            catalog_queue.append(entry)
        elif entry.name in C_BUILD_NAMES:
            radiod_needed = True
        elif entry.kind in ('library', 'infra') and not entry.install_script:
            # Handled by sigmond itself (e.g. ka9q-python via venv, wd-rac via _install_frpc).
            pass
        else:
            unknown.append(comp)

    # --- Show install plan ---
    _heading('install plan')
    if radiod_needed:
        _info('native:       radiod  (apt deps + make install)')
    for entry in catalog_queue:
        _info(f'catalog:      {entry.name:22s} → {entry.install_script}')
    for comp in unknown:
        _warn(f'unknown:      {comp} (not in catalog, skipping)')

    wd_rac_needed = 'wd-rac' in components
    if not catalog_queue and not radiod_needed and not wd_rac_needed:
        _warn('nothing to install')
        return 0
    if wd_rac_needed:
        _info('wd-rac:       Remote Access Channel (frpc tunnel)')

    if dry_run:
        print('\n(dry-run mode — no changes will be made)')
        return 0

    if not yes:
        resp = input('\nProceed? [Y/n] ').strip().lower()
        if resp and resp not in ('y', 'yes'):
            print('Aborted.')
            return 0

    _ensure_sigmond_dirs()
    errors = 0

    # --- 1. Install smd itself + TUI venv ---
    _heading('Sigmond')
    sigmond_dir = Path(__file__).resolve().parent.parent
    _install_smd_itself(sigmond_dir, smd_bin)
    if not _ensure_sigmond_venv():
        _warn('TUI venv setup failed — smd tui will not work')
        errors += 1

    # --- 2. radiod (C build, sigmond-native) ---
    if radiod_needed:
        _heading('ka9q-radio (apt deps + make install)')
        if not _install_radiod_native(catalog, force=getattr(args, 'force', False)):
            errors += 1

    # --- 3. Catalog-driven clients ---
    for entry in catalog_queue:
        _heading(f'install {entry.name}')
        try:
            result = _do_install_client(entry, dry_run=False, yes=yes, pull=True)
            if result:
                _ok(f'{entry.name} installed')
            else:
                _err(f'{entry.name} install failed')
                errors += 1
        except RuntimeError as exc:
            _err(f'{entry.name}: {exc}')
            errors += 1

    # --- 4. deps.conf dependencies ---
    client_dir = topology['client_dir']
    dcfg = _load_deps_conf(client_dir)
    if dcfg:
        deps_needed = _collect_deps_for_components(components)
        if deps_needed:
            _heading('dependencies (deps.conf)')
            venv_dir = Path('/opt/wsprdaemon/venv')
            for dep in deps_needed:
                if dep not in dcfg.sections():
                    _warn(f'{dep}: not found in deps.conf — skipping')
                    continue
                dep_type = dcfg.get(dep, 'type', fallback='').strip()
                if dep_type == 'git':
                    if not _install_git_dep(dep, dcfg):
                        errors += 1
                    # Trigger build step if this dep needs one
                    if dep in BUILD_STEPS:
                        install_to = dcfg.get(dep, 'install_to', fallback='').strip()
                        if install_to:
                            build_fn = globals().get(BUILD_STEPS[dep])
                            if build_fn and not build_fn(Path(install_to)):
                                errors += 1
                elif dep_type == 'pypi':
                    # Skip pypi deps that are catalog-managed (already installed via smd catalog path).
                    from sigmond.catalog import load_catalog as _lc, get_entry as _ge
                    try:
                        _cat = _lc()
                        if _ge(dep, _cat) is not None:
                            _ok(f'{dep}: managed by sigmond catalog — skipping deps.conf install')
                            continue
                    except Exception:
                        pass
                    if not _install_pypi_dep(dep, dcfg, venv_dir):
                        errors += 1
                else:
                    _warn(f'{dep}: unknown type "{dep_type}" in deps.conf — skipping')

    # --- 5. wd-rac (frpc tunnel) ---
    if 'wd-rac' in components:
        _heading('wd-rac (Remote Access Channel)')
        if not _install_wd_rac(topology, dry_run, yes=yes):
            errors += 1

    # --- Summary ---
    print()
    if errors:
        print(f'\033[31msmd install completed with {errors} error(s).\033[0m')
        return 1
    print(f'\033[32msmd install complete.\033[0m  Run \033[1msmd status\033[0m to verify.')
    return 0


# ka9q-radio (radiod) build deps, mirrored from upstream docs/INSTALL.md
# at https://github.com/ka9q/ka9q-radio.  Update if upstream's prereq list
# changes — sigmond now owns this recipe directly rather than delegating
# to an external ka9q-update wrapper.
_RADIOD_APT_DEPS = (
    'git', 'avahi-utils', 'build-essential', 'make', 'gcc',
    'libairspy-dev', 'libairspyhf-dev', 'libavahi-client-dev',
    'libbsd-dev', 'libfftw3-dev', 'libhackrf-dev',
    'libiniparser-dev', 'libncurses5-dev', 'libncursesw5-dev',
    'libopus-dev', 'librtlsdr-dev', 'libusb-1.0-0-dev', 'libusb-dev',
    'portaudio19-dev', 'libasound2-dev', 'uuid-dev', 'rsync',
    'libogg-dev', 'libsamplerate-dev', 'libliquid-dev',
    'libbladerf-dev',
)
_RADIOD_PI_EXTRA = ('libpigpio-dev',)


def _is_raspberry_pi() -> bool:
    """True if /proc/device-tree/model identifies this host as a Raspberry Pi."""
    try:
        return Path('/proc/device-tree/model').read_bytes().startswith(b'Raspberry Pi')
    except OSError:
        return False


def _install_radiod_deps() -> bool:
    """apt-install the build-deps required by ka9q-radio."""
    deps = list(_RADIOD_APT_DEPS)
    if _is_raspberry_pi():
        deps.extend(_RADIOD_PI_EXTRA)
    _info(f'apt: ensuring {len(deps)} build deps for ka9q-radio…')
    r = _run(['apt-get', 'install', '-y'] + deps, sudo=True, capture=False)
    if r is None or (hasattr(r, 'returncode') and r.returncode != 0):
        _err('failed to install ka9q-radio build deps via apt')
        return False
    _ok(f'apt deps for ka9q-radio installed ({len(deps)} packages)')
    return True


def _install_radiod_native(catalog, *, force: bool = False) -> bool:
    """Install ka9q-radio natively under /opt/git/sigmond/radiod.

    Recipe (mirrors github.com/ka9q/ka9q-radio docs/INSTALL.md):
      1. apt-install the build deps in _RADIOD_APT_DEPS
      2. clone (or pull if cloned) ka9q-radio via the catalog
      3. make -j<nproc>  +  sudo make install   (via _build_ka9q_radio)
      4. start any radiod@ instances declared in /etc/systemd

    `force=True` triggers a `make clean` and bypasses the
    "binary already current" short-circuit so the operator can rebuild
    after changing apt deps or build flags.
    """
    entry = get_entry('ka9q-radio', catalog)
    if entry is None:
        _err('ka9q-radio not in catalog — cannot determine repo URL')
        return False
    if not _install_radiod_deps():
        return False
    try:
        src_dir = _clone_repo(entry, pull_if_exists=True)
    except RuntimeError as exc:
        _err(f'ka9q-radio clone failed: {exc}')
        return False
    if not _build_ka9q_radio(src_dir, force=force):
        return False
    _ensure_radiod_running()
    return True


def _ensure_radiod_running() -> None:
    """Start any known radiod@ instances that aren't currently active.

    Discovers instances from drop-in directories and running units so we
    catch instances that use the indirect template (no per-instance .service
    file in /etc/systemd/system/).
    """
    import glob as _glob
    seen: set[str] = set()

    # Instances with drop-in config dirs
    for d in _glob.glob('/etc/systemd/system/radiod@*.service.d'):
        name = Path(d).name  # radiod@foo.service.d
        unit = name[:-len('.d')]   # radiod@foo.service
        seen.add(unit)

    # Instances systemd already knows about (running or stopped)
    r = _run(
        ['systemctl', 'list-units', 'radiod@*', '--all',
         '--no-legend', '--plain', '--no-pager'],
        capture=True, sudo=False,
    )
    for line in r.stdout.splitlines():
        parts = line.split()
        if parts:
            seen.add(parts[0])

    for unit in sorted(seen):
        instance = unit[len('radiod@'):-len('.service')]
        r = _run(['systemctl', 'is-active', unit], capture=True, sudo=False)
        if r.stdout.strip() == 'active':
            _ok(f'radiod@{instance} already running')
            continue
        _info(f'starting radiod@{instance} ...')
        r = _run(['systemctl', 'enable', '--now', unit], capture=False, sudo=True)
        if r.returncode == 0:
            _ok(f'radiod@{instance} started')
        else:
            _warn(f'radiod@{instance} failed to start')


# ---------------------------------------------------------------------------
# smd apply
# ---------------------------------------------------------------------------

def _any_upload_service_inactive() -> bool:
    """Return True if any wd-upload-* unit is loaded but not active.

    Used by cmd_apply to decide whether to run _restart_upload_services_last
    on an otherwise-no-op apply: a broken upload should self-heal even when
    nothing else changed.
    """
    import subprocess as _sp
    r = _sp.run(
        ['systemctl', 'list-units', '--type=service',
         '--state=loaded', '--no-legend', '--no-pager', 'wd-upload-*'],
        capture_output=True, text=True,
    )
    for line in r.stdout.splitlines():
        parts = line.strip().split()
        # systemctl list-units columns: UNIT LOAD ACTIVE SUB DESCRIPTION
        if len(parts) >= 3 and parts[2] != 'active':
            return True
    return False


def _restart_upload_services_last() -> None:
    """Restart active wd-upload-* services so they start after all producers."""
    import subprocess as _sp
    r = _sp.run(
        ['systemctl', 'list-units', '--type=service', '--state=active',
         '--no-legend', '--no-pager', 'wd-upload-*'],
        capture_output=True, text=True,
    )
    units = [line.split()[0] for line in r.stdout.splitlines() if line.strip()]
    if not units:
        return
    _info('upload services: restarting last so producers are ready...')
    for unit in sorted(units):
        r2 = _run(['systemctl', 'restart', unit], sudo=True)
        if r2.returncode == 0:
            _ok(f'{unit}: restarted')
        else:
            _err(f'{unit}: {r2.stderr.strip()}')


def cmd_apply(args) -> int:
    if _need_root('apply'):
        return 1
    topology = _load_topology(
        Path(args.topology) if args.topology else TOPOLOGY_PATH,
    )
    dry_run = getattr(args, 'dry_run', False)
    _heading('apply')
    _netdiag_auto_refresh('apply')

    # Tracks whether anything observable was changed by this apply.  Drives
    # the decision to restart wd-upload-* at the end: a fully no-op apply
    # leaves them alone instead of cycling them every time.
    something_changed = False

    # Reconcile Proxmox VM `onboot` flag — silent no-op on bare-metal
    # hosts.  Catches the "host rebooted, VM didn't come back" failure
    # mode (B4-100 power outage, 2026-05-16: operator caught onboot=0
    # before booting the VM; without this check there's no way for smd
    # to know it had been reset).
    something_changed |= _ensure_proxmox_onboot(dry_run=dry_run)

    # Ensure deploy.toml link-kind install steps are present for all installed
    # catalog components.  This catches unit files that install.sh omitted or
    # that were accidentally removed.
    if _HAS_SIGMOND_LIB:
        try:
            from sigmond.installer import (
                apply_deploy_toml_links, apply_systemd_enables,
            )
            from sigmond.catalog import load_catalog
            catalog = load_catalog()
            reloaded = False
            for name, entry in sorted(catalog.items()):
                repo_dir = Path('/opt/git/sigmond') / name
                if not repo_dir.exists():
                    continue
                msgs = apply_deploy_toml_links(repo_dir, dry_run=dry_run)
                for msg in msgs:
                    if msg.startswith('  warning'):
                        _warn(msg.strip())
                    elif not msg.startswith('  (dry'):
                        _ok(f'deploy links: {msg.strip()}')
                        if '/etc/systemd' in msg:
                            reloaded = True
                # Ensure every non-template unit declared in [systemd] is
                # actually wanted by multi-user.target — guards against
                # the "boots came up but nothing started" failure mode
                # where a unit file exists but `systemctl enable` was
                # never run (B4-100 post-outage, 2026-05-16).
                enable_msgs = apply_systemd_enables(repo_dir, dry_run=dry_run)
                for msg in enable_msgs:
                    if msg.startswith('  warning'):
                        _warn(msg.strip())
                    elif not msg.startswith('  (dry'):
                        _ok(f'systemd enable: {msg.strip()}')
                        something_changed = True
            if reloaded and not dry_run:
                _run(['systemctl', 'daemon-reload'], sudo=True)
                something_changed = True
        except Exception:
            pass  # non-fatal

    # Apply radiod channel fragments declared by enabled clients before the
    # ensure-running block — so fragments are in place when each radiod
    # instance starts (or restarts) and picks up its conf.d/ contents.
    if _HAS_SIGMOND_LIB:
        try:
            from sigmond.commands.radiod_fragments import apply_fragments
            from sigmond.coordination import load_coordination
            from sigmond.paths import COORDINATION_PATH
            coord = load_coordination(COORDINATION_PATH)
            enabled = _enabled_components(topology)
            for msg in apply_fragments(coord, enabled, dry_run=dry_run):
                if msg.lstrip().startswith('warning'):
                    _warn(msg.lstrip())
                elif not msg.lstrip().startswith('(dry'):
                    _ok(f'radiod fragment: {msg.strip()}')
                else:
                    _info(f'radiod fragment: {msg.strip()}')
        except Exception:
            pass  # non-fatal — fragments are best-effort

    # Write radiod CPU affinity drop-ins and ensure radiod is running BEFORE
    # wd-ctl apply so radiod cores are reserved and streams are available
    # before decoders try to connect.
    if _HAS_SIGMOND_LIB and not dry_run:
        try:
            enabled = _enabled_components(topology)
            from sigmond.lifecycle import resolve_units as _resolve_units
            all_units = [u for u in _resolve_units(enabled, enabled) if not u.orphaned]
            radiod_units = [
                u for u in all_units
                if u.component == 'ka9q-radio' and u.kind == 'service'
            ]
            if radiod_units:
                if _ensure_radiod_affinity_drop_ins(radiod_units, topology.get('cpu_affinity')):
                    something_changed = True
                # Check wisdom file — generation is now a deliberate user
                # action via 'smd tui → Operate → FFT Wisdom' (or the CLI
                # equivalent).  We don't block apply to run it.
                wisdom_ready = _WISDOM_FILE.exists()
                if not wisdom_ready:
                    _warn('FFT wisdom file missing — radiod cannot start cleanly')
                    _warn(f'  Run:  smd tui  → Operate → FFT Wisdom')
                if wisdom_ready:
                    for u in radiod_units:
                        if _run(['systemctl', 'is-enabled', '--quiet', u.unit]).returncode != 0:
                            _run(['systemctl', 'enable', u.unit], sudo=True)
                        r_active = _run(['systemctl', 'is-active', '--quiet', u.unit])
                        if r_active.returncode != 0:
                            r_start = _run(['systemctl', 'start', u.unit], sudo=True)
                            if r_start.returncode == 0:
                                _ok(f'{u.unit}: enabled and started')
                                something_changed = True
                            else:
                                _warn(f'{u.unit}: failed to start — {r_start.stderr.strip()}')
                        # else: already running — silent
                else:
                    _warn('radiod not started — FFT wisdom not yet ready')
                    _warn('wd-decode, wd-post, wd-upload will have no data until '
                          'wisdom completes and you re-run: sudo smd apply')
        except Exception:
            pass  # non-fatal; affinity is best-effort

    ok = _run_wd_ctl_apply(topology['client_dir'], dry_run)

    # Write "other" service affinity drop-ins AFTER wd-ctl apply so smd's
    # assignments (based on actual radiod reservations) override wd-ctl's
    # 99-wdctl-cpu-affinity.conf drop-ins which use the full CPU range.
    if _HAS_SIGMOND_LIB and not dry_run:
        try:
            if _ensure_other_affinity_drop_ins(topology.get('cpu_affinity')):
                something_changed = True
        except Exception:
            pass  # non-fatal; affinity is best-effort

    # Disable hf-timestd's radiod-affinity watcher if it ever got enabled
    # (typically by a re-run of hf-timestd's deploy.sh on a host where the
    # operator forgot TIMESTD_SKIP_AFFINITY=1).  Sigmond owns radiod
    # affinity; the watcher would otherwise re-apply hf-timestd's drop-in
    # on every radiod restart.  Silent no-op when already disabled.
    if not dry_run:
        try:
            if _disable_hftimestd_affinity_watcher():
                something_changed = True
        except Exception:
            pass  # non-fatal

    # Restart wd-upload-* services AFTER everything else — they depend on
    # decoders being active and fail with "unavailable resources" if started
    # too early. Skip the cycle entirely on a no-op apply.  Also restart any
    # upload that's currently inactive/failed so a broken state self-heals.
    if not dry_run:
        if something_changed or _any_upload_service_inactive():
            _restart_upload_services_last()

    return 0 if ok else 1


# ---------------------------------------------------------------------------
# FFTW wisdom management
# ---------------------------------------------------------------------------

# Complete profile list for wsprdaemon/ka9q-radio SDR configurations.
# fftwf-wisdom reads the existing wisdomf first and skips already-planned
# transforms, so running with the full list is safe and fast when wisdom
# is already current.  Source: ka9q-radio docs/FFTW3.md
_FFT_WISDOM_PROFILES = [
    # Inverse FFTs for demodulator channels — smallest first (fast to plan)
    'cob15',   'cob45',   'cob85',
    'cob160',  'cob200',  'cob205',  'cob300',   'cob320',
    'cob400',  'cob405',  'cob480',  'cob600',   'cob800',  'cob810',
    'cob960',  'cob1200', 'cob1600', 'cob1620',  'cob1920',
    'cob3200', 'cob3240', 'cob4800', 'cob4860',  'cob6930',
    'cob8100', 'cob9600', 'cob16200', 'cob32400', 'cob40500',
    'cob81000', 'cob162000',
    # Forward real FFTs — progressively larger, most expensive last
    'rof1620000',   # RX888 MkII @  64.8 MHz, 20 ms block, overlap 5
    'rof3240000',   # RX888 MkII @ 129.6 MHz, 20 ms block, overlap 5  ← hours
]

_FFTWF_WISDOM_BIN = Path('/usr/bin/fftwf-wisdom')
_WISDOM_FILE      = Path('/etc/fftw/wisdomf')
_WISDOM_TMP       = Path('/etc/fftw/wisdomf.new')
_WISDOM_LOG       = Path('/tmp/ka9q-wisdom.log')
_WISDOM_PID       = Path('/var/run/ka9q-fft-wisdom.pid')


def _wisdom_already_running() -> bool:
    """Return True if a fftwf-wisdom process from a previous smd run is still alive."""
    if not _WISDOM_PID.exists():
        return False
    try:
        pid = int(_WISDOM_PID.read_text().strip())
        Path(f'/proc/{pid}').stat()   # raises OSError if gone
        return True
    except (ValueError, OSError):
        _WISDOM_PID.unlink(missing_ok=True)
        return False


def _install_wisdom() -> None:
    """Atomically install wisdomf.new → wisdomf if it grew (sanity check)."""
    if not _WISDOM_TMP.exists():
        return
    new_size = _WISDOM_TMP.stat().st_size
    if new_size == 0:
        _WISDOM_TMP.unlink(missing_ok=True)
        return
    old_size = _WISDOM_FILE.stat().st_size if _WISDOM_FILE.exists() else 0
    if new_size >= old_size:
        _run(['mv', str(_WISDOM_TMP), str(_WISDOM_FILE)], sudo=True)
        _ok(f'FFT wisdom: installed {new_size} bytes → {_WISDOM_FILE}')
    else:
        _warn(f'New wisdom ({new_size} B) smaller than existing ({old_size} B) — keeping old')
        _WISDOM_TMP.unlink(missing_ok=True)


def _ensure_fft_wisdom(radiod_units: list, all_units: list) -> bool:
    """Ensure FFTW wisdom is current for all supported ka9q-radio profiles.

    Stops all sigmond-managed services before running the planner so they
    don't compete for CPU during the (potentially hours-long) planning pass.

    Uses fftwf-wisdom with the full standard profile list.  Since fftwf-wisdom
    reads the existing wisdomf before planning, only missing transforms are
    computed — already-planned ones complete in milliseconds.

    Behavior:
      • If all profiles finish within 5 s → installs wisdomf, returns True.
      • If still running after 5 s → tails the log so the operator can watch.
        Ctrl+C stops the tail; generation continues in background.
        Returns False → caller must skip radiod and all dependent service starts.
      • If called while a previous generation is still running → returns False.
    """
    if not _FFTWF_WISDOM_BIN.exists():
        return True   # tool not present; don't block

    if _wisdom_already_running():
        _warn('FFT wisdom: generation still in progress from a previous run')
        _info(f'  Monitor:  tail -f {_WISDOM_LOG}')
        _info(f'  Re-run    sudo smd apply   when it completes.')
        return False

    # Stop all managed services so they don't compete for CPU during planning.
    _info('FFT wisdom: stopping all managed services before planning pass')
    for u in reversed(all_units):
        r = _run(['systemctl', 'is-active', '--quiet', u.unit])
        if r.returncode == 0:
            _run(['systemctl', 'stop', u.unit], sudo=True)

    _info(f'FFT wisdom: checking {len(_FFT_WISDOM_PROFILES)} profiles '
          f'(skips already-planned transforms — fast if wisdom is current)')

    # stdbuf -oL forces line-buffered stdout so each progress line from
    # fftwf-wisdom is flushed to the log immediately (C stdio defaults to
    # full-block buffering when stdout is a file, silencing tail -f for hours).
    _stdbuf = shutil.which('stdbuf')
    wisdom_cmd = (
        [_stdbuf, '-oL'] if _stdbuf else []
    ) + [str(_FFTWF_WISDOM_BIN), '-v', '-T', '1',
         '-o', str(_WISDOM_TMP)] + _FFT_WISDOM_PROFILES

    with open(_WISDOM_LOG, 'w') as log_f:
        proc = subprocess.Popen(
            wisdom_cmd,
            stdout=log_f, stderr=subprocess.STDOUT,
            start_new_session=True,   # insulate from terminal Ctrl+C
        )

    try:
        _WISDOM_PID.write_text(str(proc.pid))
    except OSError:
        pass

    # Wait up to 5 s — fast if wisdom is already current
    try:
        proc.wait(timeout=5)
    except subprocess.TimeoutExpired:
        pass

    if proc.returncode is not None:
        # Completed within 5 s
        _WISDOM_PID.unlink(missing_ok=True)
        if proc.returncode == 0:
            _install_wisdom()
        else:
            _warn(f'fftwf-wisdom exited {proc.returncode} — check {_WISDOM_LOG}')
        return True

    # Still running — show live output until done or Ctrl+C
    _warn('FFT wisdom planning is taking longer than 5 s '
          '(normal for large transforms like rof3240000 on first run).')
    _info(f'  This can take hours for the RX888 @ 129.6 MHz transform.')
    _info(f'  Showing live output.  '
          'Press Ctrl+C to stop watching — planning continues in background.')
    _info(f'  Until complete, radiod and all dependent services cannot start.')
    _info('')

    tail = subprocess.Popen(['tail', '-f', str(_WISDOM_LOG)])
    wisdom_done = False
    try:
        proc.wait()
        wisdom_done = True
    except KeyboardInterrupt:
        pass
    finally:
        tail.terminate()
        try:
            tail.wait(timeout=2)
        except subprocess.TimeoutExpired:
            tail.kill()

    if wisdom_done:
        _WISDOM_PID.unlink(missing_ok=True)
        if proc.returncode == 0:
            _install_wisdom()
            _ok('FFT wisdom: generation complete — restarting radiod')
            for u in radiod_units:
                _run(['systemctl', 'restart', u.unit], sudo=True)
            return True
        _warn(f'fftwf-wisdom failed (exit {proc.returncode})')
        return True   # non-fatal; let radiod try anyway

    # Ctrl+C — wisdom still running in background
    _warn('Ctrl+C: wisdom planning continues in background.')
    _info(f'  Monitor:  tail -f {_WISDOM_LOG}')
    _info(f'  Re-run:   sudo smd apply   once complete to start radiod and decoders.')
    return False


# ---------------------------------------------------------------------------
# smd start / stop / restart / reload
# ---------------------------------------------------------------------------

def _ensure_radiod_affinity_drop_ins(radiod_units: list,
                                     topology_cpu_affinity=None) -> bool:
    """Write smd-cpu-affinity.conf drop-ins for radiod service instances.

    Assigns physical core 0 to the first instance (alphabetically), core 1 to
    the second, etc.  Runs daemon-reload after writing so the constraints are
    in effect when the units start.

    For any instance already running with the wrong CPU affinity, restarts it
    so the new constraint takes effect immediately.

    Returns True if any drop-in was written, removed, or any unit restarted.
    """
    try:
        from sigmond.cpu import get_physical_cores, parse_cpu_mask
    except ImportError:
        return False

    cores = get_physical_cores()
    if not cores:
        return False

    sorted_units = sorted(radiod_units, key=lambda u: u.instance or u.unit)
    valid_unit_names = {u.unit for u in sorted_units}
    wrote_any = False
    units_to_restart: list[str] = []

    # Remove drop-in dirs for radiod instances that no longer exist.
    # These are left behind when an instance is removed from /etc/radio/
    # and would otherwise create ghost entries in CPU affinity reports.
    sys_dir = Path('/etc/systemd/system')
    for p in sorted(sys_dir.glob('radiod@*.service.d')):
        unit_name = p.name[:-2]  # strip '.d'
        if '@.' in unit_name:
            continue  # skip bare template radiod@.service.d
        if unit_name not in valid_unit_names:
            drop_in = p / _SMD_AFFINITY_DROP_IN
            if drop_in.exists():
                _ok(f'removing orphaned radiod affinity drop-in for {unit_name}')
                _run(['rm', '-rf', str(p)], sudo=True)
                wrote_any = True

    for i, unit_ref in enumerate(sorted_units):
        core_cpus = cores[i] if i < len(cores) else cores[-1]
        label = f'radiod {unit_ref.instance or unit_ref.unit} → CPUs {_cpu_list_str(core_cpus)}'
        if _write_affinity_drop_in(unit_ref.unit, core_cpus, label) == 'wrote':
            _ok(f'affinity: {unit_ref.unit} → CPUs {_cpu_list_str(core_cpus)}')
            wrote_any = True

            # Check if the unit is already running with the wrong affinity.
            r_active = _run(['systemctl', 'is-active', '--quiet', unit_ref.unit])
            if r_active.returncode == 0:
                r_cur = _run(['systemctl', 'show', '-p', 'CPUAffinity',
                              '--value', unit_ref.unit])
                current_cpus = parse_cpu_mask(r_cur.stdout.strip())
                if current_cpus != core_cpus:
                    units_to_restart.append(unit_ref.unit)

    if wrote_any:
        _run(['systemctl', 'daemon-reload'], sudo=True)

    for unit in units_to_restart:
        _info(f'affinity changed: restarting {unit} to apply new CPU pinning')
        _run(['systemctl', 'restart', unit], sudo=True)

    return wrote_any or bool(units_to_restart)


def _ensure_other_affinity_drop_ins(topology_cpu_affinity=None) -> bool:
    """Write template-level smd-cpu-affinity.conf drop-ins for all non-radiod
    managed services, restricting them to the CPUs not reserved for radiod.

    Writes at the template level (e.g. wd-decode@.service.d/) so the drop-in
    applies to all instances without needing a per-instance file.
    Also removes any foreign drop-ins written by wd-ctl or hf-timestd.
    Runs daemon-reload once after all writes.
    """
    try:
        from sigmond.cpu import (compute_affinity_plan as _cplan,
                                  AFFINITY_UNITS as _AU,
                                  cpu_list_str as _cls)
    except ImportError:
        return False

    plan = _cplan(topology_cpu_affinity)
    if not plan.other_cpus:
        return False

    other_cpus = plan.other_cpus
    label = f'other → CPUs {_cpu_list_str(other_cpus)}'
    wrote_any = False

    # Remove foreign drop-ins (written by wd-ctl or hf-timestd) first
    removed = _remove_foreign_affinity_drop_ins()
    if removed:
        wrote_any = True

    # Write template-level smd drop-ins for all AFFINITY_UNITS
    for unit in _AU:
        if _write_affinity_drop_in(unit, other_cpus, label) == 'wrote':
            wrote_any = True

    if wrote_any:
        _run(['systemctl', 'daemon-reload'], sudo=True)

    # Apply runtime affinity to running instances without restarting them
    for unit in _AU:
        pattern = unit.replace('@.service', '@*.service') if '@.' in unit else unit
        r = _run(['systemctl', 'list-units', '--no-legend', '--no-pager',
                  '--state=running', '--output=json', pattern])
        try:
            import json as _json2
            instances = [u.get('unit', '') for u in _json2.loads(r.stdout)
                         if u.get('unit', '')]
        except Exception:
            instances = []
        if not instances and '@.' not in unit:
            instances = [unit]
        for inst in instances:
            _apply_cpu_affinity_runtime(inst, other_cpus)

    return wrote_any


def cmd_start(args) -> int:
    if _need_root('start'):
        return 1
    topology = _load_topology(Path(args.topology) if args.topology else TOPOLOGY_PATH)
    only = _resolve_only_list(args, topology)
    if only is not None and not only:
        return 0  # operator named only not-enabled components; already warned

    # When the operator named specific components, walk their `requires`
    # closure so dependencies start first.  `smd start wsprdaemon-client`
    # transparently brings up radiod and wspr-recorder ahead of it, the
    # way `systemctl start httpd` follows Wants=/Requires=.
    if only is not None:
        try:
            from sigmond.catalog import load_catalog
            only = _expand_requires_closure(only, load_catalog())
        except Exception:
            pass  # best-effort; fall through with the literal `only`
    enabled = _enabled_components(topology, only)

    # Hard gate: no component starts unless installed AND configured.
    # Returns the subset of `enabled` that's safe to start.  Drops + warns
    # for the rest.  Library-kind entries (ka9q-python: pip metadata) and
    # entries that turn out to be just topology aliases for another
    # component are filtered silently — they have no units of their own.
    try:
        from sigmond.component_state import compute_state
        from sigmond.catalog import load_catalog
        topo_for_state = _load_topology(TOPOLOGY_PATH)
        catalog = load_catalog()
        startable: list[str] = []
        for name in enabled:
            entry = catalog.get(name)
            if entry is not None and getattr(entry, 'kind', None) == 'library':
                continue  # library entries have no services
            alias = getattr(entry, 'topology_alias', None) if entry else None
            s = compute_state(name, topo_for_state, alias=alias)
            if s.can_start:
                startable.append(name)
            elif not s.cloned:
                # Topology references something that has no source clone
                # — likely an alias-only entry (ka9q-radio when catalog
                # uses "radiod") or a stale topology stub.  Skip silently;
                # the lifecycle resolver will sort it out.
                startable.append(name)
            else:
                _warn(f'{name}: not started — {s.display_status}')
        enabled = startable
    except Exception:
        pass  # fall through; lifecycle check is best-effort

    if not enabled:
        _warn('no startable components — every enabled component needs install + config')
        return 0

    try:
        units = resolve_units(enabled, enabled)
    except ValueError as exc:
        _err(f"component resolution failed: {exc}")
        return 1

    # Filter to configured instances only (not orphaned)
    units = [u for u in units if not u.orphaned]

    # Order: radiod first, then clients per coordination.toml (CONTRACT §5.4)
    if _HAS_SIGMOND_LIB:
        coord = load_coordination()
        units = order_units(units, coordination=coord)

    # Write CPU affinity drop-ins for radiod instances before starting them.
    radiod_services = [u for u in units
                       if u.component == 'ka9q-radio' and u.kind == 'service']
    if radiod_services:
        _ensure_radiod_affinity_drop_ins(radiod_services, topology.get('cpu_affinity'))

    _heading('start')
    _netdiag_auto_refresh('start')
    rc = 0
    for unit in units:
        r = _run(['systemctl', 'start', unit.unit], sudo=True)
        if r.returncode == 0:
            _ok(f'{unit.unit}')
        else:
            _err(f'{unit.unit}: {r.stderr.strip()}')
            rc = 1
    return rc


def cmd_stop(args) -> int:
    if _need_root('stop'):
        return 1
    topology = _load_topology(Path(args.topology) if args.topology else TOPOLOGY_PATH)
    only = _resolve_only_list(args, topology)
    if only is not None and not only:
        return 0  # operator named only not-enabled components; already warned
    enabled = _enabled_components(topology, only)

    try:
        units = resolve_units(enabled, enabled)
    except ValueError as exc:
        _err(f"component resolution failed: {exc}")
        return 1

    # Filter to configured instances only
    units = [u for u in units if not u.orphaned]

    # Order then reverse: clients stop first, radiod last (CONTRACT §5.4)
    if _HAS_SIGMOND_LIB:
        coord = load_coordination()
        units = order_units(units, coordination=coord)

    # Build the full stop list:
    #   1. Every declared unit (services, targets, timers).
    #   2. For each .timer, also the matching .service if it's currently
    #      running.  systemctl stop foo.timer doesn't kill a foo.service
    #      that the timer triggered earlier — e.g. a grape-daily catch-up
    #      run that's still chewing on yesterday's data when we stop.
    stop_list: list[str] = [u.unit for u in reversed(units)]
    seen = set(stop_list)
    for u in stop_list[:]:  # iterate a snapshot
        if u.endswith('.timer'):
            paired_service = u[:-len('.timer')] + '.service'
            if paired_service in seen:
                continue
            # `is-active --quiet` returns 0 ONLY for "active"; it returns
            # non-zero for "activating".  We want both — a long-running
            # oneshot triggered by the timer (e.g. grape-daily mid-
            # processing) is exactly what we need to interrupt on stop.
            r = _run(['systemctl', 'is-active', paired_service])
            state = r.stdout.strip()
            if state in ('active', 'activating', 'reloading'):
                idx = stop_list.index(u)
                stop_list.insert(idx, paired_service)
                seen.add(paired_service)

    _heading('stop')
    stopped = 0
    failed: list[tuple[str, str]] = []
    for unit_name in stop_list:
        r = _run(['systemctl', 'stop', unit_name], sudo=True)
        if r.returncode == 0:
            stopped += 1
        else:
            failed.append((unit_name, r.stderr.strip() or 'unknown error'))

    # Quiet by default: just the count and any failures.  Full per-unit
    # output is overwhelming on a typical station with 30+ units; if the
    # operator wants the detail they can tail journalctl.
    if stopped:
        _ok(f'stopped {stopped} unit{"s" if stopped != 1 else ""}')
    for unit_name, err in failed:
        _err(f'{unit_name}: {err}')
    return 1 if failed else 0


# ---------------------------------------------------------------------------
# CPU affinity management
# ---------------------------------------------------------------------------
# Pure functions and constants are in lib/sigmond/cpu.py (imported above).
# CLI-only helpers that need _run() / _ok() / _err() stay here.


def _write_affinity_drop_in(unit: str, cpus: set, label: str) -> str:
    """Write /etc/systemd/system/<unit>.d/smd-cpu-affinity.conf.

    Returns:
        'wrote' — file was created or its content changed.
        'noop'  — existing file already matches; nothing written.
        'error' — write failed; an _err() message has been emitted.
    """
    import tempfile
    drop_dir = Path(f'/etc/systemd/system/{unit}.d')
    drop_in  = drop_dir / _SMD_AFFINITY_DROP_IN
    content  = _render_drop_in(cpus, label)
    if drop_in.exists():
        try:
            if drop_in.read_text() == content:
                return 'noop'
        except OSError:
            pass  # fall through and rewrite
    r = _run(['mkdir', '-p', str(drop_dir)], sudo=True)
    if r.returncode != 0:
        _err(f'{unit}: cannot create {drop_dir}')
        return 'error'
    try:
        with tempfile.NamedTemporaryFile(mode='w', suffix='.conf',
                                         delete=False, dir='/tmp') as f:
            f.write(content)
            tmp = f.name
        r = _run(['mv', tmp, str(drop_in)], sudo=True)
        if r.returncode != 0:
            _err(f'{unit}: mv failed')
            return 'error'
        # 644 so non-root processes (TUI) can read the configured CPU set
        _run(['chmod', '644', str(drop_in)], sudo=True)
    except OSError as e:
        _err(f'{unit}: {e}')
        return 'error'
    return 'wrote'


def _remove_foreign_affinity_drop_ins() -> list:
    """Remove cpu-affinity drop-ins written by hf-timestd and wd-ctl."""
    results = []
    for name in _FOREIGN_AFFINITY_DROP_INS:
        for p in sorted(Path('/etc/systemd/system').glob(f'*.d/{name}')):
            r = _run(['rm', '-f', str(p)], sudo=True)
            results.append((p, r.returncode == 0))
    return results


def _disable_hftimestd_affinity_watcher() -> bool:
    """Disable and stop the hf-timestd units that monitor radiod for reinstalls.

    Sigmond owns radiod's CPU affinity; the hf-timestd watcher would otherwise
    re-apply hf-timestd's drop-in on every radiod restart.  Returns True if
    anything was actually disabled (silent on the typical no-op case).

    Only acts when state is exactly "enabled" — `is-enabled --quiet` returns 0
    for "static", "alias", "generated", etc., so checking exit code alone
    would loop disabling units that don't have an [Install] section to begin
    with (in particular timestd-radiod-affinity.service is static).
    """
    disabled_any = False
    for unit in _HFTIMESTD_AFFINITY_UNITS:
        r = _run(['systemctl', 'is-enabled', unit])
        state = r.stdout.strip()
        if state == 'enabled':
            _run(['systemctl', 'disable', '--now', unit], sudo=True)
            _ok(f'disabled + stopped {unit}')
            disabled_any = True
        # else: silent — already disabled / static / etc.
    return disabled_any


def _apply_cpu_affinity_runtime(unit: str, cpus: set) -> bool:
    """Apply CPUAffinity/AllowedCPUs to a running unit without restarting it."""
    cpu_str = _cpu_list_str(cpus)
    r = _run(['systemctl', 'set-property', '--runtime', unit,
              f'CPUAffinity={cpu_str}', f'AllowedCPUs={cpu_str}'], sudo=True)
    if r.returncode == 0:
        return True
    r2 = _run(['systemctl', 'show', '-p', 'MainPID', '--value', unit])
    pid = r2.stdout.strip()
    if pid and pid != '0':
        mask = ','.join(str(c) for c in sorted(cpus))
        r3 = _run(['taskset', '-a', '-cp', mask, pid], sudo=True)
        return r3.returncode == 0
    return False


def cmd_diag_cpu_affinity(args) -> int:
    """Show CPU affinity of every running smd-managed service process.

    Renders from sigmond.cpu.build_affinity_report() — same report that
    powers the TUI CPU affinity screen and smd status's summary block.
    With --json, emits the full report for programmatic consumers.
    """
    import json as _json
    from sigmond.cpu import build_affinity_report, affinity_report_to_dict

    topology = _load_topology(Path(args.topology) if args.topology else TOPOLOGY_PATH)
    show_all_threads = getattr(args, 'threads', False)
    want_json = getattr(args, 'json', False)

    report = build_affinity_report(topology.get('cpu_affinity'))

    if want_json:
        _json.dump(affinity_report_to_dict(report), sys.stdout, indent=2)
        sys.stdout.write('\n')
        return 0

    _heading('diag: CPU affinity')

    any_running = False
    for ua in report.units:
        if not ua.main_pid:
            _info(f'{ua.unit}: not running')
            continue

        any_running = True
        # Preserve /proc's raw Cpus_allowed_list format so thread-group
        # keys (also raw /proc format) compare correctly against the
        # process mask in the diff-only thread display below.
        systemd_mask_str = _cpu_list_str(ua.systemd_mask) if ua.systemd_mask else ''
        proc_cpus_str = ua.observed_mask_raw or '?'
        sd_note = f'  [systemd CPUAffinity: {systemd_mask_str}]' if systemd_mask_str else ''

        if ua.mask_mismatch:
            _warn(f'{ua.unit}  (pid {ua.main_pid})  actual CPUs: {proc_cpus_str}{sd_note}')
            _info(f'       {ua.role} overrides systemd affinity via sched_setaffinity()')
        else:
            _ok(f'{ua.unit}  (pid {ua.main_pid})  CPUs: {proc_cpus_str}{sd_note}')

        thread_groups = ua.thread_groups
        if not thread_groups:
            continue

        if show_all_threads:
            display_masks = sorted(thread_groups)
        else:
            display_masks = sorted(m for m in thread_groups if m != proc_cpus_str)

        if display_masks:
            total_threads = sum(len(v) for v in thread_groups.values())
            if not show_all_threads:
                diff_count = sum(len(thread_groups[m]) for m in display_masks)
                _info(f'       {total_threads} threads — showing {diff_count} with non-process affinity:')
            else:
                _info(f'       {total_threads} threads:')
            for mask in display_masks:
                threads = thread_groups[mask]
                unique_names = sorted(set(n for _, n in threads))
                name_str = ', '.join(unique_names)
                if len(name_str) > 60:
                    name_str = name_str[:57] + '...'
                diff_flag = '  ← differs' if mask != proc_cpus_str else ''
                print(f'         CPUs {mask:<10s}  ×{len(threads):>3}  {name_str}{diff_flag}')
        elif not show_all_threads:
            total = sum(len(v) for v in thread_groups.values())
            _info(f'       {total} threads — all share process affinity ({proc_cpus_str})')

    if not any_running:
        _info('No active managed service processes found.')

    if getattr(args, 'apply', False):
        if os.geteuid() != 0:
            _err('--apply requires root  (sudo smd diag cpu-affinity --apply)')
            return 1

        plan = _compute_affinity_plan(topology.get('cpu_affinity'))
        radiod_plan = plan.radiod
        other_cpus = plan.other_cpus

        _heading('cpu-affinity apply')
        if radiod_plan:
            for unit, cpus in radiod_plan.items():
                _info(f'radiod  {unit}: CPUs {_cpu_list_str(cpus)}')
        else:
            _info('radiod: (no running instances found)')
        _info(f'other   CPUs: {_cpu_list_str(other_cpus)}')
        print()

        _info('Disabling hf-timestd affinity watcher units ...')
        _disable_hftimestd_affinity_watcher()
        print()

        _info('Removing foreign affinity drop-ins ...')
        removed = _remove_foreign_affinity_drop_ins()
        if removed:
            for path, ok in removed:
                (_ok if ok else _warn)(
                    f'{"removed" if ok else "could not remove"} {path}')
        else:
            _info('(none found)')
        print()

        _info('Writing smd affinity drop-ins ...')
        errors = 0

        for unit, cpus in radiod_plan.items():
            label = f'radiod instance → CPUs {_cpu_list_str(cpus)}'
            res = _write_affinity_drop_in(unit, cpus, label)
            if res == 'wrote':
                _ok(f'{unit}: {label}')
            elif res == 'noop':
                _info(f'{unit}: already up-to-date ({label})')
            else:
                errors += 1

        stale = Path('/etc/systemd/system/radiod@.service.d') / _SMD_AFFINITY_DROP_IN
        if stale.exists():
            _run(['rm', '-f', str(stale)], sudo=True)
            _info('removed stale radiod@.service template drop-in')

        for unit in _AFFINITY_UNITS:
            label = f'other → CPUs {_cpu_list_str(other_cpus)}'
            res = _write_affinity_drop_in(unit, other_cpus, label)
            if res == 'wrote':
                _ok(f'{unit}: {label}')
            elif res == 'noop':
                _info(f'{unit}: already up-to-date ({label})')
            else:
                errors += 1
        print()

        _info('Running systemctl daemon-reload ...')
        r = _run(['systemctl', 'daemon-reload'], sudo=True)
        _ok('daemon-reload done') if r.returncode == 0 else _warn('daemon-reload reported errors')
        print()

        _info('Applying to running units via systemctl set-property --runtime ...')
        for unit, cpus in radiod_plan.items():
            if _apply_cpu_affinity_runtime(unit, cpus):
                _ok(f'{unit}: applied')
            else:
                _info(f'{unit}: not running or set-property unsupported')

        for unit in _AFFINITY_UNITS:
            glob_pat = unit.replace('@.service', '@*.service')
            r2 = _run(['systemctl', 'list-units', '--no-legend', '--no-pager',
                       '--state=running', '--output=json', glob_pat])
            try:
                instances = [u.get('unit', '') for u in _json.loads(r2.stdout)
                             if u.get('unit', '')]
            except Exception:
                instances = []
            if not instances and '@' not in unit:
                instances = [unit]
            for inst in instances:
                if _apply_cpu_affinity_runtime(inst, other_cpus):
                    _ok(f'{inst}: applied')
                else:
                    _info(f'{inst}: not running or set-property unsupported')
        print()

        if errors:
            _err(f'{errors} drop-in(s) failed to write')
            return 1
        _ok('CPU affinity policy applied')
        _info('(Services will fully enforce AllowedCPUs via cgroup after next restart)')

    print()
    return 0


def cmd_diag_cpu_freq(args) -> int:
    """Show and optionally apply per-CPU scaling_max_freq based on radiod CPU assignment."""
    topology  = getattr(args, '_topology_override', None) or \
                _load_topology(Path(args.topology) if args.topology else TOPOLOGY_PATH)
    cfg       = topology.get('cpu_freq', {})
    radiod_max_mhz = cfg.get('radiod_max_mhz', 3200)
    other_max_mhz  = cfg.get('other_max_mhz',  1400)
    do_apply  = getattr(args, 'apply', False)

    _heading('diag: CPU frequencies')

    if do_apply and os.geteuid() != 0:
        _err('--apply requires root  (sudo smd diag cpu-freq --apply)')
        return 1

    radiod_cpus = _get_radiod_cpus()
    cpu_count   = os.cpu_count() or 1

    _info(f'Policy:  radiod CPUs → {radiod_max_mhz} MHz max  |  '
          f'other CPUs → {other_max_mhz} MHz max')
    if radiod_cpus:
        _info(f'Radiod CPUs (CPUAffinity): {sorted(radiod_cpus)}')
    else:
        _warn('No radiod CPUAffinity detected — radiod may not be running')
    print()
    _info('  (Configure limits in /etc/sigmond/topology.toml  [cpu_freq])')
    print()

    # --reapply: re-execute the Proxmox host hookscript via SSH so freq
    # caps + vCPU pinning are restored without bouncing the VM.  Useful
    # when the host's governor / tuned reset scaling_max_freq, or when
    # the hookscript hasn't fired since the last host reboot.
    if getattr(args, 'reapply', False):
        if Path('/sys/devices/system/cpu/cpu0/cpufreq').exists():
            _err('--reapply only applies inside a Proxmox VM; bare metal '
                 'should use --apply')
            return 1
        if (Path('/etc/sigmond/install-state.env').exists()
                and not os.access('/etc/sigmond/install-state.env', os.R_OK)):
            if _need_root('cpu --reapply'):
                return 1
        state = _read_install_state()
        host = state.get('PROXMOX_HOST') if state else None
        vmid = state.get('VMID', '') if state else ''
        if not host or not vmid:
            _err('install-state.env missing PROXMOX_HOST / VMID — '
                 'cannot reach the host')
            return 1
        hookscript = f'/var/lib/vz/snippets/cpu-pin-{vmid}.sh'
        _info(f'Re-running {hookscript} on {host} as {state.get("PROXMOX_USER", "root")} ...')
        try:
            r = _ssh_proxmox_host(state, 'bash', hookscript, vmid, 'post-start',
                                  timeout=30)
        except subprocess.TimeoutExpired:
            _err('ssh timed out')
            return 1
        if r.returncode != 0:
            _err(f'hookscript returned {r.returncode}:')
            if r.stderr:
                print(r.stderr)
            return 1
        _ok('hookscript completed')
        # Show what the hookscript just logged via syslog, so the operator
        # sees the per-pCPU writes confirmed.
        log = _ssh_proxmox_host(state, 'journalctl', '-t', f'cpu-pin-{vmid}',
                                '--since', '30 seconds ago', '--no-pager', '-q',
                                timeout=10)
        if log.returncode == 0 and log.stdout.strip():
            for line in log.stdout.splitlines():
                _info(f'  {line}')
        return 0

    # No /sys/cpufreq at all → we're in a guest VM (KVM doesn't expose host
    # frequency scaling, and /proc/cpuinfo's "cpu MHz" inside KVM is the
    # calibration TSC value, not the live running freq).  The caps must be
    # set on the Proxmox host; print the policy here and tell the operator
    # how to verify on the host.
    if not Path('/sys/devices/system/cpu/cpu0/cpufreq').exists():
        # KVM doesn't expose host frequency scaling to the guest; fetch live
        # data over SSH using the same channel install.sh used for grub edits.
        # That requires reading /etc/sigmond/install-state.env (root-only)
        # plus the install-time SSH key at /root/.ssh/id_ed25519, so elevate
        # when the install-state file exists but isn't readable as us.
        if (Path('/etc/sigmond/install-state.env').exists()
                and not os.access('/etc/sigmond/install-state.env', os.R_OK)):
            if _need_root('cpu'):
                return 1
        state = _read_install_state()
        host = state.get('PROXMOX_HOST') if state else None
        if not host:
            _info('No /sys/cpufreq detected — running in a VM.')
            _info('No /etc/sigmond/install-state.env present, so I cannot reach')
            _info('the Proxmox host automatically.  Frequency caps are applied')
            _info('on the host hookscript at /var/lib/vz/snippets/cpu-pin-<vmid>.sh.')
            return 0

        rows = _fetch_host_cpu_freqs(state)
        if rows is None:
            _err(f'could not query host {host} via SSH '
                 f'(check /root/.ssh/id_ed25519 + reachability)')
            return 1
        roles = _fetch_host_cpu_pin_roles(state)

        _info(f"VM detected — live data from host {host} "
              f"(VMID {state.get('VMID', '?')})")
        print()
        # Header.
        print('  pCPU   cur MHz   max MHz   hw_max MHz   role     governor')
        print('  ' + '─' * 56)
        for r in rows:
            cur = r['cur_khz']  // 1000
            mx  = r['max_khz']  // 1000
            hw  = r['hw_max_khz'] // 1000
            role = roles.get(r['pcpu'], 'host')   # 'host' = not pinned to VM
            # Highlight the boosted/throttled ratio: < 50% of hw is throttled,
            # > 90% is at-or-near max.
            cur_frac = cur / hw if hw else 0
            marker = ' ⚡' if cur_frac >= 0.9 else ('  ' if cur_frac > 0.5 else ' ↓')
            print(f"  {r['pcpu']:4d}  {cur:8d}  {mx:8d}  {hw:11d}   "
                  f"{role:7s}  {r['governor']}{marker}")
        print()
        # Roll-up summary so the operator doesn't have to skim 16 rows.
        radiod = [r for r in rows if roles.get(r['pcpu']) == 'radiod']
        worker = [r for r in rows if roles.get(r['pcpu']) == 'worker']
        host_p = [r for r in rows if r['pcpu'] not in roles]
        for label, group in (('radiod', radiod), ('workers', worker), ('host  ', host_p)):
            if not group:
                continue
            cpus = ','.join(str(r['pcpu']) for r in group)
            cap  = max(r['max_khz']  for r in group) // 1000
            avg  = sum(r['cur_khz'] for r in group) // len(group) // 1000
            _info(f'  {label}  pCPUs[{cpus}]  cap={cap} MHz  '
                  f'avg cur={avg} MHz')

        if do_apply:
            print()
            _warn('--apply has no effect inside a VM; edit the host hookscript')
            _warn(f'(/var/lib/vz/snippets/cpu-pin-{state.get("VMID","<vmid>")}.sh)')
        return 0

    changes = 0
    errors  = 0

    for cpu in range(cpu_count):
        role       = 'radiod' if cpu in radiod_cpus else 'other '
        target_mhz = radiod_max_mhz if cpu in radiod_cpus else other_max_mhz
        target_khz = target_mhz * 1000

        freq_dir = Path(f'/sys/devices/system/cpu/cpu{cpu}/cpufreq')
        if not freq_dir.exists():
            _warn(f'cpu{cpu:2d}: no cpufreq sysfs — driver not loaded or VM?')
            continue

        try:
            current_khz = int((freq_dir / 'scaling_max_freq').read_text().strip())
        except (OSError, ValueError) as e:
            _warn(f'cpu{cpu:2d}: cannot read scaling_max_freq: {e}')
            continue

        avail_path = freq_dir / 'scaling_available_frequencies'
        if avail_path.exists():
            try:
                avail = sorted(int(f) for f in avail_path.read_text().split() if f.isdigit())
                candidates = [f for f in avail if f <= target_khz]
                nearest_khz = max(candidates) if candidates else (avail[0] if avail else target_khz)
            except (ValueError, IndexError):
                nearest_khz = target_khz
        else:
            nearest_khz = target_khz

        current_mhz = current_khz  // 1000
        nearest_mhz = nearest_khz // 1000

        if current_khz == nearest_khz:
            _ok(f'cpu{cpu:2d}  [{role}]  {current_mhz:5d} MHz  ✓')
        else:
            arrow = f'{current_mhz} → {nearest_mhz} MHz'
            if do_apply:
                try:
                    (freq_dir / 'scaling_max_freq').write_text(str(nearest_khz))
                    _ok(f'cpu{cpu:2d}  [{role}]  {arrow}  applied')
                    changes += 1
                except OSError as e:
                    _err(f'cpu{cpu:2d}: write failed: {e}')
                    errors += 1
            else:
                _warn(f'cpu{cpu:2d}  [{role}]  {arrow}  (run with --apply to set)')
                changes += 1

    print()
    if do_apply:
        if errors:
            _err(f'{errors} CPU(s) failed to update')
            return 1
        _ok(f'{changes} CPU(s) updated' if changes else 'All CPUs already match policy')
    else:
        if changes:
            _info(f'{changes} CPU(s) differ from policy')
        else:
            _ok('All CPUs match policy')

    return 0


def cmd_restart(args) -> int:
    if _need_root('restart'):
        return 1
    topology = _load_topology(Path(args.topology) if args.topology else TOPOLOGY_PATH)
    only = _resolve_only_list(args, topology)
    if only is not None and not only:
        return 0  # operator named only not-enabled components; already warned

    # Walk the requires closure for the same reason cmd_start does —
    # restarting a leaf without its deps would race or fail outright.
    if only is not None:
        try:
            from sigmond.catalog import load_catalog
            only = _expand_requires_closure(only, load_catalog())
        except Exception:
            pass
    enabled = _enabled_components(topology, only)

    # Same configured-before-start gate as cmd_start (see comment there
    # for the library-kind / alias-only filtering rationale).
    try:
        from sigmond.component_state import compute_state
        from sigmond.catalog import load_catalog
        topo_for_state = _load_topology(TOPOLOGY_PATH)
        catalog = load_catalog()
        startable: list[str] = []
        for name in enabled:
            entry = catalog.get(name)
            if entry is not None and getattr(entry, 'kind', None) == 'library':
                continue
            alias = getattr(entry, 'topology_alias', None) if entry else None
            s = compute_state(name, topo_for_state, alias=alias)
            if s.can_start or not s.cloned:
                startable.append(name)
            else:
                _warn(f'{name}: not restarted — {s.display_status}')
        enabled = startable
    except Exception:
        pass

    if not enabled:
        _warn('no restartable components — every enabled component needs install + config')
        return 0

    try:
        units = resolve_units(enabled, enabled)
    except ValueError as exc:
        _err(f"component resolution failed: {exc}")
        return 1

    # Filter to configured instances only
    units = [u for u in units if not u.orphaned]

    # Order: radiod first, then clients per coordination.toml (CONTRACT §5.4)
    if _HAS_SIGMOND_LIB:
        coord = load_coordination()
        units = order_units(units, coordination=coord)

    _heading('restart')
    any_failed = False
    for unit in units:
        # Reset any failed state before restarting
        _run(['systemctl', 'reset-failed', unit.unit], sudo=True)
        r = _run(['systemctl', 'restart', unit.unit], sudo=True)
        if r.returncode == 0:
            _ok(f'{unit.unit}')
        else:
            _err(f'{unit.unit}: {r.stderr.strip()}')
            any_failed = True
    return 1 if any_failed else 0


def cmd_reload(args) -> int:
    if _need_root('reload'):
        return 1
    topology = _load_topology(Path(args.topology) if args.topology else TOPOLOGY_PATH)
    only = _resolve_only_list(args, topology)
    if only is not None and not only:
        return 0  # operator named only not-enabled components; already warned
    enabled = _enabled_components(topology, only)

    try:
        units = resolve_units(enabled, enabled)
    except ValueError as exc:
        _err(f"component resolution failed: {exc}")
        return 1

    # Filter to configured instances only
    units = [u for u in units if not u.orphaned]

    # Order: radiod first, then clients per coordination.toml (CONTRACT §5.4)
    if _HAS_SIGMOND_LIB:
        coord = load_coordination()
        units = order_units(units, coordination=coord)

    _heading('reload')
    any_failed = False
    for unit in units:
        # Try systemctl reload first; fall back to try-restart
        r = _run(['systemctl', 'reload', unit.unit], sudo=True)
        if r.returncode == 0:
            _ok(f'{unit.unit}')
        else:
            # Fall back to try-restart
            r = _run(['systemctl', 'try-restart', unit.unit], sudo=True)
            if r.returncode == 0:
                _ok(f'{unit.unit} (via try-restart)')
            else:
                _err(f'{unit.unit}: {r.stderr.strip()}')
                any_failed = True
    return 1 if any_failed else 0


# smd status / list
# ---------------------------------------------------------------------------

def cmd_status(args) -> int:
    topology = _load_topology(Path(args.topology) if args.topology else TOPOLOGY_PATH)
    only = _resolve_only_list(args, topology)
    if only is not None and not only:
        return 0  # operator named only not-enabled components; already warned
    enabled = _enabled_components(topology, only)

    # ── action needed ────────────────────────────────────────────────────────
    if _HAS_SIGMOND_LIB:
        try:
            from sigmond.catalog import load_catalog, next_steps
            _catalog = load_catalog()
            _items = next_steps(enabled, _catalog)
            if _items:
                _heading('action needed')
                for kind, subject, action in _items:
                    if kind == 'install':
                        _warn(f'{subject}  —  enabled in topology but not yet installed')
                        _info(f'       run:  {action}')
                    elif kind == 'enable_dep':
                        _warn(subject)
                        _info(f'       fix:  {action}')
                print()
        except Exception:
            pass

    try:
        units = resolve_units(enabled, enabled)
    except ValueError as exc:
        _err(f"component resolution failed: {exc}")
        return 1

    _heading('status')
    any_bad = False

    # Group by component for display
    by_component: dict[str, list[UnitRef]] = {}
    for unit in units:
        if unit.component not in by_component:
            by_component[unit.component] = []
        by_component[unit.component].append(unit)

    for comp in sorted(by_component.keys()):
        comp_units = by_component[comp]
        print(f'\n  {comp}:')
        if not comp_units:
            _info('(no managed services)')
            continue

        for unit_ref in comp_units:
            # Check unit state
            r = _run(['systemctl', 'is-active', unit_ref.unit])
            state = r.stdout.strip() or 'unknown'
            sym = '✓' if state == 'active' else '✗'
            color = '\033[32m' if state == 'active' else '\033[31m'

            orphan_tag = ' [orphaned]' if unit_ref.orphaned else ''
            print(f'    {color}{sym}\033[0m  {unit_ref.unit}: {state}{orphan_tag}')

            if state not in ('active', 'inactive'):
                any_bad = True

    # Inventory enrichment for installed clients
    if _HAS_SIGMOND_LIB:
        try:
            catalog = load_catalog()
        except FileNotFoundError:
            catalog = {}
        seen = set()
        for comp in sorted(by_component.keys()):
            entry = get_entry(comp, catalog) if catalog else None
            if entry is None or entry.kind != 'client' or entry.name in seen:
                continue
            seen.add(entry.name)
            inv = _get_client_inventory(entry.name)
            if inv is None:
                continue
            version = inv.get('version', '?')
            contract = inv.get('contract_version', '?')
            instances = inv.get('instances', [])
            issues = inv.get('issues', [])
            git = inv.get('git', {})
            sha = git.get('short', '')
            sha_tag = f'  ({sha})' if sha else ''

            print(f'\n  {entry.name}  v{version}{sha_tag}  contract={contract}')
            for inst in instances:
                name = inst.get('instance', '?')
                channels = inst.get('ka9q_channels', 0)
                freqs = inst.get('frequencies_hz', [])
                modes = inst.get('modes', [])
                parts = [f'{channels} ch'] if channels else []
                if modes:
                    parts.append(f'modes={",".join(str(m) for m in modes)}')
                elif freqs:
                    parts.append(f'{len(freqs)} freqs')
                if _HAS_SIGMOND_LIB:
                    from sigmond.ui import format_data_path_tag
                    tag = format_data_path_tag(inst.get('data_path'))
                    if tag:
                        parts.append(tag)
                _info(f'{name}: {", ".join(parts)}' if parts else name)
            for issue in issues:
                sev = issue.get('severity', 'warn') if isinstance(issue, dict) else 'warn'
                msg = issue.get('message', str(issue)) if isinstance(issue, dict) else str(issue)
                if sev == 'fail':
                    _err(msg)
                else:
                    _warn(msg)

    # CPU affinity summary — one block, surfaced only when there's a
    # local radiod (otherwise there's nothing to protect).
    if _HAS_SIGMOND_LIB:
        try:
            from sigmond.cpu import build_affinity_report
            _aff_report = build_affinity_report()
        except Exception:
            _aff_report = None
        if _aff_report is not None and _aff_report.radiod_cpus:
            print('\n  CPU affinity:')
            _info(f'radiod cores: {sorted(_aff_report.radiod_cpus)} '
                  f'(other pool: {len(_aff_report.plan.other_cpus)} CPUs)')
            foreign_count = sum(len(u.foreign_drop_ins) for u in _aff_report.units)
            unenforced = [u.unit for u in _aff_report.units
                          if u.role == 'radiod' and u.main_pid
                          and not u.drop_in_present]
            pinned = [c for c in _aff_report.contention if not c.is_default]
            bad_gov = [cpu for cpu in _aff_report.radiod_cpus
                       if _aff_report.capabilities.governors.get(cpu) not in
                       (None, 'performance')]
            warnings = []
            if unenforced:
                warnings.append(
                    f'{len(unenforced)} radiod unit(s) unenforced — run '
                    f'sudo smd diag cpu-affinity --apply')
            if foreign_count:
                warnings.append(f'{foreign_count} foreign drop-in(s) present')
            if pinned:
                warnings.append(
                    f'{len(pinned)} pinned process(es) overlap radiod cores')
            if bad_gov:
                warnings.append(
                    f'governor not \'performance\' on cpus {sorted(bad_gov)}')
            if warnings:
                for w in warnings:
                    _warn(w)
                any_bad = True
            else:
                _ok('plan applied, no contention, no foreign drop-ins')

    _netdiag_status_line()

    print()
    return 1 if any_bad else 0


# ---------------------------------------------------------------------------
# smd log
# ---------------------------------------------------------------------------

def cmd_log(args) -> int:
    client = getattr(args, 'client', None)
    level = getattr(args, 'level', None)
    files = getattr(args, 'files', False)

    # --- set log level mode ---
    if level:
        topology = _load_topology(Path(args.topology) if args.topology else TOPOLOGY_PATH)
        key = set_log_level(client, level)
        _ok(f'{key}={level.upper()} written to coordination.env')

        if client:
            only = [client]
            enabled = _enabled_components(topology, only)
            if not enabled:
                enabled = [client]
            try:
                units = resolve_units(enabled, _enabled_components(topology))
                unit_names = [u.unit for u in units if not u.orphaned]
            except (ValueError, Exception):
                unit_names = []

            if unit_names:
                failed = send_sighup(unit_names)
                for u in unit_names:
                    if u in failed:
                        _warn(f'SIGHUP {u}: failed')
                    else:
                        _ok(f'SIGHUP {u}')
            else:
                _info(f'no units resolved for {client} — SIGHUP skipped')
        else:
            _info('CLIENT_LOG_LEVEL set; send SIGHUP to individual clients to apply')
        return 0

    # --- follow mode (requires a client name) ---
    if not client:
        _err('smd log: specify a client name (e.g. smd log psk-recorder)')
        return 1

    if files:
        log_paths = get_inventory_log_paths(client)
        if not log_paths:
            _err(f'{client}: no log_paths in inventory (is {client} installed?)')
            return 1
        paths = flatten_log_paths(log_paths)
        if not paths:
            _err(f'{client}: log_paths is empty')
            return 1
        missing = [p for p in paths if not Path(p).exists()]
        if missing:
            for m in missing:
                _warn(f'not found: {m}')
        existing = [p for p in paths if Path(p).exists()]
        if not existing:
            _err(f'{client}: none of the log files exist yet')
            return 1
        _info(f'tailing {len(existing)} file(s) for {client}...')
        follow_files(existing)
        return 0  # unreachable after exec

    # --- default: journalctl follow ---
    topology = _load_topology(Path(args.topology) if args.topology else TOPOLOGY_PATH)
    only = [client]
    enabled = _enabled_components(topology, only)
    if not enabled:
        enabled = [client]
    try:
        all_enabled = _enabled_components(topology)
        units = resolve_units(enabled, all_enabled)
        unit_names = [u.unit for u in units if not u.orphaned]
    except (ValueError, Exception):
        unit_names = []

    if not unit_names:
        try:
            from sigmond.catalog import load_catalog
            entry = load_catalog().get(client)
        except Exception:
            entry = None
        if entry is not None and not entry.is_installed():
            _err(f'{client}: enabled in topology but not installed. '
                 f'Install first:  sudo smd install {client}')
        else:
            _err(f'{client}: no systemd units resolved (no deploy.toml or '
                 f'fallback shim).  Is it fully installed?')
        return 1

    _info(f'following journal for: {", ".join(unit_names)}')
    follow_journal(unit_names)
    return 0  # unreachable after exec


# ---------------------------------------------------------------------------
# smd list — unified status surface (formerly `smd list` + `smd update`)
# ---------------------------------------------------------------------------

def _resolve_repo_dir(name: str, repo_url: str) -> Path | None:
    """Return the cloned repo path for a catalog entry, or None.

    Sigmond clients live under /opt/git/sigmond/<name>; non-sigmond infra
    repos (ka9q-radio, ka9q-web, ka9q-python) live in the general /opt/git/
    space and are matched by the URL stem.
    """
    primary = Path('/opt/git/sigmond') / name
    if primary.exists():
        return primary
    if repo_url:
        stem = repo_url.rstrip('/').rsplit('/', 1)[-1].removesuffix('.git')
        if stem and stem != name:
            fallback = Path('/opt/git') / stem
            if fallback.exists():
                return fallback
    return None


def _git_divergence(repo_dir: Path) -> tuple[str, str, int, int]:
    """Return (local_short, upstream_short, behind, ahead) for a repo.

    Uses cached upstream refs (no network). Empty strings + zeros if the
    repo has no upstream branch configured. behind = commits in upstream
    that are not in HEAD; ahead = commits in HEAD not in upstream.
    """
    sd = f'safe.directory={repo_dir}'
    local = subprocess.run(
        ['git', '-c', sd, '-C', str(repo_dir), 'rev-parse', '--short', 'HEAD'],
        capture_output=True, text=True,
    ).stdout.strip()
    up_ref = subprocess.run(
        ['git', '-c', sd, '-C', str(repo_dir),
         'rev-parse', '--abbrev-ref', '@{u}'],
        capture_output=True, text=True,
    )
    if up_ref.returncode != 0 or not up_ref.stdout.strip():
        return local, '', 0, 0
    upstream_name = up_ref.stdout.strip()
    upstream_sha = subprocess.run(
        ['git', '-c', sd, '-C', str(repo_dir), 'rev-parse', '--short',
         upstream_name],
        capture_output=True, text=True,
    ).stdout.strip()
    counts = subprocess.run(
        ['git', '-c', sd, '-C', str(repo_dir), 'rev-list',
         '--left-right', '--count', f'{upstream_name}...HEAD'],
        capture_output=True, text=True,
    )
    behind = ahead = 0
    if counts.returncode == 0 and counts.stdout.strip():
        try:
            parts = counts.stdout.strip().split()
            behind, ahead = int(parts[0]), int(parts[1])
        except (ValueError, IndexError):
            pass
    return local, upstream_sha, behind, ahead


def _git_commit_date(repo_dir: Path, ref: str = 'HEAD') -> str:
    """Short commit date (YYYY-MM-DD) of the given ref, or '' on failure."""
    sd = f'safe.directory={repo_dir}'
    r = subprocess.run(
        ['git', '-c', sd, '-C', str(repo_dir), 'log', '-1',
         '--format=%cs', ref],
        capture_output=True, text=True,
    )
    return r.stdout.strip() if r.returncode == 0 else ''


def _git_commit_index(repo_dir: Path, ref: str = 'HEAD') -> int:
    """Linear depth of `ref` (count of reachable commits).

    Acts as a monotonic local identifier — every new commit on a linear
    branch increments this by 1, so the operator can compare "where is
    each repo on its timeline" at a glance.  Returns 0 on failure.
    """
    sd = f'safe.directory={repo_dir}'
    r = subprocess.run(
        ['git', '-c', sd, '-C', str(repo_dir), 'rev-list', '--count', ref],
        capture_output=True, text=True,
    )
    try:
        return int(r.stdout.strip()) if r.returncode == 0 else 0
    except ValueError:
        return 0


def _is_binary_only_component(entry) -> bool:
    """True when a component's only systemd footprint is a template that
    no instance has ever materialized for.

    Canonical case: wspr-recorder ships `wspr-recorder@.service`, but
    wsprdaemon-client never runs an instance — it `os.execv`s the
    binary as a child of wd-ka9q-record instead.  Without this check,
    ComponentState labels wspr-recorder "enabled, stopped" forever.

    Detection: deploy.toml declares ONLY templated units (no concrete
    units), AND `systemctl list-units --type=service '<comp>@*'`
    returns nothing.  The systemctl query is the reliable signal —
    instance discovery via filesystem is too brittle (psk-recorder
    keys instances off `[[radiod]]` blocks in its own toml, with no
    matching .conf / .env files).  Best-effort: any failure falls
    through to False so the normal classifier still runs.
    """
    try:
        repo_dir = _resolve_repo_dir(entry.name, entry.repo)
        if repo_dir is None:
            return False
        deploy_path = repo_dir / 'deploy.toml'
        if not deploy_path.exists():
            return False
        import tomllib as _tomllib
        with open(deploy_path, 'rb') as f:
            cfg = _tomllib.load(f)
        sd = cfg.get('systemd', {}) or {}
        templated = list(sd.get('templated_units', []) or [])
        # `units` sometimes carries templated names under the deprecated
        # form (lifecycle.py auto-promotes); treat `<...>@...` names there
        # as templated for this purpose.
        for u in (sd.get('units', []) or []):
            if '@' in u:
                templated.append(u)
        concrete = [u for u in (sd.get('units', []) or []) if '@' not in u]
        if not templated or concrete:
            return False  # has an always-on service unit — not a tool

        # Ask systemd directly: does any instance of any template exist?
        for tpl in templated:
            base = tpl.split('@')[0]
            r = subprocess.run(
                ['systemctl', 'list-units', '--type=service',
                 '--all', '--no-legend', '--no-pager', f'{base}@*'],
                capture_output=True, text=True,
            )
            if r.stdout.strip():
                return False  # template has at least one instance
        return True
    except (OSError, Exception):
        return False


def _component_statuses(args, *, fetch: bool) -> list[dict]:
    """Build a status row per catalog component.

    Returns a list of dicts: {name, kind, lifecycle, repo_dir, local,
    local_date, upstream, upstream_date, behind, ahead, commit_index,
    dirty, dirty_reason, policy, verdict}.

    `fetch=True` runs `git fetch --quiet` per repo first so divergence is
    live; otherwise relies on whatever upstream refs were last cached.
    """
    try:
        catalog = load_catalog()
    except FileNotFoundError as exc:
        _err(str(exc))
        return []

    components_filter: set[str] | None = None
    if getattr(args, 'components', None):
        components_filter = {c.strip() for c in args.components.split(',')}

    from sigmond.topology import load_topology as _lib_load_topology
    topo = _lib_load_topology(
        Path(args.topology) if args.topology else TOPOLOGY_PATH
    )
    try:
        from sigmond.component_state import compute_state
    except Exception:
        compute_state = None

    rows: list[dict] = []
    for name in sorted(catalog):
        entry = catalog[name]
        if components_filter and name not in components_filter:
            continue
        # library-kind entries (e.g. ka9q-python) have no systemd units but
        # do have a repo on disk and a version policy — surface them so the
        # operator sees git divergence and can target them with --update.

        comp = topo.components.get(name)
        policy = (comp.version if comp else 'latest') or 'latest'

        # Lifecycle state — three regimes:
        #
        #   library   ka9q-python and friends.  No systemd units, never
        #             "running" — either importable from the venv or
        #             not.  ComponentState's cloned/installed/active
        #             chain doesn't apply; ask the catalog directly.
        #
        #   binary    Components whose deploy.toml declares only
        #             templated units that no other client instantiates
        #             (e.g. wspr-recorder, exec'd as a child by
        #             wd-ka9q-record).  ComponentState would label
        #             these "enabled, stopped"; in reality they're
        #             pure command-line tools.  Show "binary,
        #             on-PATH" / "binary, missing" so the operator
        #             isn't told to start something there's no service
        #             for.
        #
        #   service   The normal case — display_status drives the label.
        kind = getattr(entry, 'kind', '')
        lifecycle_label = '—'
        lifecycle_color = ''

        if kind == 'library':
            # Importability depends on which Python interpreter looks —
            # smd's own interpreter doesn't have client venvs' pip-
            # installed packages, so find_spec() from here gives a
            # false-negative on libraries that the running clients
            # plainly use.  Just label "library" and let the operator
            # judge by whether downstream clients work.
            lifecycle_label = 'library'
            lifecycle_color = '\033[32m'
        elif _is_binary_only_component(entry):
            on_path = shutil.which(entry.name) is not None
            if on_path:
                lifecycle_label = 'binary, on PATH'
                lifecycle_color = '\033[32m'
            else:
                lifecycle_label = 'binary, missing'
        elif compute_state is not None:
            try:
                state = compute_state(
                    name, topo,
                    alias=getattr(entry, 'topology_alias', None),
                )
                lifecycle_label = state.display_status
                if state.active:
                    lifecycle_color = '\033[32m'
                elif state.enabled or state.configured:
                    lifecycle_color = '\033[33m'
            except Exception:
                pass

        repo_dir = _resolve_repo_dir(name, entry.repo)
        if repo_dir is None:
            rows.append({
                'name': name,
                'kind': getattr(entry, 'kind', ''),
                'lifecycle': lifecycle_label,
                'lifecycle_color': lifecycle_color,
                'repo_dir': None,
                'local': '',
                'local_date': '',
                'upstream': '',
                'upstream_date': '',
                'behind': 0,
                'ahead': 0,
                'commit_index': 0,
                'dirty': False,
                'dirty_reason': '',
                'policy': policy,
                'verdict': 'not installed',
            })
            continue

        if fetch:
            subprocess.run(
                ['git', '-c', f'safe.directory={repo_dir}', '-C',
                 str(repo_dir), 'fetch', '--quiet'],
                capture_output=True, text=True,
            )

        local, upstream, behind, ahead = _git_divergence(repo_dir)
        local_date  = _git_commit_date(repo_dir, 'HEAD')
        commit_index = _git_commit_index(repo_dir, 'HEAD')
        upstream_date = ''
        if upstream:
            up_ref = subprocess.run(
                ['git', '-c', f'safe.directory={repo_dir}', '-C',
                 str(repo_dir), 'rev-parse', '--abbrev-ref', '@{u}'],
                capture_output=True, text=True,
            ).stdout.strip()
            if up_ref:
                upstream_date = _git_commit_date(repo_dir, up_ref)
        dirty, reason = _repo_is_dirty(repo_dir)

        # Verdict ladder — first match wins.
        if dirty:
            verdict = f'dirty: {reason}'
        elif policy == 'ignore':
            verdict = 'ignored (developer mode)'
        elif policy != 'latest':
            # Pinned ref. Drift either direction is a finding.
            verdict = (f'pinned to {policy}'
                       if local.startswith(policy[:7]) or local == policy
                       else f'pinned drift: at {local} (want {policy})')
        elif behind > 0:
            verdict = f'{behind} commit{"s" if behind != 1 else ""} behind upstream'
        elif ahead > 0:
            verdict = f'{ahead} unpushed commit{"s" if ahead != 1 else ""}'
        else:
            verdict = 'up to date'

        rows.append({
            'name': name,
            'kind': getattr(entry, 'kind', ''),
            'lifecycle': lifecycle_label,
            'lifecycle_color': lifecycle_color,
            'repo_dir': str(repo_dir),
            'local': local,
            'local_date': local_date,
            'upstream': upstream,
            'upstream_date': upstream_date,
            'behind': behind,
            'ahead': ahead,
            'commit_index': commit_index,
            'dirty': dirty,
            'dirty_reason': reason or '',
            'policy': policy,
            'verdict': verdict,
        })
    return rows


def _print_status_table(rows: list[dict]) -> None:
    if not rows:
        _info('(no components)')
        return

    # Fixed-width tabular layout — one line per component.  Columns are
    # sized so the common cases (enabled/stopped, up to date, latest) fit
    # without truncation; verbose hints in lifecycle (e.g. "missing — repo
    # not cloned") are split on ' — ' and only the leading state token is
    # shown.  INDEX is the linear depth of HEAD in history (a stable
    # monotonic id); BEHIND is the count of upstream commits not in HEAD.
    # The count moved into BEHIND, so verdict drops it ("3 behind" → "behind").
    W_NAME, W_LIFE, W_VERDICT, W_INDEX, W_BEHIND, W_DATE, W_UP_DATE, W_POLICY = (
        22, 18, 14, 7, 8, 12, 12, 8,
    )

    def _short_lifecycle(s: str) -> str:
        return s.split(' — ', 1)[0] if ' — ' in s else s

    def _short_verdict(v: str) -> str:
        if v.startswith('pinned drift'):
            return 'pinned drift'
        if v.startswith('pinned to '):
            return 'pinned'
        if v.startswith('dirty:'):
            return 'dirty'
        if 'behind upstream' in v:
            return 'behind'
        if 'unpushed commit' in v:
            return 'ahead'
        if v == 'ignored (developer mode)':
            return 'ignored'
        return v

    def _verdict_color(v: str) -> str:
        if v == 'up to date' or v.startswith('pinned to '):
            return '\033[32m'
        if v == 'ignored (developer mode)':
            return '\033[90m'
        if v.startswith('dirty:') or 'pinned drift' in v:
            return '\033[31m'
        if 'behind' in v or 'unpushed' in v:
            return '\033[33m'
        return ''

    print(
        f'  \033[1m{"NAME":<{W_NAME}}{"LIFECYCLE":<{W_LIFE}}'
        f'{"VERDICT":<{W_VERDICT}}{"INDEX":<{W_INDEX}}{"BEHIND":<{W_BEHIND}}'
        f'{"HEAD DATE":<{W_DATE}}{"UPSTREAM":<{W_UP_DATE}}'
        f'{"POLICY":<{W_POLICY}}\033[0m'
    )
    for r in rows:
        name    = r['name']
        ncol    = r['lifecycle_color']
        nreset  = '\033[0m' if ncol else ''
        life    = _short_lifecycle(r['lifecycle'])
        verdict = _short_verdict(r['verdict'])
        vcol    = _verdict_color(r['verdict'])
        vreset  = '\033[0m' if vcol else ''
        index   = str(r['commit_index']) if r['repo_dir'] and r['commit_index'] else ''
        behind  = str(r['behind'])       if r['repo_dir'] else ''
        date    = r['local_date']        if r['repo_dir'] else ''
        # UPSTREAM DATE column — colour yellow when local HEAD date is
        # older than upstream, so a stale checkout pops visually even
        # before the operator reads BEHIND.  When local==upstream the
        # value is identical to HEAD DATE; we still print it so the
        # column doesn't go blank on up-to-date rows (a blank field
        # would read as "missing", not "same as HEAD").
        up_date_raw = r.get('upstream_date', '') if r['repo_dir'] else ''
        if up_date_raw and date and up_date_raw > date:
            up_cell = f'\033[33m{up_date_raw:<{W_UP_DATE}.{W_UP_DATE}}\033[0m'
        else:
            up_cell = f'{up_date_raw:<{W_UP_DATE}.{W_UP_DATE}}'
        policy  = r['policy']

        print(
            f'  {ncol}{name:<{W_NAME}.{W_NAME}}{nreset}'
            f'{life:<{W_LIFE}.{W_LIFE}}'
            f'{vcol}{verdict:<{W_VERDICT}.{W_VERDICT}}{vreset}'
            f'{index:<{W_INDEX}.{W_INDEX}}'
            f'{behind:<{W_BEHIND}.{W_BEHIND}}'
            f'{date:<{W_DATE}.{W_DATE}}'
            f'{up_cell}'
            f'{policy:<{W_POLICY}.{W_POLICY}}'
        )


def _print_action_hint(rows: list[dict]) -> None:
    needs_apply = [r for r in rows
                   if r['repo_dir'] and not r['dirty']
                   and r['policy'] != 'ignore'
                   and (r['behind'] > 0 or
                        (r['policy'] != 'latest' and 'pinned drift' in r['verdict']))]
    if needs_apply:
        names = ', '.join(r['name'] for r in needs_apply)
        print()
        _info(f'{len(needs_apply)} component(s) have updates available: {names}')
        _info('run: sudo smd list --update  (preview: sudo smd list --update --dry-run)')


def _emit_status_json(rows: list[dict]) -> int:
    import json as _json
    print(_json.dumps(rows, indent=2))
    return 0


def _print_catalog(args) -> int:
    """Catalog of known clients (replaces old `smd list --available`)."""
    import json as _json
    try:
        catalog = load_catalog()
    except FileNotFoundError as exc:
        _err(str(exc))
        return 1

    if getattr(args, 'json', False):
        out = []
        for name, entry in sorted(catalog.items()):
            out.append({
                'name': entry.name,
                'kind': entry.kind,
                'description': entry.description,
                'repo': entry.repo,
                'uses': list(entry.uses),
                'contract': entry.contract,
                'install_script': entry.install_script,
                'installed': entry.is_installed(),
            })
        print(_json.dumps(out, indent=2))
        return 0

    def _print_entry(entry):
        sym = '✓' if entry.is_installed() else '·'
        col = '\033[32m' if entry.is_installed() else '\033[90m'
        contract_tag = f'  contract={entry.contract}' if entry.contract else ''
        print(f'    {col}{sym}\033[0m  {entry.name:22s} {entry.description}{contract_tag}')

    servers = [(n, e) for n, e in sorted(catalog.items()) if e.kind == 'server']
    clients = [(n, e) for n, e in sorted(catalog.items()) if e.kind == 'client']
    infra   = [(n, e) for n, e in sorted(catalog.items()) if e.kind == 'infra']

    _heading('catalog — known clients')
    if servers:
        print(f'\n  Servers ({len(servers)})')
        for _, e in servers: _print_entry(e)
    if clients:
        print(f'\n  Clients ({len(clients)})')
        for _, e in clients: _print_entry(e)
    if infra:
        print(f'\n  Infra ({len(infra)})')
        for _, e in infra: _print_entry(e)
    return 0


def _apply_updates(args, rows: list[dict]) -> int:
    """Pull each catalog repo per its version policy, then run `smd apply`.

    This is the action half of `smd list` — invoked when --update is given.
    Honors per-component version from topology.toml: 'ignore' is skipped,
    pinned refs are checked out, 'latest' (or absent) does ff-only pull.
    --ref overrides the policy.  Refuses to clobber dirty repos.
    """
    if _need_root('list --update'):
        return 1

    dry_run = getattr(args, 'dry_run', False)
    ref = getattr(args, 'ref', None)
    components_filter: set[str] | None = None
    if getattr(args, 'components', None):
        components_filter = {c.strip() for c in args.components.split(',')}

    try:
        catalog = load_catalog()
    except FileNotFoundError as exc:
        _err(str(exc))
        return 1

    from sigmond.topology import load_topology as _lib_load_topology
    _topo_obj = _lib_load_topology(
        Path(args.topology) if args.topology else TOPOLOGY_PATH
    )

    errors = 0
    pulled = 0  # count of repos whose HEAD actually advanced

    # --- sigmond self-update (only on full apply, not component-targeted) ---
    if not components_filter:
        sigmond_dir = Path(__file__).resolve().parent.parent
        if (sigmond_dir / '.git').exists():
            dirty, reason = _repo_is_dirty(sigmond_dir)
            if dirty:
                _warn(f'sigmond: skipping pull — {reason}')
                _warn('         commit, stash, or push before running smd list --update')
            elif dry_run:
                _info('sigmond: (dry-run) would pull and sync catalog')
            else:
                before = _git_head_ref(sigmond_dir)
                r = _git_pull_as_owner(sigmond_dir)
                if r.returncode != 0:
                    err_msg = (r.stderr.strip() or r.stdout.strip()
                               or 'git pull failed')
                    _err(f'sigmond: self-update failed — {err_msg}')
                    errors += 1
                else:
                    after = _git_head_ref(sigmond_dir)
                    if after != before:
                        _ok(f'sigmond: {before} → {after}')
                        pulled += 1
                    else:
                        _ok(f'sigmond: up to date ({after})')
                catalog_src = sigmond_dir / 'etc' / 'catalog.toml'
                catalog_dst = Path('/etc/sigmond/catalog.toml')
                if catalog_src.exists():
                    try:
                        import shutil as _shutil
                        if (not catalog_dst.exists()
                                or catalog_src.read_bytes() != catalog_dst.read_bytes()):
                            _shutil.copy2(str(catalog_src), str(catalog_dst))
                            _ok('sigmond: catalog updated')
                    except Exception as _exc:
                        _warn(f'sigmond: could not sync catalog: {_exc}')

    for name in sorted(catalog):
        entry = catalog[name]
        if components_filter and name not in components_filter:
            continue
        if not entry.repo:
            continue

        repo_dir = _resolve_repo_dir(name, entry.repo)
        if repo_dir is None:
            if components_filter:
                _warn(f'{name}: not installed — install first with: smd install {name}')
            continue

        comp = _topo_obj.components.get(name)
        comp_version = (comp.version if comp else 'latest') or 'latest'
        effective_ref = ref
        if effective_ref is None:
            if comp_version == 'ignore':
                _info(f'{name}: version = ignore — skipping')
                continue
            elif comp_version != 'latest':
                effective_ref = comp_version

        dirty, reason = _repo_is_dirty(repo_dir)
        if dirty:
            _warn(f'{name}: skipping pull — {reason}')
            _warn(f'         commit, stash, or push in {repo_dir} before running smd list --update')
            continue

        before = _git_head_ref(repo_dir) if not dry_run else '?'
        if dry_run:
            if comp_version == 'ignore' and ref is None:
                _info(f'{name}: (dry-run) would skip (version = ignore)')
            else:
                action = (f'checkout {effective_ref}'
                          if effective_ref else 'pull latest')
                _info(f'{name}: (dry-run) would {action}')
            continue

        try:
            _clone_repo(entry, pull_if_exists=True, ref=effective_ref)
            after = _git_head_ref(repo_dir)
            if after != before:
                _ok(f'{name}: {before} → {after}')
                pulled += 1
                if name == 'ka9q-radio':
                    _warn('ka9q-radio: source updated — rebuild binaries: smd install --components ka9q-radio')
            else:
                _ok(f'{name}: up to date ({after})')
        except RuntimeError as exc:
            _err(f'{name}: {exc}')
            errors += 1

    if dry_run:
        _info('(dry-run) no changes made')
        return 0

    if pulled > 0:
        args.dry_run = False
        apply_rc = cmd_apply(args)
        if apply_rc != 0:
            errors += 1

    if errors:
        _warn(f'apply finished with {errors} error(s)')
        return 1
    _ok('all components up to date')
    return 0


def cmd_list(args) -> int:
    """Unified status surface: per-component lifecycle + git state + version policy.

    Default (no flags): print the status table — read-only, safe to run as
    any user.  Adds an action hint at the bottom if anything is updatable.

    Flags:
      --update    Pull + reconcile (the old `smd update` / `--apply`).
                  Requires root.  `--apply` kept as a hidden alias.
      --catalog   Show the catalog of known clients (was `smd list --available`).
      --fetch     Run `git fetch` per repo before computing divergence.
      --json      Machine-readable output of the chosen mode.
      --components C1,C2  Restrict to these components.
      --ref R     With --update: force a specific ref.
      --dry-run   With --update: preview without making changes.
    """
    if getattr(args, 'catalog', False):
        return _print_catalog(args)

    # `--update` requires root, and _need_root re-execvps the whole command
    # under sudo when invoked as a non-root user — so any output produced
    # before this check is duplicated by the re-exec.  Check first.
    if getattr(args, 'update', False) and _need_root('list --update'):
        return 1

    fetch = getattr(args, 'fetch', False)
    rows = _component_statuses(args, fetch=fetch)

    if getattr(args, 'json', False):
        return _emit_status_json(rows)

    _print_status_table(rows)

    if not getattr(args, 'update', False):
        _print_action_hint(rows)
        return 0

    print()
    return _apply_updates(args, rows)


# ---------------------------------------------------------------------------
# smd diag
# ---------------------------------------------------------------------------

def _netdiag_auto_refresh(verb: str) -> None:
    """Ensure the net-diag cache is fresh before a mutating verb runs.

    Best-effort: any failure is non-fatal (we don't want a broken diag
    path to block install/apply/start). Prints a one-liner summary of
    the classification so the operator sees the network verdict every
    time they mutate state.

    When the cache is stale and we are root, the Tier-2 passive IGMP
    listen (~130 s) is launched as a detached background process so it
    never blocks the calling verb.  Results are written to the cache and
    also logged to /var/log/sigmond/net-diag.log.
    """
    if not _HAS_SIGMOND_LIB:
        return
    try:
        from sigmond import net_diag
    except Exception:
        return
    try:
        cache = net_diag.load_cache()
        if net_diag.is_cache_fresh(cache):
            report = net_diag._report_from_dict(cache['report'])
            # Only surface the cache verdict if it's a problem the operator
            # needs to act on. Healthy "lan-capable" stays silent.
            if report.classification in ('lan-needs-querier', 'lan-unsafe'):
                _warn(f'network: {report.classification} '
                      f'(cached {int(cache["age_s"]/60)}m ago)')
            return
        if os.geteuid() != 0:
            # Tier-1 only (no raw socket), completes quickly.
            report, _from_cache = net_diag.run_cached(
                listen_seconds=0, force=True)
            if report.classification in ('lan-needs-querier', 'lan-unsafe'):
                _warn(f'network: {report.classification}')
                for line in report.recommendation.split('. '):
                    line = line.strip().rstrip('.')
                    if line:
                        _warn(line)
        else:
            # Tier-2 passive IGMP listen takes ~130 s — never block the
            # calling verb.  Spawn a detached child to run it in the
            # background; results land in the cache for the next invocation.
            import datetime
            log_path = Path('/var/log/sigmond/net-diag.log')
            try:
                log_path.parent.mkdir(parents=True, exist_ok=True)
                lf = open(log_path, 'a')
                lf.write(f'\n# {datetime.datetime.now().isoformat()} '
                         f'— triggered by smd {verb}\n')
                lf.flush()
                smd_bin = sys.argv[0] if (sys.argv and
                                          os.path.isfile(sys.argv[0])) else 'smd'
                subprocess.Popen(
                    [smd_bin, 'diag', 'net'],
                    stdout=lf, stderr=lf,
                    start_new_session=True,
                    close_fds=True,
                )
                _info(f'network: IGMP diagnosis running in background '
                      f'→ {log_path}')
            except Exception as bg_exc:
                _warn(f'network: could not launch background diagnosis: {bg_exc}')
    except Exception as exc:
        # Diagnosis must never block a mutating verb.
        _warn(f'network diagnosis skipped: {exc}')


def _netdiag_status_line() -> None:
    """Render the cached classification as a block in `smd status`."""
    if not _HAS_SIGMOND_LIB:
        return
    try:
        from sigmond import net_diag
    except Exception:
        return
    cache = net_diag.load_cache()
    print('\n  network:')
    if cache is None:
        _info('no cached diagnosis — run: sudo smd diag net')
        return
    report = net_diag._report_from_dict(cache['report'])
    age_min = int(cache['age_s'] / 60)
    stale = ' [stale]' if not net_diag.is_cache_fresh(cache) else ''
    label = f'{report.classification} (checked {age_min}m ago){stale}'
    if report.classification == 'lan-capable':
        _ok(label)
    elif report.classification in ('lan-needs-querier', 'lan-unsafe'):
        _warn(label)
    else:
        _info(label)
    if report.queriers:
        q = report.queriers[0]
        _info(f'querier: v{q.version} {q.source} on {q.interface or "?"}')
    if report.classification in ('lan-needs-querier', 'lan-unsafe'):
        _info(f'fix: {report.recommendation}')


def cmd_diag_net(args) -> int:
    """Classify the host's network environment for multi-host radiod safety.

    Tier 1 checks run unprivileged (interface enum, /proc/net/igmp).
    Tier 2 (passive raw-socket IGMP listen) needs root; without it, we
    still classify from kernel state but may return 'unknown'.
    """
    import json as _json
    from sigmond import net_diag

    listen_s = getattr(args, 'listen', None)
    if listen_s is None:
        listen_s = 130
    iface = getattr(args, 'interface', None)
    want_json = getattr(args, 'json', False)

    # Progress callback for the passive listen — prints to stderr so
    # --json stdout stays clean. Skipped in JSON mode to keep logs tidy.
    def _progress(elapsed, total, n_queriers):
        if want_json:
            return
        suffix = f', {n_queriers} querier(s) seen' if n_queriers else ''
        print(f'  listening for IGMP queries... {elapsed}/{total} s{suffix}',
              file=sys.stderr, flush=True)

    prog = _progress if (os.geteuid() == 0 and listen_s > 0) else None

    try:
        report = net_diag.run(listen_seconds=listen_s, interface=iface,
                              progress=prog)
    except KeyboardInterrupt:
        _warn('interrupted before classification could complete')
        return 130
    # Explicit `smd diag net` always refreshes the cache so subsequent
    # fast verbs (status, list, validate) see the latest classification.
    if report.listen_root and report.classification != 'unknown':
        net_diag.save_cache(report)

    if want_json:
        _json.dump(report.to_dict(), sys.stdout, indent=2)
        sys.stdout.write('\n')
        return 0

    _heading('diag: network')

    # Interfaces
    _info('Interfaces:')
    for i in report.interfaces:
        if not i.is_up or i.is_loopback:
            continue
        tags = []
        if i.is_wireless:    tags.append('wireless')
        if i.is_bridge:      tags.append(f'bridge[{",".join(i.bridge_members) or "-"}]')
        if i.is_bond:        tags.append('bond')
        if i.is_overlay:     tags.append('overlay')
        if not i.has_multicast: tags.append('no-multicast')
        if i.is_default_route: tags.append('default-route')
        tag_str = f'  ({", ".join(tags)})' if tags else ''
        addrs = ', '.join(i.addrs_v4) or '(no v4)'
        print(f'         {i.name:<14s}  {addrs}{tag_str}')
    print()

    # Joined groups by interface (collapsed)
    if report.joined_groups:
        _info('Multicast groups joined (/proc/net/igmp):')
        by_iface: dict = {}
        for g in report.joined_groups:
            by_iface.setdefault(g.interface, []).append(g)
        for ifname, groups in sorted(by_iface.items()):
            ver = groups[0].igmp_version
            uniq = sorted({g.group for g in groups})
            non_local = [g for g in uniq if not g.startswith('224.0.0.')]
            local_count = len(uniq) - len(non_local)
            if non_local:
                extra = f'  [+{local_count} link-local]' if local_count else ''
                shown = ', '.join(non_local[:6]) + ('...' if len(non_local) > 6 else '')
            else:
                extra = ''
                shown = f'(link-local only: {local_count} group{"s" if local_count != 1 else ""})'
            print(f'         {ifname:<14s}  {ver}   {shown}{extra}')
        print()

    # Queriers
    if report.listen_root:
        if report.queriers:
            _info('IGMP queriers observed:')
            for q in report.queriers:
                qqic = f', QQIC={q.qqic_s}s' if q.qqic_s is not None else ''
                _ok(f'{q.interface or "?"}  v{q.version} from {q.source}  '
                    f'(max_resp={q.max_resp_ms}ms{qqic})')
        else:
            _info(f'IGMP queriers: none observed in {report.listen_seconds}s listen')
        for err in report.listen_errors:
            _warn(err)
        print()
    else:
        _info('IGMP queriers: passive listen skipped (re-run with sudo for '
              'definitive querier detection)')
        print()

    # Classification
    _info(f'Classification: {report.classification}')
    from sigmond.net_diag import CLASSES
    _info(f'  {CLASSES.get(report.classification, "")}')
    for reason in report.reasons:
        _info(f'  • {reason}')
    print()
    _info('Recommendation:')
    for line in report.recommendation.split('. '):
        line = line.strip().rstrip('.')
        if line:
            _info(f'  {line}.')
    print()
    return 0


def cmd_diag(args) -> int:
    topology = _load_topology(Path(args.topology) if args.topology else TOPOLOGY_PATH)
    client_dir = topology['client_dir']

    _heading('diagnostics')
    errors = 0

    # Network
    for host in ['wsprnet.org', 'graphs.wsprdaemon.org', 'logs.wsprdaemon.org']:
        r = _run(['ping', '-c1', '-W2', host])
        if r.returncode == 0:
            _ok(f'network: {host} reachable')
        else:
            _warn(f'network: {host} unreachable')

    # Deps commit check
    dcfg = _load_deps_conf(client_dir)
    if dcfg:
        print()
        _info('Dependency versions:')
        for dep in dcfg.sections():
            dep_type   = dcfg.get(dep, 'type', fallback='').strip()
            pinned     = dcfg.get(dep, 'commit', fallback='').strip()
            install_to = dcfg.get(dep, 'install_to', fallback='').strip()
            if dep_type == 'git' and install_to:
                r = _run(['git', '-c', f'safe.directory={install_to}',
                          '-C', install_to, 'rev-parse', 'HEAD'])
                current = r.stdout.strip()
                if r.returncode != 0 or not current:
                    _warn(f'{dep}: not installed at {install_to}')
                    errors += 1
                elif current.startswith(pinned[:12]):
                    _ok(f'{dep}: {current[:12]}')
                else:
                    _warn(f'{dep}: have {current[:12]}, want {pinned[:12]}')
                    errors += 1

    # Client self-validation
    if _HAS_SIGMOND_LIB:
        try:
            catalog = load_catalog()
        except FileNotFoundError:
            catalog = {}

        if catalog:
            only = [c.strip() for c in args.components.split(',')] if getattr(args, 'components', None) else None
            enabled = _enabled_components(topology, only)
            print()
            _info('Client validation:')
            seen = set()
            for comp in enabled:
                entry = get_entry(comp, catalog)
                if entry is None or entry.kind != 'client' or entry.name in seen:
                    continue
                seen.add(entry.name)
                val = _get_client_validate(entry.name)
                if val is None:
                    _info(f'  {entry.name}: validate unavailable')
                    continue
                ok = val.get('ok', False)
                if ok:
                    _ok(f'{entry.name}: all checks passed')
                else:
                    _warn(f'{entry.name}: validation failed')
                    errors += 1
                for issue in val.get('issues', []):
                    if isinstance(issue, dict):
                        sev = issue.get('severity', 'warn')
                        msg = issue.get('message', '')
                    else:
                        sev, msg = 'warn', str(issue)
                    if sev == 'fail':
                        _err(f'  {entry.name}: {msg}')
                    else:
                        _warn(f'  {entry.name}: {msg}')

    # Service health
    print()
    cmd_status(args)

    print()
    if errors:
        print(f'\033[33mdiag: {errors} issue(s) found\033[0m')
    else:
        print('\033[32mdiag: all checks passed\033[0m')
    return 0 if not errors else 1


# ---------------------------------------------------------------------------
# smd completion
# ---------------------------------------------------------------------------

_BASH_COMPLETION = r"""
# bash completion for smd
# Source this file or drop it in /etc/bash_completion.d/smd
# Generate with: smd completion bash

_smd_complete() {
    local cur prev words cword
    _init_completion 2>/dev/null || {
        cur="${COMP_WORDS[COMP_CWORD]}"
        prev="${COMP_WORDS[COMP_CWORD-1]}"
        words=("${COMP_WORDS[@]}")
        cword=$COMP_CWORD
    }

    # Keep alphabetical except for grouping by lifecycle/observe/configure.
    # When adding a new top-level verb, also add it here.  TODO: derive
    # this list from argparse rather than hand-maintaining it.
    local top_cmds="add software install apply enable disable remove start stop restart reload status list log config tui environment cpu diag validate watch verifier ka9q-watch psk-watch wspr-watch hfdl-watch codar-watch wisdom timestd-tune-storage storage public-ip completion"
    local components="radiod wspr-recorder hf-timestd psk-recorder wsprdaemon-client ka9q-web rac"
    local log_clients="wspr-recorder hf-timestd psk-recorder wsprdaemon-client"

    if [[ "$prev" == "--components" ]]; then
        COMPREPLY=($(compgen -W "$components" -- "$cur"))
        return
    fi

    if [[ "$prev" =~ ^(--topology|--from|--to|--client-dir|--input|--output)$ ]]; then
        COMPREPLY=($(compgen -f -- "$cur"))
        return
    fi

    if [[ "$prev" == "--level" ]]; then
        COMPREPLY=($(compgen -W "DEBUG INFO WARNING ERROR CRITICAL" -- "$cur"))
        return
    fi

    if [[ "$prev" == "--via" ]]; then
        COMPREPLY=($(compgen -W "auto systemd socket" -- "$cur"))
        return
    fi

    case $cword in
        1)
            COMPREPLY=($(compgen -W "$top_cmds" -- "$cur"))
            ;;
        2)
            case "${words[1]}" in
                install)
                    COMPREPLY=($(compgen -W "$components --components --client-dir --dry-run --yes --topology" -- "$cur"))
                    ;;
                apply)
                    COMPREPLY=($(compgen -W "--dry-run --topology" -- "$cur"))
                    ;;
                start|stop|status|restart)
                    COMPREPLY=($(compgen -W "$components --components --topology" -- "$cur"))
                    ;;
                reload)
                    COMPREPLY=($(compgen -W "$components --components --via --topology" -- "$cur"))
                    ;;
                list)
                    COMPREPLY=($(compgen -W "--update --apply --catalog --fetch --components --ref --dry-run --json --topology" -- "$cur"))
                    ;;
                log)
                    COMPREPLY=($(compgen -W "$log_clients --files --level --topology" -- "$cur"))
                    ;;
                diag)
                    COMPREPLY=($(compgen -W "cpu-affinity cpu-freq net --components --topology" -- "$cur"))
                    ;;
                cpu)
                    COMPREPLY=($(compgen -W "--apply --reapply --radiod-max-mhz --other-max-mhz --topology" -- "$cur"))
                    ;;
                validate)
                    COMPREPLY=($(compgen -W "--json --topology" -- "$cur"))
                    ;;
                config)
                    COMPREPLY=($(compgen -W "show migrate backup restore init edit" -- "$cur"))
                    ;;
                storage)
                    COMPREPLY=($(compgen -W "migrate-to-sqlite trim" -- "$cur"))
                    ;;
                software)
                    COMPREPLY=($(compgen -W "install apply" -- "$cur"))
                    ;;
                watch)
                    COMPREPLY=($(compgen -W "wspr psk hfdl codar ka9q uploads verifier" -- "$cur"))
                    ;;
                verifier)
                    COMPREPLY=($(compgen -W "report" -- "$cur"))
                    ;;
                completion)
                    COMPREPLY=($(compgen -W "bash" -- "$cur"))
                    ;;
                wspr-watch)
                    COMPREPLY=($(compgen -W "-v --verbose --instance --backlog --rejected -r" -- "$cur"))
                    ;;
                psk-watch|hfdl-watch|codar-watch)
                    COMPREPLY=($(compgen -W "-v --verbose --instance" -- "$cur"))
                    ;;
                ka9q-watch)
                    COMPREPLY=($(compgen -W "--ka9q-python --ka9q-radio --remote --branch --no-fetch --json" -- "$cur"))
                    ;;
                public-ip)
                    COMPREPLY=($(compgen -W "--no-v6 -q --quiet" -- "$cur"))
                    ;;
                tui)
                    COMPREPLY=()
                    ;;
            esac
            ;;
        *)
            case "${words[1]}" in
                storage)
                    case "${words[2]}" in
                        migrate-to-sqlite)
                            COMPREPLY=($(compgen -W "--yes" -- "$cur"))
                            ;;
                        trim)
                            COMPREPLY=($(compgen -W "--max-age --db --target-db --target-table --yes" -- "$cur"))
                            ;;
                    esac
                    ;;
                watch)
                    case "${words[2]}" in
                        wspr)
                            COMPREPLY=($(compgen -W "-v --verbose --instance --backlog --rejected -r" -- "$cur"))
                            ;;
                        psk|hfdl|codar)
                            COMPREPLY=($(compgen -W "-v --verbose --instance" -- "$cur"))
                            ;;
                        ka9q)
                            COMPREPLY=($(compgen -W "--ka9q-python --ka9q-radio --remote --branch --no-fetch --json" -- "$cur"))
                            ;;
                    esac
                    ;;
                software)
                    case "${words[2]}" in
                        install)
                            COMPREPLY=($(compgen -W "$components --components --client-dir --dry-run --yes --force --topology" -- "$cur"))
                            ;;
                        apply)
                            COMPREPLY=($(compgen -W "--dry-run --topology" -- "$cur"))
                            ;;
                    esac
                    ;;
                install)
                    COMPREPLY=($(compgen -W "$components --components --client-dir --dry-run --yes --topology" -- "$cur"))
                    ;;
                apply)
                    COMPREPLY=($(compgen -W "--dry-run --topology" -- "$cur"))
                    ;;
                start|stop|status|restart)
                    COMPREPLY=($(compgen -W "$components --components --topology" -- "$cur"))
                    ;;
                reload)
                    COMPREPLY=($(compgen -W "$components --components --via --topology" -- "$cur"))
                    ;;
                list)
                    COMPREPLY=($(compgen -W "--update --apply --catalog --fetch --components --ref --dry-run --json --topology" -- "$cur"))
                    ;;
                log)
                    COMPREPLY=($(compgen -W "$log_clients --files --level --topology" -- "$cur"))
                    ;;
                diag)
                    case "${words[2]}" in
                        cpu-affinity)
                            COMPREPLY=($(compgen -W "--components --threads --apply --json --topology" -- "$cur"))
                            ;;
                        cpu-freq)
                            COMPREPLY=($(compgen -W "--apply --reapply --radiod-max-mhz --other-max-mhz --topology" -- "$cur"))
                            ;;
                        net)
                            COMPREPLY=($(compgen -W "--interface --listen --json --topology" -- "$cur"))
                            ;;
                        *)
                            COMPREPLY=($(compgen -W "cpu-affinity cpu-freq net --components --topology" -- "$cur"))
                            ;;
                    esac
                    ;;
                validate)
                    COMPREPLY=($(compgen -W "--json --topology" -- "$cur"))
                    ;;
                config)
                    case "${words[2]}" in
                        show)
                            COMPREPLY=($(compgen -W "--json --topology" -- "$cur"))
                            ;;
                        migrate)
                            COMPREPLY=($(compgen -W "--from --to --write --force --topology" -- "$cur"))
                            ;;
                        backup)
                            COMPREPLY=($(compgen -W "--output" -- "$cur"))
                            ;;
                        restore)
                            COMPREPLY=($(compgen -W "--input" -- "$cur"))
                            ;;
                        init|edit)
                            COMPREPLY=($(compgen -W "$components radiod" -- "$cur"))
                            ;;
                        *)
                            COMPREPLY=($(compgen -W "show migrate backup restore init edit" -- "$cur"))
                            ;;
                    esac
                    ;;
                completion)
                    case "${words[2]}" in
                        bash)
                            COMPREPLY=($(compgen -W "--install" -- "$cur"))
                            ;;
                        *)
                            COMPREPLY=($(compgen -W "bash" -- "$cur"))
                            ;;
                    esac
                    ;;
                verifier)
                    case "${words[2]}" in
                        report)
                            COMPREPLY=($(compgen -W "--window --rx-call --lost --in-flight --delivered --cadence --rejected --silent-drop --json --db" -- "$cur"))
                            ;;
                        *)
                            COMPREPLY=($(compgen -W "report" -- "$cur"))
                            ;;
                    esac
                    ;;
            esac
            ;;
    esac
}

complete -F _smd_complete smd

# Short aliases for common smd subcommands.
# Add to your shell with: source <(smd completion bash)
smdt()   { smd tui "$@"; }
smdtui() { smd tui "$@"; }

# Re-source the completion script in-place — use this after smd is updated
# (`smd list --update`, a fresh `git pull` on the dev tree, etc.) so the
# current shell picks up newly-added subcommands / flags without having to
# log out + back in.  Has to be a shell function rather than an alias
# because `source <(...)` only takes effect when run in the caller's own
# scope, which aliases don't provide.
smdrefresh() {
    source <(smd completion bash) && echo "smd: tab-completion refreshed"
}

# smdt / smdtui take no subcommands; just complete --topology via file completion.
_smdt_complete() {
    local cur="${COMP_WORDS[COMP_CWORD]}"
    COMPREPLY=($(compgen -W "--topology" -- "$cur"))
    if [[ "$cur" == --topology* || "${COMP_WORDS[COMP_CWORD-1]}" == "--topology" ]]; then
        COMPREPLY=($(compgen -f -- "$cur"))
    fi
}
complete -F _smdt_complete smdt smdtui
"""


# ---------------------------------------------------------------------------
# wisdom — FFTW3 wisdom-file planner
# ---------------------------------------------------------------------------

# ────────────────────────────────────────────────────────────────────────────
# Proxmox host SSH — same mechanism install.sh uses to edit grub on the host.
#
# When sigmond is installed inside a Proxmox VM, install.sh stashes the host
# address and VMID in /etc/sigmond/install-state.env and pins an SSH key at
# /root/.ssh/id_ed25519 (mirroring scripts/proxmox/lib.sh's `ssh_host`).  CPU
# frequency scaling lives on the host, not the guest, so wisdom-plan boosts
# the right pCPU by SSHing in.
# ────────────────────────────────────────────────────────────────────────────

_INSTALL_STATE_PATH = Path('/etc/sigmond/install-state.env')


def _read_install_state() -> dict:
    """Parse /etc/sigmond/install-state.env (KEY='value' lines).  {} on miss."""
    try:
        text = _INSTALL_STATE_PATH.read_text()
    except (FileNotFoundError, PermissionError):
        return {}
    out: dict = {}
    for line in text.splitlines():
        line = line.strip()
        if not line or line.startswith('#') or '=' not in line:
            continue
        key, _, val = line.partition('=')
        if len(val) >= 2 and val[0] == "'" and val[-1] == "'":
            val = val[1:-1]
        out[key] = val
    return out


def _ssh_proxmox_host(state: dict, *cmd: str,
                      timeout: float = 15) -> subprocess.CompletedProcess:
    """Run `cmd` on the Proxmox host as root via the install-time SSH key."""
    target = f"{state.get('PROXMOX_USER', 'root')}@{state['PROXMOX_HOST']}"
    return subprocess.run(
        ['ssh',
         '-o', 'BatchMode=yes',
         '-o', 'ConnectTimeout=10',
         '-o', 'StrictHostKeyChecking=accept-new',
         '-i', '/root/.ssh/id_ed25519',
         '-o', 'IdentitiesOnly=yes',
         target, *cmd],
        capture_output=True, text=True, timeout=timeout, check=False,
    )


def _ensure_proxmox_onboot(dry_run: bool = False) -> bool:
    """Reconcile Proxmox VM `onboot` to 1 if we can reach the host.

    Bare-metal hosts (no PROXMOX_HOST in install-state.env) → silent
    no-op.  Hosts that can't reach the Proxmox API or whose SSH key
    isn't authorized → one-line warning, no fix.  Already onboot=1
    → one-line ok and return False (nothing changed).

    Returns True iff a change was made.
    """
    state = _read_install_state()
    host = state.get('PROXMOX_HOST')
    vmid = state.get('VMID')
    if not host or not vmid:
        return False
    try:
        r = _ssh_proxmox_host(state, 'qm', 'config', vmid)
    except (subprocess.TimeoutExpired, OSError) as exc:
        _warn(f'proxmox onboot: cannot reach {host}: {exc}')
        return False
    if r.returncode != 0:
        _warn(f'proxmox onboot: qm config {vmid} failed on {host}: '
              f'{(r.stderr or r.stdout).strip()}')
        return False
    onboot = None
    for line in r.stdout.splitlines():
        if line.startswith('onboot:'):
            onboot = line.split(':', 1)[1].strip()
            break
    if onboot == '1':
        _ok(f'proxmox: VM {vmid} on {host} onboot=1')
        return False
    if dry_run:
        _info(f'proxmox: would set VM {vmid} on {host} onboot=1 '
              f'(currently: {onboot!r})')
        return False
    r2 = _ssh_proxmox_host(state, 'qm', 'set', vmid, '--onboot', '1')
    if r2.returncode == 0:
        _ok(f'proxmox: set VM {vmid} on {host} onboot=1 (was: {onboot!r})')
        return True
    _warn(f'proxmox onboot: qm set --onboot 1 failed: '
          f'{(r2.stderr or r2.stdout).strip()}')
    return False


# ---- host CPU cap helpers REMOVED — see commit history.
# amd-pstate-epp in active mode (the Proxmox default) treats
# scaling_max_freq as advisory; even with governor=powersave, EPP=power,
# and per-CPU boost=0 the firmware kept the host pCPUs at ~2.5 GHz under
# load.  A hard cap would require switching the host to amd-pstate=passive
# globally, which would also clamp the radiod-pinned cores' boost
# headroom.  Operator preferred to accept the soft cap behaviour rather
# than ship a flag that didn't do what its name implied.
# Original implementation: sigmond commit b61dc58.



def _discover_pcpu_for_vcpu0(state: dict) -> int | None:
    """Return host pCPU id that VM vCPU 0 is pinned to.

    Reads /var/lib/vz/snippets/cpu-pin-<VMID>.sh on the host (rendered by
    sigmond install.sh from cpu-pin-VMID.sh.template) and grabs the first
    entry of RADIOD_CPUS.  Sequential vCPU pinning means RADIOD_CPUS[0]
    is the pCPU running vCPU 0.
    """
    vmid = state.get('VMID', '')
    if not vmid:
        return None
    try:
        r = _ssh_proxmox_host(
            state, 'cat', f'/var/lib/vz/snippets/cpu-pin-{vmid}.sh',
        )
    except subprocess.TimeoutExpired:
        return None
    if r.returncode != 0:
        return None
    for line in r.stdout.splitlines():
        m = re.match(r'^RADIOD_CPUS=\(([^)]+)\)\s*$', line.strip())
        if m:
            cpus = m.group(1).split()
            if cpus:
                try:
                    return int(cpus[0])
                except ValueError:
                    return None
    return None


def _fetch_host_cpu_freqs(state: dict) -> list[dict] | None:
    """SSH to the Proxmox host and read live freq + caps for every pCPU.

    Single batched shell script so we make one SSH round-trip even on a
    16-core box.  Returns one dict per pCPU sorted by id, or None on
    SSH/parse failure.
    """
    # IMPORTANT: pass as a single command string — see _wisdom_boost_cpu0
    # for the ssh-quoting lesson (multi-arg remote commands lose quoting).
    script = (
        'for d in /sys/devices/system/cpu/cpufreq/policy*/; do '
        'c=$(basename "$d" | sed "s/policy//"); '
        'cur=$(cat "${d}scaling_cur_freq" 2>/dev/null); '
        'mx=$(cat "${d}scaling_max_freq" 2>/dev/null); '
        'mn=$(cat "${d}scaling_min_freq" 2>/dev/null); '
        'hw=$(cat "${d}cpuinfo_max_freq" 2>/dev/null); '
        'gv=$(cat "${d}scaling_governor" 2>/dev/null); '
        'echo "$c $cur $mx $mn $hw $gv"; '
        'done'
    )
    try:
        r = _ssh_proxmox_host(state, script)
    except subprocess.TimeoutExpired:
        return None
    if r.returncode != 0:
        return None
    out: list[dict] = []
    for line in r.stdout.splitlines():
        parts = line.split()
        if len(parts) != 6:
            continue
        try:
            out.append({
                'pcpu': int(parts[0]),
                'cur_khz': int(parts[1]),
                'max_khz': int(parts[2]),
                'min_khz': int(parts[3]),
                'hw_max_khz': int(parts[4]),
                'governor': parts[5],
            })
        except ValueError:
            continue
    return sorted(out, key=lambda r: r['pcpu']) if out else None


def _fetch_host_cpu_pin_roles(state: dict) -> dict:
    """Parse /var/lib/vz/snippets/cpu-pin-<VMID>.sh on the host.

    Returns {pcpu_id: 'radiod'|'worker'} for pCPUs the hookscript pinned
    to this VM; pCPUs not in either list are presumed unpinned/host-side.
    Empty dict if the hookscript can't be read.
    """
    vmid = state.get('VMID', '')
    if not vmid:
        return {}
    try:
        r = _ssh_proxmox_host(
            state, 'cat', f'/var/lib/vz/snippets/cpu-pin-{vmid}.sh',
        )
    except subprocess.TimeoutExpired:
        return {}
    if r.returncode != 0:
        return {}
    roles: dict = {}
    for line in r.stdout.splitlines():
        line = line.strip()
        for prefix, role in (('RADIOD_CPUS=(', 'radiod'),
                             ('WORKER_CPUS=(', 'worker')):
            if line.startswith(prefix):
                inside = line[len(prefix):].rstrip(')').strip()
                for c in inside.split():
                    try:
                        roles[int(c)] = role
                    except ValueError:
                        pass
    return roles


def _wisdom_boost_cpu0() -> dict:
    """Save current scaling_max_freq and boost to cpuinfo_max_freq.

    On a Proxmox-managed VM, operates on the host pCPU pinned to vCPU 0;
    on bare metal, on local /sys.  Best-effort: failures degrade to a
    'noop' result and let the wisdom run continue at whatever the OS picks.
    """
    state = _read_install_state()
    if state.get('PROXMOX_HOST'):
        host = state['PROXMOX_HOST']
        try:
            pcpu = _discover_pcpu_for_vcpu0(state)
        except subprocess.TimeoutExpired:
            return {'mode': 'noop',
                    'reason': f'ssh to {host} timed out'}
        if pcpu is None:
            return {'mode': 'noop',
                    'reason': f'could not read cpu-pin hookscript on {host}'}
        remote_dir = f'/sys/devices/system/cpu/cpufreq/policy{pcpu}'
        sm_path = f'{remote_dir}/scaling_max_freq'
        try:
            r = _ssh_proxmox_host(
                state, 'cat', sm_path, f'{remote_dir}/cpuinfo_max_freq',
            )
        except subprocess.TimeoutExpired:
            return {'mode': 'noop',
                    'reason': f'ssh to {host} timed out reading freq'}
        if r.returncode != 0:
            return {'mode': 'noop',
                    'reason': f'ssh {host} freq read failed: '
                              f'{(r.stderr or r.stdout).strip() or "no output"}'}
        try:
            saved, hw_max = (int(x) for x in r.stdout.split())
        except ValueError:
            return {'mode': 'noop',
                    'reason': f'unparseable freq response from {host}: {r.stdout!r}'}
        out = {'mode': 'proxmox', 'state': state, 'pcpu': pcpu, 'host': host,
               'remote_path': sm_path, 'saved_khz': saved,
               'hw_max_khz': hw_max, 'boosted_khz': None}
        if saved < hw_max:
            try:
                # IMPORTANT: pass the redirect as a single command string,
                # not as ('sh', '-c', '...').  ssh joins multi-arg remote
                # commands with bare spaces and the remote shell re-parses;
                # ('sh', '-c', 'echo X > Y') becomes `sh -c echo X > Y`
                # which means "run sh -c echo with $0=X, redirect stdout
                # to Y".  A bare newline gets written to scaling_max_freq
                # and the kernel rejects with EIO.
                w = _ssh_proxmox_host(state, f'echo {hw_max} > {sm_path}')
                if w.returncode == 0:
                    out['boosted_khz'] = hw_max
                else:
                    out['boost_error'] = (w.stderr or 'unknown').strip()
            except subprocess.TimeoutExpired:
                out['boost_error'] = f'ssh to {host} timed out writing freq'
        return out

    # Bare-metal path: write local sysfs.
    sm = Path('/sys/devices/system/cpu/cpu0/cpufreq/scaling_max_freq')
    hw = Path('/sys/devices/system/cpu/cpu0/cpufreq/cpuinfo_max_freq')
    if not (sm.exists() and hw.exists()):
        return {'mode': 'noop', 'reason': 'cpufreq sysfs unavailable'}
    try:
        saved = int(sm.read_text().strip())
        hw_max = int(hw.read_text().strip())
    except (OSError, ValueError) as exc:
        return {'mode': 'noop', 'reason': str(exc)}
    out = {'mode': 'local', 'sm_path': sm, 'saved_khz': saved,
           'hw_max_khz': hw_max, 'boosted_khz': None}
    if saved < hw_max:
        try:
            sm.write_text(f'{hw_max}\n')
            out['boosted_khz'] = hw_max
        except OSError as exc:
            out['boost_error'] = str(exc)
    return out


def _wisdom_restore_cpu0(b: dict) -> str | None:
    """Restore the saved scaling_max_freq.  Return error string on failure."""
    if b.get('boosted_khz') is None:
        return None
    saved = b['saved_khz']
    if b['mode'] == 'proxmox':
        try:
            # Single command string — see _wisdom_boost_cpu0 for why.
            r = _ssh_proxmox_host(
                b['state'], f"echo {saved} > {b['remote_path']}",
                timeout=10,
            )
        except subprocess.TimeoutExpired:
            return f"ssh to {b['host']} timed out"
        if r.returncode != 0:
            return (r.stderr or 'ssh failed').strip()
        return None
    if b['mode'] == 'local':
        try:
            b['sm_path'].write_text(f'{saved}\n')
        except OSError as exc:
            return str(exc)
    return None


def cmd_wisdom_plan(args) -> int:
    """Run fftwf-wisdom for every transform radiod uses; install /etc/fftw/wisdomf.

    Streams output line-by-line so an operator on a tmux/screen session
    can watch progress.  Profiles are smallest-first, so the early
    transforms land in seconds and the operator gets immediate visual
    confirmation that planning is moving — the multi-hour rof3240000
    is last.

    Refuses to run if any sigmond-managed services are still active —
    FFTW's planner picks the fastest implementation by literally
    benchmarking each candidate, and a busy CPU pollutes those numbers.
    Pass --no-install to keep the result at /etc/fftw/wisdomf.new
    instead of swapping it over /etc/fftw/wisdomf (useful when comparing
    runs).
    """
    from sigmond.wisdom import (
        FFT_WISDOM_PROFILES, WISDOM_FILE, WISDOM_TMP, WISDOM_LOG,
        install_wisdom,
    )

    fftwf = shutil.which('fftwf-wisdom')
    if fftwf is None:
        _err('fftwf-wisdom not on PATH; install it with: '
             'sudo apt-get install -y libfftw3-bin')
        return 1

    # Refuse to plan if anything is running.
    r = subprocess.run(
        ['systemctl', 'list-units', '--type=service', '--state=active',
         '--no-legend', '--no-pager',
         'radiod@*', 'timestd-*', 'psk-recorder@*'],
        capture_output=True, text=True,
    )
    busy = [line.split()[0] for line in r.stdout.splitlines() if line.strip()]
    if busy:
        _err(f'{len(busy)} sigmond-managed service(s) still active — '
             f'planning would benchmark on a busy CPU and produce wrong wisdom.')
        for u in busy[:6]:
            print(f'      {u}')
        if len(busy) > 6:
            print(f'      … and {len(busy) - 6} more')
        _info('Run:  sudo smd stop')
        _info('Then re-run:  sudo smd wisdom plan')
        return 1

    WISDOM_TMP.parent.mkdir(parents=True, exist_ok=True)

    # Pin to CPU 0 for the entire run.  FFTW's planner picks the
    # fastest implementation by literally benchmarking each candidate;
    # if the kernel migrates the process to a different core mid-plan,
    # cache behaviour shifts and the timings get noisy — leading to
    # suboptimal plans.  taskset's affinity is inherited by children,
    # so stdbuf and fftwf-wisdom both stay on CPU 0.
    cmd = ['taskset', '-c', '0',
           'stdbuf', '-oL', fftwf, '-v', '-T', '1',
           '-o', str(WISDOM_TMP), *FFT_WISDOM_PROFILES]

    # Stage the pCPU running vCPU 0 at its hardware-max frequency for the
    # duration of the run, then restore.  FFTW's planner is timing-sensitive
    # — running at a throttled `scaling_max_freq` produces both slower
    # planning AND a wisdom plan biased toward implementations that do well
    # at the throttled rate but not at full clock.  CPU frequency lives on
    # the host, not the guest; on a Proxmox VM (detected via /etc/sigmond/
    # install-state.env), this SSHes to the host using the same key
    # install.sh used for grub edits and writes the host pCPU's sysfs.
    # Best-effort: failures degrade to "run at whatever the OS picks".
    boost = _wisdom_boost_cpu0()

    _heading(f'wisdom plan ({len(FFT_WISDOM_PROFILES)} profiles)')
    _info(f'output:   {WISDOM_TMP}')
    _info(f'log:      {WISDOM_LOG}')
    _info(f'affinity: CPU 0  (single-core for stable FFTW timing measurements)')
    if boost['mode'] == 'proxmox':
        if boost.get('boosted_khz') is not None:
            _info(f"CPU freq:  host {boost['host']} pCPU {boost['pcpu']} via SSH: "
                  f"{boost['saved_khz']/1000:.0f} → {boost['boosted_khz']/1000:.0f} MHz "
                  f"(will restore on exit)")
        elif boost.get('boost_error'):
            _warn(f"CPU freq:  could not raise host pCPU {boost['pcpu']} on "
                  f"{boost['host']}: {boost['boost_error']} — running at host cap")
        else:
            _info(f"CPU freq:  host {boost['host']} pCPU {boost['pcpu']} already at "
                  f"hardware max ({boost['saved_khz']/1000:.0f} MHz)")
    elif boost['mode'] == 'local':
        if boost.get('boosted_khz') is not None:
            _info(f"CPU freq:  raised {boost['saved_khz']/1000:.0f} → "
                  f"{boost['boosted_khz']/1000:.0f} MHz (will restore on exit)")
        elif boost.get('boost_error'):
            _warn(f"CPU freq:  could not raise CPU 0: {boost['boost_error']}")
        else:
            _info(f"CPU freq:  already at hardware max "
                  f"({boost['saved_khz']/1000:.0f} MHz)")
    else:
        _info(f"CPU freq:  not boosted ({boost.get('reason', 'unknown')}) — "
              f"running at OS default")
    _info('this will take a long time — the rof3240000 transform alone '
          'can run for hours.  Open in a tmux/screen session if you '
          'plan to disconnect.')
    print()
    print('  $ ' + ' '.join(cmd))
    print()

    # Run synchronously in foreground; tee to log so disconnects don't
    # lose progress.  fftwf-wisdom emits progress lines on stderr; merge.
    # try/finally ensures the freq restore fires even on Ctrl-C / errors.
    start = time.monotonic()
    rc: int = 0
    try:
        try:
            with open(WISDOM_LOG, 'a') as logf:
                logf.write(f'\n# {time.strftime("%Y-%m-%dT%H:%M:%S%z")} '
                           f'— smd wisdom plan ({len(FFT_WISDOM_PROFILES)} profiles)\n')
                proc = subprocess.Popen(
                    cmd, stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
                    text=True, bufsize=1,
                )
                assert proc.stdout is not None
                for line in proc.stdout:
                    sys.stdout.write(line)
                    sys.stdout.flush()
                    logf.write(line)
                    logf.flush()
                rc = proc.wait()
        except KeyboardInterrupt:
            proc.terminate()
            proc.wait(timeout=5)
            _warn('aborted by operator (Ctrl-C)')
            return 130
    finally:
        if boost.get('boosted_khz') is not None:
            saved_mhz = boost['saved_khz'] / 1000
            err = _wisdom_restore_cpu0(boost)
            if err is None:
                if boost['mode'] == 'proxmox':
                    _info(f"CPU freq:  restored host pCPU {boost['pcpu']} on "
                          f"{boost['host']} → {saved_mhz:.0f} MHz")
                else:
                    _info(f"CPU freq:  restored to {saved_mhz:.0f} MHz")
            else:
                if boost['mode'] == 'proxmox':
                    _warn(f"could not restore host pCPU {boost['pcpu']} on "
                          f"{boost['host']} to {saved_mhz:.0f} MHz: {err} — "
                          f"on host run: echo {boost['saved_khz']} > "
                          f"{boost['remote_path']}")
                else:
                    _warn(f"could not restore CPU 0 freq to {saved_mhz:.0f} MHz: "
                          f"{err} — set manually with: echo {boost['saved_khz']} "
                          f"| sudo tee {boost['sm_path']}")

    elapsed = time.monotonic() - start
    if rc != 0:
        _err(f'fftwf-wisdom exited {rc} after {int(elapsed)}s')
        _info(f'partial output (if any) at {WISDOM_TMP}; log at {WISDOM_LOG}')
        return rc

    _ok(f'fftwf-wisdom finished in {int(elapsed // 3600)}h '
        f'{int((elapsed % 3600) // 60)}m {int(elapsed % 60)}s')

    if getattr(args, 'no_install', False):
        _info(f'--no-install: leaving result at {WISDOM_TMP}')
        _info(f'to install manually: sudo mv {WISDOM_TMP} {WISDOM_FILE}')
        return 0

    try:
        install_wisdom(WISDOM_TMP, WISDOM_FILE)
    except (FileNotFoundError, OSError) as exc:
        _err(f'could not install: {exc}')
        return 1
    _ok(f'installed → {WISDOM_FILE}')
    _info('Now: sudo smd start')
    return 0


def cmd_wisdom_status(args) -> int:
    """Show whether /etc/fftw/wisdomf exists and how recent it is."""
    from sigmond.wisdom import WISDOM_FILE
    if not WISDOM_FILE.exists():
        _warn(f'{WISDOM_FILE} does not exist — radiod will fall back to a '
              'fast (but suboptimal) "measure"-level plan at startup')
        _info('To generate:  sudo smd wisdom plan   (after sudo smd stop)')
        return 1
    st = WISDOM_FILE.stat()
    age_s = time.time() - st.st_mtime
    age_str = (f'{int(age_s / 86400)}d ago' if age_s > 86400
               else f'{int(age_s / 3600)}h ago' if age_s > 3600
               else f'{int(age_s / 60)}m ago')
    _ok(f'{WISDOM_FILE}  ({st.st_size:,} bytes, last updated {age_str})')
    return 0


# ---------------------------------------------------------------------------
# public-ip — quick lookup of this host's outbound IP
# ---------------------------------------------------------------------------

# Public IP resolvers, tried in order.  These are well-known plain-text
# echo services that return only the client's outbound IP, no JSON, no
# HTML — so a 200 OK whose body is a single IP address is the success
# signal.  Multiple resolvers give a fallback path when one is down or
# rate-limited, and let us cross-check that two independent sources
# agree (a defence against captive-portal / proxy mis-reporting).
_PUBLIC_IP_RESOLVERS_V4 = (
    'https://api.ipify.org',
    'https://ifconfig.me/ip',
    'https://icanhazip.com',
    'https://ipinfo.io/ip',
)
_PUBLIC_IP_RESOLVERS_V6 = (
    'https://api64.ipify.org',
    'https://ifconfig.co/ip',
)


def _fetch_public_ip(url: str, timeout: float = 5.0) -> Optional[str]:
    """Fetch a plain-text public-IP echo URL.  Returns the trimmed body
    on 2xx with what looks like an IP, None otherwise."""
    import urllib.request
    import urllib.error
    try:
        with urllib.request.urlopen(url, timeout=timeout) as resp:
            if 200 <= resp.status < 300:
                body = resp.read(64).decode('ascii', errors='replace').strip()
                # Sanity: must contain a digit and a '.' or ':' (rough
                # IPv4/IPv6 check; not strict because the body will be
                # well-formed if the service responded at all).
                if body and any(c.isdigit() for c in body) and (
                    '.' in body or ':' in body
                ):
                    return body
    except (urllib.error.URLError, TimeoutError, OSError):
        pass
    return None


def cmd_public_ip(args) -> int:
    """Show the host's outbound public IP (IPv4 and, if reachable, IPv6).

    Useful when you need to declare the station's WAN address to an
    upstream service (wsprdaemon.org RAC, the wsprnet "station map",
    a firewall rule on the router upstream of this host) and you
    don't want to fiddle with curl + a third-party site by hand.

    Probes a small list of well-known plain-text echo services in
    order.  If two resolvers agree the IP is trusted; if they
    disagree the result is shown with a warning so the operator can
    investigate (CGNAT, dual-WAN, captive portal).
    """
    show_v6 = bool(getattr(args, 'v6', True))
    quiet = bool(getattr(args, 'quiet', False))

    if not quiet:
        _heading('public IP')

    def _consensus(urls, label):
        results: list[tuple[str, str]] = []
        for u in urls:
            ip = _fetch_public_ip(u)
            if ip is not None:
                results.append((u, ip))
                # Two agreements is enough; stop probing to keep this fast.
                ips_seen = {r[1] for r in results}
                if len(ips_seen) == 1 and len(results) >= 2:
                    break
        if not results:
            return None, []
        # Pick the most-agreed-upon IP.
        counts: dict[str, int] = {}
        for _, ip in results:
            counts[ip] = counts.get(ip, 0) + 1
        winner = max(counts, key=counts.get)
        disagreers = [(u, ip) for u, ip in results if ip != winner]
        return winner, disagreers

    rc = 0
    v4, v4_disagree = _consensus(_PUBLIC_IP_RESOLVERS_V4, 'IPv4')
    if quiet:
        if v4:
            print(v4)
        else:
            rc = 1
    else:
        if v4:
            _ok(f'IPv4: {v4}')
            for u, ip in v4_disagree:
                _warn(f'  disagreement: {u} returned {ip}')
        else:
            _err('IPv4: no resolver responded')
            rc = 1

    if show_v6:
        v6, v6_disagree = _consensus(_PUBLIC_IP_RESOLVERS_V6, 'IPv6')
        if quiet:
            if v6:
                print(v6)
        else:
            if v6 and ':' in v6:
                _ok(f'IPv6: {v6}')
                for u, ip in v6_disagree:
                    _warn(f'  disagreement: {u} returned {ip}')
            elif v6:
                # The "v6" resolvers fall back to v4 if no v6 reachable;
                # don't report it as v6 in that case.
                if not quiet:
                    _info('IPv6: (not reachable; v6 resolvers returned v4)')

    return rc


def cmd_timestd_tune_storage(args) -> int:
    """Detect disk size and install prune drop-ins for hf-timestd retention.

    hf-timestd's `timestd-prune.timer` is upstream-defaulted to daily-at-
    03:00 with `--threshold 80 --min-days 2`.  At its default 9-channel
    metrology config raw_buffer grows ~2 GB/channel/day = ~20 GB/day.
    On hosts with <100 GB disk the daily cadence is too slow to prevent
    the buffer from filling the disk, and the 80 % threshold + 2-day
    floor combine to forbid eviction below 36 GB of raw_iq — which is
    larger than the entire disk on a typical small-VM deploy.

    This verb computes appropriate values from the disk total and writes
    sigmond drop-ins under
    `/etc/systemd/system/timestd-prune.{timer,service}.d/`:

        Disk total       Cadence    Threshold   Min raw_iq days
        --------------   --------   ---------   ---------------
        > 200 GB         daily      80 %        2     (upstream defaults)
        100-200 GB       6-hourly   70 %        2
        50-100 GB        hourly     65 %        1
        < 50 GB          hourly     60 %        1

    Default mode prints the recommendation and current state without
    writing.  Pass `--apply` to install the drop-ins (auto-elevates).
    """
    target_dir = Path('/var/lib/timestd')
    if not target_dir.exists():
        _info(f'{target_dir} not present — hf-timestd not installed?')
        return 0

    # Disk total/used for the filesystem hosting /var/lib/timestd.
    st = os.statvfs(str(target_dir))
    total_bytes = st.f_blocks * st.f_frsize
    avail_bytes = st.f_bavail * st.f_frsize
    used_pct = 100.0 * (total_bytes - avail_bytes) / total_bytes if total_bytes else 0
    total_gb = total_bytes / 1_000_000_000

    # Pick policy from disk total.
    if total_gb >= 200:
        cadence, threshold, min_days = 'daily-at-03:00 UTC', 80, 2
        cadence_calendar = '*-*-* 03:00:00 UTC'
        rationale = 'large disk — upstream defaults are fine'
    elif total_gb >= 100:
        cadence, threshold, min_days = '6-hourly', 70, 2
        cadence_calendar = '00/6:00:00'
        rationale = 'medium disk — slightly tighter than upstream'
    elif total_gb >= 50:
        cadence, threshold, min_days = 'hourly', 65, 1
        cadence_calendar = 'hourly'
        rationale = 'small disk — hourly prune to keep ahead of fill'
    else:
        cadence, threshold, min_days = 'hourly', 60, 1
        cadence_calendar = 'hourly'
        rationale = 'very small disk — aggressive eviction needed'

    _heading('hf-timestd storage tuning')
    _info(f'  disk:     {target_dir} on filesystem with '
          f'{total_gb:.1f} GB total ({used_pct:.0f}% used)')
    _info(f'  policy:   {cadence}, --threshold {threshold}, '
          f'--min-days {min_days}')
    _info(f'  rationale: {rationale}')
    print()

    timer_drop = (
        '# sigmond auto-tuned for this host (smd timestd-tune-storage).\n'
        f'# Disk total: {total_gb:.1f} GB → {cadence}.\n'
        '\n'
        '[Timer]\n'
        'OnCalendar=\n'
        f'OnCalendar={cadence_calendar}\n'
        'RandomizedDelaySec=300\n'
    )
    service_drop = (
        '# sigmond auto-tuned for this host (smd timestd-tune-storage).\n'
        f'# Disk total: {total_gb:.1f} GB → threshold={threshold}, '
        f'min_days={min_days}.\n'
        '\n'
        '[Service]\n'
        'ExecStart=\n'
        'ExecStart=/opt/hf-timestd/venv/bin/python -m hf_timestd.quota_manager \\\n'
        '    --data-root /var/lib/timestd \\\n'
        f'    --threshold {threshold} \\\n'
        f'    --min-days {min_days} \\\n'
        '    --max-derived-days 7 \\\n'
        '    --archive-root /mnt/timestd-archive \\\n'
        '    -v\n'
    )

    if not getattr(args, 'apply', False):
        _info('  (run with --apply to install drop-ins)')
        print()
        print(' --- timer drop-in (would write to '
              '/etc/systemd/system/timestd-prune.timer.d/sigmond-storage.conf) ---')
        print(timer_drop)
        print(' --- service drop-in (would write to '
              '/etc/systemd/system/timestd-prune.service.d/sigmond-storage.conf) ---')
        print(service_drop)
        return 0

    if _need_root('timestd-tune-storage --apply'):
        return 1

    timer_dir = Path('/etc/systemd/system/timestd-prune.timer.d')
    service_dir = Path('/etc/systemd/system/timestd-prune.service.d')
    timer_drop_path = timer_dir / 'sigmond-storage.conf'
    service_drop_path = service_dir / 'sigmond-storage.conf'

    timer_dir.mkdir(parents=True, exist_ok=True)
    service_dir.mkdir(parents=True, exist_ok=True)
    timer_drop_path.write_text(timer_drop)
    service_drop_path.write_text(service_drop)
    _ok(f'wrote {timer_drop_path}')
    _ok(f'wrote {service_drop_path}')

    rc = subprocess.run(['systemctl', 'daemon-reload']).returncode
    if rc != 0:
        _warn('systemctl daemon-reload failed; reload manually')
    else:
        _ok('systemctl daemon-reload OK')

    # If the timer is enabled, restart it so the new cadence takes effect.
    if Path('/etc/systemd/system/timestd-prune.timer').exists():
        rc = subprocess.run(
            ['systemctl', 'try-restart', 'timestd-prune.timer']
        ).returncode
        if rc == 0:
            _ok('timestd-prune.timer restarted with new cadence')
    return 0


def cmd_storage_migrate_to_sqlite(args) -> int:
    """Remove a local ClickHouse install once SQLite is the chosen sink.

    SQLite is the sigmond sink (see hamsci_sink.Writer.from_env).
    On hosts that were set up when ClickHouse was the only option, the
    `clickhouse-server` package + /var/lib/clickhouse + sigmond-clickhouse
    service unit keep consuming RAM and merge-CPU even after producer
    clients have moved over to SQLite.  This verb enumerates and (with
    --yes) removes those artifacts.

    Default behavior is dry-run.  --yes is required to actually stop
    services, purge packages, and delete data.
    """
    try:
        from sigmond.storage_migrate import (
            plan_clickhouse_removal, execute_removal, NotConfirmed,
        )
    except ImportError as e:
        _err(f"storage migration module not available: {e}")
        return 1

    apply = getattr(args, 'yes', False)
    if apply and _need_root('storage migrate-to-sqlite --yes'):
        return 1

    plan = plan_clickhouse_removal()

    if plan.is_empty:
        print("Storage is already migrated and correctly configured — "
              "nothing to do.")
        return 0

    # Distinguish "real CH still here" from "post-migration cleanup
    # (perms / explicit-pin) only" so the dry-run header doesn't lie
    # about what's about to happen.
    has_ch_remnant = bool(
        plan.services_to_stop or plan.services_to_disable
        or plan.packages_to_purge or plan.paths_to_remove
        or plan.files_to_remove or plan.env_lines_to_neutralize
    )
    if has_ch_remnant:
        print("ClickHouse artifacts detected on this host:")
    else:
        print("Post-migration cleanup pending "
              "(group / perms / sandbox / explicit pin):")
    print()
    if plan.group_to_create:
        print(f"  Group to create:  {plan.group_to_create}")
    if plan.users_to_add_to_group:
        print("  Users to add to sink group:")
        for user, group in plan.users_to_add_to_group:
            print(f"    - {user} → {group}")
    if plan.sink_dir_to_setup:
        path, group, mode = plan.sink_dir_to_setup
        print(f"  Sink dir to configure: {path} ({oct(mode)} root:{group})")
    if plan.sink_db_to_pre_create:
        path, group, mode = plan.sink_db_to_pre_create
        print(f"  Sink db to pre-create: {path} ({oct(mode)} root:{group})")
    if plan.sandbox_dropins_to_write:
        print("  systemd sandbox drop-ins to write (ReadWritePaths fix):")
        for dropin_path, unit in plan.sandbox_dropins_to_write:
            print(f"    - {dropin_path}  (for {unit})")
    if plan.env_lines_to_neutralize:
        # Show env neutralization first — it's what unblocks the
        # producers, and surfacing it up top makes the cause-and-effect
        # legible in the dry-run output.
        print("  Env lines to comment out (preserves audit trail):")
        for path, line in plan.env_lines_to_neutralize:
            print(f"    - {path}: {line}")
    if plan.env_lines_to_set:
        print("  Env lines to append (explicit SQLite pin):")
        for path, line in plan.env_lines_to_set:
            print(f"    - {path}: {line}")
    if plan.consumers_to_restart:
        print("  Producer services to restart (so they switch to SQLite):")
        for u in plan.consumers_to_restart:
            print(f"    - {u}")
    if plan.services_to_stop:
        print("  Services to stop:")
        for u in plan.services_to_stop:
            print(f"    - {u}")
    if plan.services_to_disable:
        print("  Services to disable:")
        for u in plan.services_to_disable:
            print(f"    - {u}")
    if plan.packages_to_purge:
        print("  Debian packages to purge:")
        for p in plan.packages_to_purge:
            print(f"    - {p}")
    if plan.paths_to_remove:
        print("  Directories to delete (data + config + venv):")
        for d in plan.paths_to_remove:
            print(f"    - {d}")
    if plan.files_to_remove:
        print("  Files to delete:")
        for f in plan.files_to_remove:
            print(f"    - {f}")
    print()

    if not apply:
        print("Dry run.  Re-run with --yes to apply the changes above.")
        if plan.paths_to_remove and any(
                p.startswith("/var/lib/clickhouse") for p in plan.paths_to_remove):
            print("WARNING: --yes will permanently delete /var/lib/clickhouse "
                  "and any rows it holds.  Drain unsent rows first if needed.")
        return 0

    print("Executing removal...")
    plan.confirmed = True
    try:
        if _HAS_SIGMOND_LIB:
            # Acquire the lifecycle lock — stopping clickhouse-server
            # counts as a service mutation, mustn't race with
            # smd start / stop / apply.
            with lifecycle_lock(reason='storage migrate-to-sqlite'):
                report = execute_removal(plan)
        else:
            report = execute_removal(plan)
    except NotConfirmed as e:  # belt-and-braces; we just set confirmed
        _err(str(e))
        return 1

    if report.group_created:
        print(f"  group created: {report.group_created}")
    if report.users_added_to_group:
        print(f"  group adds:    "
              + ", ".join(f"{u}->{g}" for u, g in report.users_added_to_group))
    if report.sink_dir_configured:
        print(f"  sink dir:      {report.sink_dir_configured}")
    if report.sink_db_pre_created:
        print(f"  sink db:       {report.sink_db_pre_created}")
    if report.sandbox_dropins_written:
        print(f"  drop-ins:      {', '.join(report.sandbox_dropins_written)}")
    if report.env_files_rewritten:
        print(f"  env rewritten: {', '.join(report.env_files_rewritten)}")
    if report.env_lines_appended:
        print("  env appended:  "
              + "; ".join(f"{p}: {l}" for p, l in report.env_lines_appended))
    if report.consumers_restarted:
        print(f"  restarted:     {', '.join(report.consumers_restarted)}")
    if report.stopped:
        print(f"  stopped:      {', '.join(report.stopped)}")
    if report.disabled:
        print(f"  disabled:     {', '.join(report.disabled)}")
    if report.purged:
        print(f"  purged:       {', '.join(report.purged)}")
    if report.removed_paths:
        print(f"  removed dirs: {', '.join(report.removed_paths)}")
    if report.removed_files:
        print(f"  removed file: {', '.join(report.removed_files)}")
    if report.errors:
        print()
        print("Errors (some artifacts may still be present):")
        for err in report.errors:
            print(f"  - {err}")
        return 2
    print()
    print("ClickHouse removal complete.")
    return 0


def _cmd_storage_trim_all(db_path, apply, *, plan_trim_all, execute_trim_all):
    """Apply per-target retention policies; one trim per (db,table).

    The policy set comes from sigmond.storage_trim.policy_from_env(),
    which folds env overrides (PSK_RETENTION_MIN, WSPR_RETENTION_MIN, …)
    over the per-target defaults and clamps anything below the min
    floor.  Each policy's clamp/source is reported so an operator can
    tell whether their PSK_RETENTION_MIN=10 silently became 30.
    """
    policy_plans = plan_trim_all(db_path)
    print(f"Trim-all from {db_path}")
    print("  Per-target retention policies:")
    any_rows = False
    for pp in policy_plans:
        pol, plan = pp.policy, pp.plan
        age_min = pol.max_age_seconds / 60.0
        print(f"    {pol.target_db}.{pol.target_table}: "
              f"retain {age_min:.0f} min  [{pol.source}]")
        if plan.is_empty:
            print(f"      → no rows older than threshold")
        else:
            any_rows = True
            for tdb, ttbl, n in plan.rows_per_target:
                print(f"      → {tdb}.{ttbl}: {n} rows")
    if not any_rows:
        print()
        print("Nothing to trim.")
        return 0
    if not apply:
        print()
        print("Dry run.  Re-run with --yes to apply the DELETEs above.")
        return 0
    print()
    print("Executing trim...")
    for pp in policy_plans:
        pp.plan.confirmed = True
    try:
        if _HAS_SIGMOND_LIB:
            with lifecycle_lock(reason="storage trim --all"):
                reports = execute_trim_all(policy_plans)
        else:
            reports = execute_trim_all(policy_plans)
    except Exception as exc:
        _err(f"trim execution failed: {exc}")
        return 2
    total_deleted = 0
    any_errors = False
    for pol, rep in reports:
        if rep.errors:
            any_errors = True
            for err in rep.errors:
                print(f"  ERROR {pol.target_db}.{pol.target_table}: {err}")
        if rep.rows_deleted:
            print(f"  {pol.target_db}.{pol.target_table}: "
                  f"deleted {rep.rows_deleted} rows")
            total_deleted += rep.rows_deleted
    print(f"  Total: {total_deleted} rows deleted")
    return 2 if any_errors else 0


def cmd_storage_trim(args) -> int:
    """Delete pending_uploads rows older than `--max-age` (or --all).

    The SQLite sink is a FIFO queue: producers append, the
    `hs-uploader` source `commit()`s acked rows.  Producers without a
    consumer wired (currently hfdl.spots and timestd.events — no
    external upload destination is configured for them) leave rows
    queued indefinitely; this verb provides a TTL-based cleanup.

    Two modes:
      * Default (--max-age): trim one (db,table) bracket at the given
        age.  Enforces the min retention floor (30 min default; override
        with TRIM_MIN_FLOOR_SECONDS).
      * --all: apply per-target retention policies from env
        (PSK_RETENTION_MIN, WSPR_RETENTION_MIN, ...).  Same floor.

    Default is dry-run: report what WOULD be deleted, do not touch
    the sink.  `--yes` actually runs the DELETE (requires root + the
    lifecycle lock so it can't race with `apply` / migrate).
    """
    try:
        from sigmond.storage_trim import (
            plan_trim, execute_trim, parse_duration, NotConfirmed,
            RetentionTooShort, DEFAULT_DB_PATH,
            plan_trim_all, execute_trim_all,
        )
    except ImportError as e:
        _err(f"storage trim module not available: {e}")
        return 1

    db_path = getattr(args, "db", None) or DEFAULT_DB_PATH
    apply = getattr(args, "yes", False)
    trim_all = getattr(args, "trim_all", False)
    if apply and _need_root("storage trim --yes"):
        return 1

    if trim_all:
        return _cmd_storage_trim_all(
            db_path, apply,
            plan_trim_all=plan_trim_all,
            execute_trim_all=execute_trim_all,
        )

    try:
        max_age_seconds = parse_duration(args.max_age)
    except ValueError as exc:
        _err(f"--max-age {args.max_age!r}: {exc}")
        return 2

    target_db = getattr(args, "target_db", None)
    target_table = getattr(args, "target_table", None)

    try:
        plan = plan_trim(
            db_path, max_age_seconds,
            target_db=target_db, target_table=target_table,
        )
    except RetentionTooShort as exc:
        _err(str(exc))
        return 2
    print(f"Trim from {plan.db_path}")
    print(f"  cutoff:  rows queued_at < {plan.cutoff_iso}")
    print(f"  max-age: {args.max_age}  ({max_age_seconds:.0f} s)")
    if target_db is not None or target_table is not None:
        scope = f"target_db={target_db or '*'}, target_table={target_table or '*'}"
        print(f"  filter:  {scope}")
    print()
    if plan.is_empty:
        print("  No rows older than threshold.")
        return 0
    for target_db, target_table, count in plan.rows_per_target:
        print(f"  {target_db}.{target_table}: {count} rows")
    print(f"  Total: {plan.total_rows} rows")

    if not apply:
        print()
        print("Dry run.  Re-run with --yes to apply the DELETE above.")
        return 0

    print()
    print("Executing trim...")
    plan.confirmed = True
    try:
        if _HAS_SIGMOND_LIB:
            with lifecycle_lock(reason="storage trim"):
                report = execute_trim(plan)
        else:
            report = execute_trim(plan)
    except NotConfirmed as e:  # belt-and-braces; we just set confirmed
        _err(str(e))
        return 1

    if report.errors:
        print()
        print("Errors:")
        for err in report.errors:
            print(f"  - {err}")
        return 2
    print(f"  deleted: {report.rows_deleted} rows")
    return 0


def _psk_watch_cycle_loop(
    log_path: Path, ft8_log: Path, ft4_log: Path,
    *, max_lines_per_mode: Optional[int],
) -> int:
    """Per-FT8-cycle psk-watch loop — default, N, and -v all share this.

    Every 15 s (FT8 cadence), after a settle window for the decoder
    to finish, read every new line that landed in `<instance>-ft8.log`
    and `<instance>-ft4.log` since the previous fire.  Two FT4 cycles
    (2 × 7.5 s) fit inside one FT8 cycle, so a 15 s window naturally
    catches "previous two FT4 cycles + most recent FT8 cycle".

    `max_lines_per_mode` controls per-spot detail:
      * `0`   (no args)  — summary line only, no per-spot detail.
      * `N`   (positional N) — show up to N spots per mode under
                                the summary (truncates after sort).
      * `None` (`-v`)    — show every spot, no cap.

    Loop cadence is wall-clock UTC: fire at the next 15 s boundary
    plus `SETTLE` seconds (4 s — long enough for decode_ft8 to finish
    even on a busy slot).  We track byte-position into each log
    instead of timestamp parsing — append-only, race-free.
    """
    SETTLE = 4.0
    SLOT_SEC = 15.0
    show_spots = max_lines_per_mode != 0
    _heading(f'PSK Reporter per-cycle activity ({log_path.name})')
    _info(f'   ▸ every {int(SLOT_SEC)} s (FT8 cadence) + {SETTLE:.0f} s settle:')
    if max_lines_per_mode is None:
        _info(f'     ALL FT8 spots from the last {int(SLOT_SEC)} s cycle')
        _info(f'     ALL FT4 spots from the last {int(SLOT_SEC)} s (= 2 × 7.5 s)')
    elif max_lines_per_mode > 0:
        _info(f'     first {max_lines_per_mode} spot'
              f'{"s" if max_lines_per_mode != 1 else ""} of each mode '
              f'(sorted by time then freq); summary below')
    else:
        _info(f'     summary counts only (pass N to see first N spots, '
              f'-v to see all)')
    _info('   Ctrl-C to exit.')
    print(flush=True)

    sudo_prefix = [] if os.geteuid() == 0 else ['sudo', '-n']

    def _file_size(p: Path) -> int:
        # `stat` via sudo when the daemon's logs are root-readable
        # only (uncommon but possible if the dir was relocated).
        try:
            return p.stat().st_size
        except (FileNotFoundError, PermissionError):
            try:
                r = subprocess.run(
                    [*sudo_prefix, 'stat', '-c', '%s', str(p)],
                    capture_output=True, text=True, check=False,
                )
                return int(r.stdout.strip()) if r.returncode == 0 else 0
            except (FileNotFoundError, ValueError):
                return 0

    def _read_since(p: Path, start: int) -> tuple[int, list]:
        end = _file_size(p)
        if end <= start:
            return start, []
        try:
            r = subprocess.run(
                [*sudo_prefix, 'tail', '-c', f'+{start + 1}', str(p)],
                capture_output=True, text=True, check=False,
            )
            text = r.stdout
        except FileNotFoundError:
            return start, []
        # The chunk we just read can extend a bit past `end` if the
        # daemon appended while we were reading — accept what we got
        # and resync `end` for the next pass.
        new_end = start + len(text.encode())
        lines = [l for l in text.splitlines() if l.strip()]
        return new_end, lines

    # Prime positions: start at the current end so we don't dump
    # historical content on first fire.
    ft8_pos = _file_size(ft8_log)
    ft4_pos = _file_size(ft4_log)

    import re as _re
    # Each spot line: "YYYY/MM/DD HH:MM:SS  SCORE  +DT  FREQ  ~  MSG"
    spot_re = _re.compile(r'^\d{4}/\d{2}/\d{2}\s+(\d{2}:\d{2}:\d{2})\s')

    def _key(line: str):
        """(time, freq) for sort.  Lines that don't parse sink to the end."""
        m = spot_re.match(line)
        parts = line.split()
        if not m or len(parts) < 5:
            return ('zz', 0.0)
        time_str = m.group(1)
        try:
            freq = float(parts[4].replace(',', ''))
        except ValueError:
            freq = 0.0
        return (time_str, freq)

    # Map a spot frequency to a ham-band label.  Upper bounds match
    # the spread covered by each band's FT8/FT4 channel — generous
    # enough that audio-offset wander (a few kHz around the channel
    # center) stays in the right bucket.
    _BAND_RANGES = [
        (2.0, '160m'), (4.0, '80m'), (5.5, '60m'), (10.0, '40m'),
        (14.0, '30m'), (18.0, '20m'), (21.0, '17m'),
        (24.5, '15m'), (28.0, '12m'), (50.0, '10m'), (54.0, '6m'),
    ]
    _BAND_ORDER = {label: idx
                   for idx, (_hi, label) in enumerate(_BAND_RANGES)}

    def _band(line: str) -> str:
        parts = line.split()
        if len(parts) < 5:
            return '??'
        try:
            mhz = float(parts[4].replace(',', '')) / 1e6
        except ValueError:
            return '??'
        for hi, label in _BAND_RANGES:
            if mhz < hi:
                return label
        return f'{mhz:.0f}MHz'

    def _bands_summary(lines: list) -> str:
        """Compact 'band:N band:N' string in canonical band order."""
        counts: dict = {}
        for line in lines:
            b = _band(line)
            counts[b] = counts.get(b, 0) + 1
        if not counts:
            return ''
        ordered = sorted(counts,
                         key=lambda b: _BAND_ORDER.get(b, 99))
        return ' '.join(f'{b}:{counts[b]}' for b in ordered)

    try:
        while True:
            # Next fire: next 15 s UTC boundary + SETTLE.
            now = time.time()
            next_boundary = math.ceil(now / SLOT_SEC) * SLOT_SEC
            fire_at = next_boundary + SETTLE
            time.sleep(max(0.1, fire_at - time.time()))

            ft8_pos, ft8_lines = _read_since(ft8_log, ft8_pos)
            ft4_pos, ft4_lines = _read_since(ft4_log, ft4_pos)

            # Sort each mode by (time, freq).  Within one 15 s FT8
            # window all FT8 timestamps are equal, so the sort is
            # effectively by frequency.  FT4 has two timestamps (the
            # two 7.5 s cycles), so the sort groups them naturally.
            ft8_lines.sort(key=_key)
            ft4_lines.sort(key=_key)

            wall = time.strftime('%H:%M:%S', time.gmtime(next_boundary))
            now_str = time.strftime('%H:%M:%S')

            # Slice to max_lines_per_mode if requested.  None = no cap.
            cap = max_lines_per_mode
            ft8_show = ft8_lines if cap is None else ft8_lines[:cap]
            ft4_show = ft4_lines if cap is None else ft4_lines[:cap]

            # Per-band counts come from the FULL list — the cap only
            # affects what we PRINT, not what we COUNT.
            ft8_bands = _bands_summary(ft8_lines)
            ft4_bands = _bands_summary(ft4_lines)
            ft8_bands_part = f' ({ft8_bands})' if ft8_bands else ''
            ft4_bands_part = f' ({ft4_bands})' if ft4_bands else ''

            if show_spots:
                # Detail path (cap=N or no-cap with -v): per-spot dump
                # bracketed by a slot heading, summary at the end.
                print(f'─── slot UTC {wall} ─────────────────────────────────',
                      flush=True)
                for line in ft8_show:
                    print(f'  ft8: {line}', flush=True)
                if cap is not None and len(ft8_lines) > len(ft8_show):
                    print(f'  ft8: … ({len(ft8_lines) - len(ft8_show)} more)',
                          flush=True)
                # Blank line between the FT8 block and the FT4 block
                # when both have content, and another blank between
                # the two FT4 cycle blocks.  Lines are already sorted
                # by (timestamp, freq), so a timestamp change marks a
                # cycle boundary.
                if ft8_show and ft4_show:
                    print(flush=True)
                prev_ts: str = ''
                for line in ft4_show:
                    m = spot_re.match(line)
                    this_ts = m.group(1) if m else ''
                    if prev_ts and this_ts and this_ts != prev_ts:
                        print(flush=True)
                    print(f'  ft4: {line}', flush=True)
                    prev_ts = this_ts
                if cap is not None and len(ft4_lines) > len(ft4_show):
                    print(f'  ft4: … ({len(ft4_lines) - len(ft4_show)} more)',
                          flush=True)
                if not ft8_lines and not ft4_lines:
                    print('  (no decodes this cycle)', flush=True)
                else:
                    print(f'  → ft8 total={len(ft8_lines)}{ft8_bands_part}   '
                          f'ft4 total={len(ft4_lines)}{ft4_bands_part}',
                          flush=True)
            else:
                # Summary path (no args, cap=0): one line per cycle.
                print(
                    f'[{now_str}] slot UTC {wall}  '
                    f'ft8={len(ft8_lines):>3}{ft8_bands_part}  '
                    f'ft4={len(ft4_lines):>3}{ft4_bands_part}',
                    flush=True,
                )
    except KeyboardInterrupt:
        return 130


def cmd_verifier_watch(args) -> int:
    """Live tail of upload-verifier passes.

    Verifiers run as background threads inside wspr-recorder.  Each
    pass fetches the upload server's recent spot set and confirms our
    locally-produced spots round-trip cleanly.

    Two verifiers exist today:

      * ``wsprnet-verifier`` (HTML scrape of wsprnet.org's olddb +
        local pending_uploads cleanup)
      * ``wsprdaemon-verifier`` (parallel ClickHouse queries against
        wd10/wd20/wd30; observe-only)

    Both emit lines of the same shape::

        <src>-verifier[<rx_sign>]: pass complete verified=N
            dropped_old=M wsprnet_set_size=K …

    The ``[<rx_sign>]`` tag is critical on multi-receiver hosts where
    two wspr-recorder@<id> instances run side by side: this watch
    displays the reporter as its own column so AC0G/B4 and AC0G/B5
    don't smear into a single confusing stream.  Pre-tag log lines
    (older builds without the ``[<rx_sign>]`` prefix) still display,
    with ``-`` in the reporter column.

    Startup and error lines from the verifier threads are also
    surfaced via a catch-all so a broken pass doesn't silently
    disappear.
    """
    instance = getattr(args, 'instance', None)
    if instance is None:
        unit_pattern = 'wspr-recorder@*'
    else:
        unit_pattern = f'wspr-recorder@{instance}.service'

    backlog_min = max(0, int(getattr(args, 'backlog', 60) or 0))

    import re as _re
    import datetime as _datetime

    # Per-pass summary line (the routine one — fires every ~5 min).
    # The reporter tag (``[<rx_sign>]``) is optional so pre-tag log
    # lines from older wspr-recorder builds still parse.
    #
    # The wsprdaemon-verifier also emits ``wsprdaemon_set_size`` and
    # ``wsprnet_set_size`` in the same line; we capture either via the
    # generic ``\w+_set_size`` form and pick the larger as the
    # displayed ``set=`` value (it's the firehose count when present,
    # the deduped wsprnet count otherwise).
    pass_re = _re.compile(
        r'(?P<src>[a-z][a-z0-9-]*)-verifier'
        r'(?:\[(?P<rx>[^\]]+)\])?:\s+pass\s+complete\s+'
        r'verified=(?P<v>\d+)\s+dropped_old=(?P<d>\d+)'
        r'(?:\s+(?:wsprdaemon|wsprnet|\w+)_set_size=(?P<set>\d+))?'
        r'(?:\s+wsprnet_set_size=(?P<set2>\d+))?'
        # Accept both names: ``missing_total`` (legacy, wsprdaemon-only)
        # and ``missing_wd_total`` (current; paired with ``missing_wn_total``).
        r'(?:\s+missing(?:_wd)?_total=(?P<miss_wd>\d+))?'
        r'(?:\s+missing_wn_total=(?P<miss_wn>\d+))?'
        r'(?:.*?\(totals\s+verified=(?P<tv>\d+)\s+dropped_old=(?P<td>\d+)\))?'
    )
    # Catch-all for non-pass-complete verifier lines (startup, fetch
    # warnings, per-server status, exceptions).  Capture the reporter
    # tag too so per-server detail aligns with the canonical line in
    # the displayed output.
    other_re = _re.compile(
        r'(?P<src>[a-z][a-z0-9-]*)-verifier'
        r'(?:\[(?P<rx>[^\]]+)\])?(?:[: ](?P<rest>.*))?$'
    )

    _heading(f'Upload-verifier activity ({unit_pattern})')
    _info('   ▸ one line per ~5 min verifier pass — confirms our spots')
    _info('     round-tripped through the upload server\'s recent set')
    _info(f'   ▸ replaying last {backlog_min} min of history')
    _info('   Ctrl-C to exit.')
    print(flush=True)

    sudo_prefix = [] if os.geteuid() == 0 else ['sudo', '-n']
    since_arg = ['--since', f'{backlog_min} min ago'] if backlog_min > 0 \
        else ['--since', 'now']
    try:
        proc = subprocess.Popen(
            [*sudo_prefix, 'journalctl', '-f',
             '-u', unit_pattern,
             '-o', 'cat', *since_arg],
            stdout=subprocess.PIPE,
        )
    except FileNotFoundError as exc:
        _err(f'journalctl not available: {exc}')
        return 1

    assert proc.stdout is not None
    import select as _select
    fd = proc.stdout.fileno()
    buf = b''

    def _next_line():
        nonlocal buf
        if b'\n' in buf:
            line, _, buf = buf.partition(b'\n')
            return line.decode('utf-8', errors='replace')
        return None

    try:
        while True:
            line = _next_line()
            if line is None:
                rlist, _w, _x = _select.select([fd], [], [], 1.0)
                if not rlist:
                    continue
                try:
                    chunk = os.read(fd, 65536)
                except OSError:
                    break
                if not chunk:
                    break
                buf += chunk
                continue

            wall = _datetime.datetime.now().strftime('%H:%M:%S')
            pm = pass_re.search(line)
            if pm:
                src = pm.group('src')
                rx = pm.group('rx') or '-'
                verified = int(pm.group('v'))
                dropped = int(pm.group('d'))
                # The wsprdaemon-verifier reports two set sizes
                # (wsprdaemon then wsprnet); show whichever pair the
                # line carries.  ``set`` captures the first, ``set2``
                # captures an explicit second one.
                set_size = pm.group('set')
                set_size_2 = pm.group('set2')
                if set_size and set_size_2:
                    set_part = f' set=wd:{set_size},wn:{set_size_2}'
                elif set_size:
                    set_part = f' set={set_size}'
                else:
                    set_part = ''
                # Cross-server divergence per table.  ``missing_wd``
                # is the wsprdaemon.spots delta (data-loss signal);
                # ``missing_wn`` is the wspr.rx mirror delta
                # (replication-lag signal).  Show whichever non-None
                # field the line carries; suppress zeros to keep the
                # all-agree pass concise.
                missing_wd = pm.group('miss_wd')
                missing_wn = pm.group('miss_wn')
                miss_bits = []
                if missing_wd and missing_wd != '0':
                    miss_bits.append(f'wd:{missing_wd}')
                if missing_wn and missing_wn != '0':
                    miss_bits.append(f'wn:{missing_wn}')
                if miss_bits:
                    missing_part = ' missing=' + ','.join(miss_bits)
                elif missing_wd is not None or missing_wn is not None:
                    # Field was reported but zero — say so explicitly
                    # so the operator sees "checked, all agree".
                    missing_part = ' missing=0'
                else:
                    missing_part = ''
                tv = pm.group('tv')
                td = pm.group('td')
                tot_part = ''
                if tv is not None and td is not None:
                    tot_part = f'   (since start: v={tv} d={td})'
                print(
                    f'[{wall}] {src:<10}  {rx:<10}  verified={verified:>3}  '
                    f'dropped_old={dropped:>3}{set_part}{missing_part}'
                    f'{tot_part}',
                    flush=True,
                )
                continue

            om = other_re.search(line)
            if om:
                src = om.group('src')
                rx = om.group('rx') or '-'
                # Trim everything up to and including the verifier name
                # + optional [rx_sign] so the visible payload is what
                # the verifier actually said about this pass.
                tail = line[om.start():]
                tail = _re.sub(
                    r'^[a-z0-9-]+-verifier(?:\[[^\]]+\])?[: ]\s*',
                    '', tail,
                )
                print(
                    f'[{wall}] {src:<10}  {rx:<10}  {tail}',
                    flush=True,
                )
                continue

    except KeyboardInterrupt:
        return 130
    finally:
        try:
            proc.terminate()
            proc.wait(timeout=2)
        except Exception:
            pass
    return 0


def cmd_uploads_watch(args) -> int:
    """Live tail of all spot-uploader services on this host.

    Two log sources are followed and tagged:

      * `journalctl -u wd-upload-hs@*` → WSPRnet (+ wsprdaemon.org SFTP
        when WD_SFTP_SERVERS is set).  Lines look like:
            `wspr-uploader-hs: shipped wsprdaemon=N wsprnet=M
                                       (total wsprdaemon=A wsprnet=B, work=W)`

      * `tail -F /var/log/psk-recorder/<id>.log` → PSK Reporter.  The
        uploader runs inside the recorder process and logs to a file,
        not the journal:
            `INFO:psk_recorder.core.hs_uploader_shim: psk-uploader-hs:
              shipped ft8=N ft4=M (total ft8=A ft4=B, work=W)`

    The two sources are followed by separate subprocesses and merged
    via select() — neither blocks the other.  Output is one line per
    shipped event, tagged with the target, plus running totals straight
    from the log payload so the operator can answer "is my call
    actually being reported?" without checking three web UIs.
    """
    backlog_min = max(0, int(getattr(args, 'backlog', 10) or 0))

    import re as _re
    import datetime as _datetime

    wspr_re = _re.compile(
        r'wspr-uploader-hs:\s+shipped\s+'
        r'wsprdaemon=(\d+)\s+wsprnet=(\d+)\s+'
        r'\(total\s+wsprdaemon=(\d+)\s+wsprnet=(\d+),\s+work=(\d+)\)'
    )
    psk_re = _re.compile(
        r'psk-uploader-hs:\s+shipped\s+'
        r'ft8=(\d+)\s+ft4=(\d+)\s+'
        r'\(total\s+ft8=(\d+)\s+ft4=(\d+),\s+work=(\d+)\)'
    )
    # WSPR-side log lines lead with the Python logger's
    # "YYYY-MM-DD HH:MM:SS,uuu" prefix; PSK-side lines do not (the
    # file logger uses the default Python format which omits time).
    # For PSK lines we substitute wall_now at the moment of receipt
    # — the lag is at most a few-hundred-ms tail buffering jitter.
    ts_re = _re.compile(r'^(\d{4}-\d{2}-\d{2})\s+(\d{2}:\d{2}:\d{2}),')

    _heading('Upload activity (WSPRnet + PSK Reporter)')
    _info('   ▸ one line per shipped batch — every ~60 s for WSPR,')
    _info('     every few seconds during a busy FT8 minute for PSK')
    if backlog_min > 0:
        _info(f'   ▸ replaying last {backlog_min} min of history')
    _info('   Ctrl-C to exit.')
    print(flush=True)

    sudo_prefix = [] if os.geteuid() == 0 else ['sudo', '-n']

    # --- WSPR side: journalctl follower ----------------------------------
    since_arg = ['--since', f'{backlog_min} min ago'] if backlog_min > 0 \
        else ['--since', 'now']
    try:
        jproc = subprocess.Popen(
            [*sudo_prefix, 'journalctl', '-f',
             '-u', 'wd-upload-hs@*',
             '-o', 'cat', *since_arg],
            stdout=subprocess.PIPE,
        )
    except FileNotFoundError as exc:
        _err(f'journalctl not available: {exc}')
        return 1

    # --- PSK side: file tail follower ------------------------------------
    # psk-recorder writes to /var/log/psk-recorder/<radiod_id>.log; the
    # SAME shipped events appear in the per-mode files too but the main
    # log is the canonical surface.  Glob accepts all configured
    # radiod_ids on this host.
    _PSK_LOG_GLOB = '/var/log/psk-recorder/*-rx888.log'
    psk_log_paths = sorted(Path('/var/log/psk-recorder').glob('*.log'))
    # Exclude the per-mode files — they contain decode_ft8 output, not
    # uploader lines, so they'd just be noise on the tail.
    psk_log_paths = [
        p for p in psk_log_paths
        if not (p.name.endswith('-ft8.log') or p.name.endswith('-ft4.log'))
    ]
    pproc = None
    if psk_log_paths:
        # `tail -F` follows by name (handles log rotation) and accepts
        # multiple files.  Backlog from `--backlog MIN` is deliberately
        # NOT replayed for the PSK side: the file log has no embedded
        # timestamps, so we can't accurately label old batches — every
        # backlog line would carry the same wall_now stamp.  WSPR
        # backlog through journalctl IS accurately timestamped and DOES
        # replay.  PSK batches arrive every few minutes so live-only is
        # enough to confirm "PSK reporter is being fed".
        try:
            pproc = subprocess.Popen(
                ['tail', '-F', '-n', '0', *map(str, psk_log_paths)],
                stdout=subprocess.PIPE,
            )
        except FileNotFoundError as exc:
            _err(f'tail not available: {exc}')

    # --- merged read loop ------------------------------------------------
    import select as _select
    assert jproc.stdout is not None
    j_fd = jproc.stdout.fileno()
    p_fd = pproc.stdout.fileno() if (pproc and pproc.stdout) else None

    j_buf = b''
    p_buf = b''

    def _emit_wspr(line: str) -> bool:
        m = wspr_re.search(line)
        if not m:
            return False
        wd_n, wn_n, wd_total, wn_total, work = m.groups()
        wd_n_i, wn_n_i = int(wd_n), int(wn_n)
        wd_total_i, wn_total_i = int(wd_total), int(wn_total)
        work_i = int(work)
        ts = ts_re.match(line)
        hms = ts.group(2) if ts else _datetime.datetime.now().strftime('%H:%M:%S')
        print(
            f'[{hms}] WSPRnet         '
            f'+{wn_n_i:>4} spots   '
            f'total={wn_total_i:>6}   '
            f'batch={work_i}',
            flush=True,
        )
        if wd_n_i > 0 or wd_total_i > 0:
            print(
                f'[{hms}] wsprdaemon.org  '
                f'+{wd_n_i:>4} spots   '
                f'total={wd_total_i:>6}   '
                f'batch={work_i}',
                flush=True,
            )
        return True

    def _emit_psk(line: str) -> bool:
        m = psk_re.search(line)
        if not m:
            return False
        ft8_n, ft4_n, ft8_total, ft4_total, work = m.groups()
        # PSK lines have no timestamp prefix in the file log — substitute
        # wall_now.  For backlog replay this means the displayed time is
        # "when the operator started watching", not "when the batch
        # actually shipped".  Acceptable: the running totals carry the
        # historical record.
        hms = _datetime.datetime.now().strftime('%H:%M:%S')
        print(
            f'[{hms}] PSKReporter     '
            f'+{int(ft8_n):>3} FT8 +{int(ft4_n):>3} FT4   '
            f'total={int(ft8_total):>5} FT8 {int(ft4_total):>4} FT4   '
            f'batch={int(work)}',
            flush=True,
        )
        return True

    def _drain(buf: bytes, emit) -> bytes:
        """Pop complete lines from buf, dispatch each to emit()."""
        while b'\n' in buf:
            line_bytes, _, buf = buf.partition(b'\n')
            emit(line_bytes.decode('utf-8', errors='replace'))
        return buf

    try:
        while True:
            fds = [j_fd] + ([p_fd] if p_fd is not None else [])
            rlist, _w, _x = _select.select(fds, [], [], 1.0)
            if j_fd in rlist:
                try:
                    chunk = os.read(j_fd, 65536)
                except OSError:
                    chunk = b''
                if not chunk:
                    # journalctl died; bail
                    break
                j_buf += chunk
                j_buf = _drain(j_buf, _emit_wspr)
            if p_fd is not None and p_fd in rlist:
                try:
                    chunk = os.read(p_fd, 65536)
                except OSError:
                    chunk = b''
                if not chunk:
                    p_fd = None  # tail died; carry on with journalctl
                else:
                    p_buf += chunk
                    p_buf = _drain(p_buf, _emit_psk)

    except KeyboardInterrupt:
        return 130
    finally:
        for proc in (jproc, pproc):
            if proc is None:
                continue
            try:
                proc.terminate()
                proc.wait(timeout=2)
            except Exception:
                pass
    return 0


def cmd_wspr_watch(args) -> int:
    """Per-cycle live view of wspr-recorder's WSPR pipeline.

    Watches `wspr-recorder@<id>.service` journals for the
    CycleBatcher's atomic per-cycle write event:

        cycle UTC HH:MM → N spots in wspr.spots (B bands, write Tms)

    This event fires exactly once per WSPR cycle (every 2 min),
    the instant after CycleBatcher commits a single transaction
    containing all bands' decoded spots into sigmond's
    `pending_uploads` table.  It IS the wake-up — no polling.

    On each cycle event we emit a one-line summary, then query
    sqlite directly for per-band counts (and per-spot detail in
    `-v` / N modes).  Rows are deleted by `wd-upload-hs` ~18 s
    after CycleBatcher writes, so the read happens in that window;
    for replayed backlog cycles the rows are already gone and we
    emit the journal-line summary only.

    Display modes:
      * default — one line per cycle: spots / bands / per-band counts
      * `N`     — same, + first N spots per band underneath
      * `-v`    — same, with ALL spots per band

    No more polling.  The CycleBatcher journal line is the only
    edge we care about — the producer tells us exactly when the
    decode cycle has fully landed.
    """
    instance = getattr(args, 'instance', None)
    if instance is None:
        unit_pattern = 'wspr-recorder@*'
    else:
        unit_pattern = f'wspr-recorder@{instance}.service'

    n_recent = int(getattr(args, 'recent', 0) or 0)
    verbose = bool(getattr(args, 'verbose', False))
    if verbose:
        cap: Optional[int] = None
    else:
        cap = n_recent if n_recent > 0 else 0
    show_spots = cap != 0
    backlog_min = max(0, int(getattr(args, 'backlog', 10) or 0))
    show_rejected = bool(getattr(args, 'rejected', False))

    import re as _re
    import datetime as _datetime
    # Cycle-write event line as emitted by wspr_recorder.spot_sink._flush().
    # With `journalctl -o cat` the systemd prefix is stripped and we see
    # the Python logger's own format:
    #   2026-05-12 21:42:31,897 - wspr_recorder.spot_sink - INFO -
    #     cycle UTC 02:40 → 62 spots in wspr.spots (9 bands, write 4 ms)
    # As of 2026-05-14 Phase 2 (in-process noise capture), spot_sink
    # also emits an optional ", N noise rows in wspr.noise" clause
    # between the spots count and the (B bands, write Tms) tail:
    #     cycle UTC 17:08 → 30 spots in wspr.spots, 15 noise rows in
    #         wspr.noise (4 bands, write 2 ms)
    # The noise clause is captured optionally so pre-Phase-2 hosts
    # without noise plumbing still parse correctly.
    cycle_re = _re.compile(
        r'cycle\s+UTC\s+(\d{2}):(\d{2})\s+\S+\s+'
        r'(\d+)\s+spots\s+in\s+wspr\.spots'
        r'(?:,\s+(\d+)\s+noise\s+rows\s+in\s+wspr\.noise)?\s+'
        r'\((\d+)\s+bands?,\s+(?:sqlite\s+)?write\s+(\d+)\s*ms\)'
    )
    # wd-upload-hs's per-pump line.  Two shapes — the simple one when
    # posted==added, and the "posted:N/added:M" shape when wsprnet
    # under-accepted.
    upload_re = _re.compile(
        r'wspr-uploader-hs:\s+shipped\s+wsprdaemon=\d+\s+'
        r'wsprnet=(?:posted:(\d+)/added:(\d+)|(\d+))\s+'
        r'\(total\s+wsprdaemon=\d+\s+'
        r'wsprnet=(?:posted:(\d+)/added:(\d+)|(\d+)),\s+work=(\d+)\)'
    )
    # Python logger's ISO-ish datetime prefix on the same line.  Local
    # wallclock (the logger format is %Y-%m-%d %H:%M:%S,%f).  We use
    # it only for the displayed [HH:MM:SS] tag; the cycle's UTC time
    # is the authoritative key for sqlite lookups.
    ts_re = _re.compile(r'^(\d{4}-\d{2}-\d{2})\s+(\d{2}:\d{2}:\d{2}),')

    _heading(f'WSPR cycle activity ({unit_pattern})')
    _info('   ▸ one line per WSPR cycle, fired by wspr-recorder\'s')
    _info('     CycleBatcher the instant all bands\' spots are committed')
    if cap is None:
        _info('   + ALL spots per band')
    elif cap > 0:
        _info(f'   + first {cap} spot{"s" if cap != 1 else ""} per band')
    if backlog_min > 0:
        _info(f'   ▸ replaying last {backlog_min} min of cycle events '
              '(per-band detail unavailable — rows already shipped)')
    _info('   Ctrl-C to exit.')
    print(flush=True)

    sudo_prefix = [] if os.geteuid() == 0 else ['sudo', '-n']
    since_arg = ['--since', f'{backlog_min} min ago'] if backlog_min > 0 \
        else ['--since', 'now']

    # `journalctl -f -u GLOB` bails out immediately ("Failed to add
    # filter for units: No data available") when none of its -u globs
    # match a unit that has ever logged — exactly the state before
    # wspr-recorder has run even once.  Probe first and, if there is
    # nothing to follow yet, wait politely instead of dying on that
    # cryptic error, so `smd wspr-watch` can be started ahead of
    # wspr-recorder and springs to life when it comes up.
    import time as _time
    watch_units = [unit_pattern, 'wd-upload-hs@*']

    def _journal_has_data() -> bool:
        probe = subprocess.run(
            [*sudo_prefix, 'journalctl', '-n', '1', '-q', '--no-pager',
             *[a for u in watch_units for a in ('-u', u)]],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        )
        return probe.returncode == 0

    if not _journal_has_data():
        _info(f'   ⏳ no journal data for {unit_pattern} yet — waiting '
              'for wspr-recorder to start (Ctrl-C to exit)')
        try:
            while not _journal_has_data():
                _time.sleep(3.0)
        except KeyboardInterrupt:
            print(flush=True)
            return 0
        _info('   ▸ wspr-recorder journal detected — following')

    try:
        # See cmd_psk_watch / cmd_hfdl_watch for the binary-pipe +
        # raw os.read rationale: select.select + TextIOWrapper interact
        # badly — buffered bytes hide from select after the first read.
        # Follow BOTH the recorder unit (cycle events) AND the uploader
        # unit (shipped events).  systemd's journal multiplexes them in
        # wall-clock order, so the merged stream reads naturally as
        # "cycle … shipped" pairs per WSPR period.
        proc = subprocess.Popen(
            [*sudo_prefix, 'journalctl', '-f',
             *[a for u in watch_units for a in ('-u', u)],
             '-o', 'cat', *since_arg],
            stdout=subprocess.PIPE,
        )
    except FileNotFoundError as exc:
        _err(f'journalctl not available: {exc}')
        return 1

    # --- per-cycle sqlite lookup helpers ----------------------------------
    _SINK_DB = Path('/var/lib/sigmond/sink.db')

    def _cycle_iso(hh: str, mm: str) -> str:
        """Map cycle UTC HH:MM → ISO time matching the sink payload."""
        now = _datetime.datetime.now(_datetime.timezone.utc)
        cycle = now.replace(hour=int(hh), minute=int(mm),
                            second=0, microsecond=0)
        # Cycle just past UTC midnight may appear in a journal line
        # logged a few minutes later; if our "today UTC" cycle lies in
        # the future, roll back one day.
        if cycle > now + _datetime.timedelta(minutes=5):
            cycle -= _datetime.timedelta(days=1)
        return cycle.strftime('%Y-%m-%dT%H:%M:00Z')

    def _query_cycle(cycle_iso: str):
        """Return [(band, callsign, grid, snr_db, dt, drift_hz_s,
        freq_hz, pwr_dbm), ...] for one cycle, or None on error / no rows.

        We open read-only so this never contends with the producer's
        writer thread.  Empty result (rows already shipped + deleted)
        is normal for backlog cycles."""
        if not _SINK_DB.exists():
            return None
        try:
            import sqlite3 as _sqlite3
            uri = f'file:{_SINK_DB}?mode=ro'
            con = _sqlite3.connect(uri, uri=True, timeout=2.0)
            try:
                cur = con.execute(
                    "SELECT json_extract(payload_json,'$.band'),"
                    "       json_extract(payload_json,'$.callsign'),"
                    "       json_extract(payload_json,'$.grid'),"
                    "       json_extract(payload_json,'$.snr_db'),"
                    "       json_extract(payload_json,'$.dt'),"
                    "       json_extract(payload_json,'$.drift_hz_per_s'),"
                    "       json_extract(payload_json,'$.frequency_hz'),"
                    "       json_extract(payload_json,'$.pwr_dbm') "
                    "FROM pending_uploads "
                    "WHERE target_db='wspr' AND target_table='spots' "
                    "  AND json_extract(payload_json,'$.time')=? "
                    "ORDER BY 1, 7, 2",
                    (cycle_iso,),
                )
                rows = cur.fetchall()
            finally:
                con.close()
            return rows
        except Exception:
            return None

    # --- rejected-spot lookup (--rejected flag) --------------------------
    # State across iterations: highest wsprnet_audit_batch.id we've shown
    # rejects for.  Bumped after each query so we don't replay history.
    # Initialized lazily on first query (we can't query before journal
    # data appears).
    _rejected_state = {'last_batch_id': None}

    def _query_rejected_since() -> list:
        """Return new rejected (spot_key, uploaded_at) since last call.

        Only meaningful when WSPRNET_BATCH_SIZE=1 — for larger batches
        n_posted > 1 and we can't attribute rejection to a specific
        spot_key.  Returns [] when the audit tables don't exist, the
        sink db is missing, or no new rejects since last call.
        """
        if not _SINK_DB.exists():
            return []
        try:
            import sqlite3 as _sqlite3
            uri = f'file:{_SINK_DB}?mode=ro'
            con = _sqlite3.connect(uri, uri=True, timeout=2.0)
            try:
                # Init last_batch_id on first call to avoid dumping
                # every historical rejection — we only want events
                # since the watch started.
                if _rejected_state['last_batch_id'] is None:
                    cur = con.execute(
                        "SELECT COALESCE(MAX(id), 0) "
                        "FROM wsprnet_audit_batch"
                    )
                    _rejected_state['last_batch_id'] = cur.fetchone()[0]
                    return []
                last_id = _rejected_state['last_batch_id']
                cur = con.execute(
                    """
                    SELECT a.spot_key, a.uploaded_at, b.id
                      FROM wsprnet_audit a
                      JOIN wsprnet_audit_batch b ON a.batch_id = b.id
                     WHERE b.id > ?
                       AND b.n_posted = 1
                       AND b.n_added = 0
                  ORDER BY b.id
                    """,
                    (last_id,),
                )
                rows = cur.fetchall()
                # Track the max id we've SEEN, not just rejected — so a
                # successful batch between rejected ones still bumps us
                # forward.  Cheap second query rather than tangling the
                # logic.
                cur = con.execute(
                    "SELECT COALESCE(MAX(id), ?) FROM wsprnet_audit_batch",
                    (last_id,),
                )
                _rejected_state['last_batch_id'] = cur.fetchone()[0]
                return rows
            finally:
                con.close()
        except Exception:
            return []

    def _format_rejected(spot_key: str) -> str:
        """spot_key format: '<cycle_iso>|<callsign>|<freq_hz>'."""
        try:
            cycle_iso, call, freq_hz = spot_key.split('|', 2)
            freq_mhz = f'{int(freq_hz) / 1_000_000:.6f}'
            cycle_short = cycle_iso[11:16]  # 'HH:MM'
        except (ValueError, TypeError):
            cycle_short = '?'
            call = spot_key
            freq_mhz = '?'
        return (f'             ↳ rejected by wsprnet  cycle {cycle_short}  '
                f'{call:>12}  @ {freq_mhz} MHz')

    # Band display order: low → high, with the 17 default bands first
    # so the per-band counts read naturally.  Unknown bands fall to end.
    _BAND_ORDER = {b: i for i, b in enumerate([
        '2200', '630', '160', '80', '80eu', '60', '60eu',
        '40', '30', '22', '20', '17', '15', '12', '10', '8', '6',
    ])}

    def _band_sort_key(b: str):
        return (_BAND_ORDER.get(b, 999), b)

    def _per_band_counts(rows):
        counts: dict = {}
        for r in rows:
            band = r[0] or '?'
            counts[band] = counts.get(band, 0) + 1
        return counts

    def _format_band_counts(counts: dict) -> str:
        if not counts:
            return ''
        ordered = sorted(counts, key=_band_sort_key)
        return ' '.join(f'{b}m:{counts[b]}' for b in ordered)

    def _format_spot(row) -> str:
        band, call, grid, snr_db, dt, drift, freq_hz, pwr = row
        try:
            freq_mhz = f'{float(freq_hz) / 1_000_000:.6f}'
        except (TypeError, ValueError):
            freq_mhz = '----.------'
        try:
            snr_i = int(snr_db)
        except (TypeError, ValueError):
            snr_i = 0
        try:
            dt_f = float(dt)
        except (TypeError, ValueError):
            dt_f = 0.0
        try:
            drift_f = float(drift)
        except (TypeError, ValueError):
            drift_f = 0.0
        try:
            pwr_i = int(pwr)
        except (TypeError, ValueError):
            pwr_i = 0
        grid_disp = (grid or '----')[:6]
        call_disp = (call or '?')[:12]
        return (f'           {(band or "?"):>4}m  '
                f'{freq_mhz:>11} MHz  '
                f'{call_disp:>12}  {grid_disp:<6}  '
                f'SNR {snr_i:+3} dB  '
                f'DT {dt_f:+5.2f}s  '
                f'drift {drift_f:+5.2f} Hz/s  '
                f'{pwr_i:>2} dBm')

    # --- main read loop ---------------------------------------------------
    assert proc.stdout is not None
    import select as _select
    fd = proc.stdout.fileno()
    buf = b''

    def _next_line():
        nonlocal buf
        if b'\n' in buf:
            line, _, buf = buf.partition(b'\n')
            return line.decode('utf-8', errors='replace')
        return None

    # Pending-cycle state: each cycle is buffered until either the
    # matching wd-upload-hs `shipped` event arrives (so we can render
    # decode + ship as one line) or the deadline passes (signal-wake
    # was lost and the consumer's 60 s polling tick will fire eventually,
    # but we don't want to block the UI on it).
    pending: dict = {}    # keys: 'line', 'extras', 'ts', 'deadline'

    def _flush_pending(ship_suffix: str = '') -> None:
        if not pending:
            return
        print(pending['line'] + ship_suffix, flush=True)
        for extra in pending['extras']:
            print(extra, flush=True)
        pending.clear()

    try:
        while True:
            line = _next_line()
            if line is None:
                rlist, _w, _x = _select.select([fd], [], [], 1.0)
                # Idle tick — if a pending cycle has waited too long
                # for its shipped event, flush it as-is.
                if pending and time.monotonic() > pending['deadline']:
                    _flush_pending()
                if not rlist:
                    continue
                try:
                    chunk = os.read(fd, 65536)
                except OSError:
                    break
                if not chunk:
                    break
                buf += chunk
                continue

            um = upload_re.search(line)
            if um:
                # Group ordering matches the regex:
                #   1,2: pump-shipped posted/added (verbose form)
                #   3  : pump-shipped count (compact form)
                #   4,5: total posted/added (verbose form)
                #   6  : total count (compact form)
                #   7  : work counter
                p_posted, p_added, p_compact, \
                    t_posted, t_added, t_compact, work_n = um.groups()
                pump_posted = int(p_posted or p_compact or 0)
                pump_added  = int(p_added  or p_compact or 0)
                tot_posted  = int(t_posted or t_compact or 0)
                tot_added   = int(t_added  or t_compact or 0)
                tm = ts_re.match(line)
                hms = tm.group(2) if tm else _datetime.datetime.now().strftime('%H:%M:%S')
                if pump_posted != pump_added:
                    pump_field = f'+{pump_added}/{pump_posted}'
                else:
                    pump_field = f'+{pump_posted}'
                if tot_posted != tot_added:
                    tot_field = f'{tot_added}/{tot_posted}'
                else:
                    tot_field = f'{tot_posted}'
                # When the pump had under-acceptance and --rejected was
                # requested, fetch the per-spot rejections so they can
                # be printed under the relevant cycle/standalone line.
                rejected_extras: list = []
                if show_rejected and pump_posted > pump_added:
                    for spot_key, _uploaded_at, _bid in _query_rejected_since():
                        rejected_extras.append(_format_rejected(spot_key))
                elif show_rejected:
                    # Still drain the query so last_batch_id advances —
                    # otherwise the FIRST under-accept after several
                    # clean pumps would dump every reject since startup.
                    _query_rejected_since()

                if pending:
                    # Merge with the pending cycle: append delivery
                    # summary to the cycle line, then print everything.
                    # "delivered" — wsprnet's pump completed with the
                    # server's added-count (not just upload finished).
                    ship_delta_s = int(time.monotonic() - pending['ts'])
                    if rejected_extras:
                        pending['extras'].extend(rejected_extras)
                    _flush_pending(
                        f'  → delivered {pump_field} in {ship_delta_s}s '
                        f'(total {tot_field}, batch {work_n})'
                    )
                else:
                    # Standalone — no cycle is waiting (e.g. backlog
                    # drain across multiple cycles, or signal-wake
                    # arrived before the cycle log line did).
                    #
                    # Suppress the line when the pump did nothing
                    # (posted == 0 AND added == 0): it carries no
                    # information beyond the previously-emitted cycle
                    # line and just clutters the watch.  When
                    # posted > 0 but added == 0 (server rejected every
                    # spot) we still print — that's a real signal.
                    if pump_posted or pump_added:
                        print(
                            f'[{hms}] delivered            '
                            f'{pump_field:>7} wsprnet  '
                            f'(total {tot_field}, batch {work_n})',
                            flush=True,
                        )
                        for extra in rejected_extras:
                            print(extra, flush=True)
                continue

            cm = cycle_re.search(line)
            if not cm:
                continue
            hh, mm, spots_n_s, noise_n_s, bands_n_s, write_ms_s = cm.groups()
            cycle_iso = _cycle_iso(hh, mm)
            tm = ts_re.match(line)
            hms = tm.group(2) if tm else _datetime.datetime.now().strftime('%H:%M:%S')
            spots_n = int(spots_n_s)
            noise_n = int(noise_n_s) if noise_n_s else 0
            bands_n = int(bands_n_s)
            write_ms = int(write_ms_s)

            # Query rows immediately — race window is ~18 s before
            # wd-upload-hs sweeps, so live events always succeed.
            rows = _query_cycle(cycle_iso) or []
            counts_part = ''
            if rows:
                counts_part = '  [' + _format_band_counts(
                    _per_band_counts(rows)) + ']'
            elif backlog_min > 0:
                # Backlog cycle: rows already shipped + deleted.
                # Still useful to show the journal-line counts.
                counts_part = '  [shipped]'

            noise_part = f' / {noise_n} noise' if noise_n else ''
            cycle_text = (
                f'[{hms}] cycle UTC {hh}:{mm}  '
                f'{spots_n:>3} spots{noise_part} / {bands_n} bands  '
                f'(write {write_ms} ms){counts_part}'
            )
            # If a previous cycle is still pending (no shipped event
            # ever arrived) flush it before starting the new one.
            _flush_pending()

            # Per-spot detail prints under the summary line after the
            # cycle+ship are merged.  Build it now into `extras` so it
            # follows the merged line in order.
            extras: List[str] = []
            if show_spots and rows:
                # Group rows by band so the per-band cap (N) applies
                # to each band independently — otherwise a 40m flood
                # could starve the display of any 30m / 20m detail.
                from itertools import groupby as _groupby
                rows_sorted = sorted(rows, key=lambda r: (
                    _band_sort_key(r[0] or '?'),
                    (r[6] if r[6] is not None else 0),
                ))
                for band, group in _groupby(rows_sorted,
                                             key=lambda r: r[0] or '?'):
                    group_list = list(group)
                    to_show = (group_list if cap is None
                               else group_list[:cap])
                    for r in to_show:
                        extras.append(_format_spot(r))
                    if cap is not None and len(group_list) > len(to_show):
                        extras.append(
                            f'           … ({len(group_list) - len(to_show)} '
                            f'more on {band}m)'
                        )

            # Buffer this cycle's render; the shipped event (or a 30 s
            # deadline) will trigger _flush_pending().  For backlog
            # replay (--backlog), wsprnet's old ship event is also in
            # the replayed journal so backlog cycles still get merged.
            pending.update({
                'line': cycle_text,
                'extras': extras,
                'ts': time.monotonic(),
                # 90 s: wsprnet pump cadence is ~60 s; observed ship
                # latency runs 25-40 s post-decode.  30 s was too tight
                # and split ~1-in-3 cycles into separate cycle+shipped
                # lines.
                'deadline': time.monotonic() + 90.0,
            })

    except KeyboardInterrupt:
        return 130
    finally:
        # If we have a buffered cycle without a matching ship, print it
        # before exiting — otherwise that cycle silently disappears.
        _flush_pending()
        try:
            proc.terminate()
            proc.wait(timeout=2)
        except Exception:
            pass
    return 0
def _hfdl_band_num(name: str):
    """Extract the band number from 'HFDL13' / 'HFDL13.json' → 13.

    Returns None on names that don't match (e.g. a future codec rename).
    """
    import re as _re
    m = _re.match(r'HFDL(\d+)', name)
    return int(m.group(1)) if m else None


def _hfdl_band_key(name: str):
    """Numeric sort key so HFDL5 < HFDL6 < HFDL10 < HFDL13 < HFDL21
    instead of lexical (which puts HFDL10 before HFDL5)."""
    n = _hfdl_band_num(name)
    return (n if n is not None else 999, name)


def _format_hfdl_frame(band_label: str, frame: dict, *, kind: str) -> str:
    """Render one decoded HFDL frame as a single line.

    LPDU and SPDU frames have different shapes (aircraft uplink vs
    ground-station broadcast); both map to a compact left-to-right
    layout — HH:MM:SS, MHz, who, → who, frame-type — so the watch
    output stays scan-friendly across mode kinds.
    """
    t = (frame.get('t') or {}).get('sec') or 0
    tm = time.strftime('%H:%M:%S', time.gmtime(t)) if t else '--:--:--'
    freq_hz = frame.get('freq') or 0
    freq_mhz = f'{freq_hz / 1_000_000:.3f}' if freq_hz else '----.----'

    if kind == 'spdu':
        spdu = frame.get('spdu') or {}
        src = (spdu.get('src') or {}).get('name', '?')
        return f'{tm}  {freq_mhz:>9} MHz  SPDU  ← {src}'

    ldp = frame.get('lpdu') or {}
    src = ldp.get('src') or {}
    dst = ldp.get('dst') or {}
    type_name = (ldp.get('type') or {}).get('name', '?')

    if src.get('type') == 'Aircraft':
        icao = ((ldp.get('ac_info') or {}).get('icao') or '------')
        fl = ((ldp.get('hfnpdu') or {}).get('flight_id') or '').strip()
        gs_name = dst.get('name', '?')
        ident = f'AC={icao}'
        if fl:
            ident += f' {fl}'
        return (f'{tm}  {freq_mhz:>9} MHz  {ident:<22} → '
                f'{gs_name:<22}  {type_name}')
    if src.get('type') == 'Ground station':
        gs_name = src.get('name', '?')
        dst_label = (dst.get('name')
                     or f'AC_id={dst.get("id", "?")}')
        return (f'{tm}  {freq_mhz:>9} MHz  GS={gs_name:<19} → '
                f'{dst_label:<22}  {type_name}')
    return f'{tm}  {freq_mhz:>9} MHz  (unknown src)  {type_name}'


def cmd_hfdl_watch(args) -> int:
    """Live tail of hfdl-recorder's decoded HFDL frame activity.

    dumphfdl writes one JSONL frame per line into
    ``/var/lib/hfdl-recorder/<instance>/HFDL<band>.json``, append-only.
    We poll each band file on a 15 s window and emit a summary —
    bands active, total frames, unique ground stations, unique
    aircraft.  ``N`` adds first-N frames per band; ``-v`` dumps every
    frame.  Unlike psk-watch / wspr-watch there's no slot or upload
    cycle to align with — HFDL frames arrive whenever aircraft
    transmit — so the 15 s window is purely a sampling cadence.
    """
    instance = getattr(args, 'instance', None)
    if instance is None:
        try:
            r = subprocess.run(
                ['systemctl', 'list-units', '--no-legend', '--no-pager',
                 '--type=service', '--state=active',
                 'hfdl-recorder@*.service'],
                capture_output=True, text=True, check=False,
            )
        except FileNotFoundError:
            _err('systemctl not available')
            return 1
        lines = [l for l in r.stdout.splitlines() if l.strip()]
        if not lines:
            _err('no active hfdl-recorder@* service — is hfdl-recorder '
                 'running? (smd status hfdl-recorder)')
            return 1
        unit = lines[0].split()[0]
        try:
            instance = unit.split('@', 1)[1].rsplit('.', 1)[0]
        except IndexError:
            _err(f'unexpected unit name: {unit}')
            return 1

    data_dir = Path(f'/var/lib/hfdl-recorder/{instance}')
    if not data_dir.is_dir():
        _err(f'no data directory at {data_dir} — wrong instance?')
        return 1

    band_files = sorted(data_dir.glob('HFDL*.json'),
                        key=lambda p: _hfdl_band_key(p.name))
    if not band_files:
        _err(f'no HFDL*.json files in {data_dir} — '
             f'has any band decoded yet?')
        return 1

    n_recent = int(getattr(args, 'recent', 0) or 0)
    verbose = bool(getattr(args, 'verbose', False))
    if verbose:
        cap: Optional[int] = None
    else:
        cap = n_recent if n_recent > 0 else 0
    show_frames = cap != 0

    WIN_SEC = 15.0

    _heading(f'HFDL decoded frames ({instance})')
    bands_display = ', '.join(p.stem for p in band_files)
    _info(f'   ▸ {len(band_files)} band file(s): {bands_display}')
    _info(f'   ▸ every {int(WIN_SEC)} s — summary across all bands')
    if cap is None:
        _info('     + ALL frames in this window, one line each')
    elif cap > 0:
        _info(f'     + first {cap} frame{"s" if cap != 1 else ""} per band')
    _info('   Ctrl-C to exit.')
    print(flush=True)

    sudo_prefix = [] if os.geteuid() == 0 else ['sudo', '-n']

    def _file_size(p: Path) -> int:
        try:
            return p.stat().st_size
        except (FileNotFoundError, PermissionError):
            try:
                r = subprocess.run(
                    [*sudo_prefix, 'stat', '-c', '%s', str(p)],
                    capture_output=True, text=True, check=False,
                )
                return int(r.stdout.strip()) if r.returncode == 0 else 0
            except (FileNotFoundError, ValueError):
                return 0

    def _read_since(p: Path, start: int) -> tuple[int, str]:
        end = _file_size(p)
        if end <= start:
            return start, ''
        try:
            r = subprocess.run(
                [*sudo_prefix, 'tail', '-c', f'+{start + 1}', str(p)],
                capture_output=True, text=True, check=False,
            )
            text = r.stdout
        except FileNotFoundError:
            return start, ''
        new_end = start + len(text.encode())
        return new_end, text

    # Prime cursors at current EOF — don't replay the backlog on first
    # fire.  (HFDL files can be tens to hundreds of MB; replaying would
    # flood the terminal and lock up the watch for minutes.)
    positions: dict = {p: _file_size(p) for p in band_files}

    import json as _json

    try:
        while True:
            now = time.time()
            # Fire at the next WIN_SEC UTC boundary (e.g. :00, :15, :30,
            # :45) so multiple operators see the same windows.
            next_fire = math.ceil(now / WIN_SEC) * WIN_SEC
            time.sleep(max(0.1, next_fire - time.time()))

            per_band: list = []
            total_frames = 0
            total_gs: set = set()
            total_ac: set = set()
            bands_active = 0

            for path in band_files:
                new_pos, text = _read_since(path, positions[path])
                positions[path] = new_pos

                band_label = path.stem  # 'HFDL13'
                lines = [l for l in text.splitlines() if l.strip()]
                # If the last line doesn't end with '}', dumphfdl was
                # mid-write — rewind the cursor and pick it up next pass
                # so we never half-parse a frame.
                if lines and not lines[-1].rstrip().endswith('}'):
                    bad = lines[-1].encode() + b'\n'
                    positions[path] = new_pos - len(bad)
                    lines = lines[:-1]

                gs_set: set = set()
                ac_set: set = set()
                lpdu = 0
                spdu = 0
                frames_list: list = []
                for raw in lines:
                    try:
                        frame = _json.loads(raw).get('hfdl') or {}
                    except _json.JSONDecodeError:
                        continue
                    if 'spdu' in frame:
                        spdu += 1
                        gs = (frame['spdu'].get('src') or {}).get('name')
                        if gs:
                            gs_set.add(gs)
                        if show_frames:
                            frames_list.append(_format_hfdl_frame(
                                band_label, frame, kind='spdu',
                            ))
                    elif 'lpdu' in frame:
                        lpdu += 1
                        ldp = frame['lpdu']
                        src = ldp.get('src') or {}
                        dst = ldp.get('dst') or {}
                        if (src.get('type') == 'Ground station'
                                and src.get('name')):
                            gs_set.add(src['name'])
                        if (dst.get('type') == 'Ground station'
                                and dst.get('name')):
                            gs_set.add(dst['name'])
                        icao = (ldp.get('ac_info') or {}).get('icao')
                        if icao:
                            ac_set.add(icao)
                        if show_frames:
                            frames_list.append(_format_hfdl_frame(
                                band_label, frame, kind='lpdu',
                            ))
                    # other shapes (none observed in dumphfdl 1.7.0)
                    # silently ignored — counts won't reflect them.

                fc = len(lines)
                per_band.append({
                    'band': band_label, 'frames': fc,
                    'lpdu': lpdu, 'spdu': spdu,
                    'gs': gs_set, 'ac': ac_set, 'list': frames_list,
                })
                total_frames += fc
                if fc > 0:
                    bands_active += 1
                total_gs |= gs_set
                total_ac |= ac_set

            wall = time.strftime('%H:%M:%S', time.gmtime(next_fire))
            now_str = time.strftime('%H:%M:%S')

            if show_frames:
                print(f'─── win UTC {wall} ({int(WIN_SEC)}s) '
                      f'──────────────────────────────────',
                      flush=True)
                if total_frames == 0:
                    print('  (no frames this window)', flush=True)
                else:
                    for b in per_band:
                        if b['frames'] == 0:
                            continue
                        print(f"  {b['band']:<6}: frames={b['frames']:<3} "
                              f" lpdu={b['lpdu']:<3} spdu={b['spdu']:<3} "
                              f" gs={len(b['gs']):<2} "
                              f"ac={len(b['ac']):<3}",
                              flush=True)
                        to_show = (b['list'] if cap is None
                                   else b['list'][:cap])
                        for line in to_show:
                            print(f'    {line}', flush=True)
                        if cap is not None and len(b['list']) > len(to_show):
                            print(f"    … ({len(b['list']) - len(to_show)} "
                                  f"more)", flush=True)
                    print(f'  → frames={total_frames}  '
                          f'bands={bands_active}/{len(band_files)}  '
                          f'gs={len(total_gs)}  ac={len(total_ac)}',
                          flush=True)
            else:
                active_str = ','.join(
                    str(_hfdl_band_num(b['band']))
                    for b in per_band if b['frames'] > 0
                ) or '—'
                print(
                    f'[{now_str}] win UTC {wall} ({int(WIN_SEC)}s)  '
                    f'frames={total_frames:>4}  '
                    f'bands={bands_active}/{len(band_files)}'
                    f'({active_str})  '
                    f'gs={len(total_gs):>2}  ac={len(total_ac):>3}',
                    flush=True,
                )
    except KeyboardInterrupt:
        return 130


def _format_codar_record(rec: dict) -> str:
    """Render one codar-sounder JSONL record as a single line.

    Field order chosen to match how the operator scans an ionogram —
    time first (sub-second matters since CPI window is 15 s and
    multi-peak records share a timestamp prefix), then SNR (was this
    a strong return), then the propagation geometry (group range,
    virtual height, equivalent vertical freq), then the layer label.
    The trailing (peak_index/peak_count) makes multi-peak CPIs scan-
    able as a group.
    """
    ts = rec.get('timestamp', '')
    # ISO-8601 → HH:MM:SS.fff.  Trim to 3 sub-second digits if more
    # precision is present; codar-sounder rounds at microsecond.
    try:
        time_part = ts.split('T', 1)[1].split('+', 1)[0].split('Z', 1)[0]
        if '.' in time_part:
            sec, frac = time_part.split('.', 1)
            time_part = f'{sec}.{frac[:3]}'
    except (IndexError, AttributeError):
        time_part = '--:--:--.---'

    snr = rec.get('snr_db', 0.0)
    gr = rec.get('group_range_km', 0.0)
    vh = rec.get('virtual_height_km', 0.0)
    evf = rec.get('equivalent_vertical_freq_mhz', 0.0)
    layer = rec.get('mode_layer', '?')
    p_idx = rec.get('peak_index', 0)
    p_cnt = rec.get('peak_count', 1)

    return (f'{time_part}  SNR {snr:+5.1f} dB  GR {gr:>7.1f} km  '
            f'VH {vh:>6.1f} km  EVF {evf:>6.3f} MHz  '
            f'{layer:<11} ({p_idx}/{p_cnt})')


def cmd_codar_watch(args) -> int:
    """Live tail of codar-sounder's ionospheric-sounding records.

    codar-sounder writes one JSONL record per detected peak to
    ``/var/lib/codar-sounder/<radiod>/<station>/YYYY/MM/DD.jsonl``,
    rotated daily.  We poll every active station file on a 15 s
    window (matching the daemon's CPI cadence) and emit a per-window
    rollup: total peaks, active station count, layers seen
    (E/F1/F2/F2_extreme/below_E), and SNR range.  ``N`` adds first-N
    records per station; ``-v`` dumps every record.

    Records can be sparse — a station with no open propagation path
    produces zero records for hours.  Watch shows ``peaks=0`` lines
    in that case so the operator sees the watch is alive.

    Date rollover is handled by recomputing today's path each window
    and resetting cursors when the UTC date changes.  New stations
    appearing mid-day (first detection on a previously-quiet station)
    are picked up at the next window with their cursor primed at the
    file's current size, so the watch doesn't dump a same-day backlog.
    """
    instance = getattr(args, 'instance', None)
    if instance is None:
        try:
            r = subprocess.run(
                ['systemctl', 'list-units', '--no-legend', '--no-pager',
                 '--type=service', '--state=active',
                 'codar-sounder@*.service'],
                capture_output=True, text=True, check=False,
            )
        except FileNotFoundError:
            _err('systemctl not available')
            return 1
        lines = [l for l in r.stdout.splitlines() if l.strip()]
        if not lines:
            # Fall back to picking up an existing data dir even if the
            # service isn't running — useful for tailing a stopped
            # service's recent records, and during the post-rebuild
            # restart-pending window.
            data_root = Path('/var/lib/codar-sounder')
            if not data_root.is_dir():
                _err('no active codar-sounder@* service and no '
                     f'{data_root} directory — is codar-sounder '
                     'installed? (smd status codar-sounder)')
                return 1
            candidates = sorted(
                (p for p in data_root.iterdir() if p.is_dir()),
                key=lambda p: p.stat().st_mtime, reverse=True,
            )
            if not candidates:
                _err(f'{data_root} is empty — has any radiod instance '
                     'recorded yet?')
                return 1
            instance = candidates[0].name
            _warn(f'codar-sounder@{instance} not active — tailing '
                  f'data dir anyway (records will only update once '
                  f'the service starts)')
        else:
            unit = lines[0].split()[0]
            try:
                instance = unit.split('@', 1)[1].rsplit('.', 1)[0]
            except IndexError:
                _err(f'unexpected unit name: {unit}')
                return 1

    data_dir = Path(f'/var/lib/codar-sounder/{instance}')
    if not data_dir.is_dir():
        _err(f'no data directory at {data_dir} — wrong instance?')
        return 1

    # Station list = subdirectories of the radiod's data dir.  A new
    # station added to the config but never decoded won't have a
    # subdir yet, and stations that fall silent keep their old
    # subdirs — both are correct (the day's JSONL is the source of
    # truth for "did we ever produce anything").
    def _list_stations() -> list:
        return sorted(p.name for p in data_dir.iterdir()
                      if p.is_dir() and not p.name.startswith('.'))

    stations = _list_stations()
    if not stations:
        _err(f'no station subdirs under {data_dir} — '
             f'has any peak been detected yet?')
        return 1

    n_recent = int(getattr(args, 'recent', 0) or 0)
    verbose = bool(getattr(args, 'verbose', False))
    if verbose:
        cap: Optional[int] = None
    else:
        cap = n_recent if n_recent > 0 else 0
    show_records = cap != 0

    WIN_SEC = 15.0  # codar-sounder CPI cadence

    _heading(f'CODAR ionospheric soundings ({instance})')
    _info(f'   ▸ {len(stations)} station(s): {", ".join(stations)}')
    _info(f'   ▸ every {int(WIN_SEC)} s (CPI cadence) — '
          f'per-window rollup')
    if cap is None:
        _info('     + ALL records in this window, one line each')
    elif cap > 0:
        _info(f'     + first {cap} record{"s" if cap != 1 else ""} '
              f'per station')
    _info('   Ctrl-C to exit.')
    print(flush=True)

    sudo_prefix = [] if os.geteuid() == 0 else ['sudo', '-n']

    def _file_size(p: Path) -> int:
        try:
            return p.stat().st_size
        except (FileNotFoundError, PermissionError):
            try:
                r = subprocess.run(
                    [*sudo_prefix, 'stat', '-c', '%s', str(p)],
                    capture_output=True, text=True, check=False,
                )
                return int(r.stdout.strip()) if r.returncode == 0 else 0
            except (FileNotFoundError, ValueError):
                return 0

    def _read_since(p: Path, start: int) -> tuple[int, str]:
        end = _file_size(p)
        if end <= start:
            return start, ''
        try:
            r = subprocess.run(
                [*sudo_prefix, 'tail', '-c', f'+{start + 1}', str(p)],
                capture_output=True, text=True, check=False,
            )
            text = r.stdout
        except FileNotFoundError:
            return start, ''
        new_end = start + len(text.encode())
        return new_end, text

    def _today_path(station: str) -> Path:
        # Mirrors JsonlWriter._path_for: <data_dir>/<station>/YYYY/MM/DD.jsonl
        d = time.gmtime()
        return (data_dir / station
                / f'{d.tm_year:04d}'
                / f'{d.tm_mon:02d}'
                / f'{d.tm_mday:02d}.jsonl')

    # Cursor state per station path.  Prime each existing today-file
    # at EOF so the watch doesn't dump the day's backlog on first
    # fire.  Missing files (station hasn't produced today yet) start
    # at 0 and will pick up records as soon as the daemon writes them.
    positions: dict = {}
    for st in stations:
        p = _today_path(st)
        positions[st] = _file_size(p) if p.exists() else 0
    current_date = time.gmtime().tm_yday  # cheap rollover sentinel

    import json as _json

    try:
        while True:
            now = time.time()
            next_fire = math.ceil(now / WIN_SEC) * WIN_SEC
            time.sleep(max(0.1, next_fire - time.time()))

            # Midnight UTC rollover: reset cursors so we start fresh
            # against the new day's file (which may not exist yet —
            # _read_since handles missing files gracefully).
            new_yday = time.gmtime().tm_yday
            if new_yday != current_date:
                current_date = new_yday
                stations = _list_stations()
                positions = {st: 0 for st in stations}

            # Re-glob stations in case a new one appeared mid-day —
            # JsonlWriter creates the parent dir on first record, so
            # a previously-silent station "arrives" as a new subdir.
            for st in _list_stations():
                if st not in positions:
                    p = _today_path(st)
                    positions[st] = _file_size(p) if p.exists() else 0
                    stations.append(st) if st not in stations else None

            per_station: list = []
            total_peaks = 0
            total_layers: set = set()
            snr_min: Optional[float] = None
            snr_max: Optional[float] = None
            stations_active = 0

            for st in sorted(positions):
                p = _today_path(st)
                new_pos, text = _read_since(p, positions[st])
                positions[st] = new_pos

                lines = [l for l in text.splitlines() if l.strip()]
                # Trailing-line robustness: codar-sounder flushes
                # newline-per-record so partial-line risk is small,
                # but a SIGKILL mid-write could leave one — drop and
                # rewind so we never half-parse.
                if lines and not lines[-1].rstrip().endswith('}'):
                    bad = lines[-1].encode() + b'\n'
                    positions[st] = new_pos - len(bad)
                    lines = lines[:-1]

                recs: list = []
                layers: set = set()
                st_snr_min: Optional[float] = None
                st_snr_max: Optional[float] = None
                for raw in lines:
                    try:
                        rec = _json.loads(raw)
                    except _json.JSONDecodeError:
                        continue
                    recs.append(rec)
                    layer = rec.get('mode_layer')
                    if layer:
                        layers.add(layer)
                    snr = rec.get('snr_db')
                    if isinstance(snr, (int, float)):
                        st_snr_min = snr if st_snr_min is None else min(st_snr_min, snr)
                        st_snr_max = snr if st_snr_max is None else max(st_snr_max, snr)

                rc = len(recs)
                per_station.append({
                    'station': st, 'peaks': rc, 'recs': recs,
                    'layers': layers,
                    'snr_min': st_snr_min, 'snr_max': st_snr_max,
                })
                total_peaks += rc
                if rc > 0:
                    stations_active += 1
                    total_layers |= layers
                    if st_snr_min is not None:
                        snr_min = (st_snr_min if snr_min is None
                                   else min(snr_min, st_snr_min))
                        snr_max = (st_snr_max if snr_max is None
                                   else max(snr_max, st_snr_max))

            wall = time.strftime('%H:%M:%S', time.gmtime(next_fire))
            now_str = time.strftime('%H:%M:%S')

            if show_records:
                print(f'─── win UTC {wall} ({int(WIN_SEC)}s) '
                      f'──────────────────────────────────',
                      flush=True)
                if total_peaks == 0:
                    print('  (no detections this window)', flush=True)
                else:
                    for b in per_station:
                        if b['peaks'] == 0:
                            continue
                        if b['snr_min'] == b['snr_max']:
                            snr_str = f"SNR={b['snr_min']:+.1f} dB"
                        else:
                            snr_str = (f"SNR={b['snr_min']:+.1f}/"
                                       f"{b['snr_max']:+.1f} dB")
                        layers_str = '{' + ','.join(sorted(b['layers'])) + '}'
                        print(f"  {b['station']:<6}: peaks={b['peaks']:<3} "
                              f"layers={layers_str}  {snr_str}",
                              flush=True)
                        to_show = (b['recs'] if cap is None
                                   else b['recs'][:cap])
                        for rec in to_show:
                            print(f'    {_format_codar_record(rec)}',
                                  flush=True)
                        if cap is not None and len(b['recs']) > len(to_show):
                            print(f"    … ({len(b['recs']) - len(to_show)} "
                                  f"more)", flush=True)
                    layers_total = ('{' + ','.join(sorted(total_layers)) + '}'
                                    if total_layers else '—')
                    print(f'  → peaks={total_peaks}  '
                          f'stations={stations_active}/{len(stations)}  '
                          f'layers={layers_total}',
                          flush=True)
            else:
                if total_peaks == 0:
                    print(
                        f'[{now_str}] win UTC {wall} ({int(WIN_SEC)}s)  '
                        f'peaks=   0  stations=0/{len(stations)}  —',
                        flush=True,
                    )
                else:
                    active_ids = ','.join(
                        b['station'] for b in per_station if b['peaks'] > 0
                    )
                    layers_str = '{' + ','.join(sorted(total_layers)) + '}'
                    if snr_min == snr_max:
                        snr_str = f'SNR={snr_min:+.1f} dB'
                    else:
                        snr_str = f'SNR={snr_min:+.1f}/{snr_max:+.1f} dB'
                    print(
                        f'[{now_str}] win UTC {wall} ({int(WIN_SEC)}s)  '
                        f'peaks={total_peaks:>3}  '
                        f'stations={stations_active}/{len(stations)}'
                        f'({active_ids})  '
                        f'layers={layers_str}  {snr_str}',
                        flush=True,
                    )
    except KeyboardInterrupt:
        return 130


def cmd_psk_watch(args) -> int:
    """Live tail of psk-recorder's PSK Reporter upload activity.

    Annotates each `uploading N` line with the sum of `queued ft8=…
    ft4=…` events that fed into it, so the per-poll vs per-batch
    accounting is visible.  Without this annotation the output looks
    contradictory — a single `queued ft8=63 ft4=1` next to `uploading
    192` reads as "uploading is much bigger than queued" — when in
    fact 192 = sum of the last ~3 polls (each ~60 spots).
    """
    instance = getattr(args, 'instance', None)
    log_path = Path(f'/var/log/psk-recorder/{instance}.log') if instance \
               else None
    if log_path is None:
        # Pick the most-recently-modified daemon log if no instance was
        # specified.  psk-recorder's systemd unit writes stdout/stderr
        # to /var/log/psk-recorder/<radiod_id>.log via
        # `StandardOutput=append:`, separately from the per-mode
        # decode logs (which end in -ft8.log / -ft4.log).
        candidates = sorted(
            (p for p in Path('/var/log/psk-recorder').glob('*.log')
             if not (p.name.endswith('-ft8.log')
                     or p.name.endswith('-ft4.log'))),
            key=lambda p: p.stat().st_mtime if p.exists() else 0,
            reverse=True,
        )
        if not candidates:
            _err('no /var/log/psk-recorder/<radiod_id>.log found '
                 '— is psk-recorder running?')
            return 1
        log_path = candidates[0]

    # `recent` is the verbose-mode N: how many per-mode decoded
    # spots to print under each "shipped" line.  0 = terse counts only.
    n_recent = int(getattr(args, 'recent', 0) or 0)
    verbose = bool(getattr(args, 'verbose', False))
    # Per-mode decoded-spot logs.  These are append-only (not deleted
    # on PSKReporter ack like the spool's .spots.txt files), so they
    # always have history we can tail when verbose mode is requested.
    instance_stem = log_path.stem
    ft8_log = log_path.with_name(f'{instance_stem}-ft8.log')
    ft4_log = log_path.with_name(f'{instance_stem}-ft4.log')

    # All three modes share the per-FT8-cycle loop.  `-v` shows
    # every spot (cap=None); N shows up to N per mode; no args
    # shows summary only (cap=0).
    if verbose:
        cap: Optional[int] = None
    else:
        cap = n_recent if n_recent > 0 else 0
    return _psk_watch_cycle_loop(
        log_path, ft8_log, ft4_log, max_lines_per_mode=cap,
    )

    # NOTE: the legacy `psk-uploader-ch:` pump-event tail mode used to
    # live here; removed since the per-cycle loop above is strictly
    # more informative (counts the same events plus per-FT4-cycle
    # breakdown).  The dead code below would never execute.
    _heading(f'PSK Reporter upload activity ({log_path.name})')
    _info('   ▸ hs-uploader path (PSK_USE_HS_UPLOADER=1):')
    _info('     "shipped ft8=N ft4=M"   per ~30 s pump cycle')
    _info('     each line annotated with current time and seconds since prev')
    if n_recent > 0:
        _info(f'     + last {n_recent} spot{"s" if n_recent != 1 else ""} '
              f'of each mode from -ft8.log / -ft4.log per cycle')
    _info('   ▸ legacy CH-polled path (fallback when older uploader is active):')
    _info('     "queued ft8=N ft4=M"    per 5 s poll')
    _info('     "uploading N spots"    per ~30 s flush, with ✓/✗ reconciliation')
    _info('   Ctrl-C to exit.')
    print()

    import re as _re
    import time as _time
    import datetime as _datetime
    queue_re = _re.compile(r'queued ft8=(\d+) ft4=(\d+)')
    upload_re = _re.compile(r'uploading (\d+) spots using (\w+)')
    # New-uploader line shape:
    #   psk-uploader-hs: shipped ft8=N ft4=M (total ft8=A ft4=B, work=W)
    shipped_re = _re.compile(
        r'psk-uploader-hs: shipped ft8=(\d+) ft4=(\d+)'
    )

    # Per-batch accumulator: sum of queued spots since the last upload.
    pending_polls: int = 0
    pending_spots: int = 0
    # "Seconds since previous shipped line" — None until the first
    # shipped line is seen.  Wall-clock based, not monotonic, so
    # operators reading the timestamp see real-world time.
    last_shipped_at: Optional[float] = None
    sudo_prefix = [] if os.geteuid() == 0 else ['sudo', '-n']
    # Match all the lines we want to forward; let grep do the prefilter so
    # the python loop only sees relevant lines (the daemon log includes
    # ka9q.control LIFETIME chatter we want to suppress).  Covers both
    # generations of uploader:
    #   * legacy `psk-uploader-ch:` (CH-polling, with reconciliation lines)
    #   * new    `psk-uploader-hs:` (hs-uploader pipeline; per-mode
    #                                shipped counts per pump cycle)
    pattern = (r'psk-uploader-ch: queued ft8=|'
               r'psk-uploader-ch: batch [0-9]|'
               r'uploading [0-9]+ spots using|'
               r'psk-uploader-ch (started|stopped|disabled)|'
               r'psk-uploader-hs: shipped ft8=|'
               r'psk-uploader-hs (started|stopped)')
    try:
        tl = subprocess.Popen(
            [*sudo_prefix, 'tail', '-n', '50', '-F', str(log_path)],
            stdout=subprocess.PIPE, text=True, bufsize=1,
        )
        gp = subprocess.Popen(
            ['grep', '--line-buffered', '-E', pattern],
            stdin=tl.stdout, stdout=subprocess.PIPE,
            text=True, bufsize=1,
        )
        tl.stdout.close()
        assert gp.stdout is not None
        for line in gp.stdout:
            line = line.rstrip('\n')
            qm = queue_re.search(line)
            if qm:
                pending_polls += 1
                pending_spots += int(qm.group(1)) + int(qm.group(2))
                # flush=True: Python's stdout is block-buffered when
                # piped (e.g., `smd psk-watch | tee log`); without
                # this the operator sees no output for minutes until
                # ~4 KiB has accumulated.  Line-buffered is the right
                # mode for a live-tail tool.
                print(line, flush=True)
                continue
            um = upload_re.search(line)
            if um:
                uploaded = int(um.group(1))
                # Reconciliation tag: ✓ if uploaded matches sum of fed
                # polls, ✗ + the absolute delta otherwise.  Library may
                # batch slightly differently if a poll fires within the
                # upload() critical section — small drift is expected;
                # large drift is the "where did my spots go" signal.
                diff = uploaded - pending_spots
                if pending_polls == 0:
                    tag = '⊘ no polls fed before this flush'
                elif diff == 0:
                    tag = (
                        f'✓ matches {pending_polls} poll{"s" if pending_polls != 1 else ""} '
                        f'feeding {pending_spots} spots'
                    )
                else:
                    sign = '+' if diff > 0 else ''
                    tag = (
                        f'✗ {pending_polls} poll{"s" if pending_polls != 1 else ""} '
                        f'fed {pending_spots} spots (delta {sign}{diff})'
                    )
                print(f'{line}  [{tag}]', flush=True)
                pending_polls = 0
                pending_spots = 0
                continue
            sm = shipped_re.search(line)
            if sm:
                # New-uploader event: annotate with wall-clock time
                # and seconds-since-previous so operators reading the
                # tail get a sense of cadence at a glance.
                ft8 = int(sm.group(1))
                ft4 = int(sm.group(2))
                now = _time.time()
                hhmmss = _datetime.datetime.now().strftime('%H:%M:%S')
                if last_shipped_at is None:
                    gap = '—'
                else:
                    gap = f'{int(now - last_shipped_at)}s'
                last_shipped_at = now
                print(
                    f'[{hhmmss} +{gap}] ft8={ft8:>3} ft4={ft4:>2}',
                    flush=True,
                )
                # Verbose mode: tail the last N spots from each per-mode
                # log file.  Best-effort — a missing file (band wasn't
                # active, or the daemon hasn't created it yet) just
                # gets a "(no entries)" placeholder so the cadence of
                # output stays predictable.
                if n_recent > 0:
                    for label, mode_log in (('ft8', ft8_log),
                                            ('ft4', ft4_log)):
                        try:
                            r = subprocess.run(
                                [*sudo_prefix, 'tail', '-n',
                                 str(n_recent), str(mode_log)],
                                capture_output=True, text=True, check=False,
                            )
                            tail_text = r.stdout
                        except FileNotFoundError:
                            tail_text = ''
                        if not tail_text.strip():
                            print(f'    {label}: (no entries)', flush=True)
                            continue
                        for spot_line in tail_text.rstrip('\n').splitlines():
                            print(f'    {label}: {spot_line}', flush=True)
                continue
            # Anything else (batch summary, started/stopped) — pass through
            # untouched, don't reset the accumulator (batch summary fires
            # AROUND uploads, not in lieu of them).
            print(line, flush=True)
        gp.wait()
        tl.terminate()
    except KeyboardInterrupt:
        return 130
    except FileNotFoundError as exc:
        _err(f'tail/grep not found: {exc}')
        return 1
    return 0


def cmd_completion(args) -> int:
    sub = getattr(args, 'completion_command', None)
    if sub == 'bash':
        if getattr(args, 'install', False):
            dest = Path.home() / '.local' / 'share' / 'bash-completion' / 'completions' / 'smd'
            dest.parent.mkdir(parents=True, exist_ok=True)
            dest.write_text(_BASH_COMPLETION.strip() + '\n')
            print(f'Installed to {dest}')
            print('Activate in your current session with:')
            print('  source <(smd completion bash)')
            return 0
        print(_BASH_COMPLETION.strip())
        return 0
    print('Usage: smd completion bash [--install]')
    print()
    print('To activate in the current session:')
    print('  source <(smd completion bash)')
    print()
    print('To install for your user (creates the directory automatically):')
    print('  smd completion bash --install')
    print()
    print('To install system-wide:')
    print('  sudo smd completion bash > /etc/bash_completion.d/smd')
    print()
    print('The completion script also defines short aliases:')
    print('  smdt   →  smd tui')
    print('  smdtui →  smd tui')
    return 0


# ---------------------------------------------------------------------------
# smd tui (TUI configurator) + deprecated `smd config edit` alias
# ---------------------------------------------------------------------------

# ka9q-python is strongly recommended for the TUI radiod screen; installed
# editable from the first sibling checkout found. TUI deps (textual, rich)
# come from sigmond's own [tui] extra defined in pyproject.toml.
_KA9Q_PYTHON_PATHS = [
    Path('/home/wsprdaemon/ka9q-python'),
    Path('/home/mjh/git/ka9q-python'),
    Path('/opt/git/ka9q-python'),
]


def _ensure_sigmond_venv() -> bool:
    """Create SIGMOND_VENV and install sigmond[tui] (+ ka9q-python if present).

    Uses uv when available for faster installs; falls back to bare pip/venv.
    Returns True if the venv is ready, False on failure.
    """
    venv_python = SIGMOND_VENV / 'bin' / 'python'
    pip = SIGMOND_VENV / 'bin' / 'pip'
    sigmond_dir = Path(__file__).resolve().parent.parent
    uv = shutil.which('uv')

    if not venv_python.exists():
        _info(f'Creating TUI venv at {SIGMOND_VENV} ...')
        SIGMOND_VENV.parent.mkdir(parents=True, exist_ok=True)
        if uv:
            r = _run([uv, 'venv', '--python', sys.executable, str(SIGMOND_VENV)])
        else:
            r = _run([sys.executable, '-m', 'venv', str(SIGMOND_VENV)])
        if r.returncode != 0:
            _err(f'venv creation failed: {r.stderr.strip()}')
            return False

    def _pip_show(pkg):
        if uv:
            return _run([uv, 'pip', 'show', '--python', str(venv_python), pkg])
        if pip.exists():
            return _run([str(pip), 'show', pkg])
        # No pip and no uv — assume not installed so we attempt install.
        return subprocess.CompletedProcess([], returncode=1)

    def _pip_install(*args):
        if uv:
            return _run([uv, 'pip', 'install', '--python', str(venv_python), *args])
        return _run([str(pip), 'install', *args])

    # Install sigmond itself with [tui] extras (idempotent — check first).
    r = _pip_show('textual')
    if r.returncode != 0:
        _info('Installing sigmond[tui] into venv ...')
        r = _pip_install('-e', f'{sigmond_dir}[tui]')
        if r.returncode != 0:
            _err(f'sigmond[tui] install failed: {r.stderr.strip()[-200:]}')
            return False

    # Optional: ka9q-python editable from a sibling checkout.
    r = _pip_show('ka9q-python')
    if r.returncode != 0:
        for path in _KA9Q_PYTHON_PATHS:
            if (path / 'pyproject.toml').exists():
                _info(f'Installing ka9q-python (editable) from {path} ...')
                r = _pip_install('-e', str(path))
                if r.returncode != 0:
                    _warn(f'ka9q-python install failed: {r.stderr.strip()[-200:]}')
                break

    _ok(f'TUI venv ready at {SIGMOND_VENV}')
    return True


def cmd_tui(args) -> int:
    """Launch the sigmond TUI.

    Launches directly if the current Python can import the TUI (dev venv,
    already in /opt/sigmond/venv, or system python with deps); otherwise
    re-execs into the production venv, creating it if needed.
    """
    try:
        import textual  # noqa: F401 — probe before launch() defers the import
        from sigmond.tui import launch
        launch()
    except ImportError:
        return _reexec_into_tui_venv()
    return 0


def cmd_config_edit(args) -> int:
    """Deprecated alias for `smd tui`.  Remove after next release."""
    _warn("'smd config edit' is deprecated; use 'smd tui' instead")
    return cmd_tui(args)


# Paths archived by `smd config backup`.  Missing paths are silently skipped.
_BACKUP_PATHS = [
    Path('/etc/sigmond'),
    Path('/etc/radio'),
    Path('/etc/wsprdaemon'),
    Path('/etc/hf-timestd'),
    Path('/etc/psk-recorder'),
    Path('/etc/systemd/system/wsprdaemon.service'),
    Path('/etc/systemd/system/wsprdaemon.target'),
    Path('/etc/systemd/system/wsprdaemon.target.wants'),
    Path('/etc/sudoers.d/wsprdaemon'),
    Path('/etc/cron.d/ka9q-cleanups'),
    Path('/etc/cron.d/timestd-freshness-monitor'),
    Path('/etc/logrotate.d/hf-timestd'),
    Path('/etc/logrotate.d/wspr.rotate'),
]


def cmd_config_restore(args) -> int:
    """Extract a sigmond config backup tarball over the live system."""
    import tarfile

    src = Path(getattr(args, 'input', None) or '')
    if not src or not src.exists():
        _err('--input FILE is required and must exist')
        _info('Usage:  sudo smd config restore --input ~/sigmond-config-*.tar.gz')
        return 1
    if not tarfile.is_tarfile(src):
        _err(f'{src} is not a valid tar archive')
        return 1

    _heading('config restore')
    _info(f'Source: {src}')

    # List contents for the user to review.
    try:
        with tarfile.open(src, 'r:gz') as tar:
            members = tar.getnames()
    except Exception as exc:
        _err(f'Cannot read archive: {exc}')
        return 1

    _info(f'Archive contains {len(members)} entries, e.g.:')
    for m in members[:8]:
        _info(f'  {m}')
    if len(members) > 8:
        _info(f'  … and {len(members) - 8} more')

    _info('Extracting to / …')
    try:
        with tarfile.open(src, 'r:gz') as tar:
            tar.extractall('/')
    except PermissionError as exc:
        _err(f'Permission denied: {exc}')
        _info('Re-run with sudo:  sudo smd config restore --input ...')
        return 1
    except Exception as exc:
        _err(str(exc))
        return 1

    _ok('Restore complete')
    _info('Reconcile running services:  sudo smd apply')
    return 0


def _real_home() -> Path:
    """Return the invoking user's home dir even when running under sudo."""
    import pwd as _pwd
    sudo_user = os.environ.get('SUDO_USER')
    if sudo_user:
        try:
            return Path(_pwd.getpwnam(sudo_user).pw_dir)
        except KeyError:
            pass
    return Path.home()


def cmd_config_backup(args) -> int:
    """Create a tar.gz snapshot of all sigmond + client configuration."""
    import tarfile
    import socket

    output = Path(args.output) if getattr(args, 'output', None) else None
    if output is None:
        ts = time.strftime('%Y%m%d-%H%M%S')
        output = _real_home() / f'sigmond-config-{socket.gethostname()}-{ts}.tar.gz'

    _heading('config backup')

    present = [p for p in _BACKUP_PATHS if p.exists()]
    absent  = [p for p in _BACKUP_PATHS if not p.exists()]
    for p in absent:
        _warn(f'not found (skipping): {p}')

    _info(f'Archiving {len(present)} path(s) → {output}')
    try:
        with tarfile.open(output, 'w:gz') as tar:
            for path in present:
                tar.add(path, recursive=True)
    except PermissionError as exc:
        _err(f'Permission denied: {exc}')
        _info('Re-run with sudo:  sudo smd config backup')
        return 1
    except Exception as exc:
        _err(str(exc))
        return 1

    kb = output.stat().st_size // 1024
    _ok(f'Backup written: {output}  ({kb} KB)')
    _info(f'Copy off this machine:')
    _info(f'  scp {output} user@workstation:.')
    _info(f'Restore after OS reinstall:')
    _info(f'  ./install.sh && sudo tar xzf {output.name} -C / && sudo smd apply')
    return 0


def _reexec_into_tui_venv() -> int:
    venv_python = SIGMOND_VENV / 'bin' / 'python'

    if Path(sys.prefix) == SIGMOND_VENV:
        # Already running inside the prod venv and textual still can't import.
        _err(f'TUI venv at {SIGMOND_VENV} is missing sigmond[tui]')
        _info('Rebuild with:  sudo smd install')
        return 1

    if not venv_python.exists():
        if os.geteuid() == 0:
            if not _ensure_sigmond_venv():
                return 1
        else:
            _err(f'TUI venv not found at {SIGMOND_VENV}')
            _info('Create it with:  sudo smd tui')
            _info('(first run creates the venv; subsequent runs do not need sudo)')
            return 1

    script = str(Path(__file__).resolve())
    os.execv(str(venv_python), [str(venv_python), script, *sys.argv[1:]])
    return 1  # unreachable


