def main() -> int:
    # v2 canonical `smd log set-level [<client>] <level>` — pre-argparse
    # intercept because argparse can't cleanly mix a sub-verb with the
    # legacy positional-client shape (`smd log [<client>]`), which must
    # keep working.  Routes the same write semantics as the legacy
    # `smd log [<client>] --level <level>` path.
    # Narrow intercept: only matches when `log` is the FIRST positional
    # (no `--topology` etc. before it).  Operators needing a topology
    # override should use the legacy `log <client> --level X` shape
    # during the deprecation window.
    # Two argv shapes:
    #   smd log set-level <level>            — global CLIENT_LOG_LEVEL default
    #   smd log set-level <client> <level>   — per-client override + SIGHUP
    if len(sys.argv) >= 3 and sys.argv[1] == 'log' and sys.argv[2] == 'set-level':
        if len(sys.argv) == 4:
            return cmd_log(argparse.Namespace(
                command='log',
                client=None,
                level=sys.argv[3],
                files=False,
                topology=None,
            ))
        if len(sys.argv) >= 5:
            return cmd_log(argparse.Namespace(
                command='log',
                client=sys.argv[3],
                level=sys.argv[4],
                files=False,
                topology=None,
            ))
        print('smd log set-level: requires <level> (global default) '
              'or <client> <level> (per-client)',
              file=sys.stderr)
        return 2

    # Hide argparse's auto-generated subparser listing — the grouped
    # epilog covers the same verbs categorised by intent (Configure /
    # Observe / Operate, mirroring the TUI tree), and the alphabetical
    # auto-listing was redundant.  Per-verb detail still works via
    # `smd <verb> --help`.
    class _GroupedHelpFormatter(argparse.RawDescriptionHelpFormatter):
        def _format_action(self, action):
            if isinstance(action, argparse._SubParsersAction):
                return ''
            return super()._format_action(action)

    parser = argparse.ArgumentParser(
        prog='smd',
        description='Sigmond — HamSCI suite installer and lifecycle manager',
        formatter_class=_GroupedHelpFormatter,
        epilog=textwrap.dedent('''\
            verbs (grouped by who uses them — see docs/CLI-V2-SPEC.md):

              Operator (daily, read-mostly):
                status     service health snapshot
                watch      live tail (wspr | psk | hfdl | codar | ka9q | uploads | verifier)
                log        tail journal or file logs
                           (`log set-level <client> <lvl>` to mutate)
                validate   cross-client harmonization checks
                public-ip  external IP probe
                tui        launch interactive TUI

              Operator (mutating — needs sudo):
                start / stop / restart / reload   systemd-aligned lifecycle
                apply      reconcile running services with current config
                enable / disable                  toggle component in topology

              Installer / maintenance:
                component  catalog (list | install | update | add | remove | enable | disable)
                instance   per-reporter client instance lifecycle
                           (list | show | add | remove | edit | enable | disable | migrate)
                config     show / migrate / init / edit per-client config
                sources    per-client sensor feed selection (radiod / KiwiSDR / mag / vlf)
                environment    declared vs observed network peers (list | probe | describe)
                wisdom     FFTW3 wisdom planner (plan | status)
                storage    sink backend (migrate-to-sqlite | trim | tune-timestd)

              Diagnostics / debug:
                diag       cpu-affinity | cpu-freq | net
                verifier   wsprnet upload audit (report | rehabilitate)
                rac        wd-rac tunnel lifecycle (status | start | stop | restart | install)

              Meta:
                completion bash    emit bash tab-completion script

            Run  smd <verb> --help  for verb-specific options.
            Verbs deprecated in v2 still work but emit a warning naming
            their replacement; see CLI-V2-SPEC.md §5 for the full list.
        '''),
    )
    parser.add_argument('--topology', metavar='FILE',
                        help=f'topology file (default: {TOPOLOGY_PATH})')
    sub = parser.add_subparsers(dest='command')

    # add — clone (or pull) a component repo into /opt/git/sigmond/<name>/
    p = sub.add_parser('add', help='clone a component repo (run smd install + enable to bring it online)')
    p.add_argument('url', help='git URL of the component repo (e.g. git@github.com:owner/foo.git)')

    # enable — set [component.<name>].enabled = true in topology.toml
    p = sub.add_parser('enable', help='enable component(s) in /etc/sigmond/topology.toml')
    p.add_argument('names', nargs='+', help='one or more component names')

    # disable — set enabled = false AND stop the component's units
    p = sub.add_parser('disable', help='disable component(s) and stop their units')
    p.add_argument('names', nargs='+', help='one or more component names')

    # remove — delete the [component.<name>] section AND stop units;
    # `--purge` (or any deprecated name) escalates to a full clean
    p = sub.add_parser(
        'remove',
        help='remove component (default: topology section + stop units; '
             '--purge or deprecated names: full clean)',
    )
    p.add_argument('names', nargs='+', help='one or more component names')
    p.add_argument('--purge', action='store_true',
                   help='full clean: stop+disable units, rm source / venv / '
                        '/etc/<name>/.  Implied for names in the deprecation list.')
    p.add_argument('--force', '-f', action='store_true',
                   help='allow --purge against a name not in the deprecation list')
    p.add_argument('--yes', '-y', action='store_true',
                   help='skip the interactive confirmation prompt')
    p.add_argument('--dry-run', action='store_true',
                   help='with --purge: show the plan without making changes')

    # install + apply share their option set between the top-level form
    # (`smd install`, `smd apply` — kept for muscle memory) and the
    # grouped form (`smd software install`, `smd software apply` — the
    # preferred form going forward; "software" reads as a noun verb-pair
    # the way operators already think about it).
    def _add_install_args(p):
        p.add_argument('client', nargs='?', default=None,
                       help='specific client to install from catalog (e.g. psk-recorder)')
        p.add_argument('--components', metavar='C1,C2',
                       help='comma-separated subset (default: all enabled in topology)')
        p.add_argument('--client-dir', metavar='DIR',
                       help='path to wsprdaemon-client (overrides topology)')
        p.add_argument('--dry-run', action='store_true',
                       help='show what would be done without making changes')
        p.add_argument('--yes', '-y', action='store_true',
                       help='accept defaults, no interactive prompts')
        p.add_argument('--force', '-f', action='store_true',
                       help='rebuild/reinstall even if the binary appears current '
                            '(skips SHA short-circuits and `make` rebuild gating)')

    def _add_apply_args(p):
        p.add_argument('--dry-run', action='store_true')

    _add_install_args(sub.add_parser(
        'install', help='install and configure components '
                       '(alias for `smd software install`)'))
    _add_apply_args(sub.add_parser(
        'apply', help='reconcile services with current config '
                      '(alias for `smd software apply`)'))

    # software — grouped parent for the install/apply pair.  Both
    # subverbs accept the exact same flags as the top-level forms.
    p_software = sub.add_parser(
        'software',
        help='install or reconcile sigmond-managed software components')
    software_sub = p_software.add_subparsers(dest='software_command')
    _add_install_args(software_sub.add_parser(
        'install', help='install and configure components'))
    _add_apply_args(software_sub.add_parser(
        'apply', help='reconcile services with current config'))

    # component — v2 canonical namespace for catalog operations.
    # Bare list/install/enable/disable kept as aliases (CLI-V2-SPEC.md §4).
    # Bare add/remove are REMOVED in v2 — the namespaced forms are the
    # only canonical reach.
    p_component = sub.add_parser(
        'component',
        help='catalog operations (v2 canonical namespace; '
             'list / install / update / add / remove / enable / disable)')
    component_sub = p_component.add_subparsers(dest='component_command')

    p_c_list = component_sub.add_parser(
        'list',
        help='show component status (canonical form of bare `list`; '
             'use `component update` for the mutating path)')
    p_c_list.add_argument('--components', metavar='C1,C2',
                          help='comma-separated subset of components')
    p_c_list.add_argument('--catalog', action='store_true',
                          help='show catalog of known clients')
    p_c_list.add_argument('--fetch', action='store_true',
                          help='run `git fetch` per repo before computing divergence')
    p_c_list.add_argument('--json', action='store_true',
                          help='emit machine-readable JSON')

    _add_install_args(component_sub.add_parser(
        'install',
        help='install and configure components (canonical form of bare `install`)'))

    p_c_update = component_sub.add_parser(
        'update',
        help='pull latest code per topology version policy and reapply '
             '(replaces `list --update` / `list --apply`; requires root)')
    p_c_update.add_argument('name', nargs='?', default=None,
                            help='single component to update (default: all enabled)')
    p_c_update.add_argument('--components', metavar='C1,C2',
                            help='comma-separated subset (alternative to positional name)')
    p_c_update.add_argument('--fetch', action='store_true',
                            help='run `git fetch` per repo before computing divergence')
    p_c_update.add_argument('--ref', metavar='COMMIT_OR_BRANCH',
                            help='force a specific git ref instead of topology policy')
    p_c_update.add_argument('--dry-run', action='store_true',
                            help='preview what would be pulled without making changes')
    p_c_update.add_argument('--json', action='store_true',
                            help='emit machine-readable JSON')

    p_c_add = component_sub.add_parser(
        'add',
        help='clone a component repo (canonical; bare `add` removed in v2)')
    p_c_add.add_argument('url', help='git URL of the component repo')

    p_c_remove = component_sub.add_parser(
        'remove',
        help='remove component (canonical; bare `remove` removed in v2)')
    p_c_remove.add_argument('names', nargs='+', help='one or more component names')
    p_c_remove.add_argument('--purge', action='store_true',
                            help='full clean: stop+disable units, rm source / venv / /etc/<name>/')
    p_c_remove.add_argument('--force', '-f', action='store_true',
                            help='allow --purge against a name not in the deprecation list')
    p_c_remove.add_argument('--yes', '-y', action='store_true',
                            help='skip the interactive confirmation prompt')
    p_c_remove.add_argument('--dry-run', action='store_true',
                            help='with --purge: show the plan without making changes')

    p_c_enable = component_sub.add_parser(
        'enable',
        help='enable component(s) in /etc/sigmond/topology.toml')
    p_c_enable.add_argument('names', nargs='+', help='one or more component names')

    p_c_disable = component_sub.add_parser(
        'disable',
        help='disable component(s) and stop their units')
    p_c_disable.add_argument('names', nargs='+', help='one or more component names')

    # instance — v2 per-reporter client instances
    # (MULTI-INSTANCE-ARCHITECTURE.md §6)
    p_instance = sub.add_parser(
        'instance',
        help='per-reporter client instance lifecycle '
             '(list / show / add / remove / edit / enable / disable / migrate)')
    instance_sub = p_instance.add_subparsers(dest='instance_command')

    p_i_list = instance_sub.add_parser(
        'list',
        help='list all per-reporter instances on this host')
    p_i_list.add_argument('client', nargs='?', default=None,
                          help='restrict to one client (e.g. wspr-recorder)')

    p_i_show = instance_sub.add_parser(
        'show',
        help='show paths + unit status for one instance')
    p_i_show.add_argument('client', help='client name (e.g. wspr-recorder)')
    p_i_show.add_argument('reporter_id',
                          help='reporter ID (e.g. AC0G-B1)')

    p_i_add = instance_sub.add_parser(
        'add',
        help='create per-instance config/env/sources files for a new '
             'reporter (requires root; does NOT enable the unit)')
    p_i_add.add_argument('client', help='client name')
    p_i_add.add_argument('reporter_id',
                         help='reporter ID (e.g. AC0G/B1 or W1ABC-5); '
                              'slashes are stored as `=` internally and '
                              're-displayed as `/`')
    p_i_add.add_argument('--force', action='store_true',
                         help='create only missing files; leave existing ones in place')
    p_i_add.add_argument('--dry-run', action='store_true',
                         help='show what would be created without touching the filesystem')

    p_i_remove = instance_sub.add_parser(
        'remove',
        help='remove per-instance files (requires root)')
    p_i_remove.add_argument('client', help='client name')
    p_i_remove.add_argument('reporter_id', help='reporter ID')
    p_i_remove.add_argument('--purge', action='store_true',
                            help='also remove state/log/run dirs')
    p_i_remove.add_argument('--yes', '-y', action='store_true',
                            help='skip the interactive confirmation prompt')
    p_i_remove.add_argument('--dry-run', action='store_true',
                            help='show what would be removed')

    p_i_edit = instance_sub.add_parser(
        'edit',
        help='edit per-instance config (Phase-2: stub that points at $EDITOR)')
    p_i_edit.add_argument('client', help='client name')
    p_i_edit.add_argument('reporter_id', help='reporter ID')

    p_i_enable = instance_sub.add_parser(
        'enable',
        help='systemctl enable + start the instance unit (requires root)')
