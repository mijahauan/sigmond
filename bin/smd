def _run(cmd: list, *, cwd=None, capture=True, sudo=False, env=None) -> subprocess.CompletedProcess:
    if sudo and os.geteuid() != 0:
        cmd = ['sudo'] + cmd
    # When not capturing output, redirect stdin from /dev/null so interactive
    # prompts (read -p) in sub-scripts return immediately rather than hanging.
    stdin_arg = subprocess.DEVNULL if not capture else None
    return subprocess.run(cmd, cwd=cwd,
                          capture_output=capture, text=True,
                          stdin=stdin_arg, env=env)


def _repo_is_dirty(repo_dir: Path) -> tuple[bool, str | None]:
    """Return (is_dirty, reason) for a git repo.

    Considers a repo unsafe to overwrite if it has either:
    - uncommitted tracked-file changes (working tree or index), or
    - local commits ahead of its upstream branch.

    Untracked files alone don't count — git pull won't clobber them.
    """
    r = subprocess.run(
        ['git', '-C', str(repo_dir), 'status', '--porcelain', '--untracked-files=no'],
        capture_output=True, text=True,
    )
    if r.returncode == 0 and r.stdout.strip():
        files = [line[3:].strip() for line in r.stdout.splitlines() if line.strip()]
        head = ', '.join(files[:3]) + ('...' if len(files) > 3 else '')
        return True, f'uncommitted changes in {len(files)} file(s): {head}'

    up = subprocess.run(
        ['git', '-C', str(repo_dir), 'rev-parse', '--abbrev-ref', '@{u}'],
        capture_output=True, text=True,
    )
    if up.returncode == 0 and up.stdout.strip():
        upstream = up.stdout.strip()
        ahead = subprocess.run(
            ['git', '-C', str(repo_dir), 'rev-list', '--count', f'{upstream}..HEAD'],
            capture_output=True, text=True,
        )
        if ahead.returncode == 0:
            try:
                n = int(ahead.stdout.strip() or '0')
            except ValueError:
                n = 0
            if n > 0:
                return True, f'{n} unpushed local commit(s) ahead of {upstream}'

    return False, None


def _git_pull_as_owner(repo_dir: Path) -> subprocess.CompletedProcess:
    """git pull --ff-only, dropping privileges to a user who can talk to the remote.

    sigmond's self-update runs under sudo. If the repo has an SSH remote
    (git@github.com:...), root has no usable key.  Drop privs to a user
    who does, in this preference order:

      1. $SUDO_USER — the human who invoked sudo.  Most likely to have
         a personal SSH key already registered with the remote.
      2. The repo's owning user — works when the tree is owned by a
         human (the legacy single-user setup) but not when ownership
         is the `sigmond` system user, which has no shell or SSH key.

    Output is captured (not streamed) so caller controls display.  Compare
    HEAD ref before/after to decide whether anything changed.
    """
    git_cmd = ['git', '-C', str(repo_dir), 'pull', '--ff-only']
    if os.geteuid() == 0:
        target_user = os.environ.get('SUDO_USER') or ''
        if not target_user or target_user == 'root':
            try:
                owner_uid = os.stat(repo_dir).st_uid
                if owner_uid != 0:
                    target_user = pwd.getpwuid(owner_uid).pw_name
            except (OSError, KeyError):
                target_user = ''
        if target_user and target_user != 'root':
            git_cmd = ['sudo', '-u', target_user, '-H', '--'] + git_cmd
    return subprocess.run(git_cmd, stdin=subprocess.DEVNULL,
                          capture_output=True, text=True)


def _ok(msg):   print(f'  \033[32m✓\033[0m  {msg}')
def _warn(msg): print(f'  \033[33m⚠\033[0m  {msg}')
def _err(msg):  print(f'  \033[31m✗\033[0m  {msg}', file=sys.stderr)
def _info(msg): print(f'     {msg}')


def _deprecated(verb: str, replacement: str) -> None:
    """Emit a one-line CLI-v2 deprecation warning to stderr.

    Used at the entry of each verb scheduled for removal in the next
    release (see CLI-V2-SPEC.md §5).  The handler still runs; this
    just teaches the operator the new spelling.
    """
    print(f'smd: `{verb}` is deprecated; use `{replacement}` instead '
          f'(CLI-V2-SPEC.md §5)',
          file=sys.stderr)


def _heading(title: str):
    print(f'\n\033[1m━━━ {title} ━━━\033[0m')


def _expand_requires_closure(names, catalog) -> list[str]:
    """Walk the catalog's `requires` graph and return the names plus all
    transitive dependencies in topological order (deps before dependents).

    Mirrors systemctl's behaviour where `systemctl start httpd` follows
    `Wants=` / `Requires=` and brings up nginx (or whatever) first.
    Sigmond reads the same intent from `[client] requires = [...]` in
    each component's deploy.toml.

    Rules:
      - kind="library" entries (e.g. ka9q-python) are skipped — no
        service to start.
      - Aliases (entry.topology_alias) are emitted alongside the
        canonical name so the enabled-components filter matches whichever
        key the topology uses (radiod's catalog name is "radiod" but
        topology.toml has [component.ka9q-radio]).
      - Cycles are detected via a visited set and silently broken.
      - Unknown names (not in catalog) pass through unchanged for the
        caller's not-enabled warning to fire normally.
    """
    # Build alias → canonical map so requires using either name resolve.
    alias_to_canonical: dict[str, str] = {}
    for canonical_name, entry in catalog.items():
        alias_to_canonical[canonical_name] = canonical_name
        a = getattr(entry, 'topology_alias', None)
        if a:
            alias_to_canonical[a] = canonical_name

    visited: set[str] = set()
    order: list[str] = []

    def visit(name: str) -> None:
        canonical = alias_to_canonical.get(name, name)
        if canonical in visited:
            return
        visited.add(canonical)

        entry = catalog.get(canonical)
        if entry is not None:
            for req in getattr(entry, 'requires', ()) or ():
                visit(req)
            if getattr(entry, 'kind', None) == 'library':
                return
            # Emit canonical name + alias.  Caller's enabled-components
            # filter picks whichever is in topology.toml.
            order.append(canonical)
            alias = getattr(entry, 'topology_alias', None)
            if alias and alias != canonical:
                order.append(alias)
        else:
            # Unknown — pass through; downstream filter / lifecycle resolver
            # will handle it.
            order.append(name)

    for n in names:
        visit(n)

    return order


def _resolve_only_list(args, topology):
    """Combine positional `names` + legacy `--components` into the lifecycle
    `only` filter.

    Returns:
      None  if the operator wants "all enabled" (no args, or the literal
            keyword `all`).
      list  the explicit subset to operate on (already validated against
            the topology — components that aren't enabled get a warning
            but stay in the list so the caller's gate can show the right
            error).
    """
    positional = list(getattr(args, 'names', None) or [])
    legacy: list[str] = []
    legacy_arg = getattr(args, 'components', None)
    if legacy_arg:
        legacy = [c.strip() for c in legacy_arg.split(',') if c.strip()]
    combined = positional + legacy

    if not combined or 'all' in combined:
        return None  # operate on every enabled component

    # Canonicalize user-typed names.  topology.py's load_topology rewrites
    # legacy keys (radiod → ka9q-radio) on read, so the enabled set is
    # always keyed by canonical names.  An operator typing `smd start
    # radiod` (the systemd-service name and former canonical name) needs
    # the same translation applied to their argv before the enabled-set
    # check, otherwise we reject a perfectly valid alias as "not enabled".
    if _HAS_SIGMOND_LIB:
        try:
            _catalog = load_catalog()
            combined = [resolve_name(c, _catalog) for c in combined]
        except (FileNotFoundError, OSError):
            pass

    # Validate: warn (but proceed) for components that aren't enabled,
    # so the operator gets a clear "not enabled" cue rather than silent
    # no-op.
    enabled_set = set(_enabled_components(topology) or [])
    not_enabled = [c for c in combined if c not in enabled_set]
    if not_enabled:
        for name in not_enabled:
            _warn(f'{name}: not enabled in topology — skipping (run: smd enable {name})')
    return [c for c in combined if c in enabled_set]


def _need_root(cmd_name: str) -> bool:
    """Auto-elevate to root via sudo when invoked as a normal user.

    Mutating verbs (start, stop, install, enable, etc.) call this at the
    top.  Rather than printing "must run as root" and bailing, we re-exec
    ourselves under sudo with the same argv — the operator never has to
    prefix `sudo` themselves.

    Returns True only if elevation isn't possible (no sudo on PATH);
    callers should still check the return value and exit on True.
    """
    if os.geteuid() == 0:
        return False
    sudo = shutil.which('sudo')
    if sudo:
        # Replace the current process — sudo prompts for password if
        # needed, then runs the same script with the same args as root.
        os.execvp(sudo, [sudo, '--', sys.argv[0], *sys.argv[1:]])
        # execvp doesn't return on success; if it does, fall through.
    print(f'smd {cmd_name}: must run as root (sudo not found on PATH)',
          file=sys.stderr)
    return True


# ---------------------------------------------------------------------------
# Client contract queries
